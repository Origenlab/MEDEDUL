    badge: 'Sofisticación EU',
    badgeColor: '#a87a3c',
    link: '/sucursales/cdmx/mesa-de-quesos-y-embutidos',
    features: ['Maestro cortador en sitio', 'Sommelier de quesos', '6 países de origen D.O.P.']
