            loading="lazy"
            width="720"
            height="480"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== Paquetes Baby Shower CDMX ===================== -->
  <PricingPackages
    id="paquetes-baby-cdmx"
    badge="Paquetes Baby Shower CDMX"
    title="Elige el formato para"
    titleHighlight="tu baby shower en CDMX"
    subtitle="3 niveles claros con todo incluido. Cotización en menos de 24 h"
    content={`<p>Diseñamos <strong>tres niveles de paquete específicos para baby shower CDMX</strong>, pensados para diferentes tamaños y niveles de detalle. El paquete <strong>Esencial</strong> está pensado para baby showers íntimos en casa (20-40 invitadas); el <strong>Premium</strong> es el más solicitado para baby showers medianos (40-80) e incluye backdrop con el nombre del bebé, globos pastel y cajas-recuerdo personalizadas; el <strong>Luxury</strong> es nuestra propuesta editorial para baby showers grandes (80+) e incluye estación complementaria, backdrop floral 360°, sesión fotográfica de la mesa y mini sets con foto del ultrasonido.</p><p>Todos los paquetes incluyen el <strong>mismo estándar tierno de diseño, surtido seguro para mamá embarazada y operación cálida</strong>. Lo que cambia es la escala del surtido y la complejidad del backdrop. Si tu baby shower es <strong>gender reveal</strong>, el elemento sorpresa se integra en cualquiera de los 3 paquetes sin costo adicional — solo necesitamos saber la mecánica del reveal en el brief inicial.</p>`}
