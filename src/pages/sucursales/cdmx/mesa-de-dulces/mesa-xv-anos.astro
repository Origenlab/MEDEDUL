    color: var(--texto-oscuro, #1a1a1a);
    margin-bottom: 22px;
  }

  .xvcdmx-intro__copy h2 span { color: var(--rosa-principal, #D1007A); }

  .xvcdmx-intro__copy p {
    font-size: 1.02rem;
    color: var(--texto-light, #555);
    line-height: 1.75;
    margin: 0 0 16px;
  }

  .xvcdmx-intro__copy strong { color: var(--texto-oscuro, #1a1a1a); }
  .xvcdmx-intro__copy a {
    color: var(--rosa-principal, #D1007A);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .xvcdmx-intro__visual {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
  }

  .xvcdmx-intro__visual img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ---------- Galería ---------- */
  .xvcdmx-galeria {
    padding: 90px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff9fb 100%);
  }

  .xvcdmx-galeria__bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 200px);
    gap: 20px;
    margin-top: 40px;
  }

  .xvcdmx-galeria__item {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .xvcdmx-galeria__item img {
    width: 100%;
