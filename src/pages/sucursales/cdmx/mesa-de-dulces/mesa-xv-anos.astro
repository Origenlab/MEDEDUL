    color: var(--texto-light, #666);
    font-weight: 500;
  }

  /* ---------- Intro SEO ---------- */
  .xvcdmx-intro {
    padding: 90px 0;
    background: #fff;
  }

  .xvcdmx-intro__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .xvcdmx-intro__badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%);
    color: #fff;
    padding: 8px 22px;
    border-radius: 50px;
    font-size: 0.8rem;
