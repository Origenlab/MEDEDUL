<style>
  /* ==========================================================
     XV Años CDMX — Subsección Mesa de Dulces L5
     Prefijo: xvcdmx-
     ========================================================== */

  /* ---------- Stats ---------- */
  .xvcdmx-stats {
    padding: 50px 0;
    background: linear-gradient(180deg, #fff 0%, #fdf8fa 100%);
  }

  .xvcdmx-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    text-align: center;
  }

  .xvcdmx-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 22px 14px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(233, 30, 140, 0.08);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
  }

  .xvcdmx-stat__num {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--rosa-principal, #D1007A);
