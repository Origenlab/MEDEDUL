      <div class="xvcdmx-zonas__cta">
        <p>¿No ves tu zona? <strong>Cubrimos las 16 alcaldías de CDMX y zona metropolitana premium</strong>.</p>
        <a href="/zonas-cdmx" class="xvcdmx-zonas__cta-btn">
          Ver todas las zonas CDMX
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== Testimonios XV CDMX ===================== -->
  <section class="xvcdmx-testimonios">
    <div class="container">
      <SectionHeader
        title="Testimonios de XV reales en"
        titleHighlight="CDMX"
        subtitle="Lo que dicen las familias que ya celebraron con MEDEDUL"
      />
      <div class="xvcdmx-testimonios__grid">
        {testimonios.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Otros candy bars CDMX (cross-link) ===================== -->
  <section class="xvcdmx-otros-eventos" id="otros-candy-bars-cdmx">
    <div class="container">
      <SectionHeader
        title="Descubre nuestros otros Candy Bars en CDMX"
        titleHighlight="CDMX"
        subtitle="Otros 4 montajes especializados que operamos en Ciudad de México"
        content={`<p>Además de la <strong>mesa de XV Años</strong>, MEDEDUL opera montajes especializados en CDMX para <strong>boda, baby shower, cumpleaños infantil y eventos corporativos</strong>. Cada formato tiene su propio enfoque visual, surtido curado y paquetes específicos. Si tu evento combina con el XV (por ejemplo, fiesta de preparación previa o post-vals) podemos cotizar ambos servicios con <strong>descuento por paquete combinado</strong>.</p>`}
      />

      <div class="xvcdmx-otros-eventos__grid">
        {eventos.map(ev => (
          <ServiceCard
            href={ev.href}
            image={ev.img}
            alt={`${ev.title} por MEDEDUL`}
            title={ev.title}
            excerpt={ev.excerpt}
            badge={ev.badge}
            cta={ev.cta}
