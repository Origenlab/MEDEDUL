<BaseLayout
  title="Cumpleaños Infantil CDMX | Candy Bar Temático 30+ Personajes | MEDEDUL"
  description="Mesa de dulces para cumpleaños infantil en CDMX por MEDEDUL: 30+ temáticas (Disney, Marvel, Pokemon, Frozen, Bluey, Paw Patrol), control alergias, operador disfrazado y coordinación con animadores. Sucursales Anzures y Condesa. Desde $3,500 MXN. Cotiza gratis."
  canonical="/sucursales/cdmx/mesa-de-dulces/cumpleanos-infantil"
  ogImage="/img/galeria/candy-bar-superheroes-cumpleanos-nino.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />

