  <!-- ===================== Paquetes Cumple CDMX ===================== -->
  <PricingPackages
    id="paquetes-cumple-cdmx"
    badge="Paquetes Cumple CDMX"
    title="Elige el formato para"
    titleHighlight="el cumpleaños de tu hijo en CDMX"
    subtitle="3 niveles claros con todo incluido. Cotización en menos de 24 h"
    content={`<p>Diseñamos <strong>tres niveles de paquete específicos para cumpleaños infantil CDMX</strong>, pensados para diferentes tamaños y niveles de sofisticación temática. El paquete <strong>Esencial</strong> es ideal para cumpleaños íntimos en casa (15-30 niños); el <strong>Premium</strong> es el más solicitado para cumples medianos (30-60 niños) e incluye backdrop personalizado, operador disfrazado opcional y bolos sorpresa premium; el <strong>Luxury</strong> es nuestra propuesta espectacular para cumples grandes (60+) con estación complementaria, photobooth integrado y sesión fotográfica del cumpleañero.</p><p>Todos los paquetes incluyen el <strong>mismo control estricto de alergias</strong> (sin nueces por defecto, ajustes sin costo). Lo que cambia es la escala del surtido, la complejidad del atrezzo temático y la duración del servicio.</p>`}
    packages={paquetesKid}
    note="💡 <strong>Todos los paquetes Cumple CDMX incluyen:</strong> diseño temático del personaje, surtido aprobado por niños sin nueces por defecto, control de alergias, cristalería temática, backdrop con nombre del cumpleañero, montaje 1-2 h antes en casa o salón, operación durante la fiesta, coordinación con otros proveedores y empaque en bolos sorpresa."
