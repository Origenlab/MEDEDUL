    desc: 'Contraste salado para tu mesa de frutas: quesos europeos D.O.P. (Brie, Manchego, Parmigiano) y charcutería reserva (Jamón Ibérico, Prosciutto di Parma). Maestro cortador en sitio.',
    img: '/img/tipos-de-mesas/quesos-embutidos/tabla-quesos-embutidos-gourmet.avif',
    badge: 'Sofisticación EU',
    badgeColor: '#a87a3c',
    link: '/sucursales/cdmx/mesa-de-quesos-y-embutidos',
    features: ['25+ productos D.O.P.', 'Maestro cortador profesional', 'Sommelier de quesos opcional']
  }
];

// =============== Image responsive widths ===============
const galleryWidths = [320, 480, 640, 800, 960, 1200];
const gallerySizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw';
const stationWidths = [240, 320, 400, 560, 720];
const stationSizes = '(max-width: 1024px) 100vw, 420px';

// =============== JSON-LD: Service + LocalBusiness + FAQ + Breadcrumb ===============
const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://mesas-de-dulces.com/sucursales/cdmx/mesa-de-frutas#service",
      "name": "Mesa de Frutas en CDMX",
      "serviceType": "Mesa de Frutas Premium para Eventos",
      "description": "Mesa de frutas premium en Ciudad de México para bodas, XV años, baby shower, eventos corporativos y celebraciones sociales. Fruta surtida en Central de Abasto la madrugada del evento, cadena de frío controlada, presentación editorial. Operación desde sucursales Anzures y Condesa, cobertura completa CDMX.",
      "provider": {
        "@type": "LocalBusiness",
        "name": "MEDEDUL - Sucursal CDMX",
        "image": getCdnUrl('/img/branding/logo-mededul-mesas-de-dulces.avif'),
        "telephone": "+525525226442",
        "url": "https://mesas-de-dulces.com/sucursales/cdmx",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Av. Ejercito Nacional Mexicano 216",
          "addressLocality": "Anzures, Miguel Hidalgo",
          "postalCode": "11590",
          "addressRegion": "Ciudad de Mexico",
          "addressCountry": "MX"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "127",
          "bestRating": "5"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": "Ciudad de Mexico"
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "MXN",
        "lowPrice": "4800",
        "highPrice": "13900",
        "offerCount": "3",
        "offers": paquetesMesaFrutasCdmx.map(pkg => ({
          "@type": "Offer",
          "name": `Mesa de Frutas CDMX ${pkg.name}`,
          "price": pkg.price.replace(/[$,]/g, ''),
          "priceCurrency": "MXN",
          "description": pkg.guests,
          "availability": "https://schema.org/InStock"
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mesas-de-dulces.com/" },
        { "@type": "ListItem", "position": 2, "name": "Sucursales", "item": "https://mesas-de-dulces.com/sucursales" },
        { "@type": "ListItem", "position": 3, "name": "CDMX", "item": "https://mesas-de-dulces.com/sucursales/cdmx" },
        { "@type": "ListItem", "position": 4, "name": "Mesa de Frutas", "item": "https://mesas-de-dulces.com/sucursales/cdmx/mesa-de-frutas" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Mesa de Frutas CDMX | Arreglos Frutales Premium Sucursal Anzures y Condesa"
  description="Mesa de frutas premium en CDMX por MEDEDUL. Fruta fresca seleccionada en Central de Abasto la madrugada del evento, cadena de frío, presentación editorial. Sucursales Anzures y Condesa, cobertura 16 alcaldías. Bodas, XV años, baby shower y corporativos. Desde $4,800 MXN."
  canonical="/sucursales/cdmx/mesa-de-frutas"
  ogImage="/img/tipos-de-mesas/frutas/mesa-frutas-frescas-eventos.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesa de Frutas en CDMX"
    highlight="Frutas"
    subtitle="Arreglos frutales premium | Sucursal MEDEDUL CDMX (Anzures + Condesa)"
    secondaryContent={`<p><strong>Frescura y color en cada bocado</strong>. Arreglos espectaculares con fruta de temporada que refrescan y deleitan a todos tus invitados. En MEDEDUL Sucursal CDMX diseñamos, montamos y operamos mesas de frutas premium para bodas, XV años, baby shower, eventos corporativos y celebraciones en los venues más exigentes de Ciudad de México: Hotel W, Four Seasons, Hacienda de los Morales, Casa Lamm, Club de Industriales y más.</p><p>Surtimos en la <strong>Central de Abasto la madrugada del evento</strong> y montamos en sitio con cadena de frío controlada para que cada pieza llegue en su punto óptimo. Operamos desde nuestras dos sucursales fijas en <strong>Anzures (Miguel Hidalgo) y Condesa (Cuauhtémoc)</strong>, llegando en menos de 30 minutos a cualquier zona premium de CDMX con bandejas talladas, brochetas artesanales, fuente de chocolate belga opcional y opciones tropicales con chamoy.</p>`}
  />

  <!-- ===================== Trust Stats Bar ===================== -->
  <section class="cdmx-mf-stats">
    <div class="container">
      <div class="cdmx-mf-stats__grid">
        {stats.map(s => (
          <div class="cdmx-mf-stat">
            <span class="cdmx-mf-stat__num">{s.number}</span>
            <span class="cdmx-mf-stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Subsecciones por estilo (4 cards) ===================== -->
  <section class="cdmx-mf-subsecciones" id="subsecciones">
    <div class="container">
      <SectionHeader
        title="Mesa de Frutas CDMX por"
        titleHighlight="Estilo y Presentación"
        subtitle="Cuatro enfoques especializados en arreglos frutales para tu evento"
        content={`<p>La <strong>mesa de frutas premium CDMX</strong> se adapta al estilo y temática de cada celebración. Trabajamos cuatro enfoques especializados: brochetas artesanales individuales, torres decorativas escultóricas, combo con fuente de chocolate belga y cortes tropicales con chamoy. Cada propuesta parte del mismo estándar premium de MEDEDUL y se ajusta al venue, paleta y tipo de evento en Ciudad de México.</p>`}
      />

      <div class="cdmx-mf-subsecciones__grid">
        {subsecciones.map(sub => (
          <ServiceCard
            href={sub.href}
            image={sub.img}
            alt={`${sub.title} en CDMX por MEDEDUL`}
            title={sub.title}
            excerpt={sub.excerpt}
            badge={sub.badge}
            cta={sub.cta}
          />
        ))}
      </div>

      <div class="cdmx-mf-subsecciones__cta">
        <p>¿Listo para diseñar tu mesa de frutas CDMX? <strong>Respuesta en menos de 24 horas</strong>.</p>
        <a href="https://wa.me/525525226442?text=Hola%20MEDEDUL%2C%20me%20interesa%20cotizar%20una%20Mesa%20de%20Frutas%20en%20CDMX" target="_blank" rel="noopener" class="cdmx-mf-btn cdmx-mf-btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Cotizar Mesa de Frutas CDMX
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== Paquetes Mesa de Frutas CDMX ===================== -->
  <PricingPackages
    id="paquetes-mf-cdmx"
    badge="Paquetes Mesa de Frutas CDMX"
    title="Elige tu"
    titleHighlight="Paquete CDMX"
    subtitle="3 niveles claros, sin sorpresas. Cotización en menos de 24 h"
    content={`<p>Diseñamos <strong>tres niveles de paquete CDMX</strong> según el tamaño y estándar de tu evento. Todos incluyen el mismo nivel profesional de surtido, cadena de frío, montaje y operación; lo que cambia es la variedad de frutas, presencia de exóticas y sofisticación del montaje. Anticipo del 50% para reservar fecha, liquidación 48 h antes del evento.</p>`}
    packages={paquetesMesaFrutasCdmx}
    note="💡 <strong>Todos los paquetes CDMX incluyen:</strong> surtido en Central de Abasto la madrugada del evento, cadena de frío controlada, mobiliario completo, montaje 2-3 h antes, operación durante el evento, reposición continua, desmontaje y empaque de sobrantes."
  />

  <!-- ===================== Por qué elegirnos ===================== -->
  <WhyChooseUs
    id="por-que-mf-cdmx"
    badge="Diferenciadores Sucursal CDMX"
    title="Por qué elegir nuestra Mesa de Frutas en"
    titleHighlight="CDMX"
    descriptions={[
      "Con <strong>300+ mesas de frutas montadas en CDMX</strong> y 8 años de experiencia en bodas, XV años, baby showers y eventos corporativos en los venues más exigentes de la ciudad, somos la opción de referencia cuando necesitas <strong>fruta premium con presentación editorial y operación profesional</strong>.",
      "Cada mesa de frutas parte del mismo estándar: surtido en Central de Abasto la madrugada del evento, cadena de frío controlada, presentación editorial, mobiliario exclusivo, coordinación con tu venue y operación impecable. Lo que cambia es la <strong>variedad y sofisticación</strong>, no la calidad."
    ]}
    stats={[
      { number: "300+", label: "Mesas de frutas CDMX" },
      { number: "100%", label: "Fresca del día" },
      { number: "15+", label: "Variedades en Luxury" },
      { number: "< 24h", label: "Cotización" }
    ]}
    features={caracteristicas}
  />

  <!-- ===================== Galería visual CDMX ===================== -->
  <section class="cdmx-mf-galeria" id="galeria-cdmx">
    <div class="container">
      <SectionHeader
        title="Mesas de Frutas reales montadas en"
        titleHighlight="CDMX"
        subtitle="Selección curada de arreglos frutales MEDEDUL en eventos de Ciudad de México"
      />

      <div class="cdmx-mf-galeria__bento">
        {galeriaImages.map(img => (
          <div class="cdmx-mf-galeria__item">
            <img
              src={getCdnUrl(img.src, { w: 800, q: 80 })}
              srcset={getCdnSrcSet(img.src, galleryWidths, { q: 80 })}
              sizes={gallerySizes}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="800"
              height="533"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Qué incluye ===================== -->
  <section class="cdmx-mf-incluye">
    <div class="container">
      <div class="cdmx-mf-incluye__header">
        <span class="cdmx-mf-incluye__badge">Todo Incluido</span>
        <h2>¿Qué incluye nuestra <span>Mesa de Frutas CDMX</span>?</h2>
        <p>Servicio completo: selección, cadena de frío, montaje, operación y desmontaje para tu evento en Ciudad de México</p>
      </div>

      <div class="cdmx-mf-incluye__grid">
        {incluye.map(item => (
          <div class="cdmx-mf-incluye__card">
            <span class="cdmx-mf-incluye__num">{item.num}</span>
            <h4>{item.title}</h4>
            <p>{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Proceso CDMX ===================== -->
  <ProcessSteps
    id="proceso-mf-cdmx"
    badge="Cómo trabajamos en CDMX"
    title="4 pasos para tu"
    titleHighlight="Mesa de Frutas CDMX"
    subtitle="Proceso claro, sin estrés, con tiempos definidos"
    steps={procesoCdmx}
  />

  <!-- ===================== Eventos compatibles (8) ===================== -->
  <EventsGrid
    badge="Versatilidad Total"
    title="Tu Mesa de Frutas CDMX para"
    titleHighlight="Cualquier Ocasión"
    subtitle="Diseñamos mesa de frutas para cada tipo de celebración en Ciudad de México. Desde brunch de boda en Polanco hasta XV Años en Hacienda de los Morales, cada evento merece su propia mesa frutal."
    events={eventos}
  />

  <!-- ===================== Estaciones complementarias ===================== -->
  <section class="cdmx-mf-estaciones">
    <div class="container">
      <div class="cdmx-mf-estaciones__header">
        <span class="cdmx-mf-estaciones__badge">Complementa tu Mesa</span>
        <h2>Combina tu <span>Mesa de Frutas</span> con Más Estaciones</h2>
        <p>Eleva la experiencia de tus invitados sumando estaciones complementarias. Ideales para bodas, XV Años y eventos corporativos en CDMX.</p>
      </div>

      <div class="cdmx-mf-estaciones__grid">
        {estaciones.map(est => (
          <div class="cdmx-mf-estacion-card">
            <div class="cdmx-mf-estacion-card__image">
              <img
                src={getCdnUrl(est.img, { w: 420, q: 80 })}
                srcset={getCdnSrcSet(est.img, stationWidths, { q: 80 })}
                sizes={stationSizes}
                alt={`${est.title} en CDMX por MEDEDUL`}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                width="640"
                height="800"
              />
              <span class="cdmx-mf-estacion-card__badge" style={`background: linear-gradient(135deg, ${est.badgeColor} 0%, ${est.badgeColor}cc 100%)`}>{est.badge}</span>
            </div>
            <div class="cdmx-mf-estacion-card__content">
              <h3>{est.title}</h3>
              <p>{est.desc}</p>
              <ul>
                {est.features.map(f => (
                  <li>
                    <svg width="16" height="16" fill="var(--rosa-principal)" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href={est.link} class="cdmx-mf-estacion-card__link">
                Ver {est.title}
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="cdmx-mf-estaciones__cta">
        <p>¿Quieres combinar Mesa de Frutas con candy bar o fuentes interactivas? <strong>Pregunta por paquetes especiales CDMX</strong></p>
        <a href="/estaciones-interactivas" class="cdmx-mf-btn cdmx-mf-btn--ghost">Ver Todas las Estaciones</a>
      </div>
    </div>
  </section>

  <!-- ===================== Testimonios CDMX ===================== -->
  <section class="cdmx-mf-testimonios">
    <div class="container">
      <SectionHeader
        title="Lo que dicen clientes de"
        titleHighlight="Mesa de Frutas CDMX"
        subtitle="Bodas, XV años y baby showers reales montados por MEDEDUL en CDMX"
      />
      <div class="cdmx-mf-testimonios__grid">
        {testimonios.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FAQ + Contacto ===================== -->
  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  /* ==========================================================
     CDMX Mesa de Frutas - Sucursal-specific styles
     Reutiliza tokens globales (--rosa-principal, --texto-oscuro)
     Patrón homologado a /sucursales/cdmx/mesa-de-dulces
     ========================================================== */

  /* ---------- Stats Trust Bar ---------- */
  .cdmx-mf-stats {
    padding: 50px 0;
    background: linear-gradient(180deg, #fff 0%, #fdf8fa 100%);
  }

  .cdmx-mf-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    text-align: center;
  }

  .cdmx-mf-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px 14px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(233, 30, 140, 0.08);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
  }

  .cdmx-mf-stat__num {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--rosa-principal, #D1007A);
    line-height: 1;
  }

  .cdmx-mf-stat__label {
    font-size: 0.85rem;
    color: var(--texto-light, #666);
    font-weight: 500;
  }

  /* ---------- Subsecciones (4 cards de estilo) ---------- */
  .cdmx-mf-subsecciones {
    padding: 80px 0;
    background: #fff;
  }

  .cdmx-mf-subsecciones__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .cdmx-mf-subsecciones__cta {
    text-align: center;
    margin-top: 50px;
    padding: 30px;
    background: linear-gradient(135deg, #fdf8fa 0%, #fff0f7 100%);
    border-radius: 20px;
    border: 1px dashed rgba(233, 30, 140, 0.2);
  }

  .cdmx-mf-subsecciones__cta p {
    font-size: 1.05rem;
    color: var(--texto-light, #666);
    margin: 0 0 18px;
  }

  .cdmx-mf-subsecciones__cta strong {
    color: var(--rosa-principal, #D1007A);
  }

  /* ---------- Buttons ---------- */
  .cdmx-mf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 50px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }

  .cdmx-mf-btn--primary {
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: #fff;
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3);
  }

  .cdmx-mf-btn--ghost {
    background: #fff;
    color: var(--rosa-principal, #D1007A);
    border: 2px solid var(--rosa-principal, #D1007A);
  }

  /* ---------- Galería bento ---------- */
  .cdmx-mf-galeria {
    padding: 90px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff9fb 100%);
  }

  .cdmx-mf-galeria__bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 200px);
    gap: 20px;
    margin-top: 40px;
  }

  .cdmx-mf-galeria__item {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .cdmx-mf-galeria__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cdmx-mf-galeria__item:nth-child(1) {
    grid-column: span 2;
    grid-row: span 2;
  }

  .cdmx-mf-galeria__item:nth-child(5),
  .cdmx-mf-galeria__item:nth-child(6) {
    grid-column: span 2;
  }

  /* ---------- Incluye ---------- */
  .cdmx-mf-incluye {
    padding: 90px 0;
    background: #fff;
  }

  .cdmx-mf-incluye__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 50px;
  }

  .cdmx-mf-incluye__badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%);
    color: #fff;
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .cdmx-mf-incluye__header h2 {
    font-size: 2.2rem;
    color: var(--texto-oscuro, #1a1a1a);
    margin-bottom: 12px;
  }

  .cdmx-mf-incluye__header h2 span {
    color: var(--rosa-principal, #D1007A);
  }

  .cdmx-mf-incluye__header p {
    font-size: 1.05rem;
    color: var(--texto-light, #666);
    line-height: 1.6;
  }

  .cdmx-mf-incluye__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cdmx-mf-incluye__card {
    background: #fff;
    border: 1px solid rgba(233, 30, 140, 0.1);
    border-radius: 20px;
    padding: 32px 28px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.04);
  }

  .cdmx-mf-incluye__num {
    display: inline-block;
