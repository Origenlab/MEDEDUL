  { title: 'Barra Infantil Cumpleaños Niño/a', excerpt: 'La estrella del cumpleaños. Decoración temática (dinos, princesas, unicornio, superhéroes), candy carrousel giratorio, estación decorar galletas, máquina algodón azúcar, photo wall y bolsitas/cajitas recuerdo personalizadas. Residenciales Las Marinas, San Carlos, La Providencia Metepec.', img: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif', badge: 'Estrella', href: '/sucursales/toluca/mesa-de-dulces/cumpleanos-infantil', cta: 'Ver Cumpleaños Infantil' },
  { title: 'Barra Infantil Baby Shower', excerpt: 'Para baby showers donde hay niños sobrinos/primos. Sección kids paralela a la barra adultos con snacks suaves sin alergenos, decoración pastel coordinada al baby shower (rosa niña / azul niño / amarillo neutro). Tranquilidad total para mamá invitadas.', img: '/img/blog/cupcakes-macarons-rosa-baby-shower-boda-02.avif', href: '/sucursales/toluca/mesa-de-dulces/baby-shower', badge: 'Sin Alergenos', cta: 'Ver Baby Shower' },
  { title: 'Barra Infantil Bodas con Niños', excerpt: 'Para bodas Hacienda La Magdalena Metepec con muchos sobrinitos invitados. Sección kids separada de la barra adultos con snacks apropiados, photo wall infantil y operador supervisor. Niños felices = padres tranquilos = boda exitosa.', img: '/img/galeria/candy-bar-boda-lujoso-cristal-flores.avif', href: '/sucursales/toluca/mesa-de-dulces/candy-bar-boda', cta: 'Ver Bodas Toluca' },
  { title: 'Barra Infantil Posadas y Navidad', excerpt: 'Posadas con piñata y muchos niños. Decoración navideña kid-friendly, bastones de caramelo, galletas Santa Claus, palomitas con caramelo natural. Ambiente festivo seguro para todos los pequeños invitados Valle Toluca.', img: '/img/galeria/candy-bar-navidad-elegante-galletas-decoradas.avif', href: '/candy-bar-eventos', cta: 'Ver Posadas' },
  { title: 'Barra Infantil Primera Comunión', excerpt: 'Para celebración de Primera Comunión con primos y compañeros. Decoración blanca con detalles dorados, galletas con cruces decoradas, palomitas dulces y snacks suaves apropiados. Sin colorantes artificiales para evento religioso elegante.', img: '/img/eventos/bautizo/candy-bar-bautizo-celeste-cruz-macarons.avif', href: '/candy-bar-eventos/mesa-dulces-primera-comunion', cta: 'Ver Primera Comunión' },
  { title: 'Barra Infantil Eventos Familiares', excerpt: 'Reuniones familiares grandes (cumple abuelita, aniversario padres, navidad) con muchos niños primos. Sección kids dedicada para que los pequeños tengan su propio "candy heaven" sin invadir la barra adultos. Cobertura Valle Toluca completo.', img: '/img/galeria/candy-bar-elegante-terraza-atardecer.avif', href: '/candy-bar-eventos', cta: 'Ver Reuniones' }
