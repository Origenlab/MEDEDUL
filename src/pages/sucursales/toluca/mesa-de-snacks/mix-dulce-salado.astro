  { name: 'Daniela Ruiz', initials: 'DR', review: 'Para mi cumpleaños 40 en Las Marinas Metepec elegí Mix 14. La proporción 60/40 salado-dulce funcionó perfecto: nadie se cansó de un solo perfil. Las combinaciones firma (papas kettle + chocolate 70%) fueron una sorpresa elegante para mis invitados.', event: 'Cumpleaños Las Marinas Metepec', rating: 5 },
  { name: 'Luis Aguilar', initials: 'LA', review: 'Contraté Mix 14 para el lanzamiento de marca en Parque Industrial Lerma. Pedí proporción 70/30 salado-dulce (corporativo C-level) y MEDEDUL ajustó perfecto. Los frutos secos premium + Lindor para cierre fue justo el balance que buscábamos para directivos.', event: 'Lanzamiento Lerma', rating: 5 }
