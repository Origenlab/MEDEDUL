  <EventsGrid badge="Versatilidad Total" title="Tus Snacks Salados Valle Toluca para" titleHighlight="Cualquier Ocasión" subtitle="Diseñamos barras de salados premium para cada tipo de celebración en Valle de Toluca. Desde boda after-party en Hacienda La Magdalena Metepec con palomitas trufa, hasta cocktail corporativo en Parque Industrial Lerma con frutos secos premium." events={eventos} />

  <!-- ===================== Subsecciones hermanas ===================== -->
  <section class="tol-ss-hermanas">
    <div class="container">
      <SectionHeader
        title="Otras Subsecciones de"
        titleHighlight="Mesa de Snacks Toluca"
        subtitle="Si prefieres mix dulce-salado, barra infantil sin alergenos, o quieres la vista completa del hub L4"
      />
      <div class="tol-ss-hermanas__grid">
        {subsecciones.map(sub => (
          <ServiceCard href={sub.href} image={sub.img} alt={`${sub.title} en Valle Toluca por MEDEDUL`} title={sub.title} excerpt={sub.excerpt} badge={sub.badge} cta={sub.cta} />
        ))}
      </div>
    </div>
