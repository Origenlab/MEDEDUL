  <!-- ===================== Testimonios ===================== -->
  <section class="tol-ss-testimonios">
    <div class="container">
      <SectionHeader title="Lo que dicen clientes de" titleHighlight="Snacks Salados Valle Toluca" subtitle="Bodas, corporativos y celebraciones reales montadas por MEDEDUL en Valle de Toluca" />
      <div class="tol-ss-testimonios__grid">
        {testimonios.map(t => (
          <ReviewCard name={t.name} initials={t.initials} review={t.review} event={t.event} rating={t.rating} verified={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Sucursal Info Card ===================== -->
  <section class="tol-suc-info" aria-label="Información Sucursal MEDEDUL Toluca-Metepec">
    <div class="container">
      <div class="tol-suc-info__card">
        <header class="tol-suc-info__header">
          <span class="tol-suc-info__badge">Sucursal Toluca-Metepec</span>
          <h2>Operamos desde <span>Metepec</span> con cobertura completa Valle de Toluca</h2>
          <p>Te atendemos en menos de 24 horas. Cotización gratuita, anticipo 50% para reservar fecha y liquidación 48 h antes del evento.</p>
        </header>
        <div class="tol-suc-info__grid">
          <div class="tol-suc-info__item">
            <span class="tol-suc-info__icon" aria-hidden="true">📍</span>
            <h3>Dirección Sucursal</h3>
            <p>Blvd. Toluca-Metepec 913<br/>San Jorge Pueblo Nuevo<br/>Metepec, 52169, Edo. Méx.</p>
            <a href="https://maps.google.com/?q=Blvd.+Toluca-Metepec+913,+San+Jorge+Pueblo+Nuevo,+Metepec,+52169" target="_blank" rel="noopener">Ver en Google Maps →</a>
          </div>
          <div class="tol-suc-info__item">
            <span class="tol-suc-info__icon" aria-hidden="true">📞</span>
            <h3>Teléfono</h3>
            <p><a href="tel:+525521775184">+52 55 2177 5184</a></p>
            <p>Lun-Sáb 10:00-19:00 h</p>
          </div>
          <div class="tol-suc-info__item">
            <span class="tol-suc-info__icon" aria-hidden="true">💬</span>
            <h3>WhatsApp directo</h3>
            <p>Respuesta ejecutiva &lt; 24 h</p>
            <a href="https://wa.me/525521775184?text=Hola%20MEDEDUL%20Toluca%2C%20me%20interesa%20cotizar%20Snacks%20Salados" class="tol-suc-info__btn" target="_blank" rel="noopener">Escribir por WhatsApp</a>
          </div>
          <div class="tol-suc-info__item">
            <span class="tol-suc-info__icon" aria-hidden="true">🚗</span>
            <h3>Cobertura Valle Toluca</h3>
            <p>Metepec · Toluca · Zinacantepec · Lerma · Ocoyoacac · San Mateo · Calimaya</p>
            <a href="/sucursales/toluca">Ver Sucursal completa →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ + Contacto ===================== -->
  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  /* ==========================================================
     Toluca Snacks Gourmet Salados L5 - Sucursal Toluca-Metepec
     Prefix: tol-ss-
     Acento naranja-ámbar (#e8851a) + amarillo dorado popcorn (#f5b800)
     ========================================================== */

  /* Stats */
  .tol-ss-stats { padding: 50px 0; background: linear-gradient(180deg, #fff 0%, #fffaf0 100%); }
  .tol-ss-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
  .tol-ss-stat { display: flex; flex-direction: column; gap: 6px; padding: 20px 14px; background: #fff; border-radius: 16px; border: 1px solid rgba(232, 133, 26, 0.15); box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04); }
  .tol-ss-stat__num { font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 800; color: #e8851a; line-height: 1; }
  .tol-ss-stat__label { font-size: 0.85rem; color: var(--texto-light, #666); font-weight: 500; }

  /* Buttons */
  .tol-ss-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 28px; border-radius: 50px; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.95rem; text-decoration: none; }
  .tol-ss-btn--primary { background: linear-gradient(135deg, #25D366 0%, #128C7E 100%); color: #fff; box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3); }

  /* Carta 12 snacks (DARK) */
  .tol-ss-carta { padding: 100px 0; background: linear-gradient(180deg, #1c1410 0%, #2a1f0e 100%); color: #fff; position: relative; overflow: hidden; }
  .tol-ss-carta::before { content: ''; position: absolute; top: -20%; right: -10%; width: 700px; height: 700px; background: radial-gradient(circle, rgba(245, 184, 0, 0.18) 0%, transparent 70%); pointer-events: none; }
