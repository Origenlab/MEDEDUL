          <div class="tol-qe-stat">
            <span class="tol-qe-stat__num">{s.number}</span>
            <span class="tol-qe-stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Carta Quesos Europeos (12 piezas) ===================== -->
  <section class="tol-qe-carta">
    <div class="container">
      <div class="tol-qe-carta__header">
        <span class="tol-qe-carta__badge">Carta del Affineur</span>
        <h2>Los <span>12 Quesos Europeos D.O.P.</span> de la Casa</h2>
        <p>Cada pieza con su origen, leche, tiempo de curación, perfil de sabor y maridaje sugerido. La carta completa que servimos en eventos del Valle de Toluca.</p>
      </div>

      <div class="tol-qe-carta__grid">
        {cartaQuesos.map((q, i) => (
          <article class="tol-qe-queso-card">
            <header class="tol-qe-queso-card__head">
              <span class="tol-qe-queso-card__num">{String(i + 1).padStart(2, '0')}</span>
