  </section>

  <!-- ===================== FAQ + Contacto ===================== -->
  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  /* ==========================================================
     Toluca Tabla Mixta Premium L5 - Sucursal Toluca-Metepec
     Prefix: tol-tm-
     Acento gradient dorado vintage (#a87a3c) + vino reserva (#7d2438)
     "Mixta" = combinación visual de ambas paletas
     ========================================================== */

  /* Stats */
