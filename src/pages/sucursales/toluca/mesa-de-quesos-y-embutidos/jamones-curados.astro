        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Blvd. Toluca-Metepec 913",
          "addressLocality": "San Jorge Pueblo Nuevo, Metepec",
          "postalCode": "52169",
          "addressRegion": "Estado de Mexico",
          "addressCountry": "MX"
        },
        "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "54", "bestRating": "5" }
