  { title: 'Fuente de Chocolate Belga', desc: 'Chocolate Callebaut premium en cascada como contraste dulce a la tabla salada. Para sumergir fresas, peras y malvaviscos. Operador profesional incluido. Suma sensorialidad al evento Valle Toluca.', img: '/img/estaciones-interactivas/fuente-chocolate/fuente-de-chocolate-para-eventos.avif', badge: 'Sensorial', badgeColor: '#8B4513', link: '/estaciones-interactivas/fuente-de-chocolate', features: ['Chocolate Callebaut', 'Acompañantes incluidos', 'Operador profesional'] }
