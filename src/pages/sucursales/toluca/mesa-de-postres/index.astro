  <!-- ===================== Ingredientes Premium ===================== -->
  <section class="tol-mp-ingredientes">
    <div class="container">
      <div class="tol-mp-ingredientes__header">
        <span class="tol-mp-ingredientes__badge">Insumos Importados</span>
        <h2>Ingredientes <span>Premium Que Marcan la Diferencia</span></h2>
        <p>No es solo presentación. Cada pieza de nuestra mesa de postres está elaborada con insumos importados de origen y producto local del Estado de México seleccionado.</p>
      </div>

      <div class="tol-mp-ingredientes__grid">
        {ingredientesPremium.map(ing => (
          <div class="tol-mp-ingrediente">
