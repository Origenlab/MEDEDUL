  </section>

  <!-- ===================== Paquetes Mesa de Postres Toluca ===================== -->
  <PricingPackages
    id="paquetes-mp-toluca"
    badge="Paquetes Mesa de Postres Toluca"
    title="Elige tu"
    titleHighlight="Paquete Boutique Toluca"
    subtitle="3 niveles claros, sin sorpresas. Carta del chef incluida"
    content={`<p>Diseñamos <strong>tres niveles de paquete Toluca</strong> según el tamaño y estándar de tu evento. Todos incluyen carta del chef personalizada, ingredientes premium, mobiliario boutique y cadena de frío. Lo que escala es la <strong>variedad signature, sofisticación del montaje y experiencia in-situ</strong>. Anticipo del 50% para reservar fecha, liquidación 48 h antes del evento.</p>`}
    packages={paquetesMesaPostresToluca}
    note="💡 <strong>Todos los paquetes Toluca incluyen:</strong> carta del chef personalizada, producción 48-72 h antes del evento, ingredientes premium, mobiliario boutique, transporte refrigerado profesional desde Sucursal Metepec, operador con uniforme protocolo, reposición continua, desmontaje y empaque de sobrantes."
  />

  <!-- ===================== Maridajes Sugeridos ===================== -->
  <section class="tol-mp-maridajes">
    <div class="container">
      <div class="tol-mp-maridajes__header">
        <span class="tol-mp-maridajes__badge">Pairings & Maridajes</span>
        <h2>Maridajes <span>Recomendados</span></h2>
        <p>Llevamos tu mesa de postres al siguiente nivel coordinando bebidas que potencien cada nota del paladar. Sugerencias del sommelier de la casa.</p>
      </div>

      <div class="tol-mp-maridajes__grid">
        {maridajes.map(m => (
          <div class="tol-mp-maridaje-card">
            <span class="tol-mp-maridaje-card__icon">{m.icon}</span>
            <h3>{m.bebida}</h3>
            <p>{m.detalle}</p>
            <span class="tol-mp-maridaje-card__eventos">{m.eventos}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Por qué elegirnos ===================== -->
  <WhyChooseUs
    id="por-que-mp-toluca"
    badge="Diferenciadores Sucursal Toluca"
    title="Por qué elegir nuestra Mesa de Postres en"
    titleHighlight="Valle de Toluca"
    descriptions={[
      "Con <strong>90+ mesas de postres montadas en Valle Toluca</strong> y 8 años de experiencia MEDEDUL en alta repostería para bodas, XV años y corporativos premium en los venues más exigentes del Valle, somos la opción de referencia cuando lo que necesitas es <strong>pastelería boutique con ejecución de hacienda 5 estrellas</strong>.",
      "Cada mesa de postres parte del mismo estándar: carta del chef personalizada, ingredientes importados premium, producción 48-72 h antes en Sucursal Metepec, técnicas francesas profesionales, mobiliario editorial y cadena de frío controlada. Lo que cambia es la <strong>escala y sofisticación</strong>, no la calidad."
    ]}
    stats={[
      { number: "90+", label: "Mesas postres Valle Toluca" },
      { number: "100%", label: "Artesanal in-house" },
      { number: "15+", label: "Variedades signature" },
      { number: "< 24h", label: "Cotización" }
    ]}
    features={caracteristicas}
  />

  <!-- ===================== Galería visual Toluca ===================== -->
  <section class="tol-mp-galeria" id="galeria-toluca">
    <div class="container">
      <SectionHeader
        title="Mesas de Postres reales montadas en"
        titleHighlight="Valle de Toluca"
        subtitle="Selección curada de mesas boutique MEDEDUL en bodas, XV y corporativos del Valle"
      />

      <div class="tol-mp-galeria__bento">
        {galeriaImages.map(img => (
          <div class="tol-mp-galeria__item">
            <img
              src={getCdnUrl(img.src, { w: 800, q: 80 })}
              srcset={getCdnSrcSet(img.src, galleryWidths, { q: 80 })}
              sizes={gallerySizes}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              width="800"
              height="533"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Qué incluye ===================== -->
  <section class="tol-mp-incluye">
    <div class="container">
