            src={getCdnUrl('/img/galeria/candy-bar-boda-rosa-dorado-elegante-peonias.avif', { w: 720, q: 82 })}
            alt="Candy bar nupcial elegante MEDEDUL en boda Valle Toluca con peonías rosadas y dorado"
            loading="lazy"
            width="720"
            height="480"
          />
        </div>
