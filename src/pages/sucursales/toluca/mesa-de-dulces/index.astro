     Toluca Mesa de Dulces - Sucursal-specific styles
     Reutiliza tokens globales (--rosa-principal, --texto-oscuro)
     Acento verde-natural Valle de Toluca
     ========================================================== */

  /* ---------- Stats Trust Bar ---------- */
  .tol-md-stats { padding: 50px 0; background: linear-gradient(180deg, #fff 0%, #f8fbf6 100%); }
  .tol-md-stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; text-align: center; }
  .tol-md-stat { display: flex; flex-direction: column; gap: 6px; padding: 20px 14px; background: #fff; border-radius: 16px; border: 1px solid rgba(125, 155, 105, 0.12); box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04); }
  .tol-md-stat__num { font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 800; color: var(--rosa-principal, #D1007A); line-height: 1; }
  .tol-md-stat__label { font-size: 0.85rem; color: var(--texto-light, #666); font-weight: 500; }

  /* ---------- Subsecciones (4 cards de evento) ---------- */
  .tol-md-subsecciones { padding: 80px 0; background: #fff; }
  .tol-md-subsecciones__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 40px; }
  .tol-md-subsecciones__cta { text-align: center; margin-top: 50px; padding: 30px; background: linear-gradient(135deg, #f8fbf6 0%, #fff5f9 100%); border-radius: 20px; border: 1px dashed rgba(125, 155, 105, 0.3); }
  .tol-md-subsecciones__cta p { font-size: 1.05rem; color: var(--texto-light, #666); margin: 0 0 18px; }
  .tol-md-subsecciones__cta strong { color: var(--rosa-principal, #D1007A); }

  /* ---------- Buttons ---------- */
  .tol-md-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 28px; border-radius: 50px; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.95rem; text-decoration: none; }
  .tol-md-btn--primary { background: linear-gradient(135deg, #25D366 0%, #128C7E 100%); color: #fff; box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3); }
  .tol-md-btn--ghost { background: #fff; color: var(--rosa-principal, #D1007A); border: 2px solid var(--rosa-principal, #D1007A); }

  /* ---------- Galería bento ---------- */
  .tol-md-galeria { padding: 90px 0; background: linear-gradient(180deg, #f8fbf6 0%, #fff9fb 100%); }
  .tol-md-galeria__bento { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(3, 200px); gap: 20px; margin-top: 40px; }
  .tol-md-galeria__item { border-radius: 20px; overflow: hidden; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08); }
  .tol-md-galeria__item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .tol-md-galeria__item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
  .tol-md-galeria__item:nth-child(5), .tol-md-galeria__item:nth-child(6) { grid-column: span 2; }

  /* ---------- Incluye ---------- */
  .tol-md-incluye { padding: 90px 0; background: #fff; }
  .tol-md-incluye__header { text-align: center; max-width: 720px; margin: 0 auto 50px; }
  .tol-md-incluye__badge { display: inline-block; background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%); color: #fff; padding: 8px 20px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
  .tol-md-incluye__header h2 { font-size: 2.2rem; color: var(--texto-oscuro, #1a1a1a); margin-bottom: 12px; }
  .tol-md-incluye__header h2 span { color: var(--rosa-principal, #D1007A); }
  .tol-md-incluye__header p { font-size: 1.05rem; color: var(--texto-light, #666); line-height: 1.6; }
  .tol-md-incluye__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .tol-md-incluye__card { background: #fff; border: 1px solid rgba(125, 155, 105, 0.15); border-radius: 20px; padding: 32px 28px; box-shadow: 0 5px 20px rgba(0, 0, 0, 0.04); }
  .tol-md-incluye__num { display: inline-block; width: 36px; height: 36px; background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%); color: #fff; border-radius: 10px; font-size: 0.95rem; font-weight: 700; line-height: 36px; text-align: center; margin-bottom: 18px; }
  .tol-md-incluye__card h4 { font-size: 1.15rem; color: var(--texto-oscuro, #1a1a1a); margin-bottom: 12px; }
  .tol-md-incluye__card p { font-size: 0.92rem; color: var(--texto-light, #666); line-height: 1.7; margin: 0; }

  /* ---------- Estaciones complementarias ---------- */
  .tol-md-estaciones { padding: 90px 0; background: linear-gradient(180deg, #f8fbf6 0%, #fff 100%); }
  .tol-md-estaciones__header { text-align: center; max-width: 720px; margin: 0 auto 50px; }
  .tol-md-estaciones__badge { display: inline-block; background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%); color: #fff; padding: 8px 22px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
  .tol-md-estaciones__header h2 { font-size: 2.1rem; color: var(--texto-oscuro, #1a1a1a); margin-bottom: 12px; }
  .tol-md-estaciones__header h2 span { color: var(--rosa-principal, #D1007A); }
  .tol-md-estaciones__header p { font-size: 1.05rem; color: var(--texto-light, #666); line-height: 1.7; }
  .tol-md-estaciones__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .tol-md-estacion-card { background: #fff; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08); border: 1px solid rgba(125, 155, 105, 0.1); display: flex; flex-direction: column; }
  .tol-md-estacion-card__image { position: relative; height: 200px; overflow: hidden; }
  .tol-md-estacion-card__image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .tol-md-estacion-card__badge { position: absolute; top: 14px; left: 14px; color: #fff; padding: 6px 14px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .tol-md-estacion-card__content { padding: 28px; display: flex; flex-direction: column; flex-grow: 1; }
  .tol-md-estacion-card__content h3 { font-size: 1.25rem; color: var(--texto-oscuro, #1a1a1a); margin-bottom: 12px; }
  .tol-md-estacion-card__content > p { font-size: 0.92rem; color: var(--texto-light, #666); line-height: 1.7; margin-bottom: 18px; }
  .tol-md-estacion-card__content ul { list-style: none; padding: 0; margin: 0 0 22px; flex-grow: 1; }
  .tol-md-estacion-card__content li { font-size: 0.85rem; color: var(--texto-light, #666); padding: 6px 0; display: flex; align-items: center; gap: 8px; }
  .tol-md-estacion-card__link { display: flex; align-items: center; justify-content: center; gap: 8px; background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%); color: #fff; padding: 13px 22px; border-radius: 12px; font-weight: 600; text-decoration: none; font-size: 0.92rem; box-shadow: 0 4px 15px rgba(233, 30, 140, 0.25); }
  .tol-md-estaciones__cta { text-align: center; margin-top: 50px; }
  .tol-md-estaciones__cta p { font-size: 1rem; color: var(--texto-light, #666); margin-bottom: 20px; }
  .tol-md-estaciones__cta strong { color: var(--rosa-principal, #D1007A); }

  /* ---------- Testimonios ---------- */
  .tol-md-testimonios { padding: 90px 0; background: #fff; }
  .tol-md-testimonios__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 40px; }

  /* ---------- CDMX cross-link CTA ---------- */
  .tol-md-cdmx-cta { padding: 90px 0; background: linear-gradient(180deg, #fff 0%, #f8fbf6 100%); }
  .tol-md-cdmx-cta__card { background: linear-gradient(135deg, #D1007A 0%, #7d9b69 100%); border-radius: 24px; padding: 50px; display: grid; grid-template-columns: 1.3fr 1fr; gap: 40px; align-items: center; color: #fff; box-shadow: 0 25px 60px rgba(208, 0, 122, 0.25); }
  .tol-md-cdmx-cta__badge { display: inline-block; background: rgba(255, 255, 255, 0.2); padding: 8px 18px; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 16px; backdrop-filter: blur(8px); }
  .tol-md-cdmx-cta__body h2 { font-size: 2rem; line-height: 1.2; margin-bottom: 16px; color: #fff; }
  .tol-md-cdmx-cta__body h2 span { color: #fff8e1; font-weight: 800; }
  .tol-md-cdmx-cta__body p { line-height: 1.7; color: rgba(255, 255, 255, 0.95); margin-bottom: 24px; }
  .tol-md-cdmx-cta__body p strong { color: #fff; }
  .tol-md-cdmx-cta__link { display: inline-block; background: #fff; color: #D1007A; padding: 14px 32px; border-radius: 50px; font-weight: 700; text-decoration: none; transition: transform 0.2s ease; }
  .tol-md-cdmx-cta__link:hover { transform: translateY(-2px); }
  .tol-md-cdmx-cta__visual img { width: 100%; border-radius: 16px; box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25); }

  /* ==========================================================
     RESPONSIVE
     ========================================================== */
  @media (max-width: 1024px) {
    .tol-md-stats__grid { grid-template-columns: repeat(2, 1fr); }
    .tol-md-subsecciones__grid { grid-template-columns: repeat(2, 1fr); }
    .tol-md-galeria__bento { grid-template-columns: repeat(2, 1fr); grid-template-rows: auto; }
    .tol-md-galeria__item:nth-child(1) { grid-column: span 2; grid-row: span 1; }
    .tol-md-galeria__item:nth-child(5), .tol-md-galeria__item:nth-child(6) { grid-column: span 1; }
    .tol-md-incluye__grid { grid-template-columns: repeat(2, 1fr); }
    .tol-md-estaciones__grid { grid-template-columns: repeat(2, 1fr); }
    .tol-md-testimonios__grid { grid-template-columns: repeat(2, 1fr); }
    .tol-md-cdmx-cta__card { grid-template-columns: 1fr; padding: 32px; }
  }

  @media (max-width: 768px) {
    .tol-md-stats { padding: 40px 0; }
    .tol-md-stat__num { font-size: 1.6rem; }
    .tol-md-subsecciones, .tol-md-galeria, .tol-md-incluye, .tol-md-estaciones, .tol-md-testimonios, .tol-md-cdmx-cta { padding: 60px 0; }
    .tol-md-subsecciones__grid { grid-template-columns: 1fr; }
    .tol-md-incluye__header h2, .tol-md-estaciones__header h2 { font-size: 1.6rem; }
    .tol-md-incluye__grid { grid-template-columns: 1fr; }
    .tol-md-incluye__card { padding: 26px 22px; }
    .tol-md-estaciones__grid { grid-template-columns: 1fr; }
    .tol-md-estacion-card__image { height: 180px; }
    .tol-md-estacion-card__content { padding: 22px; }
    .tol-md-testimonios__grid { grid-template-columns: 1fr; }
    .tol-md-cdmx-cta__body h2 { font-size: 1.5rem; }
  }

  @media (max-width: 480px) {
    .tol-md-stats__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .tol-md-stat { padding: 16px 10px; }
    .tol-md-stat__num { font-size: 1.4rem; }
    .tol-md-stat__label { font-size: 0.78rem; }
    .tol-md-subsecciones__cta { padding: 24px 18px; }
    .tol-md-subsecciones__cta p { font-size: 0.95rem; }
  }

  /* ==========================================================
     Sucursal Info Card (homologado 5 páginas Toluca)
     ========================================================== */
  .tol-suc-info { padding: 80px 0; background: #fff; }
  .tol-suc-info__card { background: linear-gradient(135deg, #fff5f9 0%, #f8fbf6 100%); border-radius: 24px; padding: 50px 40px; border: 1px solid rgba(125, 155, 105, 0.15); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.05); }
  .tol-suc-info__header { text-align: center; max-width: 720px; margin: 0 auto 40px; }
  .tol-suc-info__badge { display: inline-block; background: linear-gradient(135deg, #D1007A 0%, #7d9b69 100%); color: #fff; padding: 8px 20px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
  .tol-suc-info__header h2 { font-size: 1.8rem; color: #1a1a1a; margin-bottom: 10px; line-height: 1.3; }
  .tol-suc-info__header h2 span { color: #D1007A; }
  .tol-suc-info__header p { font-size: 1rem; color: #666; line-height: 1.6; }
  .tol-suc-info__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .tol-suc-info__item { background: #fff; border-radius: 16px; padding: 28px 22px; text-align: center; border: 1px solid rgba(125, 155, 105, 0.1); transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .tol-suc-info__item:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(208, 0, 122, 0.1); }
  .tol-suc-info__icon { font-size: 2.4rem; display: block; margin-bottom: 10px; }
  .tol-suc-info__item h3 { font-size: 1rem; color: #1a1a1a; margin-bottom: 10px; font-weight: 700; }
  .tol-suc-info__item p { font-size: 0.88rem; color: #555; line-height: 1.6; margin-bottom: 10px; }
  .tol-suc-info__item a { color: #D1007A; font-weight: 600; text-decoration: none; font-size: 0.88rem; }
  .tol-suc-info__item a:hover { text-decoration: underline; }
  .tol-suc-info__btn { display: inline-block; background: linear-gradient(135deg, #25D366 0%, #128C7E 100%); color: #fff !important; padding: 10px 18px; border-radius: 50px; font-weight: 600; font-size: 0.85rem; box-shadow: 0 6px 18px rgba(37, 211, 102, 0.25); }
  .tol-suc-info__btn:hover { text-decoration: none !important; transform: translateY(-2px); }
  @media (max-width: 1024px) { .tol-suc-info__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .tol-suc-info { padding: 60px 0; } .tol-suc-info__card { padding: 36px 26px; } .tol-suc-info__header h2 { font-size: 1.4rem; } }
  @media (max-width: 480px) { .tol-suc-info__grid { grid-template-columns: 1fr; } }
</style>
