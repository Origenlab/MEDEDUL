              image={s.img}
              alt={`${s.title} para eventos en Toluca y Valle de Toluca por MEDEDUL`}
              title={s.title}
              excerpt={s.excerpt}
              badge={s.badge}
              cta={s.cta}
            />
          ))}
        </div>
      </div>

      <!-- =============== C. Estaciones Interactivas =============== -->
