---

<BaseLayout
  title="Sucursales MEDEDUL | Mesas de Dulces en CDMX, Condesa y Toluca Metepec"
  description="3 sucursales de mesas de dulces premium: Anzures y Condesa en CDMX, y Toluca–Metepec en EdoMex. 500+ eventos. Bodas, XV años, baby shower y corporativos. Cotiza gratis."
  canonical="/sucursales"
  ogImage="/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif"
  includeCategoryStyles={true}
>
  <meta name="geo.region" content="MX-CMX" slot="head" />
  <meta name="geo.placename" content="Ciudad de México, México" slot="head" />
  <meta name="geo.position" content="19.4326;-99.1832" slot="head" />
  <meta name="ICBM" content="19.4326, -99.1832" slot="head" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaLD)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <Hero
    title="Tres Sucursales. Un mismo estándar de"
    highlight="Calidad Premium"
    subtitle="CDMX · Estado de México · Valle de Toluca"
    secondaryContent={`
      <p>Operamos desde <strong>tres puntos estratégicos</strong> para garantizar puntualidad, tiempos de respuesta cortos y logística eficiente en cada evento. Desde Anzures hasta Metepec, el mismo nivel de servicio, los mismos productos y el mismo equipo capacitado.</p>
      <p>¿No sabes cuál sucursal te corresponde? Escríbenos la colonia o el nombre del venue y te asignamos la sede operativa con el menor costo de traslado posible.</p>
    `}
  />


  <!-- ═══════════════════════════════════════════════════════
       ANCLAS DE NAVEGACIÓN
  ═══════════════════════════════════════════════════════ -->
  <nav class="branch-nav" aria-label="Ir a sucursal">
    <div class="container">
      <p class="branch-nav__label">Ir directamente a:</p>
      <div class="branch-nav__links">
        {sucursales.map(s => (
          <a href={`#${s.id}`} class={`branch-nav__link branch-nav__link--${s.tipoColor}`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {s.nombre}
            <span class="branch-nav__estado">{s.estado}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════
       SUCURSALES — una por una
  ═══════════════════════════════════════════════════════ -->
  {sucursales.map((s, i) => (
    <section
      class={`branch-section ${i % 2 === 0 ? 'branch-section--light' : 'branch-section--alt'}`}
      id={s.id}
      aria-label={s.nombreCompleto}
    >
      <div class="container">

        <!-- Encabezado de sucursal -->
        <header class="branch-header">
          <div class="branch-header__meta">
            <span class={`branch-tag branch-tag--${s.tipoColor}`}>{s.tipo}</span>
            <span class="branch-header__estado">{s.estado}</span>
          </div>
          <div class="branch-header__title-row">
            <h2 class="branch-title">{s.nombreCompleto}</h2>
            <div class="branch-header__ctas">
              <a
                href={s.whatsapp}
                class="btn-wa btn-wa--compact"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`WhatsApp ${s.nombreCompleto}`}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Cotizar por WhatsApp
              </a>
              <a href={s.hubHref} class="btn-secondary-sm">
                Ver página de sucursal
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
          <p class="branch-descripcion">{s.descripcion}</p>
        </header>

        <!-- Layout principal: contenido + visual -->
