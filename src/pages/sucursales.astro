<BaseLayout
  title="Sucursales MEDEDUL | Mesas de Dulces en CDMX, Condesa y Toluca Metepec"
  description="3 sucursales de mesas de dulces premium: Anzures y Condesa en CDMX, y Toluca–Metepec en EdoMex. 500+ eventos. Bodas, XV años, baby shower y corporativos. Cotiza gratis."
  canonical="/sucursales"
  ogImage="/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif"
  includeCategoryStyles={true}
>
  <!-- GEO Meta Tags -->
  <meta name="geo.region" content="MX-CMX" slot="head" />
  <meta name="geo.placename" content="Ciudad de México, México" slot="head" />
  <meta name="geo.position" content="19.4326;-99.1832" slot="head" />
  <meta name="ICBM" content="19.4326, -99.1832" slot="head" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaLD)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <Hero
    title="Sucursales MEDEDUL en CDMX y Toluca"
    highlight="Sucursales"
    subtitle="3 puntos estratégicos · Cobertura CDMX · Estado de México · Valle de Toluca"
    secondaryContent={`
      <p>Operamos desde <strong>tres sucursales activas</strong> para garantizar puntualidad, tiempos de respuesta cortos y logística eficiente en todos los rincones del área metropolitana. Cada sucursal opera con el mismo estándar de calidad, los mismos productos premium y el mismo equipo capacitado.</p>
      <p><strong>¿No sabes cuál te corresponde?</strong> No te preocupes — escríbenos el venue de tu evento y te asignamos la sucursal óptima con el menor costo de traslado posible.</p>
    `}
  />

  <!-- ═══════════════════════════════════════════════════════
       STATS STRIP
  ═══════════════════════════════════════════════════════ -->
  <section class="stats-strip">
    <div class="container">
      <div class="stats-grid">
        {stats.map(s => (
          <div class="stat-item">
            <span class="stat-icono" aria-hidden="true">{s.icono}</span>
            <span class="stat-numero">{s.numero}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       MAPA RÁPIDO DE SUCURSALES
  ═══════════════════════════════════════════════════════ -->
  <section class="selector-section section-padding">
    <div class="container">
      <SectionHeader
        title="Elige tu"
        titleHighlight="Sucursal"
        subtitle="Selecciona la más cercana a tu evento para cotización inmediata"
        align="center"
      />
      <div class="selector-grid">
        {sucursales.map(s => (
          <a href={`#${s.id}`} class={`selector-chip selector-chip--${s.badgeColor}`}>
            <span class="selector-emoji" aria-hidden="true">{s.emoji}</span>
            <div class="selector-info">
              <span class="selector-nombre">{s.nombre}</span>
              <span class="selector-estado">{s.estado}</span>
            </div>
            <svg class="selector-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 5v14M5 12l7 7 7-7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SUCURSALES — una por una, layout alternado
  ═══════════════════════════════════════════════════════ -->
  {sucursales.map((s, i) => (
    <article
      class={`sucursal-section ${i % 2 === 0 ? 'sucursal-section--light' : 'sucursal-section--alt'}`}
      id={s.id}
    >
      <div class="container">
        <div class={`sucursal-layout ${i % 2 !== 0 ? 'sucursal-layout--reverse' : ''}`}>

          {/* Columna imagen + mapa */}
          <div class="sucursal-visual">
            <div class="sucursal-imagen-wrap">
              <img
                src={s.imagen}
                alt={s.imagenAlt}
                width="560"
                height="420"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="sucursal-img"
              />
              <div class={`sucursal-badge-overlay sucursal-badge-overlay--${s.badgeColor}`}>
                {s.badge}
              </div>
              <div class="sucursal-eventos-badge">
                <span class="sucursal-eventos-num">{s.eventos}</span>
                <span class="sucursal-eventos-label">eventos</span>
              </div>
            </div>

            {/* Mapa embed */}
            <div class="sucursal-mapa-wrap">
              <iframe
                src={s.mapsEmbed}
                width="100%"
                height="200"
                style="border:0;"
                allowfullscreen={false}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Mapa de ubicación ${s.nombreCompleto}`}
              ></iframe>
              <a
                href={s.mapLink}
                target="_blank"
                rel="noopener noreferrer"
                class="sucursal-mapa-link"
                aria-label={`Ver ${s.nombreCompleto} en Google Maps`}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </div>

          {/* Columna info */}
          <div class="sucursal-info">
            <header class="sucursal-header">
              <span class="sucursal-emoji" aria-hidden="true">{s.emoji}</span>
              <div>
                <span class={`sucursal-estado-tag sucursal-estado-tag--${s.badgeColor}`}>{s.estado}</span>
                <h2 class="sucursal-titulo">{s.nombreCompleto}</h2>
              </div>
            </header>

            <p class="sucursal-descripcion">{s.descripcion}</p>

            {/* Datos de contacto */}
            <div class="sucursal-datos">
              <div class="sucursal-dato">
                <div class="sucursal-dato-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div class="sucursal-dato-body">
                  <span class="sucursal-dato-label">Dirección</span>
                  <strong class="sucursal-dato-valor">{s.direccion}</strong>
                  <span class="sucursal-dato-extra">{s.colonia} · CP {s.cp} · {s.ciudadCompleta}</span>
                </div>
              </div>

              <div class="sucursal-dato">
                <div class="sucursal-dato-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <div class="sucursal-dato-body">
                  <span class="sucursal-dato-label">Horario de atención</span>
                  <strong class="sucursal-dato-valor">{s.horario}</strong>
                  <span class="sucursal-dato-extra">Cotización online 24/7 por WhatsApp</span>
                </div>
              </div>

              <div class="sucursal-dato">
                <div class="sucursal-dato-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                </div>
                <div class="sucursal-dato-body">
                  <span class="sucursal-dato-label">Teléfono</span>
                  <strong class="sucursal-dato-valor">{s.telefono}</strong>
                  <span class="sucursal-dato-extra">Lunes a Sábado · 10:00 – 19:00 h</span>
                </div>
              </div>
            </div>

            {/* Zonas de cobertura */}
            <div class="sucursal-cobertura">
              <h3 class="sucursal-cobertura-titulo">Zonas de cobertura</h3>
              <div class="sucursal-zonas">
                {s.cobertura.map(zona => (
                  <span class="zona-chip">{zona}</span>
                ))}
              </div>
            </div>

            {/* Servicios disponibles */}
            <div class="sucursal-servicios-links">
              <h3 class="sucursal-servicios-titulo">Servicios en esta sucursal</h3>
              <div class="sucursal-servicios-grid">
                {s.servicios.map(srv => (
                  <a href={srv.href} class="sucursal-servicio-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                    {srv.label}
                  </a>
                ))}
              </div>
            </div>

            {/* CTAs */}
            <div class="sucursal-ctas">
              <a
                href={s.whatsapp}
                class="btn-wa"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`WhatsApp ${s.nombreCompleto}`}
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Cotizar por WhatsApp
              </a>
              <a href={s.telefonoHref} class="btn-tel">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                </svg>
                {s.telefono}
              </a>
              <a href={s.hubHref} class="btn-hub">
                Ver página de sucursal →
              </a>
            </div>
          </div>

        </div>
      </div>
    </article>
  ))}

  <!-- ═══════════════════════════════════════════════════════
       COBERTURA GEO — CDMX por alcaldía
  ═══════════════════════════════════════════════════════ -->
  <section class="geo-cobertura section-padding">
    <div class="container">
      <SectionHeader
        title="Cobertura en"
        titleHighlight="Ciudad de México"
        subtitle="Las dos sucursales CDMX cubren las 16 alcaldías"
        content={`
          <p>Con dos sucursales estratégicamente ubicadas en CDMX, garantizamos tiempos de traslado óptimos y costo de logística eficiente para cualquier venue de la ciudad. Seleccionamos la sucursal más cercana según la colonia de tu evento.</p>
        `}
      />

      <div class="geo-grid">
        {zonasCDMX.map(a => (
          <div class="geo-alcaldia">
            <h3 class="geo-alcaldia-nombre">{a.alcaldia}</h3>
            <div class="geo-zonas">
              {a.zonas.map(z => <span class="geo-chip">{z}</span>)}
            </div>
          </div>
        ))}
      </div>

      <div class="geo-toluca-wrap">
        <h3 class="geo-toluca-titulo">
          Cobertura en <span class="titulo-decorativo">Valle de Toluca</span>
        </h3>
        <p class="geo-toluca-desc">Sucursal Toluca–Metepec: Blvd. Toluca–Metepec 913, San Jorge Pueblo Nuevo, CP 52169. Atendemos todo el Valle de Toluca.</p>
        <div class="geo-grid geo-grid--toluca">
          {zonasToluca.map(m => (
            <div class="geo-alcaldia">
              <h4 class="geo-alcaldia-nombre">{m.municipio}</h4>
              <div class="geo-zonas">
                {m.zonas.map(z => <span class="geo-chip geo-chip--morado">{z}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SERVICIOS DISPONIBLES (ServiceCards)
  ═══════════════════════════════════════════════════════ -->
  <section class="servicios-section section-padding">
    <div class="container">
      <SectionHeader
        title="Todos los Servicios en"
        titleHighlight="Todas las Sucursales"
        subtitle="El mismo catálogo completo en CDMX y Toluca–Metepec"
        align="center"
      />
      <div class="service-grid">
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-dulces"
          image={getCdnUrl('/img/tipos-de-mesas/dulces-personalizadas/mesas-de-dulces-infantiles.avif')}
          alt="Mesa de dulces premium para eventos en CDMX y Toluca"
          title="Mesa de Dulces"
          excerpt="Candy bar personalizado con dulces premium para bodas, XV años, baby shower y cualquier celebración. Diseño único, montaje incluido."
          cta="Ver servicio"
          badge="Popular"
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-postres"
          image={getCdnUrl('/img/tipos-de-mesas/postres/mesas-de-postres-cdmx.avif')}
          alt="Mesa de postres gourmet para bodas y XV años en CDMX y Toluca"
          title="Mesa de Postres"
          excerpt="Macarons, éclairs, pays y repostería fina de alto nivel. Para eventos donde lo gourmet marca la diferencia."
          cta="Ver postres"
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-frutas"
          image={getCdnUrl('/img/tipos-de-mesas/frutas/mesas-de-frutas-para-eventos.avif')}
          alt="Mesa de frutas frescas para eventos en CDMX y Toluca"
          title="Mesa de Frutas"
          excerpt="Arreglos espectaculares con fruta de temporada. Frescura, color y sabor en cada evento."
          cta="Ver frutas"
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos"
          image={getCdnUrl('/img/tipos-de-mesas/quesos-embutidos/renta-de-mesa-de-quesos.avif')}
          alt="Mesa de quesos y embutidos gourmet para eventos corporativos y bodas"
          title="Quesos y Embutidos"
          excerpt="Selección de quesos finos, jamones curados y acompañamientos premium. El toque sofisticado para bodas y corporativos."
          cta="Ver tabla"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TESTIMONIOS
  ═══════════════════════════════════════════════════════ -->
  <section class="testimonios-section section-padding">
    <div class="container">
      <SectionHeader
        title="Lo que dicen de nuestras"
        titleHighlight="Sucursales"
        subtitle="Clientes reales, experiencias verificadas en CDMX y Toluca"
      />
      <div class="testimonios-grid">
        {testimonios.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CTA COTIZAR
  ═══════════════════════════════════════════════════════ -->
  <CTAServices
    href="/cotizar"
    badge="Elige tu sucursal más cercana"
    title="¿Cuál Sucursal Atiende tu Evento?"
    titleHighlight="Sucursal"
    text="Dinos la colonia o venue de tu evento y te asignamos la sucursal óptima. Cotización personalizada en menos de 2 horas en horario de atención."
    buttonText="Solicitar Cotización Gratis"
  />

  <!-- ═══════════════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════════════ -->
  <section class="faq-section section-padding">
    <div class="container">
      <SectionHeader
        title="Preguntas Frecuentes sobre"
        titleHighlight="Nuestras Sucursales"
        subtitle="Todo lo que necesitas saber antes de contactarnos"
        align="center"
      />
      <FAQ items={faqItems} id="faq-sucursales" />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CONTACTO
  ═══════════════════════════════════════════════════════ -->
  <ContactSection />

</BaseLayout>

<style>
  /* ─────────────────────────────────────────
     STATS STRIP
  ───────────────────────────────────────── */
  .stats-strip {
    padding: 56px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: #fff;
  }

  .stat-icono {
    font-size: 1.8rem;
    margin-bottom: 4px;
  }

  .stat-numero {
    font-family: 'Poppins', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.88rem;
    font-weight: 500;
    opacity: 0.88;
  }

  /* ─────────────────────────────────────────
     SELECTOR DE SUCURSAL
  ───────────────────────────────────────── */
  .selector-section {
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .selector-grid {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .selector-chip {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 28px;
    border-radius: 16px;
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 0.25s ease;
    min-width: 220px;
    cursor: pointer;
  }

  .selector-chip--rosa {
    background: linear-gradient(135deg, #fff5fb 0%, #fff 100%);
    border-color: rgba(233, 30, 140, 0.2);
    color: var(--texto-oscuro);
  }

  .selector-chip--morado {
    background: linear-gradient(135deg, #f5f0ff 0%, #fff 100%);
    border-color: rgba(122, 43, 194, 0.2);
    color: var(--texto-oscuro);
  }

  .selector-chip:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(233, 30, 140, 0.15);
  }

  .selector-chip--rosa:hover { border-color: var(--rosa-principal); }
  .selector-chip--morado:hover { border-color: #7A2BC2; }

  .selector-emoji { font-size: 2rem; flex-shrink: 0; }

  .selector-info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .selector-nombre {
    font-family: 'Poppins', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .selector-estado {
    font-size: 0.78rem;
    color: var(--gris-texto);
    font-weight: 500;
    margin-top: 2px;
  }

  .selector-arrow {
    color: var(--rosa-principal);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .selector-chip:hover .selector-arrow { transform: translateY(4px); }

  /* ─────────────────────────────────────────
     SUCURSALES — layout alternado
  ───────────────────────────────────────── */
  .sucursal-section {
    padding: 100px 0;
    scroll-margin-top: 120px;
  }

  .sucursal-section--light { background: #fff; }
  .sucursal-section--alt { background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%); }

  .sucursal-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .sucursal-layout--reverse {
    direction: rtl;
  }
  .sucursal-layout--reverse > * {
    direction: ltr;
  }

  /* Visual */
  .sucursal-visual {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sucursal-imagen-wrap {
    position: relative;
    border-radius: 20px 20px 0 0;
    overflow: hidden;
  }

  .sucursal-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .sucursal-imagen-wrap:hover .sucursal-img {
    transform: scale(1.03);
  }

  .sucursal-badge-overlay {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #fff;
  }

  .sucursal-badge-overlay--rosa {
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    box-shadow: 0 4px 14px rgba(233, 30, 140, 0.4);
  }

  .sucursal-badge-overlay--morado {
