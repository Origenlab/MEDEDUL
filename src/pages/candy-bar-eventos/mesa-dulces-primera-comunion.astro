            <div class="comunion-simbolo__icon" aria-hidden="true">{s.icon}</div>
            <h3 class="comunion-simbolo__title">{s.nombre}</h3>
            <p class="comunion-simbolo__desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

