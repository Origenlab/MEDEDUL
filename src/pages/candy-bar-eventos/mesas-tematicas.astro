      "description": "Mesas de dulces temáticas personalizadas en Ciudad de México con concepto a medida (12 conceptos top trabajados), moodboard previo aprobado, props impresos a medida, dulces con logo grabado disponibles, dirección de arte completa. 4 líneas: infantiles, adultos, corporativa y tradicional mexicana. Operación desde sucursales Anzures y Condesa.",
      "provider": {
        "@type": "LocalBusiness",
        "name": "MEDEDUL",
        "image": getCdnUrl('/img/branding/logo-mededul-mesas-de-dulces.avif'),
        "telephone": "+525525226442",
        "url": "https://mesas-de-dulces.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Ciudad de Mexico",
          "addressRegion": "CDMX",
          "addressCountry": "MX"
        }
      },
      "areaServed": { "@type": "City", "name": "Ciudad de Mexico" },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "MXN",
        "lowPrice": "5200",
        "highPrice": "14800",
        "offerCount": "3",
        "offers": paquetes.map(pkg => ({
          "@type": "Offer",
          "name": `Mesa Temática ${pkg.name}`,
          "price": pkg.price.replace(/[$]/g, ''),
          "priceCurrency": "MXN",
          "description": pkg.guests,
