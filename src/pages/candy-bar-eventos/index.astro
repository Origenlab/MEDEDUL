---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { getCdnUrl } from '@/lib/cdn';
import {
  subsCBTematicas,
  subsCBBoda, subsCBXV, subsCBBabyShower, subsCBCumple,
  subsCBBautizo, subsCBComunion, subsCBCorporativo, subsCBGraduacion,
  subsFuenteChocolate, subsFuenteChamoy, subsParedDulces, subsStandPastel,
  subsDisenoPersonalizado, subsCalidadPremium, subsServicioCompleto, subsCeroEstres,
} from '@/data/subsections';

const breadcrumbItems = [
  { name: 'Servicios', url: '/servicios' },
  { name: 'Candy Bar por Evento', url: '/candy-bar-eventos' }
];

const faqItems = [
  {
    question: 'Que incluye un candy bar para eventos?',
    answer: 'Incluye planeacion, diseno visual, seleccion de producto, montaje profesional, coordinacion en sitio y desmontaje. Ajustamos la propuesta segun tipo de evento, invitados y presupuesto.'
  },
  {
    question: 'Puedo personalizar el candy bar por tematica?',
    answer: 'Si. Personalizamos paleta de color, estilo decorativo, tipos de dulces, etiquetas y presentacion para que el montaje sea coherente con la identidad de tu celebracion. Para conceptos integrales (Barbie, dinosaurios, casino, branding corporativo, dia de muertos, etc.) revisa nuestra pagina especializada de Mesas Tematicas en /candy-bar-eventos/mesas-tematicas con paquetes desde $5,200 MXN, moodboard previo, etiquetas y props impresos a medida.'
  },
  {
    question: 'Con cuanta anticipacion debo reservar?',
    answer: 'Recomendamos reservar entre 2 y 4 semanas antes de la fecha del evento para asegurar agenda, curaduria de producto y produccion sin prisa.'
  },
  {
    question: 'Atienden eventos corporativos y sociales?',
    answer: 'Si. Operamos candy bars para bodas, XV anos, baby shower, bautizos, comuniones, graduaciones y eventos corporativos en CDMX y area metropolitana.'
  },
  {
    question: 'Los paquetes son fijos o personalizados?',
    answer: 'Los paquetes son referenciales. Definimos una cotizacion personalizada segun aforo, sede, horario, alcance de diseno y nivel de servicio requerido.'
  },
  {
    question: 'Que zonas cubren?',
    answer: 'Atendemos toda la CDMX y area metropolitana, incluyendo Polanco, Santa Fe, Lomas, Interlomas, Coyoacan, Pedregal, Satelite, Naucalpan, Roma y Condesa.'
  }
];

const packages = [
  {
    name: 'Basico',
    icon: '🍭',
    priceAmount: '$4,900',
    priceNote: 'MXN',
    guests: '30-50 personas',
    description: 'Ideal para eventos pequenos',
    features: [
      'Candy bar para 1 tipo de evento',
      'Diseno base por tematica',
      'Montaje profesional',
      'Mobiliario incluido',
      'Desmontaje al finalizar'
    ],
    popular: false
  },
  {
    name: 'Signature',
    icon: '⭐',
    priceAmount: '$8,400',
    priceNote: 'MXN',
    guests: '50-100 personas',
    description: 'La combinacion mas solicitada',
    features: [
      'Candy bar premium por evento',
      'Diseno personalizado por concepto',
      'Surtido curado de mayor variedad',
      'Montaje y coordinacion en sitio',
      'Asesoria comercial previa',
      'Mejor equilibrio costo-beneficio'
    ],
    popular: true
  },
  {
    name: 'Premium',
    icon: '💎',
    priceAmount: '$13,500',
    priceNote: 'MXN',
    guests: '100+ personas',
    description: 'Experiencia integral de alto impacto',
    features: [
      'Candy bar de alto volumen',
      'Direccion estetica completa',
      'Curaduria premium de producto',
      'Operacion profesional extendida',
      'Configuracion para eventos grandes',
      'Acompanamiento operativo total'
    ],
    popular: false
  }
];

const processSteps = [
  {
    number: 1,
    title: 'Brief del Evento',
    description: 'Levantamos tipo de celebracion, perfil de invitados, sede y objetivo para definir el candy bar correcto.'
  },
  {
    number: 2,
    title: 'Propuesta Comercial',
    description: 'Presentamos alcance, niveles de diseno, volumen de producto y plan de ejecucion con cotizacion clara.'
  },
  {
    number: 3,
    title: 'Planeacion Operativa',
    description: 'Alineamos tiempos, accesos, montaje y coordinacion con el venue para evitar errores el dia del evento.'
  },
  {
    number: 4,
    title: 'Montaje y Servicio',
    description: 'Ejecutamos el montaje completo y cuidamos presentacion, experiencia de invitados y cierre operativo.'
  }
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Candy Bar por Tipo de Evento en CDMX',
  description: 'Catalogo completo de candy bars por tipo de evento en CDMX: mesas tematicas personalizadas, bodas, XV anos, baby shower, bautizo, primera comunion, cumpleanos infantil, eventos corporativos y graduaciones',
  numberOfItems: 9,
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'Service', name: 'Mesas Tematicas Personalizadas', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesas-tematicas' } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'Service', name: 'Mesa de Dulces para Boda', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-boda' } },
    { '@type': 'ListItem', position: 3, item: { '@type': 'Service', name: 'Mesa de Dulces para XV Anos', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-xv-anos' } },
    { '@type': 'ListItem', position: 4, item: { '@type': 'Service', name: 'Mesa de Dulces para Baby Shower', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-baby-shower' } },
    { '@type': 'ListItem', position: 5, item: { '@type': 'Service', name: 'Mesa de Dulces para Cumpleanos Infantil', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-cumpleanos-infantil' } },
    { '@type': 'ListItem', position: 6, item: { '@type': 'Service', name: 'Mesa de Dulces para Bautizo', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-bautizo' } },
    { '@type': 'ListItem', position: 7, item: { '@type': 'Service', name: 'Mesa de Dulces para Primera Comunion', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-primera-comunion' } },
    { '@type': 'ListItem', position: 8, item: { '@type': 'Service', name: 'Mesa de Dulces para Eventos Corporativos', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-corporativos' } },
    { '@type': 'ListItem', position: 9, item: { '@type': 'Service', name: 'Mesa de Dulces para Graduacion', url: 'https://mesas-de-dulces.com/candy-bar-eventos/mesa-dulces-graduacion' } }
  ]
};

// Comparison table data for all 9 L4
const comparativaEventos = [
  { evento: 'Mesas Temáticas', precio: '$5,200 - $14,800', audiencia: '30-100+ invitados', destacado: 'Concepto a medida · Moodboard previo', url: '/candy-bar-eventos/mesas-tematicas' },
  { evento: 'Bodas', precio: '$8,500 - $22,000', audiencia: '50-200+ invitados', destacado: 'Coordinación wedding planner · Monograma novios', url: '/candy-bar-eventos/mesa-dulces-boda' },
  { evento: 'XV Años', precio: '$7,500 - $18,500', audiencia: '50-200+ invitadas', destacado: 'Backdrop instagrameable · Coordinación vals', url: '/candy-bar-eventos/mesa-dulces-xv-anos' },
  { evento: 'Baby Shower', precio: '$4,500 - $11,800', audiencia: '20-80+ invitadas', destacado: '100% apto mamá embarazada · Gender Reveal', url: '/candy-bar-eventos/mesa-dulces-baby-shower' },
  { evento: 'Cumpleaños Infantil', precio: '$3,500 - $9,500', audiencia: '15-60+ niños', destacado: '40+ personajes · Sin nueces default · Disfrazado', url: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil' },
  { evento: 'Bautizo', precio: '$3,800 - $10,500', audiencia: '30-100+ invitados', destacado: '15+ parroquias CDMX · Símbolos religiosos', url: '/candy-bar-eventos/mesa-dulces-bautizo' },
  { evento: 'Primera Comunión', precio: '$4,200 - $12,800', audiencia: '40-100+ invitados', destacado: '20+ catequesis · 7 símbolos eucarísticos', url: '/candy-bar-eventos/mesa-dulces-primera-comunion' },
  { evento: 'Eventos Corporativos', precio: '$8,500 - $28,500', audiencia: '50-500+ asistentes', destacado: 'Branding integral · Factura A · NDA · 15+ venues', url: '/candy-bar-eventos/mesa-dulces-corporativos' },
  { evento: 'Graduaciones', precio: '$5,200 - $16,500', audiencia: '50-400+ invitados', destacado: '15+ universidades CDMX · 6 niveles académicos', url: '/candy-bar-eventos/mesa-dulces-graduacion' }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title="Candy Bar para Eventos en CDMX | Mesas de Dulces por Tipo de Evento"
  description="Candy bar para bodas, XV anos, baby shower, bautizos, graduaciones y eventos corporativos en CDMX. Diseno personalizado y montaje profesional."
  canonical="/candy-bar-eventos"
  ogImage="/img/eventos/bodas/mesa-dulces-boda-elegante-macarons-cristaleria.avif"
  includeCategoryStyles={true}
>
  <JsonLd type="Service" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    id="candy-bar-eventos"
    title="Candy Bar por Tipo de Evento en CDMX"
    highlight="Tipo de Evento"
    subtitle="Montajes personalizados para bodas, XV anos, baby shower, celebraciones familiares y corporativas"
    secondaryContent={`<p><strong>Candy bar</strong> estrategico por tipo de evento permite alinear diseno, surtido y experiencia de servicio con la esencia real de tu celebracion. En Mededul construimos propuestas personalizadas para que cada montaje comunique estilo, orden y valor en cada detalle.</p><p><strong>Eventos</strong> como bodas, XV anos, bautizos y activaciones corporativas requieren criterios distintos de produccion para lograr resultados premium sin improvisaciones. Nuestro equipo integra consultoria, montaje y operacion para garantizar una ejecucion impecable de principio a fin.</p>`}
  />

  <section class="section-paquetes" id="paquetes">
    <div class="paquetes-bg">
      <div class="paquetes-glow paquetes-glow--1"></div>
      <div class="paquetes-glow paquetes-glow--2"></div>
    </div>

    <div class="container paquetes-container">
      <div class="paquetes-header">
        <span class="paquetes-badge">Paquetes Referenciales</span>
        <h2 class="paquetes-title">
          Escoge el <span>Formato Correcto</span>
        </h2>
        <p class="paquetes-subtitle">
          Ajustamos cada propuesta al tipo de evento, invitados y nivel de personalizacion que necesitas.
        </p>
      </div>

      <div class="packages-grid">
        {packages.map((pkg) => (
          <div class:list={['package-card', { 'package-card--popular': pkg.popular }]}>
            {pkg.popular && (
              <div class="package-ribbon">
                <span>Mas Solicitado</span>
              </div>
            )}

            <div class="package-top">
              <div class="package-icon-wrapper">
                <span class="package-icon">{pkg.icon}</span>
              </div>
              <h3 class="package-name">{pkg.name}</h3>
              <p class="package-tagline">{pkg.description}</p>
            </div>

            <div class="package-pricing">
              <div class="package-price-wrapper">
                <span class="package-price-label">Desde</span>
                <span class="package-price-amount">{pkg.priceAmount}</span>
                <span class="package-price-currency">{pkg.priceNote}</span>
              </div>
              <div class="package-guests">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span>{pkg.guests}</span>
              </div>
            </div>

            <div class="package-separator">
              <span class="package-separator-text">Incluye</span>
            </div>

            <ul class="package-features">
              {pkg.features.map(feature => (
                <li>
                  <span class="feature-check">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                  <span class="feature-text">{feature}</span>
                </li>
              ))}
            </ul>

            <a href="/contacto" class="package-cta">
              <span>Solicitar Cotizacion</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        ))}
      </div>

      <p class="paquetes-note">
        <strong>Necesitas otra configuracion?</strong> Creamos una propuesta de candy bar personalizada para tu tipo de evento.
      </p>
    </div>
  </section>

  <section class="section-servicios section-padding" id="eventos-grid">
    <div class="container">
      <SectionHeader
        title="Candy Bar para Cada Tipo de Evento"
        titleHighlight="Tipo de Evento"
        subtitle="Selecciona el formato ideal para tu celebracion"
        content={`<p>Cada tipo de evento tiene necesidades distintas de diseno, volumen y experiencia de servicio, por eso estructuramos propuestas especificas para cada ocasion.</p><p>Explora nuestras opciones por categoria y descubre la mejor combinacion para lograr un montaje memorable y funcional.</p>`}
      />

      <div class="service-grid">
        <ServiceCard
          href="/candy-bar-eventos/mesas-tematicas"
          image={getCdnUrl('/img/tipos-de-mesas/dulces-personalizadas/mesa-dulces-personalizada-tematica.avif')}
          alt="Mesa de dulces tematica personalizada en CDMX"
          title="Mesas Tematicas"
          excerpt="Concepto a medida: Barbie, dinosaurios, casino, branding o tradicional mexicana. Moodboard, props y etiquetas a juego."
          cta="Ver Mesas Tematicas"
          badge="Personalizadas"
          subsections={subsCBTematicas}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-boda"
          image={getCdnUrl('/img/eventos/bodas/mesa-dulces-boda-elegante-macarons-cristaleria.avif')}
          alt="Candy bar para bodas elegantes en CDMX"
          title="Candy Bar para Bodas"
          excerpt="Montajes nupciales premium con enfoque en elegancia, armonia visual y experiencia de invitado."
          cta="Ver Candy Bar para Boda"
          badge="Popular"
          subsections={subsCBBoda}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-xv-anos"
          image={getCdnUrl('/img/eventos/xv-anos/mesa-de-dulces-para-xv-anos.avif')}
          alt="Candy bar para XV anos en CDMX"
          title="Candy Bar para XV Anos"
          excerpt="Propuestas espectaculares para quinceanera con diseno personalizado y montaje profesional."
          cta="Ver Candy Bar para XV"
          subsections={subsCBXV}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-baby-shower"
          image={getCdnUrl('/img/eventos/baby-shower/mesa-de-dulces-para-baby-shower.avif')}
          alt="Mesa de dulces para baby shower en CDMX"
          title="Candy Bar para Baby Shower"
          excerpt="Montajes tematicos en tonos suaves y composicion delicada para celebraciones de bienvenida."
          cta="Ver Candy Bar Baby Shower"
          subsections={subsCBBabyShower}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-cumpleanos-infantil"
          image={getCdnUrl('/img/eventos/cumpleanos/mesa-de-dulces-para-cumpleanos.avif')}
          alt="Candy bar para cumpleanos infantil"
          title="Candy Bar Infantil"
          excerpt="Experiencias coloridas y seguras para fiestas de ninos con tematica y alto impacto visual."
          cta="Ver Candy Bar Infantil"
          subsections={subsCBCumple}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-bautizo"
          image={getCdnUrl('/img/eventos/bautizo/mesa-dulces-bautizo-elegante.avif')}
          alt="Mesa de dulces para bautizo en CDMX"
          title="Candy Bar para Bautizo"
          excerpt="Disenos sobrios y elegantes con enfoque familiar para una celebracion armonica y memorable."
          cta="Ver Candy Bar Bautizo"
          subsections={subsCBBautizo}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-primera-comunion"
          image={getCdnUrl('/img/eventos/comunion/candy-bar-comunion-elegante-caliz-galletas.avif')}
          alt="Candy bar para primera comunion"
          title="Candy Bar Primera Comunion"
          excerpt="Montajes con simbolismo y estilo refinado para recepciones de comunion con identidad propia."
          cta="Ver Candy Bar Comunion"
          subsections={subsCBComunion}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-corporativos"
          image={getCdnUrl('/img/eventos/corporativos/candy-bar-empresarial.avif')}
          alt="Candy bar para eventos corporativos"
          title="Candy Bar Corporativo"
          excerpt="Soluciones para marca y hospitalidad en eventos empresariales, activaciones y lanzamientos."
          cta="Ver Candy Bar Corporativo"
          subsections={subsCBCorporativo}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-graduacion"
          image={getCdnUrl('/img/eventos/graduaciones/mesa-dulces-graduacion.avif')}
          alt="Mesa de dulces para graduacion"
          title="Candy Bar para Graduacion"
          excerpt="Montajes festivos para cierre academico con presentacion impecable y servicio ordenado."
          cta="Ver Candy Bar Graduacion"
          subsections={subsCBGraduacion}
        />
      </div>
    </div>
  </section>

  <section class="section-estaciones section-padding" id="complementos">
    <div class="container">
      <SectionHeader
        title="Complementa Tu Candy Bar con Experiencias"
        titleHighlight="Experiencias"
        subtitle="Eleva impacto y participacion en tu evento"
        content={`<p>Agregar estaciones interactivas a tu candy bar incrementa dinamica, permanencia y valor percibido por tus invitados.</p><p>Combinamos estas experiencias con el estilo del evento para construir una produccion integral, memorable y altamente fotografiable.</p>`}
      />

      <div class="service-grid service-grid--4">
        <ServiceCard
          href="/estaciones-interactivas/fuente-de-chocolate"
          image={getCdnUrl('/img/estaciones-interactivas/fuente-chocolate/fuente-de-chocolate-para-eventos.avif')}
          alt="Fuente de chocolate para eventos en CDMX"
          title="Fuente de Chocolate"
          excerpt="Estacion interactiva premium para elevar experiencia y participacion de invitados."
          cta="Ver Fuente de Chocolate"
          subsections={subsFuenteChocolate}
        />
        <ServiceCard
          href="/estaciones-interactivas/fuente-de-chamoy"
          image={getCdnUrl('/img/estaciones-interactivas/fuente-chamoy/renta-de-fuente-de-chamoy.avif')}
          alt="Fuente de chamoy para fiestas"
          title="Fuente de Chamoy"
          excerpt="Propuesta con sabor mexicano que incrementa dinamica y recordacion del evento."
          cta="Ver Fuente de Chamoy"
          subsections={subsFuenteChamoy}
        />
        <ServiceCard
          href="/estaciones-interactivas/pared-de-dulces"
          image={getCdnUrl('/img/estaciones-interactivas/pared-dulces/pared-de-dulces-candy-wall.avif')}
          alt="Pared de dulces candy wall"
          title="Pared de Dulces"
          excerpt="Elemento escenografico y funcional para sumar impacto visual al montaje principal."
          cta="Ver Pared de Dulces"
          subsections={subsParedDulces}
        />
        <ServiceCard
          href="/estaciones-interactivas/stand-para-pastel"
          image={getCdnUrl('/img/estaciones-interactivas/stand-pastel/stand-pastel-decorado-eventos.avif')}
          alt="Stand para pastel decorado"
          title="Stand para Pastel"
          excerpt="Solucion para resaltar el momento del pastel con composicion elegante y fotografiable."
          cta="Ver Stand para Pastel"
          subsections={subsStandPastel}
        />
      </div>
    </div>
  </section>


  <section class="section-proceso section-padding" id="proceso">
    <div class="container">
      <div class="proceso-header">
        <span class="proceso-badge">Nuestro Proceso</span>
        <h2 class="proceso-title">Asi Disenamos Tu <span>Candy Bar Ideal</span></h2>
        <p class="proceso-subtitle">Un metodo claro para cotizar, planear y ejecutar sin fricciones.</p>
      </div>

      <div class="process-grid">
        {processSteps.map((step) => (
          <div class="process-card">
            <div class="process-step-badge">Paso {step.number}</div>
            <div class="process-content">
              <h4 class="process-title">{step.title}</h4>
              <p class="process-description">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-porque section-padding" id="porque">
    <div class="container">
      <SectionHeader
        title="Por que Elegir Mededul para Tu Candy Bar"
        titleHighlight="Mededul"
        subtitle="Diseno, operacion y calidad en un solo equipo"
        content={`<p>Trabajamos con metodologia profesional para asegurar coherencia visual, eficiencia operativa y una experiencia premium en cada evento.</p><p>Nuestra combinacion de creatividad y ejecucion te da una solucion confiable para producir sin improvisaciones.</p>`}
      />

      <div class="service-grid service-grid--4">
        <ServiceCard
          href="/porque-mededul/diseno-personalizado"
          image={getCdnUrl('/img/porque-elegirnos/diseno-personalizado-mesas-dulces.avif')}
          alt="Diseno personalizado para candy bar"
          title="Diseno Personalizado"
          excerpt="Cada montaje se adapta al concepto real del evento y no a plantillas genericas."
          cta="Ver Diseno"
          subsections={subsDisenoPersonalizado}
        />
        <ServiceCard
          href="/porque-mededul/calidad-premium"
          image={getCdnUrl('/img/porque-elegirnos/calidad-premium-dulces.avif')}
          alt="Calidad premium en dulces"
          title="Calidad Premium"
          excerpt="Seleccion de producto y acabados de alto nivel para resultados consistentes."
          cta="Ver Calidad"
          subsections={subsCalidadPremium}
        />
        <ServiceCard
          href="/porque-mededul/servicio-completo"
          image={getCdnUrl('/img/porque-elegirnos/servicio-completo-mesas.avif')}
          alt="Servicio completo de candy bar"
