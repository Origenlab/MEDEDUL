        {industrias.map(i => (
          <div class="corp-industria">
            <div class="corp-industria__icon" aria-hidden="true">{i.icon}</div>
            <h3 class="corp-industria__sector">{i.sector}</h3>
            <div class="corp-industria__field">
              <strong>Clientes tipo:</strong>
              <span>{i.clientes}</span>
            </div>
            <div class="corp-industria__field">
              <strong>Momento clave:</strong>
              <span>{i.momento}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== Branding integral (UNIQUE - showcase) ===================== -->
