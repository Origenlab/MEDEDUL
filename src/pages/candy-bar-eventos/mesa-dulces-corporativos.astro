    stats={[
      { number: "180+", label: "Eventos B2B CDMX" },
      { number: "15+", label: "Venues corporativos" },
      { number: "100%", label: "Factura A · NDA" },
      { number: "5.0", label: "Calificación corporate" }
    ]}
    features={caracteristicas}
  />

  <!-- ===================== Galería ===================== -->
  <section class="corp-galeria" id="galeria-corp">
    <div class="container">
      <SectionHeader
        title="Eventos corporativos reales"
        titleHighlight="montados en CDMX"
        subtitle="Selección curada de eventos B2B MEDEDUL en distintas industrias y venues"
        content={`<p>Cada mesa de esta galería corresponde a un <strong>evento corporativo real en CDMX</strong> bajo NDA. La paleta cromática, el branding y el surtido fueron <strong>diseñados específicamente para cada empresa</strong> según su identidad de marca, industria y tipo de evento.</p>`}
      />
      <div class="corp-galeria__bento">
        {galeriaImages.map(img => (
          <div class="corp-galeria__item">
            <img
              src={getCdnUrl(img.src, { w: 800, q: 80 })}
