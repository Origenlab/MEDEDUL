const tiposChocolate = [
  { tipo: 'Belga con leche', icon: '🍫', desc: 'El clásico universal. Cremoso, dulce-balanceado, color caramelo. La opción más solicitada para todo tipo de evento. Aprobado por niños y adultos.', popular: true },
  { tipo: 'Belga blanco', icon: '🤍', desc: 'Dulce y suave. Sin cacao oscuro. Combina con frutos rojos, fresas, frutas tropicales. Ideal para bodas elegantes y baby showers.' },
  { tipo: 'Belga oscuro 70%', icon: '🍫', desc: 'Cacao premium, menos dulce, sabor profundo. Para perfil gourmet, post-cena de boda o evento corporativo de alto nivel.' },
  { tipo: 'Ruby chocolate', icon: '💗', desc: 'Tendencia 2026: chocolate rosa natural (sin colorantes), sabor frutal con notas ácidas. Ideal para XV Años glamour y bodas modernas.' },
  { tipo: 'Mixto / Combinado', icon: '🎨', desc: 'Dos fuentes simultáneas: una con leche para niños, una con oscuro para adultos. Permite que cada invitado elija su perfil.' }
];

// =============== Productos para bañar (UNIQUE 8 categorías) ===============
const productos = [
  { icon: '🍓', nombre: 'Fresas frescas', desc: 'Lavadas con cloro alimentario, frescas del día. La opción más solicitada y fotogénica.' },
  { icon: '🍌', nombre: 'Plátano y frutas', desc: 'Plátano, piña, melón, uvas, mango. Frutas de temporada cortadas y presentadas con brochetas.' },
  { icon: '☁️', nombre: 'Malvaviscos', desc: 'Malvaviscos blancos y de colores en brochetas. Favorito infantil. Combinan con todos los chocolates.' },
  { icon: '🥨', nombre: 'Pretzels y galletas', desc: 'Pretzels salados (contraste con dulce), galletas Oreo, mini-cookies. Para perfil gourmet adulto.' },
  { icon: '🍩', nombre: 'Mini donas', desc: 'Donas mini de azúcar, glaseadas o naturales. Combinan especialmente con chocolate con leche.' },
  { icon: '🥖', nombre: 'Churros mini', desc: 'Churros artesanales pequeños, recién hechos. Combinación clásica mexicana. Muy popular en CDMX.' },
  { icon: '🍇', nombre: 'Brochetas mixtas', desc: 'Brochetas combinadas (fruta + malvavisco + pretzel). Ideal para grupos grandes, autoservicio rápido.' },
  { icon: '🍪', nombre: 'Galletas de mantequilla', desc: 'Galletas de mantequilla artesanales, tipo shortbread. Para perfil premium y bodas elegantes.' }
];

// =============== Capacidades técnicas (UNIQUE) ===============
const capacidades = [
  { capacidad: '5 kg', icon: '🔹', invitados: '20-40 invitados', niveles: '2-3 niveles', altura: '60 cm', uso: 'Eventos íntimos: baby shower, cumpleaños familiar, reuniones boutique. Cabe en mesa estándar.' },
  { capacidad: '15 kg', icon: '🔸', invitados: '50-100 invitados', niveles: '3-4 niveles', altura: '80 cm', uso: 'Eventos medianos: XV íntimo, boda boutique, evento corporativo small. Estándar más solicitado.' },
  { capacidad: '30 kg', icon: '🔶', invitados: '100-200 invitados', niveles: '4-5 niveles', altura: '110 cm', uso: 'Eventos grandes: boda completa, XV de gran convocatoria, convención corporativa. Show visual.' },
  { capacidad: '50 kg', icon: '⭐', invitados: '200-400+ invitados', niveles: '5-6 niveles', altura: '140 cm', uso: 'Eventos masivos: graduación de generación, convención corporativa grande, evento de marca multinacional.' }
];

// =============== Características (Diferenciadores) ===============
const caracteristicas = [
  { num: 1, title: 'Chocolate belga premium 100% (no compound)', desc: 'Usamos exclusivamente chocolate belga premium con manteca de cacao real (no chocolate compound con grasa vegetal). La diferencia se nota: brillo, textura, sabor profundo y mejor experiencia para bañar productos.', img: '/img/estaciones-interactivas/fuente-chocolate/renta-fuente-chocolate-profesional.avif' },
  { num: 2, title: 'Capacidad escalable según invitados', desc: 'Fuentes de 5 kg, 15 kg, 30 kg y 50 kg según número de invitados. Cada capacidad implica diferente altura, niveles y volumen de chocolate fluido. Sin sobreconsumo ni desperdicio.', img: '/img/estaciones-interactivas/fuente-chocolate/fuente-chocolate-eventos-cdmx.avif' },
  { num: 3, title: '8 categorías de productos para bañar', desc: 'Fresas frescas, frutas variadas (plátano, piña, melón, uvas, mango), malvaviscos, pretzels, mini donas, churros artesanales, brochetas mixtas y galletas de mantequilla. Combinable según evento.', img: '/img/estaciones-interactivas/fuente-chocolate/fuente-chocolate-fiestas.avif' },
  { num: 4, title: 'Operador profesional y reposición continua', desc: 'Operador dedicado uniformado durante toda la operación: reposición de chocolate, reposición de productos, control de temperatura, limpieza continua de salpicaduras, atención a invitados.', img: '/img/estaciones-interactivas/fuente-chocolate/alquiler-fuente-chocolate-cdmx.avif' }
];

// =============== Paquetes Fuente de Chocolate CDMX ===============
const paquetes = [
  { name: 'Esencial', icon: '🔹', price: '$3,500', currency: 'MXN', guests: '20-40 invitados', tagline: 'Fuente íntima con productos clásicos', features: ['Fuente de 5 kg chocolate belga con leche', '3-4 productos para bañar (fresas, malvaviscos, plátano, brochetas)', 'Operador 2 horas', 'Montaje 1 h antes', 'Mantel decorativo', 'Brochetas y servilletas incluidas', 'Cobertura zonas centrales CDMX'], popular: false, ctaText: 'Cotizar Esencial', ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20Fuente%20de%20Chocolate%20CDMX%20-%20Esencial' },
  { name: 'Premium', icon: '🔶', price: '$5,800', currency: 'MXN', guests: '50-150 invitados', tagline: 'El más solicitado en CDMX', features: ['Fuente 15 kg chocolate belga (a elegir: leche, blanco u oscuro)', '5-6 productos para bañar (incluye churros artesanales)', 'Operador 4 horas', 'Montaje y decoración con flores', 'Iluminación LED opcional', 'Reposición continua incluida', 'Cobertura amplia CDMX (Polanco, Lomas, Coyoacán, Roma)'], popular: true, ctaText: 'Cotizar Premium', ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20Fuente%20de%20Chocolate%20CDMX%20-%20Premium' },
  { name: 'Luxury', icon: '⭐', price: '$9,500', currency: 'MXN', guests: '150-400+ invitados', tagline: 'Show gastronómico de gran escala', features: ['Fuente 30-50 kg chocolate belga premium', '8 productos para bañar (todas las categorías)', 'Operador 6 horas + ayudante', 'Backdrop iluminado con foco LED', 'Mantel y cristalería premium', 'Estación de brochetas pre-armadas', 'Reposición continua extendida', 'Sucursal preferente Anzures + Condesa CDMX'], popular: false, ctaText: 'Cotizar Luxury', ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20Fuente%20de%20Chocolate%20CDMX%20-%20Luxury' }
];

// =============== Proceso ===============
const proceso = [
  { num: 1, title: 'Brief del evento', desc: 'Recibimos brief: tipo de evento (boda, XV, infantil, corporativo), número de invitados, tipo de chocolate preferido, productos para bañar deseados, sede y horarios. Te recomendamos capacidad ideal.' },
  { num: 2, title: 'Cotización ejecutiva', desc: 'En menos de 24 h enviamos cotización cerrada en 3 niveles (Esencial 5kg, Premium 15kg, Luxury 30-50kg) con detalle de productos, duración y add-ons opcionales (iluminación LED, backdrop).' },
  { num: 3, title: 'Coordinación logística', desc: 'Coordinamos posición de la fuente en el venue, acceso eléctrico (la fuente requiere conexión 110V), tiempo de montaje, integración con mesa de dulces o pastel.' },
  { num: 4, title: 'Día del evento', desc: 'Llegamos 1-2 h antes. Calentamos el chocolate al punto óptimo (45°C), instalamos la fuente, presentamos productos para bañar. Operamos durante toda la duración con reposición continua. Desmontaje al cierre.' }
];

// =============== Galería (8 imágenes) ===============
const galeriaImages = [
  { src: '/img/estaciones-interactivas/fuente-chocolate/fuente-chocolate-eventos-cdmx.avif', alt: 'Fuente de chocolate belga para eventos en CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chocolate/renta-fuente-chocolate-profesional.avif', alt: 'Renta fuente de chocolate profesional CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chocolate/fuente-chocolate-fiestas.avif', alt: 'Fuente de chocolate para fiestas CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chocolate/alquiler-fuente-chocolate-cdmx.avif', alt: 'Alquiler fuente de chocolate CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chocolate/fuente-de-chocolate-para-eventos.avif', alt: 'Fuente de chocolate para eventos premium CDMX' },
  { src: '/img/eventos/xv-anos/mesa-dulces-xv-anos-rosa-fuente-chocolate-elegante.avif', alt: 'Fuente de chocolate para XV Años elegante CDMX' },
  { src: '/img/galeria/candy-bar-corporativo-lujo-chocolate-whisky.avif', alt: 'Fuente de chocolate para evento corporativo lujo CDMX' },
  { src: '/img/eventos/bodas/candy-bar-boda-romantico.avif', alt: 'Fuente de chocolate para boda romántica CDMX' }
];

// =============== Qué incluye ===============
const incluye = [
  { num: '01', title: 'Chocolate belga premium 100%', desc: 'Chocolate belga premium con manteca de cacao real, no compound. Sin grasas vegetales ni aceites añadidos. Disponible en leche, blanco, oscuro 70% o ruby. Cantidad calculada según número de invitados con margen de seguridad.' },
  { num: '02', title: 'Fuente profesional según capacidad', desc: 'Fuente de acero inoxidable grado alimentario, con motor de torre y sistema de calefacción controlada. Capacidades: 5 kg (60 cm altura), 15 kg (80 cm), 30 kg (110 cm), 50 kg (140 cm). 2-6 niveles según modelo.' },
  { num: '03', title: '3-8 productos para bañar', desc: 'Según paquete: Esencial 3-4 productos (fresas, malvaviscos, plátano, brochetas), Premium 5-6 productos (suma churros y pretzels), Luxury 8 productos (todas las categorías). Producto fresco lavado con cloro alimentario.' },
  { num: '04', title: 'Mobiliario y decoración', desc: 'Mesa de soporte con mantel decorativo, base estable para la fuente, bandejas para productos, brochetas y servilletas. En Premium y Luxury sumamos decoración floral, iluminación LED y backdrop opcional.' },
  { num: '05', title: 'Operador profesional uniformado', desc: 'Operador dedicado uniformado (camisa blanca, mandil, gorra) durante toda la operación. Reposición continua de chocolate y productos, control de temperatura del chocolate fluido, limpieza de salpicaduras, atención al detalle.' },
  { num: '06', title: 'Montaje y desmontaje incluidos', desc: 'Llegamos 1-2 h antes del evento para montaje completo (calentamiento del chocolate al punto óptimo 45°C, instalación, prueba de fluido). Desmontaje discreto al cierre con limpieza completa del área.' }
];

// =============== Testimonios ===============
const testimonios = [
  { name: 'Mariana López (boda)', initials: 'ML', review: 'Fuente de 30 kg para nuestra boda en Hotel Camino Real Polanco con 200 invitados. Chocolate belga oscuro 70% con fresas, churros y galletas. La estrella de la noche, todos se fotografiaron con la fuente. Operador súper profesional.', event: 'Boda · Hotel Camino Real Polanco', rating: 5 },
  { name: 'Familia Hernández (XV)', initials: 'FH', review: 'XV de mi hija en Hacienda de los Morales con 150 invitadas. Fuente de chocolate ruby (rosa) coordinada con la paleta del XV. Las amigas no paraban de subir fotos a Instagram con la fuente rosa. Perfecto.', event: 'XV Años · Hacienda de los Morales', rating: 5 },
  { name: 'Marketing Lead (corporativo)', initials: 'ML', review: 'Lanzamiento de producto en Reforma 222 con 250 invitados. Fuente de chocolate mixta (leche + oscuro) como estación de cocktail networking. Show visual impresionante para la foto de PR. Factura A timbrada inmediata.', event: 'Lanzamiento corporativo · Reforma 222', rating: 5 }
];

// =============== FAQ ===============
const faqs = [
  { question: '¿Qué incluye la renta de fuente de chocolate en CDMX?', answer: 'Incluye fuente profesional de acero inoxidable según capacidad (5, 15, 30 o 50 kg), chocolate belga premium 100% (sin compound) en tipo a elegir (leche, blanco, oscuro 70%, ruby o mixto), 3 a 8 productos para bañar según paquete (fresas frescas, frutas variadas, malvaviscos, pretzels, mini donas, churros artesanales, brochetas, galletas), mesa de soporte con mantel, brochetas y servilletas, operador profesional uniformado durante 2-6 horas según paquete, montaje 1-2 h antes con calentamiento al punto óptimo (45°C) y desmontaje al cierre.' },
  { question: '¿Cuánto cuesta rentar una fuente de chocolate en CDMX?', answer: 'En CDMX iniciamos en $3,500 MXN (Esencial, fuente 5 kg, 20-40 invitados), $5,800 MXN (Premium, fuente 15 kg, 50-150 invitados, el más solicitado) y $9,500 MXN (Luxury, fuente 30-50 kg, 150-400+ invitados con backdrop iluminado). El precio depende del número de invitados, tipo de chocolate (oscuro premium sale más alto), número de productos para bañar y duración del servicio.' },
  { question: '¿Qué tipos de chocolate manejan?', answer: 'Trabajamos 5 tipos de chocolate belga premium 100% (sin compound): Belga con leche (el clásico universal), Belga blanco (con frutos rojos), Belga oscuro 70% (perfil gourmet), Ruby chocolate (tendencia 2026, chocolate rosa natural sin colorantes con notas frutales-ácidas) y Mixto (dos fuentes simultáneas: leche para niños + oscuro para adultos).' },
  { question: '¿Qué productos para bañar incluyen?', answer: 'Trabajamos 8 categorías: fresas frescas lavadas con cloro alimentario, frutas variadas (plátano, piña, melón, uvas, mango), malvaviscos blancos y de colores, pretzels salados, mini donas glaseadas, churros mini artesanales recién hechos, brochetas mixtas pre-armadas y galletas de mantequilla premium tipo shortbread. Según paquete: Esencial 3-4, Premium 5-6, Luxury 8 categorías.' },
  { question: '¿Qué capacidad de fuente necesito para mi evento?', answer: 'La capacidad depende del número de invitados: 5 kg para 20-40 invitados (eventos íntimos), 15 kg para 50-150 invitados (el más solicitado, ideal para XV, boda boutique, evento corporativo small), 30 kg para 100-200 invitados (boda completa, XV de gran convocatoria) y 50 kg para 200-400+ invitados (graduación de generación, convención corporativa, evento de marca multinacional). Te asesoramos según tu evento.' },
  { question: '¿La fuente requiere conexión eléctrica especial?', answer: 'Sí, requiere conexión 110V estándar (toma de corriente convencional). En venues corporativos o salones grandes confirmamos disponibilidad de toma cercana. Si el venue no tiene toma accesible o si la fuente quedará en jardín exterior, podemos traer cable de extensión profesional y/o multicontacto con protección.' },
  { question: '¿Para qué tipos de evento se renta más esta fuente?', answer: 'Las 4 aplicaciones más solicitadas: <a href="/candy-bar-eventos/mesa-dulces-boda">Bodas</a> (estación estrella nupcial), <a href="/candy-bar-eventos/mesa-dulces-xv-anos">XV Años</a> (la más solicitada, ruby chocolate tendencia 2026), <a href="/candy-bar-eventos/mesa-dulces-cumpleanos-infantil">Fiestas Infantiles</a> (los niños la adoran), <a href="/candy-bar-eventos/mesa-dulces-corporativos">Eventos Corporativos</a> (show gastronómico premium para lanzamientos, posadas y convenciones).' },
  { question: '¿Pueden combinarla con otras estaciones interactivas?', answer: 'Sí, las combinaciones más solicitadas: <a href="/estaciones-interactivas/fuente-de-chamoy">Fuente de Chamoy</a> (combo dulce + picosito mexicano, muy popular en XV mexicanos modernos), <a href="/estaciones-interactivas/pared-de-dulces">Pared de Dulces</a> (autoservicio + show interactivo de la fuente), <a href="/estaciones-interactivas/stand-para-pastel">Stand para Pastel</a> (el centro de la celebración + experiencia gastronómica) o con cualquiera de nuestras mesas de dulces.' },
  { question: '¿Atienden eventos en todo CDMX y zona metropolitana?', answer: 'Sí. Operamos desde nuestras sucursales fijas Anzures y Condesa con cobertura completa CDMX: Polanco, Lomas de Chapultepec, Santa Fe, Interlomas, Coyoacán, Pedregal, Roma, Condesa, Anzures, Del Valle, Naucalpan, Huixquilucan, Tlalnepantla, Satélite y todas las 16 alcaldías. Para detalle visita nuestra <a href="/sucursales/cdmx/mesa-de-dulces">página de sucursal CDMX</a>.' },
  { question: '¿Con cuánta anticipación debo reservar?', answer: 'Para eventos regulares recomendamos 2-3 semanas de anticipación. Para temporadas altas (mayo-junio para XV/graduaciones, octubre-diciembre para bodas/corporativos/posadas) sugerimos 4-6 semanas. Trabajamos con anticipo del 50% para apartar fecha y liquidación 48 h antes del evento.' }
];

const galleryWidths = [320, 480, 640, 800, 960, 1200];
const gallerySizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://mesas-de-dulces.com/estaciones-interactivas/fuente-de-chocolate#service",
      "name": "Renta de Fuente de Chocolate en CDMX",
      "serviceType": "Estación Interactiva / Fuente de Chocolate Profesional",
      "description": "Renta de fuente de chocolate belga premium en Ciudad de México con capacidades 5kg, 15kg, 30kg y 50kg. 5 tipos de chocolate (belga con leche, blanco, oscuro 70%, ruby, mixto), 8 productos para bañar (fresas, frutas, malvaviscos, churros, galletas), operador profesional uniformado. Ideal para bodas, XV años, fiestas infantiles y eventos corporativos. Operación desde sucursales Anzures y Condesa.",
      "provider": {
        "@type": "LocalBusiness",
        "name": "MEDEDUL",
        "image": getCdnUrl('/img/branding/logo-mededul-mesas-de-dulces.avif'),
        "telephone": "+525525226442",
        "url": "https://mesas-de-dulces.com",
        "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de Mexico", "addressRegion": "CDMX", "addressCountry": "MX" },
        "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "350", "bestRating": "5" }
      },
      "areaServed": { "@type": "City", "name": "Ciudad de Mexico" },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "MXN",
        "lowPrice": "3500",
        "highPrice": "9500",
        "offerCount": "3",
        "offers": paquetes.map(pkg => ({ "@type": "Offer", "name": `Fuente Chocolate CDMX ${pkg.name}`, "price": pkg.price.replace(/[$,]/g, ''), "priceCurrency": "MXN", "description": pkg.guests, "availability": "https://schema.org/InStock" }))
      }
    },
    { "@type": "FAQPage", "mainEntity": faqs.map(faq => ({ "@type": "Question", "name": faq.question, "acceptedAnswer": { "@type": "Answer", "text": faq.answer.replace(/<[^>]+>/g, '') } })) },
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mesas-de-dulces.com/" },
      { "@type": "ListItem", "position": 2, "name": "Estaciones Interactivas", "item": "https://mesas-de-dulces.com/estaciones-interactivas" },
      { "@type": "ListItem", "position": 3, "name": "Fuente de Chocolate", "item": "https://mesas-de-dulces.com/estaciones-interactivas/fuente-de-chocolate" }
    ]}
  ]
};
