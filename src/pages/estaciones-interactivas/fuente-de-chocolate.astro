} from '@/data/subsections';

// =============== Breadcrumbs ===============
const breadcrumbItems = [
  { name: 'Estaciones Interactivas', url: '/estaciones-interactivas' },
  { name: 'Fuente de Chocolate', url: '/estaciones-interactivas/fuente-de-chocolate' }
];

// =============== Trust Stats ===============
const stats = [
  { number: '350+', label: 'Fuentes operadas CDMX' },
  { number: '5kg-50kg', label: 'Capacidad por fuente' },
  { number: '100%', label: 'Chocolate belga premium' },
  { number: '< 24h', label: 'Cotización ejecutiva' }
];

