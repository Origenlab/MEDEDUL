const incluye = [
  { num: '01', title: 'Estructura modular profesional', desc: 'Pared metálica desde 2x2m hasta 6x3m según capacidad. Dispensadores acrílicos profesionales (no genéricos). Iluminación LED opcional integrada.' },
  { num: '02', title: 'Diseño temático coordinado', desc: 'Backdrop con diseño elegido (floral, neón, geométrico, vintage, branding, temática). Coherencia visual con paleta del evento. Producción a medida disponible en Premium/Luxury.' },
  { num: '03', title: '4-8 tipos de dulces variados', desc: 'Esencial 4 tipos básicos (gomitas, chocolates, caramelos, paletas), Premium 6 (suma palomitas y cacahuates), Luxury 8 tipos premium (todas las categorías). Producto fresco con rotación.' },
