const faqs = [
  { question: '¿Qué incluye la renta de stand para pastel en CDMX?', answer: 'Incluye marco decorativo profesional según diseño elegido (clásico, arco globos, floral, neón, LED, temático personalizado), soporte pastel reforzado para 1 a 5+ pisos, decoración coordinada al evento (globos, flores frescas, telas, papel picado), iluminación opcional (LED en Premium, LED programable en Luxury), coordinación con pastelero externo, montaje 1-2 h antes del corte, recepción del pastel y operación durante el corte, desmontaje al cierre. NO producimos pasteles (solo el stand).' },
  { question: '¿Cuánto cuesta rentar un stand para pastel en CDMX?', answer: 'En CDMX iniciamos en $2,800 MXN (Esencial, marco clásico/floral simple, hasta 2 pisos), $4,800 MXN (Premium, 6 diseños a elegir incluye Arco Globos viral, hasta 3 pisos con iluminación LED, el más solicitado) y $8,500 MXN (Luxury, diseño temático personalizado, 4-5+ pisos torre, LED programable + neón, foto profesional del corte incluida). El precio depende del diseño, tamaño del pastel, decoración floral y duración.' },
  { question: '¿Producen pasteles o solo el stand?', answer: 'Solo producimos y rentamos el STAND (estructura, marco, decoración, soporte, iluminación). El PASTEL lo produce tu pastelero externo. Si no tienes pastelero, te conectamos con pasteleros confiables CDMX (boutique, premium, especializados en bodas o temáticos). Coordinamos directo con el pastelero seleccionado: tamaño, peso, hora de entrega, instrucciones de manipulación y recepción en el venue.' },
  { question: '¿Qué tipos de stand manejan?', answer: 'Trabajamos 6 diseños: Clásico elegante (marco simple con tela blanca, ideal bodas sobrias y bautizos), Arco de globos (tendencia viral 2026 en redes sociales, paleta del evento), Floral natural (flores frescas o eternas premium, paleta coordinada al ramo), Neón iluminado (letras neón con frase o nombre, tendencia XV modernos), Iluminado LED (LED programable color cambiante, ideal interiores con poca luz) y Temático personalizado (cualquier concepto con moodboard previo: princesa, casino, deportivo, corporativo).' },
  { question: '¿Qué tamaños de pastel soportan?', answer: 'Soportamos 5 tamaños: 1 piso (pastel pequeño 6-15 personas, soporte 25-30 cm), 2 pisos (mediano 15-40 personas, 35-40 cm), 3 pisos (grande 40-100 personas, 45-50 cm, el más solicitado para XV, bodas medianas, primera comunión grupal), 4 pisos (extra grande 100-200 personas, 55-65 cm, statement piece) y 5+ pisos torre (masivo 200-400+ personas, 70+ cm reforzado, para bodas grandes, graduaciones generación, eventos corporate).' },
  { question: '¿Coordinan con el fotógrafo profesional?', answer: 'Sí. El stand para pastel es el escenario de LA foto más importante del evento (corte del pastel). Coordinamos posición con tu fotógrafo: ángulo de cámara, iluminación, backdrop, momento del corte (justo después de los novios, justo después de soplar las velitas, etc.). En paquete Luxury incluimos foto profesional del corte de pastel sin costo adicional.' },
  { question: '¿Para qué tipos de evento se renta más?', answer: 'Las 4 aplicaciones más solicitadas: <a href="/candy-bar-eventos/mesa-dulces-boda">Bodas</a> (el escenario del sí, foto del corte de pastel nupcial), <a href="/candy-bar-eventos/mesa-dulces-xv-anos">XV Años</a> (momento protagonista de la quinceañera con pastel multipisos), <a href="/candy-bar-eventos/mesa-dulces-baby-shower">Baby Shower</a> (el dulce anuncio, especialmente con pastel sorpresa para gender reveal), <a href="/candy-bar-eventos/mesa-dulces-bautizo">Bautizo</a> (celebración serena con simbología religiosa).' },
  { question: '¿Pueden combinarlo con otras estaciones?', answer: 'Sí. La combinación más popular: <strong>trifecta interactiva</strong> = Stand para Pastel + <a href="/estaciones-interactivas/fuente-de-chocolate">Fuente de Chocolate</a> + <a href="/estaciones-interactivas/pared-de-dulces">Pared de Dulces</a>. También combina con <a href="/estaciones-interactivas/fuente-de-chamoy">Fuente de Chamoy</a> para eventos mexicanos modernos.' },
  { question: '¿Atienden eventos en todo CDMX?', answer: 'Sí. Operamos desde sucursales fijas Anzures y Condesa con cobertura completa CDMX: Polanco, Lomas, Santa Fe, Interlomas, Coyoacán, Pedregal, Roma, Condesa, Anzures, Del Valle, Naucalpan, Huixquilucan, Tlalnepantla, Satélite y todas las 16 alcaldías. Operamos en hoteles 5 estrellas, haciendas, edificios corporativos, salones boutique y domicilios. Visita nuestra <a href="/sucursales/cdmx/mesa-de-dulces">página de sucursal CDMX</a>.' },
  { question: '¿Con cuánta anticipación debo reservar?', answer: 'Para diseños estándar (clásico, floral, arco globos) recomendamos 2-3 semanas. Para Neón con frase personalizada, LED programable o Temático personalizado con moodboard previo, sugerimos 4-6 semanas. Anticipo del 50% para apartar fecha y liquidación 48h antes del evento.' }
];

const galleryWidths = [320, 480, 640, 800, 960, 1200];
const gallerySizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Service", "@id": "https://mesas-de-dulces.com/estaciones-interactivas/stand-para-pastel#service", "name": "Renta de Stand para Pastel en CDMX", "serviceType": "Estación Interactiva / Stand Decorativo Pastel", "description": "Renta de stand para pastel en Ciudad de México con 6 diseños temáticos (clásico, arco globos, floral, neón, LED, temático personalizado). Soporte para pasteles de 1 a 5+ pisos. Coordinación con pastelero externo. Para bodas, XV, baby shower, bautizo. Sucursales Anzures y Condesa.", "provider": { "@type": "LocalBusiness", "name": "MEDEDUL", "image": getCdnUrl('/img/branding/logo-mededul-mesas-de-dulces.avif'), "telephone": "+525525226442", "url": "https://mesas-de-dulces.com", "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de Mexico", "addressRegion": "CDMX", "addressCountry": "MX" }, "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "280", "bestRating": "5" } }, "areaServed": { "@type": "City", "name": "Ciudad de Mexico" }, "offers": { "@type": "AggregateOffer", "priceCurrency": "MXN", "lowPrice": "2800", "highPrice": "8500", "offerCount": "3", "offers": paquetes.map(pkg => ({ "@type": "Offer", "name": `Stand Pastel CDMX ${pkg.name}`, "price": pkg.price.replace(/[$,]/g, ''), "priceCurrency": "MXN", "description": pkg.guests, "availability": "https://schema.org/InStock" })) } }
  ]
