  { name: 'Premium', icon: '🔥', price: '$5,500', currency: 'MXN', guests: '50-150 invitados', tagline: 'El más solicitado en CDMX', features: ['Fuente 15 kg chamoy artesanal (4 niveles a elegir)', '5-6 productos para bañar', '3 mezclas adicionales (limón, tajín, miel)', 'Operador 4 horas', 'Backdrop con motivos mexicanos', 'Reposición continua', 'Cobertura amplia CDMX'], popular: true, ctaText: 'Cotizar Premium', ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20Fuente%20Chamoy%20CDMX%20-%20Premium' },
  { name: 'Luxury', icon: '⭐', price: '$8,800', currency: 'MXN', guests: '150-400+ invitados', tagline: 'Show mexicano de gran escala', features: ['Fuente 30 kg chamoy artesanal premium', '8 productos + 5 mezclas completas', 'Operador 6 horas + ayudante', 'Backdrop temático mexicano (papel picado)', 'Estación helado vainilla con chamoy', 'Gomitas premium importadas', 'Cobertura completa CDMX y zona metropolitana'], popular: false, ctaText: 'Cotizar Luxury', ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20Fuente%20Chamoy%20CDMX%20-%20Luxury' }
];

const proceso = [
  { num: 1, title: 'Brief del evento', desc: 'Recibimos brief: tipo de evento, número de invitados, nivel de picor preferido (suave, tradicional, picoso, extra), productos para bañar deseados, sede y horarios. Te asesoramos según el perfil de invitados.' },
  { num: 2, title: 'Cotización ejecutiva', desc: 'En 24h enviamos cotización 3 niveles (Esencial 5kg, Premium 15kg, Luxury 30kg) con detalle de productos, mezclas, duración y add-ons.' },
  { num: 3, title: 'Coordinación logística', desc: 'Coordinamos posición de la fuente (zona ventilada por el aroma del chile), acceso eléctrico (110V), tiempo de montaje, integración con mesa de dulces o estación de bebidas.' },
  { num: 4, title: 'Día del evento', desc: 'Llegamos 1-2h antes. Calentamos chamoy al punto óptimo, instalamos fuente, presentamos productos. Operamos con reposición continua y ofrecemos asesoría a invitados sobre niveles. Desmontaje al cierre.' }
];

const galeriaImages = [
  { src: '/img/estaciones-interactivas/fuente-chamoy/renta-de-fuente-de-chamoy.avif', alt: 'Fuente de chamoy artesanal mexicano para eventos CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/fuente-chamoy-eventos-mexicanos.avif', alt: 'Fuente de chamoy eventos mexicanos CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/fuente-chamoy-fiestas-cdmx.avif', alt: 'Fuente de chamoy fiestas CDMX picosito' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/alquiler-fuente-chamoy-mexico.avif', alt: 'Alquiler fuente de chamoy México CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/fuente-de-chamoy-para-fiestas.avif', alt: 'Fuente de chamoy para fiestas mexicanas premium' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/renta-fuente-chamoy-profesional.avif', alt: 'Renta fuente chamoy profesional CDMX' },
  { src: '/img/estaciones-interactivas/fuente-chamoy/fuente-chamoy-fiestas-cdmx.avif', alt: 'Fuente chamoy fiestas CDMX MEDEDUL' },
  { src: '/img/galeria/mesa-dulces-xv-anos-rosa-fuente-chocolate-elegante.avif', alt: 'Combo fuente chamoy + chocolate XV CDMX' }
];

const incluye = [
  { num: '01', title: 'Chamoy artesanal mexicano 100%', desc: 'Chamoy preparado en pequeño lote con receta tradicional mexicana. Sabor profundo, textura espesa, balance dulce-picoso-ácido. No industrial, no genérico.' },
  { num: '02', title: 'Fuente profesional según capacidad', desc: 'Fuente acero inoxidable grado alimentario, motor de torre, calefacción controlada. 5 kg (eventos íntimos), 15 kg (medianos, el más solicitado), 30 kg (grandes).' },
  { num: '03', title: '3-8 productos + mezclas', desc: 'Esencial 3-4 productos, Premium 5-6 + 3 mezclas, Luxury 8 productos + 5 mezclas completas (limón, tajín, miel, tamarindo, cacahuate). Producto fresco lavado.' },
  { num: '04', title: 'Mobiliario y decoración mexicana', desc: 'Mesa con mantel mexicano tradicional o papel picado, base estable, bandejas para productos, palillos, servilletas, tajín y limón en estación.' },
  { num: '05', title: 'Operador uniformado con asesoría', desc: 'Operador dedicado uniformado durante toda la operación. Reposición continua, control de temperatura, asesoría a invitados sobre niveles de picor (especialmente para invitados extranjeros).' },
  { num: '06', title: 'Montaje y desmontaje incluidos', desc: 'Llegamos 1-2h antes. Calentamiento del chamoy al punto óptimo, instalación, prueba de fluido. Desmontaje discreto al cierre con limpieza completa.' }
];

const testimonios = [
  { name: 'Andrea Méndez (XV)', initials: 'AM', review: 'XV de mi hija con temática mexicana moderna en Hacienda de los Morales. Combo fuente chocolate + fuente chamoy. La de chamoy fue la sensación, todas las amigas tomaron foto y subieron a TikTok. Súper diferenciador.', event: 'XV Años · Hacienda de los Morales · Mexicana', rating: 5 },
  { name: 'Familia Rojas (graduación)', initials: 'FR', review: 'Graduación de mi hijo de la UNAM con 200 invitados. Fuente de chamoy nivel tradicional con mango, jícama y palomitas dulces. La sensación con los compañeros mexicanos. El brindis de la victoria mexicana.', event: 'Graduación · UNAM · 200 invitados', rating: 5 },
  { name: 'Marketing Lead (corporativo)', initials: 'ML', review: 'Lanzamiento de producto con clientes internacionales en Reforma. Pedimos fuente de chamoy nivel suave para invitados extranjeros. El operador explicaba cómo combinar productos. Diferenciador cultural mexicano impresionante.', event: 'Lanzamiento corporativo internacional · Reforma', rating: 5 }
];

const faqs = [
  { question: '¿Qué incluye la renta de fuente de chamoy en CDMX?', answer: 'Incluye fuente profesional acero inoxidable según capacidad (5, 15 o 30 kg), chamoy artesanal mexicano 100% en nivel a elegir (suave, tradicional, picoso o extra picoso), 3 a 8 productos para bañar (gomitas variadas, mango, jícama, pepino, palomitas dulces, paletas Vero, pretzels, helado de vainilla), 0 a 5 mezclas adicionales (limón, tajín, miel, tamarindo, cacahuate), mesa con mantel mexicano tradicional, palillos y servilletas, operador uniformado, montaje 1-2 h antes y desmontaje al cierre.' },
  { question: '¿Cuánto cuesta rentar una fuente de chamoy en CDMX?', answer: 'En CDMX iniciamos en $3,200 MXN (Esencial, 5 kg, 20-40 invitados), $5,500 MXN (Premium, 15 kg, 50-150 invitados, el más solicitado) y $8,800 MXN (Luxury, 30 kg, 150-400+ invitados con backdrop mexicano y estación helado). El precio depende del número de invitados, nivel de picor (extra picoso sale igual que tradicional), número de productos y mezclas. Cotización 24h.' },
  { question: '¿Qué niveles de picor manejan?', answer: 'Trabajamos 4 niveles: Suave (kid-friendly, dulce con poco chile, apto niños 6+, ideal infantiles y baby showers), Tradicional (el clásico mexicano equilibrio dulce-picoso-ácido, el más solicitado para XV/bodas/graduaciones), Picoso (mayor chile, para amantes del picante, acompañar con bebidas) y Extra picoso (chile habanero, activación divertida para eventos jóvenes).' },
  { question: '¿Qué productos para bañar incluyen?', answer: 'Trabajamos 8 categorías: gomitas variadas (ositos, tubitos, gusanitos), frutas frescas (mango, sandía, jícama, pepino), mango con chile en barritas, pepino-jícama cortados, paletas Vero mexicanas tradicionales, palomitas dulces caramelizadas, pretzels y churritos salados, helado de vainilla con chamoy encima. Plus 5 mezclas: chamoy+limón, chamoy+tajín, chamoy+miel, chamoy+tamarindo, chamoy+cacahuate.' },
  { question: '¿Para qué tipos de evento se renta más?', answer: 'Las 4 aplicaciones más solicitadas: <a href="/candy-bar-eventos/mesa-dulces-xv-anos">XV Años</a> (toque picosito mexicano para quinceañeras modernas), <a href="/candy-bar-eventos/mesa-dulces-cumpleanos-infantil">Cumpleaños</a> (sabor que celebra para niños 6+ con nivel suave), <a href="/candy-bar-eventos/mesa-dulces-boda">Bodas</a> (estación diferenciadora para bodas mexicanas modernas) y <a href="/candy-bar-eventos/mesa-dulces-graduacion">Graduaciones</a> (el brindis de la victoria mexicana, especialmente UNAM/IPN/universidades públicas).' },
  { question: '¿La fuente de chamoy es apta para niños?', answer: 'Sí, en nivel Suave. Diseñamos el nivel kid-friendly con muy poco chile (apto niños 6+), sabor predominantemente dulce-frutal con apenas toque picosito. Ideal para fiestas infantiles, baby showers y eventos familiares. Para niños menores de 6 años recomendamos solo fuente de chocolate.' },
  { question: '¿Pueden combinarla con fuente de chocolate?', answer: 'Sí, es la combinación más solicitada en CDMX: fuente de chocolate (universal, para todos) + fuente de chamoy (mexicana, diferenciadora). Especialmente popular en XV mexicanos modernos, bodas con identidad nacional, graduaciones universitarias. Visita <a href="/estaciones-interactivas/fuente-de-chocolate">Fuente de Chocolate</a> para detalle.' },
  { question: '¿Pueden combinarla con otras estaciones?', answer: 'Sí: <a href="/estaciones-interactivas/fuente-de-chocolate">Fuente de Chocolate</a> (combo dulce + picosito), <a href="/estaciones-interactivas/pared-de-dulces">Pared de Dulces</a> (autoservicio + show interactivo), <a href="/estaciones-interactivas/stand-para-pastel">Stand para Pastel</a> (centro celebración + sabor mexicano).' },
  { question: '¿Atienden eventos en todo CDMX?', answer: 'Sí. Operamos desde sucursales fijas Anzures y Condesa con cobertura completa CDMX: Polanco, Lomas, Santa Fe, Interlomas, Coyoacán, Pedregal, Roma, Condesa, Anzures, Del Valle, Naucalpan, Huixquilucan, Tlalnepantla, Satélite y todas las 16 alcaldías. Visita nuestra <a href="/sucursales/cdmx/mesa-de-dulces">página de sucursal CDMX</a>.' },
  { question: '¿Con cuánta anticipación debo reservar?', answer: 'Para eventos regulares 2-3 semanas. Para temporadas altas (mayo-junio XV/graduaciones, octubre-diciembre bodas/posadas) sugerimos 4-6 semanas. Anticipo del 50% para apartar fecha y liquidación 48h antes del evento.' }
];

const galleryWidths = [320, 480, 640, 800, 960, 1200];
const gallerySizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw';

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Service", "@id": "https://mesas-de-dulces.com/estaciones-interactivas/fuente-de-chamoy#service", "name": "Renta de Fuente de Chamoy en CDMX", "serviceType": "Estación Interactiva / Fuente de Chamoy Artesanal Mexicano", "description": "Renta de fuente de chamoy artesanal mexicano en Ciudad de México con 4 niveles de picor (suave, tradicional, picoso, extra picoso), 8 productos para bañar (gomitas, mango, jícama, pepino, paletas Vero, palomitas), 5 mezclas adicionales. Capacidades 5kg, 15kg y 30kg. Para XV, bodas, graduaciones, eventos corporativos. Operación desde sucursales Anzures y Condesa.", "provider": { "@type": "LocalBusiness", "name": "MEDEDUL", "image": getCdnUrl('/img/branding/logo-mededul-mesas-de-dulces.avif'), "telephone": "+525525226442", "url": "https://mesas-de-dulces.com", "address": { "@type": "PostalAddress", "addressLocality": "Ciudad de Mexico", "addressRegion": "CDMX", "addressCountry": "MX" }, "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "180", "bestRating": "5" } }, "areaServed": { "@type": "City", "name": "Ciudad de Mexico" }, "offers": { "@type": "AggregateOffer", "priceCurrency": "MXN", "lowPrice": "3200", "highPrice": "8800", "offerCount": "3", "offers": paquetes.map(pkg => ({ "@type": "Offer", "name": `Fuente Chamoy CDMX ${pkg.name}`, "price": pkg.price.replace(/[$,]/g, ''), "priceCurrency": "MXN", "description": pkg.guests, "availability": "https://schema.org/InStock" })) } }
  ]
};
---

<BaseLayout
  title="Fuente de Chamoy CDMX | Artesanal Mexicano · 4 Niveles Picor · 8 Productos | MEDEDUL"
  description="Renta de fuente de chamoy artesanal mexicano en CDMX con 4 niveles de picor (suave, tradicional, picoso, extra picoso). 8 productos para bañar (gomitas, mango, jícama, paletas Vero), 5 mezclas. 180+ fuentes operadas. XV, bodas, graduaciones, infantiles. Desde $3,200 MXN."
  canonical="/estaciones-interactivas/fuente-de-chamoy"
  ogImage="/img/estaciones-interactivas/fuente-chamoy/renta-de-fuente-de-chamoy.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />
  <Breadcrumbs items={breadcrumbItems} />

  <Hero title="Fuente de Chamoy en CDMX" highlight="Fuente de Chamoy CDMX" subtitle="El picosito que México ama · Chamoy artesanal 100% · 180+ fuentes operadas en CDMX" secondaryContent={`<p>Chamoy casero fluyendo para los valientes que buscan ese toque agridulce irresistible. La <strong>fuente de chamoy</strong> es la estación interactiva con mayor identidad mexicana de cualquier evento en Ciudad de México: el complemento perfecto a la fuente de chocolate, el diferenciador para eventos con sello nacional y la sensación de XV, graduaciones universitarias y bodas mexicanas modernas. En <strong>MEDEDUL</strong> trabajamos exclusivamente <strong>chamoy artesanal mexicano 100%</strong> (preparado en pequeño lote, no industrial) en 4 niveles de picor: suave (kid-friendly), tradicional (el clásico, más solicitado), picoso (para amantes del picante) y extra picoso (chile habanero para los más valientes).</p><p>Manejamos 3 capacidades (5kg, 15kg, 30kg) según invitados y 8 productos para bañar: gomitas variadas, mango fresco, jícama y pepino en barritas, paletas Vero mexicanas, palomitas dulces, pretzels, helado de vainilla con chamoy encima. Plus <strong>5 mezclas adicionales</strong>: chamoy+limón, chamoy+tajín, chamoy+miel, chamoy+tamarindo, chamoy+cacahuate. Operamos desde nuestras <strong>sucursales fijas Anzures y Condesa</strong> con cobertura completa en CDMX.</p>`} />

  <section class="chamoy-stats">
    <div class="container">
      <div class="chamoy-stats__grid">
        {stats.map(s => (<div class="chamoy-stat"><span class="chamoy-stat__num">{s.number}</span><span class="chamoy-stat__label">{s.label}</span></div>))}
      </div>
    </div>
  </section>

  <section class="chamoy-niveles section-padding" id="niveles-picor">
    <div class="container">
      <SectionHeader title="4 niveles de" titleHighlight="picor mexicano" subtitle="Elige según el perfil de tus invitados. El operador asesora invitados extranjeros sobre niveles" />
      <div class="chamoy-niveles__grid">
        {niveles.map(n => (
          <div class:list={['chamoy-nivel', { 'chamoy-nivel--popular': n.popular }]}>
            {n.popular && <span class="chamoy-nivel__badge">Más solicitado</span>}
            <div class="chamoy-nivel__icon" aria-hidden="true">{n.icon}</div>
            <h3 class="chamoy-nivel__name">{n.nivel}</h3>
            <p class="chamoy-nivel__desc">{n.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="chamoy-productos section-padding" id="productos-banar">
    <div class="container">
      <SectionHeader title="8 productos" titleHighlight="para bañar en chamoy" subtitle="Gomitas, frutas frescas mexicanas, paletas Vero, palomitas y más combinaciones" content={`<p>Cada paquete incluye selección distinta: <strong>Esencial</strong> 3-4 productos, <strong>Premium</strong> 5-6 + 3 mezclas, <strong>Luxury</strong> los 8 productos + 5 mezclas completas. Producto fresco lavado con cloro alimentario.</p>`} />
      <div class="chamoy-productos__grid">
        {productos.map(p => (
          <div class="chamoy-producto">
            <span class="chamoy-producto__icon" aria-hidden="true">{p.icon}</span>
            <h3 class="chamoy-producto__name">{p.nombre}</h3>
            <p class="chamoy-producto__desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="chamoy-mezclas section-padding" id="mezclas">
    <div class="container">
      <SectionHeader title="5 mezclas" titleHighlight="diferenciadoras" subtitle="Para clientes que buscan experiencia gastronómica más profunda. Disponibles desde Premium" />
      <div class="chamoy-mezclas__grid">
        {mezclas.map(m => (
          <div class="chamoy-mezcla">
            <span class="chamoy-mezcla__icon" aria-hidden="true">{m.icon}</span>
