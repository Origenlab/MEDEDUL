  { icon: '🌶️', nombre: 'Chamoy + tajín', desc: 'Con tajín en polvo encima. Combinación clásica mexicana.' },
  { icon: '🍯', nombre: 'Chamoy + miel', desc: 'Para bajar el picor y endulzar. Para invitados sensibles.' },
  { icon: '🥒', nombre: 'Chamoy + pepino-tamarindo', desc: 'Tamarindo natural mezclado. Perfil agridulce profundo. Tendencia mexicana.' },
