const caracteristicas = [
  { num: 1, title: '100% chamoy artesanal mexicano', desc: 'Trabajamos exclusivamente chamoy artesanal preparado en pequeño lote (no industrial). Sabor profundo, textura espesa, balance dulce-picoso-ácido perfecto. Receta tradicional mexicana.', img: '/img/estaciones-interactivas/fuente-chamoy/renta-fuente-chamoy-profesional.avif' },
  { num: 2, title: '4 niveles de picor a elegir', desc: 'Suave (kid-friendly, fiestas infantiles), Tradicional (el clásico mexicano, más solicitado), Picoso (para amantes del picante) y Extra picoso (chile habanero, activación divertida).', img: '/img/estaciones-interactivas/fuente-chamoy/fuente-chamoy-eventos-mexicanos.avif' },
  { num: 3, title: '8 productos + 5 mezclas para combinar', desc: 'Gomitas variadas, frutas frescas, mango con chile, pepino-jícama, paletas Vero, palomitas dulces, pretzels, helado de vainilla. Plus 5 mezclas: chamoy+limón, chamoy+tajín, chamoy+miel, chamoy+tamarindo, chamoy+cacahuate.', img: '/img/estaciones-interactivas/fuente-chamoy/fuente-chamoy-fiestas-cdmx.avif' },
  { num: 4, title: 'Diferenciador identitario mexicano', desc: 'Mientras la fuente de chocolate es universal, la fuente de chamoy es 100% mexicana y diferenciadora. Para XV mexicanos modernos, bodas con identidad nacional, graduaciones universitarias y eventos corporativos con sello mexicano.', img: '/img/estaciones-interactivas/fuente-chamoy/alquiler-fuente-chamoy-mexico.avif' }
