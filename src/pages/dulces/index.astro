---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import ReviewCard from '@/components/global/ReviewCard.astro';
import FAQ from '@/components/global/FAQ.astro';
import ContactSection from '@/components/global/ContactSection.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import { getCdnUrl } from '@/lib/cdn';

const breadcrumbItems = [
  { name: 'Dulces', url: '/dulces' }
];

// ─── Categorías principales ───────────────────────────────────────────────
const categorias = [
  {
    href: '/dulces/a-granel',
    image: getCdnUrl('/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif'),
    alt: 'Dulces a granel para mesa de dulces CDMX',
    title: 'Dulces a Granel',
    excerpt: 'Gomitas, chocolates, enchilados y mixes gourmet por 250g, 500g o 1kg. Los mismos dulces que usamos en nuestras mesas, disponibles para ti.',
    cta: 'Ver selección',
    badge: 'Más Popular'
  },
  {
    href: '/dulces/kits-por-evento',
    image: getCdnUrl('/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif'),
    alt: 'Kits de dulces curados por tipo de evento',
    title: 'Kits por Evento',
    excerpt: 'Surtidos curados por nuestros expertos según el tipo de celebración: boda, XV años, baby shower o corporativo. Cantidad exacta calculada por número de invitados.',
    cta: 'Ver kits',
    badge: 'Nuevo'
  },
  {
    href: '/dulces/freeze-dried',
    image: getCdnUrl('/img/galeria/candy-bar-empresarial-moderno-minimalista.avif'),
    alt: 'Freeze dried candy dulces liofilizados premium para eventos México',
    title: 'Freeze-Dried Candy',
    excerpt: 'La tendencia más viral en el mundo de los dulces. Texturas crocantes, sabores intensificados e impacto visual espectacular. Únicos en CDMX para eventos premium.',
    cta: 'Descubrir',
    badge: 'Tendencia 2026'
  },
  {
    href: '/dulces/mexicanos-clasicos',
    image: getCdnUrl('/img/galeria/mesa-dulces-mexicanos-tradicionales.avif'),
    alt: 'Dulces mexicanos tradicionales para eventos y fiestas CDMX',
    title: 'Mexicanos Clásicos',
    excerpt: 'Mazapanes, tamarindos, enchilados, obleas de cajeta y paletas tradicionales. La nostalgia hecha candy bar, curada con el estándar de calidad MEDEDUL.',
    cta: 'Ver clásicos',
    badge: ''
  },
  {
    href: '/dulces/chocolates-gourmet',
    image: getCdnUrl('/img/galeria/mesa-dulces-boda-elegante-velas-chocolate.avif'),
    alt: 'Chocolates gourmet premium para mesas de dulces y candy bar CDMX',
    title: 'Chocolates Gourmet',
    excerpt: 'Chocolates belgas, trufas artesanales, tabletas con inclusiones premium y coberturas de alta calidad. El toque de lujo que eleva cualquier mesa.',
    cta: 'Ver chocolates',
    badge: ''
  },
  {
    href: '/dulces/mayoreo',
    image: getCdnUrl('/img/galeria/candy-bar-graduacion-birrete-elegante.avif'),
    alt: 'Dulces al mayoreo para organizadores de eventos wedding planners CDMX',
    title: 'Mayoreo B2B',
    excerpt: 'Para organizadores de eventos, wedding planners y salones de fiestas. Descuentos escalonados, facturación inmediata y asesoría especializada.',
    cta: 'Cotizar mayoreo',
    badge: 'Facturación'
  }
];

// ─── Dulces por ocasión ───────────────────────────────────────────────────
const ocasiones = [
  {
    emoji: '💍',
    titulo: 'Boda',
    descripcion: 'Chocolates belgas, trufas, macarons y gomitas premium en la paleta de tu evento.',
    href: '/dulces/kits-por-evento#boda',
    tag: 'Kit Boda Elegante'
  },
  {
    emoji: '👑',
    titulo: 'XV Años',
    descripcion: 'Dulces en colores personalizados, gomitas temáticas y detalles instagrameables.',
    href: '/dulces/kits-por-evento#xv-anos',
    tag: 'Kit XV Romantico'
  },
  {
    emoji: '🍼',
    titulo: 'Baby Shower',
    descripcion: 'Paleta pasteles, dulces tiernos y surtidos en azul, rosa o verde menta.',
    href: '/dulces/kits-por-evento#baby-shower',
    tag: 'Kit Baby Shower'
  },
  {
    emoji: '🏢',
    titulo: 'Corporativo',
    descripcion: 'Presentación ejecutiva, empaque con branding y facturación CFDI inmediata.',
    href: '/dulces/kits-por-evento#corporativo',
    tag: 'Kit Corporativo'
  },
  {
    emoji: '🎂',
    titulo: 'Cumpleaños',
    descripcion: 'Desde temáticas infantiles hasta surtidos de adulto. Personalización total.',
    href: '/dulces/kits-por-evento#cumpleanos',
    tag: 'Kit Cumpleaños'
  },
  {
    emoji: '🕊️',
    titulo: 'Bautizo & Comunión',
    descripcion: 'Dulces en blanco y dorado, presentación elegante y clásica.',
    href: '/dulces/kits-por-evento#bautizo',
    tag: 'Kit Religioso'
  }
];

// ─── Cómo funciona ────────────────────────────────────────────────────────
const pasos = [
  {
    num: '01',
    titulo: 'Elige tu categoría',
    descripcion: 'Selecciona entre granel, kits por evento, freeze-dried o mexicanos clásicos. Si no sabes por dónde empezar, te asesoramos gratis por WhatsApp.',
    icono: '🍬'
  },
  {
    num: '02',
    titulo: 'Indica tu evento',
    descripcion: 'Cuéntanos el tipo de celebración, número de invitados y paleta de colores. Calculamos la cantidad exacta que necesitas sin desperdicio.',
    icono: '📋'
  },
  {
    num: '03',
    titulo: 'Recibe en CDMX',
    descripcion: 'Entrega express en CDMX y Área Metropolitana. También puedes recoger en nuestra sucursal en Anzures. Presentación premium incluida.',
    icono: '📦'
  }
];

// ─── Tendencias 2026 ──────────────────────────────────────────────────────
const tendencias = [
  {
    titulo: 'Freeze-Dried Candy',
    tag: '#1 Tendencia Global',
    descripcion: 'Crocantes, intensos y 100% instagrameables. El mercado global crece al 8.5% anual. Los primeros en CDMX con posicionamiento de eventos premium.',
    href: '/dulces/freeze-dried',
    destacado: true
  },
  {
    titulo: 'Mix Enchilados Gourmet',
    tag: 'Favorito México',
    descripcion: 'Combinaciones audaces de gomitas, chamoy y chile que elevan la experiencia en cualquier candy bar.',
    href: '/dulces/a-granel#enchilados',
    destacado: false
  },
  {
    titulo: 'Chocolates Premium',
    tag: 'Premiumización',
    descripcion: 'Tabletas con sal del Himalaya, chocolates de origen único y trufas artesanales que impactan en bodas elegantes.',
    href: '/dulces/chocolates-gourmet',
    destacado: false
  },
  {
    titulo: 'Dulces Retro Curados',
    tag: 'Nostalgia',
    descripcion: 'Mazapanes, Duvalin, obleas y paletas de la infancia, seleccionados y presentados con estética premium.',
    href: '/dulces/mexicanos-clasicos',
    destacado: false
  }
];

// ─── Testimonios ──────────────────────────────────────────────────────────
const testimonios = [
  {
    name: 'Sofía Aragón',
    initials: 'SA',
    review: 'Pedí el kit de boda para 120 invitados y quedé sorprendida. Los dulces llegaron perfectamente presentados y la variedad fue exactamente lo que necesitaba. Todo calculado sin que me sobrara nada.',
    event: 'Kit Boda Elegante — Polanco',
    rating: 5
  },
  {
    name: 'Grupo Nextel MX',
    initials: 'GN',
    review: 'Para nuestra convención anual compramos el kit corporativo. El empaque con nuestra paleta de marca fue impecable. Facturación inmediata y entrega puntual. Nuestro proveedor oficial.',
    event: 'Kit Corporativo — Santa Fe',
    rating: 5
  },
  {
    name: 'Valentina Cruz',
    initials: 'VC',
    review: 'El freeze-dried candy para la mesa de los XV de mi hija fue el elemento más fotografiado de la fiesta. Mis amigas no habían visto nada igual en México. Absolutamente único.',
    event: 'Freeze-Dried + Kit XV — Interlomas',
    rating: 5
  }
];

// ─── Diferenciadores vs competencia ──────────────────────────────────────
const diferenciadores = [
  {
    icono: '🏆',
    titulo: '8 años de curaduría',
    texto: 'No vendemos cualquier dulce. Vendemos los dulces que hemos seleccionado y probado en 500+ eventos. Cada producto pasó por nuestro estándar de calidad.'
  },
  {
    icono: '🎯',
    titulo: 'Cantidad exacta por evento',
    texto: 'Calculamos la cantidad que necesitas según el número de invitados y tipo de evento. Sin desperdicio, sin quedarte corto.'
  },
  {
    icono: '📸',
    titulo: 'Impacto visual garantizado',
    texto: 'Seleccionamos dulces que no solo saben bien, sino que se ven espectaculares en fotos y en mesa. Pensados para ser el centro de atención.'
  },
  {
    icono: '🚚',
    titulo: 'Entrega express CDMX',
    texto: 'Entrega en 24-48h en toda la CDMX y Área Metropolitana. Recogida en sucursal Anzures o Condesa sin costo.'
  },
  {
    icono: '🧾',
    titulo: 'Facturación CFDI',
    texto: 'Emitimos factura inmediata para empresas y organizadores. Somos proveedores registrados con comprobantes fiscales válidos.'
  },
  {
    icono: '💬',
    titulo: 'Asesoría gratuita',
    texto: 'No sabes qué pedir ni cuánto. Escríbenos por WhatsApp y un experto te arma el surtido ideal para tu evento en minutos.'
  }
];

// ─── FAQ ──────────────────────────────────────────────────────────────────
const faqItems = [
  {
    question: '¿Cuántos dulces necesito para mi evento?',
    answer: 'Depende del tipo de evento y si es mesa principal o complementaria. Como regla general: 150-200g por persona para candy bar estándar, 300-400g para mesa principal. Escríbenos el número de invitados y te calculamos exacto sin costo.'
  },
  {
    question: '¿Hacen entregas a domicilio en CDMX?',
    answer: 'Sí. Entregamos en toda la CDMX y Zona Metropolitana en 24-48 horas. También puedes recoger sin costo en nuestras sucursales de Anzures (Av. Ejército Nacional 216) y Condesa. Para eventos urgentes contáctanos directamente por WhatsApp.'
  },
  {
    question: '¿Qué es el freeze-dried candy y por qué está de moda?',
    answer: 'Es dulce liofilizado: el proceso de secado elimina la humedad creando una textura crocante y sabores ultra-concentrados. Es viral en TikTok con millones de vistas y el segmento de más crecimiento mundial (8.5% anual). Para eventos es el elemento más "instagrameable" que existe actualmente. Somos de los pocos en CDMX que lo venden con presentación premium para candy bars.'
  },
  {
    question: '¿Puedo pedir muestras antes de hacer un pedido grande?',
    answer: 'Sí, ofrecemos caja de degustación para pedidos de mayoreo (+$5,000 MXN). Para pedidos estándar, consulta nuestra selección en sucursal previa cita.'
  },
  {
    question: '¿Los kits por evento incluyen presentación y empaque?',
    answer: 'Sí. Todos los kits incluyen presentación premium: bolsas, etiquetas y empaque acorde al estilo del evento. Los kits corporativos incluyen la opción de empaque con logo o paleta de marca.'
  },
  {
    question: '¿Tienen precios de mayoreo para organizadores?',
    answer: 'Sí, contamos con esquema B2B para wedding planners, organizadores de eventos y salones de fiestas. Descuentos del 15-25% según volumen mensual, facturación CFDI y asesor dedicado. Consulta más en /dulces/mayoreo o escríbenos directamente.'
  },
  {
    question: '¿Puedo comprar solo dulces sin contratar el servicio de mesa?',
    answer: 'Por supuesto. La sección de venta de dulces es completamente independiente de nuestro servicio de montaje. Puedes comprar los dulces y armar tu propia mesa, o contratar el servicio completo. Muchos clientes combinan ambas opciones.'
  },
  {
    question: '¿Qué diferencia hay entre sus dulces y los de una dulcería normal?',
    answer: 'Tres cosas: curaduría experta (8 años seleccionando dulces para 500+ eventos), presentación premium (no granel en bolsa genérica, sino empaque cuidado), y asesoría incluida (te decimos exactamente qué y cuánto para tu evento). No vendemos cualquier dulce, vendemos los dulces que hacen que una mesa se vea espectacular.'
  }
];

// ─── Schema ───────────────────────────────────────────────────────────────
const dulcesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Dulces Premium para Eventos — MEDEDUL CDMX",
  "description": "Venta de dulces a granel, kits por evento y freeze-dried candy. Los dulces que usamos en nuestras mesas de dulces, disponibles para compra.",
  "url": "https://mesas-de-dulces.com/dulces",
  "numberOfItems": 6,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Dulces a Granel",
      "url": "https://mesas-de-dulces.com/dulces/a-granel"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Kits por Evento",
      "url": "https://mesas-de-dulces.com/dulces/kits-por-evento"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Freeze-Dried Candy",
      "url": "https://mesas-de-dulces.com/dulces/freeze-dried"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Mexicanos Clásicos",
      "url": "https://mesas-de-dulces.com/dulces/mexicanos-clasicos"
    },
    {
      "@type": "ListItem",
      "position": 5,
      "name": "Chocolates Gourmet",
      "url": "https://mesas-de-dulces.com/dulces/chocolates-gourmet"
    },
    {
      "@type": "ListItem",
      "position": 6,
      "name": "Mayoreo B2B",
      "url": "https://mesas-de-dulces.com/dulces/mayoreo"
    }
  ]
};
---

<BaseLayout
  title="Comprar Dulces para Mesa de Dulces y Candy Bar | MEDEDUL CDMX"
  description="Venta de dulces a granel, kits curados por evento y freeze-dried candy en CDMX. Los dulces de nuestras mesas de dulces premium, disponibles para ti. Entrega express."
  canonical="/dulces"
  ogImage="/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(dulcesSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <Hero
    title="Dulces Premium para tu Evento"
    highlight="Dulces Premium"
    subtitle="Los dulces de nuestras mesas, ahora disponibles para compra"
    secondaryContent={`
      <p>Durante <strong>8 años y 500+ eventos</strong> hemos seleccionado, probado y curado los dulces que hacen que una mesa se vea espectacular. Ahora puedes comprarlos directamente.</p>
      <p>Desde <strong>dulces a granel por kilo</strong> hasta <strong>kits completos calculados para tu número de invitados</strong>. Con asesoría gratuita y entrega express en toda la CDMX.</p>
    `}
    showCTA={true}
    ctaHref="/dulces/kits-por-evento"
    ctaBadge="Nuevo en MEDEDUL"
    ctaTitle="¿No sabes cuánto ni qué pedir?"
    ctaTitleHighlight="cuánto"
    ctaText="Escríbenos el tipo de evento y número de invitados. Te armamos el surtido ideal en minutos, sin costo."
    ctaButtonText="Asesoría Gratis por WhatsApp"
  />

  <!-- ═══════════════════════════════════════════════════════
       STATS STRIP
  ═══════════════════════════════════════════════════════ -->
  <section class="stats-strip">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-numero">500+</span>
          <span class="stat-label">Eventos abastecidos</span>
        </div>
        <div class="stat-item">
          <span class="stat-numero">8 años</span>
          <span class="stat-label">Seleccionando calidad</span>
        </div>
        <div class="stat-item">
          <span class="stat-numero">6</span>
          <span class="stat-label">Categorías premium</span>
        </div>
        <div class="stat-item">
          <span class="stat-numero">24h</span>
          <span class="stat-label">Entrega en CDMX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CATEGORÍAS PRINCIPALES
  ═══════════════════════════════════════════════════════ -->
  <section class="categorias-section section-padding">
    <div class="container">
      <SectionHeader
        title="Nuestra Selección de"
        titleHighlight="Dulces Premium"
        subtitle="Curados por expertos. Pensados para eventos. Entregados en CDMX."
        content={`
          <p>No vendemos cualquier dulce. Cada producto en nuestro catálogo pasó por el mismo criterio que usamos para seleccionar los dulces de nuestras mesas: calidad visual, sabor excepcional y capacidad de generar impacto en la celebración.</p>
          <p>Desde <strong>granel por peso</strong> hasta <strong>kits completos calculados</strong> para tu evento específico.</p>
        `}
      />
      <div class="service-grid">
        {categorias.map(cat => (
          <ServiceCard
            href={cat.href}
            image={cat.image}
            alt={cat.alt}
            title={cat.title}
            excerpt={cat.excerpt}
            cta={cat.cta}
            badge={cat.badge || undefined}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       POR OCASIÓN
  ═══════════════════════════════════════════════════════ -->
  <section class="ocasiones-section section-padding">
    <div class="container">
      <SectionHeader
        title="Dulces para Cada"
        titleHighlight="Celebración"
        subtitle="Curaduría específica según el tipo de evento"
        align="center"
      />
      <div class="ocasiones-grid">
        {ocasiones.map(oc => (
          <a href={oc.href} class="ocasion-card">
            <span class="ocasion-emoji">{oc.emoji}</span>
            <div class="ocasion-body">
              <span class="ocasion-tag">{oc.tag}</span>
              <h3 class="ocasion-titulo">{oc.titulo}</h3>
              <p class="ocasion-desc">{oc.descripcion}</p>
            </div>
            <span class="ocasion-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TENDENCIAS 2026
  ═══════════════════════════════════════════════════════ -->
  <section class="tendencias-section section-padding">
    <div class="container">
      <SectionHeader
        title="Tendencias en"
        titleHighlight="Dulces 2026"
        subtitle="Lo que está marcando la diferencia en los eventos más memorables"
        content={`
          <p>El mundo de los dulces para eventos evoluciona rápido. En MEDEDUL estamos siempre un paso adelante, incorporando las tendencias globales con el estándar de calidad que nuestros clientes esperan.</p>
        `}
      />
      <div class="tendencias-grid">
        {tendencias.map(t => (
          <a href={t.href} class={`tendencia-card ${t.destacado ? 'tendencia-card--featured' : ''}`}>
            <span class="tendencia-tag">{t.tag}</span>
            <h3 class="tendencia-titulo">{t.titulo}</h3>
            <p class="tendencia-desc">{t.descripcion}</p>
            <span class="tendencia-cta">Ver más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CÓMO FUNCIONA
  ═══════════════════════════════════════════════════════ -->
  <section class="como-funciona-section section-padding">
    <div class="container">
      <SectionHeader
        title="¿Cómo"
        titleHighlight="Funciona?"
        subtitle="Simple, rápido y sin complicaciones"
        align="center"
      />
      <div class="pasos-grid">
        {pasos.map(paso => (
          <div class="paso-card">
            <div class="paso-header">
              <span class="paso-icono">{paso.icono}</span>
              <span class="paso-num">{paso.num}</span>
            </div>
            <h3 class="paso-titulo">{paso.titulo}</h3>
            <p class="paso-desc">{paso.descripcion}</p>
          </div>
        ))}
      </div>
      <div class="como-cta">
        <a
          href="https://wa.me/525525226442?text=Hola!%20Me%20interesa%20comprar%20dulces%20para%20mi%20evento.%20%C2%BFPueden%20asesorarme?"
          class="btn-whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pedir asesoría gratis
