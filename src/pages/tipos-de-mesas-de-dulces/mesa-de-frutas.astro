---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import ProcessSteps from '@/components/global/ProcessSteps.astro';
import EventsGrid from '@/components/global/EventsGrid.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { buildServiceSchema } from '@/lib/schema';

const breadcrumbItems = [
  { name: 'Tipos de Mesas', url: '/tipos-de-mesas-de-dulces' },
  { name: 'Mesa de Frutas', url: '/tipos-de-mesas-de-dulces/mesa-de-frutas' }
];

const faqs = [
  {
    question: 'Que incluye una mesa de frutas para fiestas y celebraciones?',
    answer: 'Incluye seleccion de fruta fresca como sandia, mango, kiwi, pina y naranja, arreglo decorativo en bandejas elegantes, centro de mesa con diseno atractivo, pinchos para servir y desmontaje al finalizar la fiesta.'
  },
  {
    question: 'La fruta se prepara el mismo dia del cumpleanos o fiesta?',
    answer: 'Si. Coordinamos preparacion y montaje el mismo dia para conservar frescura, color y textura. Cada pieza de sandia, mango o kiwi llega en su punto optimo de consumo.'
  },
  {
    question: 'Puedo combinar frutas con toppings o chamoy en mi fiesta?',
    answer: 'Si. Podemos agregar complementos como chamoy, chile, limon y chocolate para crear combinaciones deliciosas. Es una idea muy popular en cumpleanos y fiestas infantiles.'
  },
  {
    question: 'Para cuantas personas alcanza un buffet de frutas?',
    answer: 'Definimos porciones y volumen segun tu celebracion. Contamos con paquetes desde fiestas intimas de 30 personas hasta buffets grandes de 100+ invitados.'
  },
  {
    question: 'Sirve como centro de mesa decorativo?',
    answer: 'Si, cada arreglo de frutas funciona como centro de mesa espectacular. Usamos bandejas multinivel, pinchos decorativos y disenos inspirados en Pinterest que elevan la decoracion de cualquier fiesta.'
  },
  {
    question: 'Que frutas incluyen en el arreglo?',
    answer: 'Trabajamos con sandia, mango, kiwi, pina, naranja, fresas y uvas. Combinamos colores y texturas para crear una bandeja visualmente deliciosa que complementa la decoracion de tu cumpleanos o fiesta.'
  }
];

const packages = [
  {
    name: 'Esencial',
    icon: '🍓',
    price: '$4,200',
    currency: 'MXN',
    guests: '30-50 personas',
    tagline: 'Ideal para fiestas intimas y cumpleanos',
    features: [
      'Bandeja de frutas con sandia, mango y kiwi',
      'Arreglo decorativo con pinchos',
      'Centro de mesa elegante',
      'Diseno tipo Pinterest',
      'Desmontaje al finalizar'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Mesa de Frutas - Paquete Esencial'
  },
  {
    name: 'Favorito',
    icon: '⭐',
    price: '$7,400',
    currency: 'MXN',
    guests: '50-100 personas',
    tagline: 'La opcion mas solicitada para fiestas',
    features: [
      'Buffet amplio con pina, naranja y fresas',
      'Decoracion tematica personalizada',
      'Bandejas multinivel de exhibicion',
      'Montaje y coordinacion en sitio',
      'Asesoria de diseno previa',
      'Mejor equilibrio costo-beneficio'
    ],
    popular: true,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Mesa de Frutas - Paquete Favorito'
  },
  {
    name: 'Luxury',
    icon: '💎',
    price: '$11,900',
    currency: 'MXN',
    guests: '100+ personas',
    tagline: 'Experiencia completa para grandes fiestas',
    features: [
      'Buffet de frutas tropicales completo',
      'Direccion estetica y decoracion total',
      'Arreglos multiples como centros de mesa',
      'Configuracion para celebraciones grandes',
      'Acompanamiento operativo integral',
      'Presentacion de alto impacto visual'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Mesa de Frutas - Paquete Luxury'
  }
];

const whyStats = [
  { number: '100%', label: 'Fruta Fresca' },
  { number: '4h+', label: 'Frescura Garantizada' },
  { number: '500+', label: 'Fiestas Realizadas' },
  { number: '24h', label: 'Respuesta Rapida' }
];

const whyFeatures = [
  {
    num: 1,
    title: 'Frutas de Temporada Deliciosas',
    desc: 'Seleccionamos sandia, mango, kiwi, pina y naranja en su punto optimo para sabor y frescura en tu fiesta.',
    img: '/img/tipos-de-mesas/frutas/mesas-de-frutas-para-eventos.avif'
  },
  {
    num: 2,
    title: 'Diseno Estilo Pinterest',
    desc: 'Arreglos decorativos con bandejas multinivel y pinchos creativos que se convierten en centro de mesa espectacular.',
    img: '/img/tipos-de-mesas/frutas/mesa-frutas-frescas-eventos.avif'
  },
  {
    num: 3,
    title: 'Alternativa Saludable y Deliciosa',
    desc: 'Formato ideal para balancear tu buffet de cumpleanos o fiesta con una opcion fresca y visualmente atractiva.',
    img: '/img/tipos-de-mesas/frutas/servicio-mesa-frutas-profesional.avif'
  },
  {
    num: 4,
    title: 'Decoracion que Impresiona',
    desc: 'Cada bandeja de frutas esta disenada para complementar la decoracion de tu celebracion con colores vibrantes.',
    img: '/img/tipos-de-mesas/frutas/mesas-de-frutas-para-eventos.avif'
  }
];

const processSteps = [
  { num: 1, title: 'Contactanos', desc: 'Platícanos sobre tu fiesta, cumpleanos o celebracion: fecha, lugar e invitados.' },
  { num: 2, title: 'Disenamos', desc: 'Creamos el arreglo ideal con sandia, mango, kiwi y frutas de tu preferencia.' },
  { num: 3, title: 'Confirmamos', desc: 'Cerramos propuesta, bandejas, decoracion y logistica de montaje.' },
  { num: 4, title: 'Ejecutamos', desc: 'Instalamos tu buffet de frutas listo para disfrutar en tu fiesta.' }
];

const eventCards = [
  {
    title: 'Frutas para Bodas',
    excerpt: 'Arreglo de frutas elegante con sandia y mango para recepciones nupciales. Decoracion deliciosa.',
    img: '/img/eventos/bodas/mesa-de-dulces-para-bodas.avif',
    href: '/candy-bar-eventos/mesa-dulces-boda',
    cta: 'Ver Bodas'
  },
  {
    title: 'Frutas para Cumpleanos',
    excerpt: 'Bandeja de frutas colorida para fiestas de cumpleanos. Ideas creativas estilo Pinterest.',
    img: '/img/eventos/corporativos/candy-bar-empresarial.avif',
    href: '/candy-bar-eventos/mesa-dulces-corporativos',
    badge: 'Popular',
    cta: 'Ver Ideas'
  },
  {
    title: 'Frutas para Baby Shower',
    excerpt: 'Centro de mesa con kiwi, pina y fresas para celebraciones familiares con estilo.',
    img: '/img/eventos/baby-shower/mesa-de-dulces-para-baby-shower.avif',
    href: '/candy-bar-eventos/mesa-dulces-baby-shower',
    cta: 'Ver Baby Shower'
  },
  {
    title: 'Frutas para Fiestas',
    excerpt: 'Buffet de frutas con naranja, mango y decoracion tematica para grandes celebraciones.',
    img: '/img/eventos/graduaciones/mesa-dulces-graduacion.avif',
    href: '/candy-bar-eventos/mesa-dulces-graduacion',
    cta: 'Ver Fiestas'
  }
];

const serviceSchema = buildServiceSchema({
  name: 'Arreglos de Frutas para Fiestas y Cumpleanos en CDMX',
  description: 'Bandejas de frutas frescas con sandia, mango, kiwi y pina para fiestas, cumpleanos y celebraciones. Diseno decorativo estilo Pinterest en Ciudad de Mexico.',
  offerPrefix: 'Arreglo de Frutas',
  packages,
  canonical: '/tipos-de-mesas-de-dulces/mesa-de-frutas'
});

---

<BaseLayout
  title="Mesa de Frutas para Fiestas y Cumpleanos en CDMX | Mededul"
  description="Arreglos de frutas con sandia, mango, kiwi y pina para fiestas y cumpleanos. Bandejas decorativas, pinchos creativos y diseno estilo Pinterest en CDMX."
  canonical="/tipos-de-mesas-de-dulces/mesa-de-frutas"
  ogImage="/img/tipos-de-mesas/frutas/mesas-de-frutas-para-eventos.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesa de Frutas para Fiestas en CDMX"
    highlight="Mesa de Frutas"
    subtitle="Arreglos deliciosos con sandia, mango, kiwi y pina para cumpleanos, bodas y celebraciones"
    secondaryContent={`<p><strong>Frutas frescas</strong> como sandia, mango, kiwi, pina y naranja transforman cualquier fiesta en una experiencia deliciosa. En Mededul creamos arreglos de frutas que funcionan como centro de mesa decorativo mientras ofrecen una opcion saludable para tus invitados.</p><p><strong>Diseno estilo Pinterest</strong> con bandejas multinivel, pinchos creativos y decoracion tematica. Cada buffet de frutas esta pensado para complementar la estetica de tu cumpleanos, boda o celebracion con colores vibrantes y presentacion impecable en CDMX.</p>`}
  />

  <!-- ===================== CTA Banner: ver sucursal CDMX exclusiva ===================== -->
  <section style="padding: 30px 0; background: linear-gradient(135deg, #fdf8fa 0%, #fff0f7 100%);">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding: 24px 28px; background: #fff; border-radius: 20px; border: 1px dashed rgba(233, 30, 140, 0.3); box-shadow: 0 6px 24px rgba(0, 0, 0, 0.05);">
      <div style="flex: 1; min-width: 260px;">
        <strong style="display: block; color: #D1007A; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Evento en CDMX?</strong>
        <h3 style="margin: 0 0 6px; font-size: 1.25rem; color: #1a1a1a;">Visita nuestra pagina exclusiva <span style="color: #D1007A;">Mesa de Frutas CDMX</span></h3>
        <p style="margin: 0; color: #666; font-size: 0.95rem;">Paquetes desde $4,800 MXN, fruta surtida en Central de Abasto la madrugada del evento, cobertura 16 alcaldias desde sucursales Anzures + Condesa.</p>
      </div>
      <a href="/sucursales/cdmx/mesa-de-frutas" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; background: linear-gradient(135deg, #D1007A 0%, #A0005F 100%); color: #fff; border-radius: 50px; font-weight: 600; text-decoration: none; box-shadow: 0 6px 20px rgba(209, 0, 122, 0.3); white-space: nowrap;">
        Ver Mesa de Frutas CDMX
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </a>
    </div>
  </section>

  <PricingPackages
    id="paquetes"
    badge="Paquetes para Fiestas"
    title="Escoge el"
    titleHighlight="Arreglo Ideal"
    subtitle="Ajustamos bandejas, decoracion y diseno de tu mesa de frutas segun el tamano de tu fiesta o cumpleanos."
    packages={packages}
    note="<strong>Tienes ideas especificas?</strong> Creamos una propuesta personalizada con las frutas y decoracion que imaginas."
  />

  <WhyChooseUs
    id="ventajas"
    badge="Ideas y Ventajas"
    title="Por que elegir nuestra"
    titleHighlight="Mesa de Frutas"
    descriptions={[
      'Arreglos de frutas con sandia, mango, kiwi y pina que funcionan como centro de mesa decorativo y delicioso para tu fiesta.',
      'Combinamos diseno estilo Pinterest, bandejas elegantes y pinchos creativos para crear un buffet que impresiona en cualquier cumpleanos o celebracion.'
    ]}
    stats={whyStats}
    features={whyFeatures}
  />

  <ProcessSteps
    id="proceso"
    badge="Asi Funciona"
    title="Como Creamos tu"
    titleHighlight="Arreglo de Frutas"
    subtitle="Cuatro pasos para disenar el buffet de frutas ideal para tu fiesta o cumpleanos."
    steps={processSteps}
  />

  <EventsGrid
    id="eventos"
    badge="Ideas para tu Fiesta"
    title="Arreglos de Frutas para"
    titleHighlight="Cada Celebracion"
    subtitle="Bandejas, pinchos y decoracion adaptados al estilo de tu cumpleanos, boda o fiesta."
    events={eventCards}
  />


  <FAQContactModule faqItems={faqs} />
</BaseLayout>
