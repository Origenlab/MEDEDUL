---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import ProcessSteps from '@/components/global/ProcessSteps.astro';
import EventsGrid from '@/components/global/EventsGrid.astro';

import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { buildServiceSchema } from '@/lib/schema';

const breadcrumbItems = [
  { name: 'Tipos de Mesas', url: '/tipos-de-mesas-de-dulces' },
  { name: 'Mesa de Snacks', url: '/tipos-de-mesas-de-dulces/mesa-de-snacks' }
];

const faqs = [
  {
    question: 'Que incluye una barra de botanas para fiestas?',
    answer: 'Incluye seleccion de botanas saladas, canapes, quesos, galletas y frutos secos. Armamos bandejas decorativas con diseno estilo Pinterest y desmontaje al finalizar tu fiesta o celebracion.'
  },
  {
    question: 'Sirve para bodas y fiestas familiares?',
    answer: 'Si, es ideal para bodas, cumpleanos, reuniones familiares y fiestas sociales. Combinamos botanas deliciosas con decoracion tematica para que tus invitados disfruten.'
  },
  {
    question: 'Pueden combinar botanas clasicas con canapes y quesos?',
    answer: 'Si, configuramos una mezcla de botanas, canapes gourmet y quesos segun tu fiesta. Creamos buffets variados para cumpleanos, bodas y celebraciones especiales.'
  },
  {
    question: 'Se puede integrar con candy bar y mesa de dulces?',
    answer: 'Si, es una combinacion deliciosa para ofrecer variedad salada y dulce en tu fiesta. Renta de barra de botanas junto con candy bar para bodas y cumpleanos.'
  },
  {
    question: 'Ofrecen catering de botanas para fiestas largas?',
    answer: 'Si, nuestro catering incluye reposicion continua de bandejas para fiestas de varias horas. Ideal para bodas, graduaciones y celebraciones con muchos invitados.'
  },
  {
    question: 'Incluye instalacion y decoracion de la barra?',
    answer: 'Si, instalamos tu barra de botanas con bandejas elegantes, decoracion tematica y todo listo para tu fiesta o cumpleanos en CDMX.'
  }
];

const packages = [
  {
    name: 'Esencial',
    icon: '🍿',
    price: '$3,900',
    currency: 'MXN',
    guests: '30-50 personas',
    tagline: 'Ideal para fiestas y cumpleanos',
    features: [
      'Barra de botanas con canapes y quesos',
      'Bandejas decorativas elegantes',
      'Presentacion estilo Pinterest',
      'Mobiliario incluido',
      'Desmontaje al finalizar'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Barra de Botanas - Paquete Esencial'
  },
  {
    name: 'Favorito',
    icon: '⭐',
    price: '$6,900',
    currency: 'MXN',
    guests: '50-100 personas',
    tagline: 'La opcion mas solicitada para fiestas',
    features: [
      'Buffet amplio de botanas y canapes',
      'Decoracion tematica personalizada',
      'Variedad de quesos y galletas',
      'Instalacion y coordinacion en sitio',
      'Asesoria de diseno previa',
      'Mejor equilibrio costo-beneficio'
    ],
    popular: true,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Barra de Botanas - Paquete Favorito'
  },
  {
    name: 'Luxury',
    icon: '💎',
    price: '$10,900',
    currency: 'MXN',
    guests: '100+ personas',
    tagline: 'Experiencia completa para bodas y celebraciones',
    features: [
      'Surtido delicioso de alto volumen',
      'Direccion estetica y decoracion total',
      'Catering con reposicion continua',
      'Configuracion para grandes fiestas',
      'Acompanamiento integral',
      'Canapes y botanas selectas'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Barra de Botanas - Paquete Luxury'
  }
];

const whyStats = [
  { number: '30+', label: 'Variedades de Botanas' },
  { number: '100%', label: 'Ingredientes Frescos' },
  { number: '500+', label: 'Fiestas Realizadas' },
  { number: '24h', label: 'Respuesta Rapida' }
];

const whyFeatures = [
  {
    num: 1,
    title: 'Botanas Deliciosas y Variadas',
    desc: 'Combinamos canapes, quesos, galletas y frutos secos para crear una barra de botanas que sorprende en fiestas y cumpleanos.',
    img: '/img/tipos-de-mesas/snacks/barra-de-snacks-para-eventos.avif'
  },
  {
    num: 2,
    title: 'Diseno Estilo Pinterest',
    desc: 'Decoracion con bandejas elegantes y presentacion visual que impresiona en bodas, baby showers y celebraciones.',
    img: '/img/tipos-de-mesas/snacks/barra-snacks-eventos-corporativos.avif'
  },
  {
    num: 3,
    title: 'Buffet para Cada Fiesta',
    desc: 'Armamos buffets de botanas adaptados a cumpleanos, bodas, reuniones familiares y fiestas tematicas en CDMX.',
    img: '/img/tipos-de-mesas/snacks/renta-barra-snacks-fiestas.avif'
  },
  {
    num: 4,
    title: 'Catering con Reposicion',
    desc: 'Nuestro catering incluye bandejas frescas durante toda tu fiesta para que tus invitados disfruten sin parar.',
    img: '/img/tipos-de-mesas/snacks/barra-de-snacks-para-eventos.avif'
  }
];

const processSteps = [
  { num: 1, title: 'Contactanos', desc: 'Platicanos sobre tu fiesta, boda o cumpleanos: fecha, lugar e invitados.' },
  { num: 2, title: 'Disenamos', desc: 'Creamos tu barra de botanas con canapes, quesos y la decoracion que imaginas.' },
  { num: 3, title: 'Confirmamos', desc: 'Cerramos propuesta, bandejas y logistica de catering para tu fiesta.' },
  { num: 4, title: 'Ejecutamos', desc: 'Instalamos tu buffet de botanas listo para disfrutar en tu celebracion.' }
];

const eventCards = [
  {
    title: 'Botanas para Bodas',
    excerpt: 'Barra de canapes y quesos elegante para recepciones nupciales. Decoracion deliciosa estilo Pinterest.',
    img: '/img/eventos/bodas/mesa-de-dulces-para-bodas.avif',
    href: '/candy-bar-eventos/mesa-dulces-boda',
    badge: 'Popular',
    cta: 'Ver Bodas'
  },
  {
    title: 'Botanas para Cumpleanos',
    excerpt: 'Buffet de botanas colorido para fiestas de cumpleanos. Bandejas con variedad deliciosa.',
    img: '/img/eventos/cumpleanos/mesa-de-dulces-para-cumpleanos.avif',
    href: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil',
    cta: 'Ver Cumpleanos'
  },
  {
    title: 'Botanas para XV Anos',
    excerpt: 'Barra de botanas tematica para quinceaneras. Complemento salado ideal para fiestas largas.',
    img: '/img/eventos/xv-anos/mesa-de-dulces-para-xv-anos.avif',
    href: '/candy-bar-eventos/mesa-dulces-xv-anos',
    cta: 'Ver XV Anos'
  },
  {
    title: 'Botanas para Fiestas',
    excerpt: 'Catering de botanas para graduaciones y reuniones familiares. Bandejas frescas y deliciosas.',
    img: '/img/eventos/graduaciones/mesa-dulces-graduacion.avif',
    href: '/candy-bar-eventos/mesa-dulces-graduacion',
    cta: 'Ver Fiestas'
  }
];

const serviceSchema = buildServiceSchema({
  name: 'Barra de Botanas para Fiestas y Bodas en CDMX',
  description: 'Buffet de botanas con canapes, quesos y bandejas decorativas para fiestas, bodas, cumpleanos y celebraciones. Renta con catering y decoracion tematica en Ciudad de Mexico.',
  offerPrefix: 'Barra de Botanas',
  packages,
  canonical: '/tipos-de-mesas-de-dulces/mesa-de-snacks'
});

---

<BaseLayout
  title="Barra de Botanas para Fiestas y Bodas en CDMX | Mededul"
  description="Buffet de botanas con canapes, quesos y bandejas decorativas para fiestas, bodas y cumpleanos. Renta con catering y decoracion estilo Pinterest en CDMX."
  canonical="/tipos-de-mesas-de-dulces/mesa-de-snacks"
  ogImage="/img/tipos-de-mesas/snacks/barra-de-snacks-para-eventos.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Barra de Botanas para Fiestas en CDMX"
    highlight="Barra de Botanas"
    subtitle="Canapes, quesos y bandejas deliciosas para bodas, cumpleanos y celebraciones"
    secondaryContent={`<p><strong>Botanas deliciosas</strong> como canapes, quesos, galletas y frutos secos transforman cualquier fiesta en una experiencia memorable. En Mededul armamos barras de botanas con bandejas elegantes y decoracion estilo Pinterest para bodas, cumpleanos, baby showers y reuniones familiares en Ciudad de Mexico.</p><p><strong>Buffet salado</strong> que complementa tu candy bar y mesa de dulces. Ofrecemos renta de barra con catering incluido para fiestas de varias horas. Combinamos variedad de quesos, canapes y botanas en presentaciones que impresionan a tus invitados en cualquier celebracion.</p>`}
  />

  <!-- ===================== Selector Sucursal Toluca (incoming SEO) ===================== -->
  <section style="padding: 50px 0; background: linear-gradient(135deg, #fffaf0 0%, #fff5e6 100%);">
    <div class="container">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 36px;">
        <span style="display: inline-block; background: linear-gradient(135deg, #e8851a 0%, #f5b800 100%); color: #1c1410; padding: 8px 22px; border-radius: 50px; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 16px;">Sucursal Especializada</span>
        <h2 style="font-size: 2rem; color: #1a1a1a; margin-bottom: 10px;">¿Evento en <span style="color: #e8851a; font-style: italic;">Valle de Toluca</span>?</h2>
        <p style="font-size: 1rem; color: #666; line-height: 1.7;">MEDEDUL opera una página exclusiva de <strong>Mesa de Snacks Premium para Sucursal Toluca-Metepec</strong> con curaduría especializada, mobiliario boutique multinivel, reposición continua para fiestas largas y cobertura completa Valle de Toluca.</p>
      </div>

      <a href="/sucursales/toluca/mesa-de-snacks" style="display: block; padding: 36px 32px; background: #fff; border-radius: 20px; border: 2px solid #e8851a; box-shadow: 0 12px 40px rgba(232, 133, 26, 0.18); text-decoration: none; color: inherit; max-width: 920px; margin: 0 auto;">
        <div style="display: flex; align-items: center; gap: 24px; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 280px;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
              <span style="font-size: 2rem;">🏞️</span>
              <strong style="color: #e8851a; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 2px;">Sucursal Toluca-Metepec</strong>
            </div>
            <h3 style="margin: 0 0 10px; font-size: 1.4rem; color: #1a1a1a;">Mesa de Snacks <span style="color: #D1007A;">Valle Toluca</span></h3>
            <p style="margin: 0 0 14px; color: #555; font-size: 0.95rem; line-height: 1.65;">Hub L4 con 30+ variedades curadas: salados premium (palomitas trufa, papas kettle-cooked, pretzels alemanes), frutos secos premium, dulces importados (Lindor, Haribo), sabores mexicanos (mazapanes de la Rosa, cacahuates japoneses) y opciones healthy (kale chips, edamame). Sucursal Blvd. Toluca-Metepec 913, cobertura Metepec, Toluca, Zinacantepec, Lerma, Ocoyoacac, Calimaya.</p>
            <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.88rem; color: #555;">
              <li style="padding: 4px 0;">✓ <strong>60+</strong> barras montadas Valle Toluca</li>
              <li style="padding: 4px 0;">✓ Hacienda La Magdalena Metepec, Quinta Real Toluca, parques industriales Lerma</li>
              <li style="padding: 4px 0;">✓ Desde <strong>$3,400 MXN</strong> · Luxury After-Party $9,600</li>
            </ul>
          </div>
          <span style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: linear-gradient(135deg, #e8851a 0%, #d6740a 100%); color: #fff; border-radius: 50px; font-weight: 600; white-space: nowrap;">
            Ver Mesa de Snacks Toluca
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <PricingPackages
    id="paquetes"
    badge="Paquetes para Fiestas"
    title="Escoge el"
    titleHighlight="Buffet Ideal"
    subtitle="Ajustamos canapes, quesos y decoracion de tu barra de botanas segun tu fiesta, boda o cumpleanos."
    packages={packages}
    note="<strong>Tienes ideas de Pinterest?</strong> Creamos una propuesta tematica con las botanas y decoracion que imaginas."
  />

  <WhyChooseUs
    id="ventajas"
    badge="Ideas y Ventajas"
    title="Por que elegir nuestra"
    titleHighlight="Barra de Botanas"
    descriptions={[
      'Buffet de botanas con canapes, quesos y bandejas decorativas para fiestas, bodas y cumpleanos en Ciudad de Mexico.',
      'Combinamos decoracion estilo Pinterest, catering con reposicion y variedad deliciosa para crear una experiencia que impresiona a tus invitados.'
    ]}
    stats={whyStats}
    features={whyFeatures}
  />

  <ProcessSteps
    id="proceso"
    badge="Asi Funciona"
    title="Como Armamos tu"
    titleHighlight="Barra de Botanas"
    subtitle="Cuatro pasos para disenar el buffet de botanas ideal para tu fiesta o boda."
    steps={processSteps}
  />

  <EventsGrid
    id="ocasiones"
    badge="Ideas para tu Fiesta"
    title="Barra de Botanas para"
    titleHighlight="Cada Celebracion"
    subtitle="Canapes, quesos y decoracion adaptados al estilo de tu cumpleanos, boda o fiesta."
    events={eventCards}
  />


    <FAQContactModule faqItems={faqs} />
</BaseLayout>
