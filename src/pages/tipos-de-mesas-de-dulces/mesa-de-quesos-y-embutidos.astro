---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import ProcessSteps from '@/components/global/ProcessSteps.astro';
import EventsGrid from '@/components/global/EventsGrid.astro';

import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { buildServiceSchema, buildFaqSchema } from '@/lib/schema';

const breadcrumbItems = [
  { name: 'Tipos de Mesas', url: '/tipos-de-mesas-de-dulces' },
  { name: 'Quesos y Embutidos', url: '/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos' }
];

const faqs = [
  {
    question: 'Que quesos incluye una tabla de quesos para fiestas?',
    answer: 'Nuestra tabla incluye manchego espanol, brie frances, queso de cabra, chihuahua mexicano y monterrey. Seleccionamos variedades de alta calidad con diferentes texturas y sabores para sorprender a tus amigos y familiares.'
  },
  {
    question: 'Que embutidos y carnes frias ofrecen?',
    answer: 'Ofrecemos jamon serrano de Espana, chorizo de pamplona, salami italiano y carnes frias artesanales. Cada pieza es fresca y de alta calidad, ideal para acompanar con vino tinto o blanco.'
  },
  {
    question: 'Incluyen acompanamientos como pan y frutas?',
    answer: 'Si, nuestras tablas incluyen baguette artesanal, galletas, fresas frescas, higos, frutos secos y mermeladas de temporada. Creamos una botana completa y deliciosa para tu fiesta o reunion.'
  },
  {
    question: 'Sirve para bodas y reuniones familiares?',
    answer: 'Si, es la opcion perfecta para bodas elegantes, reuniones con amigos, fiestas familiares y celebraciones sociales. Facil de disfrutar mientras tus invitados descubren sabores ricos y variados.'
  },
  {
    question: 'Ofrecen maridaje con vinos?',
    answer: 'Si, recomendamos combinaciones de quesos con vino tinto para manchego y queso de cabra, y vino blanco para brie y quesos cremosos. Te asesoramos para crear la experiencia perfecta.'
  },
  {
    question: 'Como preparan y arman la tabla?',
    answer: 'Preparamos cada ingrediente con atencion al detalle: cortamos quesos, disponemos carnes frias con color y textura, y armamos una presentacion elegante que impresiona. Todo listo para tu celebracion en CDMX.'
  }
];

const packages = [
  {
    name: 'Esencial',
    icon: '🧀',
    price: '$5,200',
    currency: 'MXN',
    guests: '30-50 personas',
    tagline: 'Ideal para fiestas y reuniones intimas',
    features: [
      'Tabla con manchego, brie y queso de cabra',
      'Jamon serrano y salami incluidos',
      'Pan baguette, galletas y frutos',
      'Presentacion elegante con color',
      'Desmontaje al finalizar'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Tabla de Quesos - Paquete Esencial'
  },
  {
    name: 'Favorito',
    icon: '⭐',
    price: '$8,900',
    currency: 'MXN',
    guests: '50-100 personas',
    tagline: 'La opcion mas solicitada para fiestas',
    features: [
      'Tabla amplia con chihuahua y monterrey',
      'Chorizo de pamplona y carnes frias',
      'Fresas, higos y acompanamientos de temporada',
      'Instalacion y coordinacion en sitio',
      'Asesoria de maridaje con vinos',
      'Mejor equilibrio costo-beneficio'
    ],
    popular: true,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Tabla de Quesos - Paquete Favorito'
  },
  {
    name: 'Luxury',
    icon: '💎',
    price: '$13,900',
    currency: 'MXN',
    guests: '100+ personas',
    tagline: 'Experiencia completa para bodas y celebraciones',
    features: [
      'Seleccion de alta calidad ampliada',
      'Quesos de Espana y Francia',
      'Jamon serrano y chorizo artesanal',
      'Operacion en sitio extendida',
      'Configuracion para grandes reuniones',
      'Ingredientes frescos y de temporada'
    ],
    popular: false,
    ctaText: 'Cotizar Paquete',
    ctaUrl: 'https://wa.me/525525226442?text=Hola! Quiero cotizar Tabla de Quesos - Paquete Luxury'
  }
];

const whyStats = [
  { number: '20+', label: 'Variedades de Quesos' },
  { number: '100%', label: 'Ingredientes Frescos' },
  { number: '500+', label: 'Fiestas Realizadas' },
  { number: '24h', label: 'Respuesta Rapida' }
];

const whyFeatures = [
  {
    num: 1,
    title: 'Quesos de Alta Calidad',
    desc: 'Seleccionamos manchego, brie, cabra, chihuahua y monterrey con sabores ricos y texturas variadas para tu fiesta.',
    img: '/img/tipos-de-mesas/quesos-embutidos/renta-de-mesa-de-quesos.avif'
  },
  {
    num: 2,
    title: 'Jamon Serrano y Carnes Frias',
    desc: 'Incluimos jamon de Espana, chorizo de pamplona y salami italiano. Botana deliciosa que sorprende a amigos y familiares.',
    img: '/img/tipos-de-mesas/quesos-embutidos/tabla-quesos-embutidos-gourmet.avif'
  },
  {
    num: 3,
    title: 'Acompanamientos Frescos',
    desc: 'Fresas, higos, baguette, galletas y frutos de temporada. Todo listo para acompanar con vino tinto o blanco.',
    img: '/img/tipos-de-mesas/quesos-embutidos/tabla-quesos-carnes-frias-eventos.avif'
  },
  {
    num: 4,
    title: 'Tablas que Impresionan',
    desc: 'Armamos cada tabla con atencion al detalle, color y presentacion elegante para reuniones familiares y celebraciones.',
    img: '/img/tipos-de-mesas/quesos-embutidos/renta-de-mesa-de-quesos.avif'
  }
];

const processSteps = [
  { num: 1, title: 'Contactanos', desc: 'Platicanos sobre tu fiesta, boda o reunion: fecha, lugar e invitados.' },
  { num: 2, title: 'Disenamos', desc: 'Seleccionamos quesos, carnes frias y acompanamientos frescos para tu tabla.' },
  { num: 3, title: 'Confirmamos', desc: 'Cerramos propuesta, opciones de vino y detalles de preparacion.' },
  { num: 4, title: 'Ejecutamos', desc: 'Armamos tu tabla de quesos lista para compartir con amigos y familiares.' }
];

const eventCards = [
  {
    title: 'Tabla de Quesos para Bodas',
    excerpt: 'Manchego, brie y jamon serrano para recepciones elegantes. Rico maridaje con vino tinto.',
    img: '/img/eventos/bodas/mesa-de-dulces-para-bodas.avif',
    href: '/candy-bar-eventos/mesa-dulces-boda',
    badge: 'Popular',
    cta: 'Ver Bodas'
  },
  {
    title: 'Tabla para Reuniones Corporativas',
    excerpt: 'Seleccion de alta calidad con chorizo, salami y quesos de Espana. Ideal para networking.',
    img: '/img/eventos/corporativos/candy-bar-empresarial.avif',
    href: '/candy-bar-eventos/mesa-dulces-corporativos',
    badge: 'Corporativo',
    cta: 'Ver Corporativos'
  },
  {
    title: 'Tabla para Fiestas Familiares',
    excerpt: 'Quesos mexicanos con chihuahua y monterrey. Botana facil de compartir con amigos.',
    img: '/img/tipos-de-mesas/quesos-embutidos/tabla-quesos-carnes-frias-eventos.avif',
    href: '/servicios',
    cta: 'Ver Opciones'
  },
  {
    title: 'Tabla para Celebraciones',
    excerpt: 'Fresas, higos, baguette y carnes frias para reuniones especiales. Sorprende a tus invitados.',
    img: '/img/eventos/graduaciones/mesa-dulces-graduacion.avif',
    href: '/candy-bar-eventos/mesa-dulces-graduacion',
    cta: 'Ver Ideas'
  }
];

const serviceSchema = buildServiceSchema({
  name: 'Tabla de Quesos y Carnes Frias para Fiestas en CDMX',
  description: 'Tablas de quesos con manchego, brie, jamon serrano y carnes frias para fiestas, bodas y reuniones familiares. Incluye vino, fresas, higos y baguette en Ciudad de Mexico.',
  offerPrefix: 'Tabla de Quesos',
  packages
});

const faqSchema = buildFaqSchema(faqs);
---

<BaseLayout
  title="Tabla de Quesos y Carnes Frias para Fiestas en CDMX | Mededul"
  description="Tablas de quesos con manchego, brie, jamon serrano y carnes frias para fiestas y bodas. Incluye vino, fresas, higos y baguette. Reuniones familiares en CDMX."
  canonical="/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos"
  ogImage="/img/tipos-de-mesas/quesos-embutidos/renta-de-mesa-de-quesos.avif"
  includeCategoryStyles={true}
>
  <JsonLd type="Service" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Tabla de Quesos y Carnes Frias para Fiestas en CDMX"
    highlight="Tabla de Quesos"
    subtitle="Manchego, brie, jamon serrano y acompanamientos deliciosos para bodas, reuniones y celebraciones"
    secondaryContent={`<p><strong>Quesos de alta calidad</strong> como manchego espanol, brie frances, queso de cabra, chihuahua y monterrey mexicano transforman cualquier fiesta en una experiencia rica y memorable. En Mededul armamos tablas de quesos con ingredientes frescos que sorprenden a amigos y familiares en Ciudad de Mexico.</p><p><strong>Carnes frias</strong> como jamon serrano de Espana, chorizo de pamplona y salami italiano, acompanados de fresas, higos, baguette y galletas. Creamos la botana perfecta para acompanar con vino tinto o blanco en reuniones familiares, bodas y celebraciones sociales. Facil de disfrutar y descubrir nuevos sabores.</p>`}
  />

  <!-- ===================== Selector Sucursal: CDMX + Toluca ===================== -->
  <section style="padding: 50px 0; background: linear-gradient(135deg, #fefbf6 0%, #fff5e6 100%);">
    <div class="container">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 36px;">
        <span style="display: inline-block; background: linear-gradient(135deg, #a87a3c 0%, #d4a766 100%); color: #1c1814; padding: 8px 22px; border-radius: 50px; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 16px;">Elige tu Sucursal MEDEDUL</span>
        <h2 style="font-size: 2rem; color: #1a1a1a; margin-bottom: 10px;">Tabla Gourmet por <span style="color: #a87a3c; font-style: italic;">Sucursal Especializada</span></h2>
        <p style="font-size: 1rem; color: #666; line-height: 1.7;">MEDEDUL opera dos sucursales boutique con páginas exclusivas para Tabla Gourmet de Quesos D.O.P. y Charcutería Reserva. Cada una con cobertura local, maestro cortador certificado y carta de affineur personalizada.</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;">
        <!-- Card Sucursal CDMX -->
        <a href="/sucursales/cdmx/mesa-de-quesos-y-embutidos" style="display: block; padding: 32px 28px; background: #fff; border-radius: 20px; border: 2px solid #a87a3c; box-shadow: 0 10px 40px rgba(168, 122, 60, 0.15); text-decoration: none; color: inherit; transition: transform 0.25s ease, box-shadow 0.25s ease;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 2rem;">🏙️</span>
            <strong style="color: #a87a3c; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 2px;">Sucursales Anzures + Condesa</strong>
          </div>
          <h3 style="margin: 0 0 12px; font-size: 1.4rem; color: #1a1a1a;">Tabla Gourmet <span style="color: #D1007A;">CDMX</span></h3>
          <p style="margin: 0 0 16px; color: #555; font-size: 0.95rem; line-height: 1.65;">12 quesos europeos D.O.P. (Brie Meaux, Manchego, Parmigiano 24m, Roquefort, Gouda añejo 4a, Comté, Gruyère, Stilton) + 12 charcuterías reserva (Ibérico Bellota 5J 36m, Prosciutto Parma DOP, Bresaola, Speck Alto Adige). Cobertura 16 alcaldías CDMX: Polanco, Lomas, Santa Fe, Roma, Coyoacán, Pedregal.</p>
          <ul style="list-style: none; padding: 0; margin: 0 0 18px; font-size: 0.88rem; color: #555;">
            <li style="padding: 4px 0;">✓ <strong>180+</strong> tablas montadas en CDMX</li>
            <li style="padding: 4px 0;">✓ Hotel W, St. Regis, Four Seasons, Hacienda Morales</li>
            <li style="padding: 4px 0;">✓ Desde <strong>$7,500 MXN</strong> · Atelier $22,500</li>
          </ul>
          <span style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg, #a87a3c 0%, #8b6230 100%); color: #fff; border-radius: 50px; font-weight: 600; font-size: 0.95rem;">
            Ver Tabla Gourmet CDMX
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </span>
        </a>

        <!-- Card Sucursal Toluca -->
        <a href="/sucursales/toluca/mesa-de-quesos-y-embutidos" style="display: block; padding: 32px 28px; background: #fff; border-radius: 20px; border: 2px solid #7d2438; box-shadow: 0 10px 40px rgba(125, 36, 56, 0.15); text-decoration: none; color: inherit; transition: transform 0.25s ease, box-shadow 0.25s ease;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 2rem;">🏞️</span>
            <strong style="color: #7d2438; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 2px;">Sucursal Toluca-Metepec</strong>
          </div>
          <h3 style="margin: 0 0 12px; font-size: 1.4rem; color: #1a1a1a;">Tabla Gourmet <span style="color: #D1007A;">Valle Toluca</span></h3>
          <p style="margin: 0 0 16px; color: #555; font-size: 0.95rem; line-height: 1.65;">Hub L4 + 3 L5 dedicadas: Quesos Europeos D.O.P. (Affineur 6/9/12), Jamones Curados (Cortador 6/9/Ibérico 5J), Tabla Mixta Premium (Mixta 8/14/Atelier 20). Cobertura completa Valle Toluca: Metepec, Toluca, Zinacantepec, Lerma, Ocoyoacac, San Mateo, Calimaya.</p>
          <ul style="list-style: none; padding: 0; margin: 0 0 18px; font-size: 0.88rem; color: #555;">
            <li style="padding: 4px 0;">✓ <strong>70+</strong> tablas montadas Valle Toluca</li>
            <li style="padding: 4px 0;">✓ Hacienda La Magdalena, Quinta Real Toluca, Real de Minas</li>
            <li style="padding: 4px 0;">✓ Desde <strong>$5,800 MXN</strong> · Atelier $25,400</li>
          </ul>
          <span style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg, #7d2438 0%, #5d1a2a 100%); color: #fff; border-radius: 50px; font-weight: 600; font-size: 0.95rem;">
            Ver Tabla Gourmet Toluca
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </span>
        </a>
      </div>

      <!-- Sub-cards L5 Toluca (deep links SEO) -->
      <div style="margin-top: 32px; padding: 24px 28px; background: #fff; border-radius: 16px; border: 1px solid rgba(168, 122, 60, 0.18);">
        <p style="margin: 0 0 14px; font-size: 0.92rem; color: #666; text-align: center;"><strong style="color: #7d2438;">¿Buscas una especialidad concreta?</strong> Subsecciones dedicadas Sucursal Toluca:</p>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
          <a href="/sucursales/toluca/mesa-de-quesos-y-embutidos/quesos-europeos" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; background: #fefbf6; color: #a87a3c; border: 1px solid rgba(168, 122, 60, 0.3); border-radius: 50px; font-size: 0.85rem; font-weight: 600; text-decoration: none;">🧀 Quesos Europeos D.O.P. Toluca</a>
          <a href="/sucursales/toluca/mesa-de-quesos-y-embutidos/jamones-curados" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; background: #fdf6f7; color: #7d2438; border: 1px solid rgba(125, 36, 56, 0.3); border-radius: 50px; font-size: 0.85rem; font-weight: 600; text-decoration: none;">🥓 Jamones Curados Toluca</a>
          <a href="/sucursales/toluca/mesa-de-quesos-y-embutidos/tabla-mixta-premium" style="display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; background: linear-gradient(135deg, #fefbf6 0%, #fdf6f7 100%); color: #1a1a1a; border: 1px solid rgba(168, 122, 60, 0.3); border-radius: 50px; font-size: 0.85rem; font-weight: 600; text-decoration: none;">⭐ Tabla Mixta Premium Toluca</a>
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes"
    badge="Paquetes para Fiestas"
    title="Escoge la"
    titleHighlight="Tabla Ideal"
    subtitle="Ajustamos quesos, carnes frias y acompanamientos segun tu fiesta, boda o reunion familiar."
    packages={packages}
    note="<strong>Tienes una muestra especifica en mente?</strong> Creamos una tabla personalizada con los ingredientes que prefieras."
  />

  <WhyChooseUs
    id="ventajas"
    badge="Ideas y Ventajas"
    title="Por que elegir nuestra"
    titleHighlight="Tabla de Quesos"
    descriptions={[
      'Tablas con manchego, brie, jamon serrano y carnes frias de alta calidad que sorprenden a amigos y familiares en fiestas y reuniones.',
      'Combinamos quesos de Espana y Mexico, fresas, higos, baguette y galletas con opciones de vino tinto y blanco para una botana deliciosa.'
    ]}
    stats={whyStats}
    features={whyFeatures}
  />

  <ProcessSteps
    id="proceso"
    badge="Asi Funciona"
    title="Como Armamos tu"
    titleHighlight="Tabla de Quesos"
    subtitle="Cuatro pasos para preparar la tabla perfecta de quesos y carnes frias para tu fiesta."
    steps={processSteps}
  />

  <EventsGrid
    id="ocasiones"
    badge="Ideas para tu Fiesta"
    title="Tabla de Quesos para"
    titleHighlight="Cada Ocasion"
    subtitle="Manchego, brie, jamon y acompanamientos adaptados para bodas, reuniones familiares y fiestas sociales."
    events={eventCards}
  />


    <FAQContactModule faqItems={faqs} />
</BaseLayout>
