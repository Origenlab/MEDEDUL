    desc: 'Nuestra sucursal Toluca-Metepec está a 20 minutos de Zinacantepec. Tiempos de respuesta y montaje optimizados.',
    img: '/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif'
  },
  {
    num: 2,
    title: 'Estilo Hacienda y Campestre',
    desc: 'Especialistas en estilos hacienda, campestre y rústico-elegante, perfectos para los venues característicos de Zinacantepec.',
    img: '/img/galeria/mesa-dulces-mexicanos-tradicionales-exterior.avif'
  },
  {
