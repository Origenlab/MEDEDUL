const zinacantepecSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Zinacantepec",
  "description": "Servicio profesional de mesas de dulces, candy bar y estaciones interactivas para bodas, XV años, baby shower y eventos en Zinacantepec, Estado de México. Cobertura completa desde nuestra sucursal Metepec.",
  "url": "https://mesas-de-dulces.com/mesas-de-dulces-zinacantepec",
  "telephone": "+525525226442",
  "priceRange": "$5,500 - $13,500 MXN",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Blvd. Toluca-Metepec 913",
    "addressLocality": "San Jorge Pueblo Nuevo, Metepec",
    "addressRegion": "Estado de México",
    "postalCode": "52169",
    "addressCountry": "MX"
  },
  "areaServed": [
    { "@type": "City", "name": "Zinacantepec" },
    { "@type": "Place", "name": "San Pedro Tejalpa, Zinacantepec" },
    { "@type": "Place", "name": "San Antonio Acahualco, Zinacantepec" },
    { "@type": "Place", "name": "San Cristóbal, Zinacantepec" },
    { "@type": "Place", "name": "La Soledad, Zinacantepec" }
  ]
};
---

<BaseLayout
  title="Mesas de Dulces en Zinacantepec | Sucursal Metepec | Mededul"
  description="Mesas de dulces premium en Zinacantepec, Estado de México. Bodas, XV años, baby shower y eventos en haciendas y salones locales. Cobertura completa desde sucursal Metepec. Cotización gratis."
  canonical="/mesas-de-dulces-zinacantepec"
  ogImage="/img/galeria/mesa-dulces-mexicanos-tradicionales-exterior.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(zinacantepecSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Zinacantepec, EdoMex"
    highlight="Zinacantepec"
    subtitle="Servicio premium desde sucursal Metepec · Cobertura completa al pie del Nevado"
    secondaryContent={`<p><strong>Mededul</strong> atiende todo el municipio de <strong>San Miguel Zinacantepec</strong> desde nuestra <a href="/sucursales/toluca"><strong>sucursal Toluca-Metepec (Blvd. Toluca-Metepec 913)</strong></a>. Servicio profesional para bodas, XV años, baby shower y eventos en haciendas, salones y jardines locales.</p><p>Conocemos los venues clásicos de la región: Hacienda San Pedro Tejalpa, Quinta San Antonio Acahualco, salones familiares y jardines campestres. Diseñamos <strong>mesas de dulces a la altura</strong> con dulces premium, montaje impecable y traslado incluido. <a href="/sucursales/toluca">Ver sucursal Toluca-Metepec →</a></p>`}
  />

  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Venues donde hemos <span>trabajado</span></h2>
        <p>Haciendas, jardines y salones de Zinacantepec</p>
        <div class="venues-grid">
          {venuesZinacantepec.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--rosa-principal)">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-zinacantepec"
    badge="Paquetes para Zinacantepec"
    title="Servicios para"
    titleHighlight="Zinacantepec"
    subtitle="Paquetes adaptados a bodas, XV años y eventos familiares"
    packages={paquetesZinacantepec}
    note="💡 <strong>Traslado desde Metepec incluido</strong> en paquetes Premium y Luxury. Cobertura completa al municipio."
  />

  <WhyChooseUs
    id="ventajas-zinacantepec"
    badge="Servicio en Zinacantepec"
    title="Por qué confiar en"
    titleHighlight="Mededul"
    descriptions={[
      'Nuestra sucursal Metepec nos permite atender Zinacantepec con la misma calidad y profesionalismo que en CDMX. Mismo equipo, mismos estándares.',
      'Especialistas en estilos hacienda, campestre y rústico-elegante, característicos de los venues de Zinacantepec y su entorno.'
    ]}
    stats={[
      { number: '12+', label: 'Eventos en Zinacantepec' },
      { number: '5.0', label: 'Calificación' },
      { number: '20 min', label: 'Desde sucursal' },
      { number: '100%', label: 'Traslado incluido' }
    ]}
    features={caracteristicasZinacantepec}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Zinacantepec"
        subtitle="Lo que dicen nuestros clientes del municipio"
      />
      <div class="testimonios-grid">
        {testimoniosZinacantepec.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsZinacantepec} />
</BaseLayout>

<style>
  .venues-section { padding: 60px 0; background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%); }
  .venues-content { text-align: center; color: #fff; }
  .venues-content h2 { font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 700; margin: 0 0 12px; }
  .venues-content h2 span { color: rgba(255,255,255,0.8); }
  .venues-content > p { font-size: 1rem; opacity: 0.85; margin: 0 0 40px; }
  .venues-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; }
  .venue-item {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 500;
  }
  .venue-item svg { fill: #FFB800; }

  .testimonios-section { padding: 80px 0; background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%); }
  .testimonios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 50px; }

  @media (max-width: 1024px) { .testimonios-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .venues-content h2 { font-size: 1.5rem; }
    .venues-grid { gap: 10px; }
    .venue-item { padding: 10px 16px; font-size: 0.8rem; }
    .testimonios-grid { grid-template-columns: 1fr; }
  }
</style>
