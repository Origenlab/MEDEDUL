---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import ProcessSteps from '@/components/global/ProcessSteps.astro';
import EventsGrid from '@/components/global/EventsGrid.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { porqueMededulPillars, type PqmPillar } from '@/data/porqueMededul';
import { buildServiceSchema, buildFaqSchema } from '@/lib/schema';

export function getStaticPaths() {
  return porqueMededulPillars.map((pillar) => ({
    params: { pilar: pillar.slug },
    props: { pillar }
  }));
}

const { pillar } = Astro.props as { pillar: PqmPillar };
const { meta, hero, why, faqs, packages } = pillar;

const breadcrumbItems = [
  { name: 'Por que Mededul', url: '/porque-mededul' },
  { name: pillar.breadcrumbName, url: `/porque-mededul/${pillar.slug}` }
];

const serviceSchema = buildServiceSchema({
  name: pillar.schema.name,
  description: pillar.schema.description,
  offerPrefix: pillar.schema.offerPrefix,
  packages,
  bestRating: '5'
});

const faqSchema = buildFaqSchema(faqs);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={`/porque-mededul/${pillar.slug}`}
  ogImage={meta.ogImage}
  includeCategoryStyles={true}
>
  <JsonLd type="Service" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} slot="head" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title={hero.title}
    highlight={hero.highlight}
    subtitle={hero.subtitle}
    secondaryContent={hero.secondaryContent}
  />

  <PricingPackages id="paquetes" badge="Paquetes Referenciales" title="Escoge el" titleHighlight="Formato Correcto" subtitle={pillar.pricingSubtitle} packages={packages} note="<strong>Necesitas otra configuracion?</strong> Creamos una propuesta personalizada para tu celebracion." />

  <WhyChooseUs id="ventajas" badge="Ventajas Diferenciales" title={why.title} titleHighlight={why.titleHighlight} descriptions={why.descriptions} stats={pillar.whyStats} features={pillar.whyFeatures} />

  <ProcessSteps id="proceso" badge="Nuestro Proceso" title="Como" titleHighlight="Trabajamos" subtitle={pillar.processSubtitle} steps={pillar.processSteps} />

  <EventsGrid id="eventos" badge="Valor Mededul" title="Conoce Otras" titleHighlight="Ventajas Diferenciales" subtitle={pillar.eventsSubtitle} events={pillar.eventCards} />


  <FAQContactModule faqItems={faqs} />
</BaseLayout>
