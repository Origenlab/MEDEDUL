---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import { todasLasDulcerias, getDulceriasPorAlcaldia } from '@/data/dulcerias';

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'CDMX', url: '/directorio/cdmx' }
];

// Calcular proveedores dinámicamente desde la base de datos
const alcaldiasConfig = [
  { nombre: 'Álvaro Obregón', slug: 'alvaro-obregon' },
  { nombre: 'Azcapotzalco', slug: 'azcapotzalco' },
  { nombre: 'Benito Juárez', slug: 'benito-juarez' },
  { nombre: 'Coyoacán', slug: 'coyoacan' },
  { nombre: 'Cuajimalpa', slug: 'cuajimalpa' },
  { nombre: 'Cuauhtémoc', slug: 'cuauhtemoc' },
  { nombre: 'Gustavo A. Madero', slug: 'gustavo-a-madero' },
  { nombre: 'Iztacalco', slug: 'iztacalco' },
  { nombre: 'Iztapalapa', slug: 'iztapalapa' },
  { nombre: 'La Magdalena Contreras', slug: 'magdalena-contreras' },
  { nombre: 'Miguel Hidalgo', slug: 'miguel-hidalgo' },
  { nombre: 'Milpa Alta', slug: 'milpa-alta' },
  { nombre: 'Tláhuac', slug: 'tlahuac' },
  { nombre: 'Tlalpan', slug: 'tlalpan' },
  { nombre: 'Venustiano Carranza', slug: 'venustiano-carranza' },
  { nombre: 'Xochimilco', slug: 'xochimilco' }
];

const alcaldias = alcaldiasConfig.map(a => ({
  ...a,
  proveedores: getDulceriasPorAlcaldia(a.slug).length
})).sort((a, b) => b.proveedores - a.proveedores);

const totalProveedores = todasLasDulcerias.length;
---

<BaseLayout
  title="Directorio de Dulces en CDMX | Proveedores por Alcaldia"
  description={`Encuentra proveedores de dulces para fiestas en todas las alcaldías de Ciudad de México. ${totalProveedores}+ negocios verificados.`}
  canonical="/directorio/cdmx"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Proveedores de Dulces en CDMX"
    highlight="CDMX"
    subtitle="Directorio por alcaldia y zona"
    secondaryContent={`<p>Encuentra proveedores de dulces para fiestas en <strong>las 16 alcaldias de Ciudad de Mexico</strong>. Dulcerias, chocolaterias, confiterias y tiendas especializadas cerca de ti.</p><p><strong>${totalProveedores}+ proveedores verificados</strong> en toda la CDMX.</p>`}
    showCTA={false}
  />

  <!-- Todas las Alcaldias -->
  <section class="alcaldias-section">
    <div class="container">
      <SectionHeader
        title="Todas las"
        titleHighlight="Alcaldias"
        subtitle="Explora proveedores en toda la Ciudad de Mexico"
      />
      <div class="alcaldias-grid">
        {alcaldias.map(alcaldia => (
          <a href={`/directorio/cdmx/${alcaldia.slug}`} class="alcaldia-card">
            <span class="alcaldia-nombre">{alcaldia.nombre}</span>
            <span class="alcaldia-count">{alcaldia.proveedores} proveedores</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-numero">{totalProveedores}+</span>
          <span class="stat-label">Proveedores en CDMX</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">16</span>
          <span class="stat-label">Alcaldias cubiertas</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">6</span>
          <span class="stat-label">Categorias</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">100%</span>
          <span class="stat-label">Verificados</span>
        </div>
      </div>
    </div>
  </section>

  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Busco%20proveedores%20de%20dulces%20en%20CDMX"
    badge="CDMX"
    title="¿Necesitas Ayuda para Encontrar"
    titleHighlight="Proveedor"
    text="Te ayudamos a encontrar el proveedor perfecto en tu zona de CDMX."
    buttonText="Pedir Recomendacion"
  />
</BaseLayout>

<style>
  .alcaldias-section {
    padding: 80px 0;
    background: #fff;
  }

  .alcaldias-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 50px;
  }

  .alcaldia-card {
    display: flex;
    flex-direction: column;
    padding: 20px 24px;
    background: #fafafa;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .alcaldia-card:hover {
    background: rgba(209, 0, 122, 0.08);
  }

  .alcaldia-nombre {
    font-weight: 600;
    color: var(--texto-oscuro);
    margin-bottom: 4px;
  }

  .alcaldia-count {
    font-size: 0.85rem;
    color: var(--rosa-principal);
  }

  .stats-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .stat-card {
    text-align: center;
    color: #fff;
  }

  .stat-numero {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.95rem;
    opacity: 0.85;
  }

  @media (max-width: 1024px) {
    .alcaldias-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .zonas-populares,
    .alcaldias-section {
      padding: 50px 0;
    }

    .alcaldias-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .stat-numero {
      font-size: 2rem;
    }
  }
</style>
