---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias.filter(d =>
  d.productos.some(p => p.toLowerCase().includes('chocolate')) ||
  d.especialidades.some(e => e.toLowerCase().includes('chocolate'))
).sort((a, b) => b.resenas - a.resenas);

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Chocolates y Trufas', url: '/directorio/categorias/chocolates-trufas' }
];

const faqs = [
  {
    question: '¿Dónde comprar chocolates al mayoreo en CDMX?',
    answer: `Tenemos ${dulcerias.length} dulcerías que ofrecen chocolates y trufas. Las mejores opciones al mayoreo están en La Merced y tiendas especializadas en distintas alcaldías.`
  },
  {
    question: '¿Qué tipos de chocolates encuentro en estas tiendas?',
    answer: 'Encontrarás chocolates nacionales e importados, trufas artesanales, bombones finos, chocolate belga, chocolate para fuentes, barras premium y más.'
  },
  {
    question: '¿Los chocolates sirven para mesas de dulces?',
    answer: 'Sí, los chocolates son imprescindibles en cualquier mesa de dulces. Trufas, bombones y barras de chocolate son de los productos más solicitados para eventos.'
  }
];
---

<BaseLayout
  title={`Chocolates y Trufas | ${dulcerias.length} Tiendas en CDMX`}
  description={`Encuentra las mejores tiendas de chocolates y trufas en CDMX. ${dulcerias.length} dulcerías verificadas con chocolates artesanales, importados y gourmet.`}
  canonical="/directorio/categorias/chocolates-trufas"
  ogImage="/img/galeria/dulces-gourmet-chocolate-belga-lujo.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Categoria Chocolates y Trufas Gourmet"
    highlight="Chocolates"
    subtitle={`${dulcerias.length} tiendas verificadas con chocolate belga, trufas artesanales y bombones finos en Ciudad de Mexico`}
    secondaryContent={`<p><strong>Categoria chocolates y trufas</strong> concentra a los proveedores mas especializados de Ciudad de Mexico en chocolate artesanal, trufas rellenas, bombones gourmet y tabletas de cobertura premium. Filtramos solo tiendas con resenas reales de Google Maps para que encuentres producto fresco, presentacion profesional y atencion capaz de resolver pedidos personalizados para eventos o regalos corporativos.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> te permiten comparar marcas, tipos de cacao, precios y ubicaciones antes de abastecer tu mesa de dulces, fuente de chocolate o empacar detalles personalizados. Cada registro incluye horario, telefono, especialidad y ficha tecnica para que decidas rapido y sin depender de listados genericos que no verifican la operacion real del negocio.</p>`}
  />

  <section class="categoria-listado">
    <div class="container">
      <SectionHeader
        title="Tiendas de"
        titleHighlight="Chocolates y Trufas"
        subtitle={`${dulcerias.length} tiendas verificadas en Google Maps`}
      />
      <div class="proveedores-grid">
        {dulcerias.map(prov => (
          <DulceriaCard dulceria={prov} />
        ))}
      </div>
      <div class="ver-directorio">
        <a href="/directorio" class="btn-directorio">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  .categoria-listado {
    padding: 80px 0;
    background: #fff;
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .ver-directorio {
    text-align: center;
    margin-top: 40px;
  }

  .btn-directorio {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #fff;
    border: 2px solid var(--rosa-principal);
    border-radius: 50px;
    color: var(--rosa-principal);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-directorio:hover {
    background: var(--rosa-principal);
    color: #fff;
  }

  @media (max-width: 1200px) {
    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria-listado,
    .faq-section {
      padding: 50px 0;
    }

    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
