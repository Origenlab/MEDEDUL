---
import CategoriaLayout from '@/components/directorio/CategoriaLayout.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias
  .filter(
    (d) =>
      d.tipo === 'Dulcería Tradicional' ||
      d.especialidades.some((e) => e.toLowerCase().includes('tradicional'))
  )
  .sort((a, b) => b.resenas - a.resenas);

const top3 = dulcerias.slice(0, 3);

const faqs = [
  {
    question: '¿Qué son los dulces tradicionales mexicanos?',
    answer: 'Dulces artesanales con recetas de generación en generación: alegrías, cocadas, mazapanes, tamarindos enchilados y de dulce, palanquetas de cacahuate o ajonjolí, borrachitos, obleas rellenas de cajeta, jamoncillos de leche, cubiertos de camote y calabaza, muéganos, charamuscas y glorias. Varían por región — Estado de México y Puebla son dos polos históricos.'
  },
  {
    question: '¿Dónde comprar dulces tradicionales al mayoreo en la zona metropolitana?',
    answer: `El directorio MEDEDUL reúne ${dulcerias.length} dulcerías con dulce tradicional mexicano. Las mejores opciones mayoristas están en La Merced (Venustiano Carranza, CDMX) y Norte 70 (Gustavo A. Madero). En Estado de México destacan mercados de Texcoco y Chalco; en Valle de Toluca hay artesanía mexiquense en centro de Toluca y Pueblo Mágico de Metepec.`
  },
  {
    question: '¿Los dulces tradicionales sirven para mesas de dulces?',
    answer: 'Son perfectos para mesas con temática mexicana: bodas rancheras, XV años con folklor, fiestas patrias, bautizos con concepto tradicional. Alegrías, cocadas, mazapanes y palanquetas acompañan frutas cristalizadas, aguas frescas y postres de convento. También ideales para bolos de recuerdo con estética artesanal.'
  },
  {
    question: '¿Cómo conservar dulces tradicionales si compro con anticipación?',
    answer: 'La mayoría aguanta 2–4 semanas en seco y fresco (alegrías, palanquetas, mazapanes). Cocadas y borrachitos pierden textura después de 10 días. Dulces con leche (jamoncillos, cajeta) prefieren refrigeración si el evento es en temporada cálida. Comprar 3–5 días antes del evento suele ser el punto dulce entre frescura y organización.'
  },
  {
    question: '¿Qué tiendas destacan en esta categoría?',
    answer: top3.length
      ? `Entre los más reseñados figuran ${top3.map((d) => d.nombre).join(', ')}. Cada ficha incluye dulces tradicionales específicos, precios por kilo o pieza y reseñas reales de Google Maps.`
      : 'Consulta el listado para comparar por región, rating y número de reseñas.'
  }
];
---

<CategoriaLayout
  categoriaNombre="Dulces Tradicionales"
  categoriaSlug="dulces-tradicionales"
  metaTitle={`Dulces Tradicionales Mexicanos | ${dulcerias.length} Tiendas Verificadas`}
  metaDescription={`Directorio verificado de ${dulcerias.length} dulcerías con dulces tradicionales mexicanos en CDMX, Edo Mex y Valle de Toluca. Alegrías, cocadas, mazapanes, palanquetas, borrachitos y jamoncillos artesanales con reseñas reales.`}
  heroTitle="Categoría Dulces Tradicionales Mexicanos"
  heroHighlight="Dulces Tradicionales"
  heroSubtitle={`${dulcerias.length} dulcerías verificadas con dulce típico mexicano artesanal en 3 regiones`}
  heroBody={`<p><strong>Categoría dulces tradicionales</strong> reúne a las dulcerías históricas del centro de México especializadas en alegrías, cocadas, mazapanes, tamarindos, palanquetas, borrachitos y dulce de leche. Son productos artesanales con recetas que pasan de generación en generación, ideales para mesas de dulces con temática mexicana, bodas rancheras, XV años con folklor y fiestas patrias.</p><p><strong>${dulcerias.length} dulcerías verificadas</strong> en CDMX, Estado de México y Valle de Toluca te permiten comparar precios por kilo, frescura y especialidad regional. Cada ficha incluye dirección, teléfono, horarios y reseñas reales de Google Maps para que compres directamente con productores o mayoristas sin intermediarios.</p>`}
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  dulcerias={dulcerias}
  faqs={faqs}
  sectionTitle="Dulcerías de"
  sectionHighlight="Dulces Tradicionales"
/>
