---
import CategoriaLayout from '@/components/directorio/CategoriaLayout.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias
  .filter(
    (d) =>
      d.especialidades.some((e) => e.toLowerCase().includes('importado')) ||
      d.productos.some((p) => p.toLowerCase().includes('importado'))
  )
  .sort((a, b) => b.resenas - a.resenas);

const top3 = dulcerias.slice(0, 3);

const faqs = [
  {
    question: '¿Dónde comprar dulces importados en CDMX, Edo Mex o Valle de Toluca?',
    answer: `El directorio MEDEDUL lista ${dulcerias.length} tiendas verificadas con dulces importados distribuidas en las tres regiones. Encontrarás dulces americanos, japoneses, coreanos y europeos. La Merced (CDMX) y Norte 70 (GAM) siguen siendo los polos mayoristas; en Edo Mex hay opciones en Naucalpan y Tlalnepantla; en Valle de Toluca destacan tiendas de Metepec premium.`
  },
  {
    question: '¿Qué marcas de dulces importados encuentro?',
    answer: "Haribo y Trolli (Alemania), Hi-Chew y Pocky (Japón), Kit Kat japonés, Reese's, Sour Patch Kids, Swedish Fish y Airheads (USA), chocolate belga Godiva y Callebaut, galletas Walkers (UK), y marcas coreanas como Lotte. La rotación depende de importadores y estacionalidad — conviene llamar antes de ir."
  },
  {
    question: '¿Los dulces importados son más caros que los nacionales?',
    answer: 'Sí — el ticket por pieza es 2 a 4 veces mayor que el dulce nacional equivalente, por tipo de cambio, aranceles y logística internacional. Para eventos grandes el truco es mezclar 20–30% importado (como diferenciador premium) con 70–80% nacional. Comprando al mayoreo en La Merced o Central de Abasto Tultitlán el margen mejora notablemente.'
  },
  {
    question: '¿Cómo verificar que los dulces importados son frescos?',
    answer: 'Revisa siempre la fecha de caducidad en la etiqueta original del fabricante — no la etiqueta de la tienda. Dulces japoneses y coreanos rotan rápido en tiendas especializadas; americanos y europeos suelen tener vida de anaquel más larga. Evita comprar empaques con puntos blancos (chocolate "quemado" por temperatura) o con sellos rotos.'
  },
  {
    question: '¿Qué tiendas destacan en esta categoría?',
    answer: top3.length
      ? `Entre los más reseñados figuran ${top3.map((d) => d.nombre).join(', ')}. Cada ficha incluye productos importados específicos, horarios verificados y reseñas reales de Google Maps.`
      : 'Consulta el listado para comparar por región, rating y número de reseñas.'
  }
];
---

<CategoriaLayout
  categoriaNombre="Dulces Importados"
  categoriaSlug="dulces-importados"
  metaTitle={`Dulces Importados | ${dulcerias.length} Tiendas en CDMX, Edo Mex y Valle de Toluca`}
  metaDescription={`Directorio verificado de ${dulcerias.length} tiendas de dulces importados en CDMX, Estado de México y Valle de Toluca. Haribo, Hi-Chew, Kit Kat japonés, Reese's, Sour Patch y más marcas de USA, Japón, Corea y Europa.`}
  heroTitle="Categoría Dulces Importados Premium"
  heroHighlight="Dulces Importados"
  heroSubtitle={`${dulcerias.length} tiendas verificadas con dulces americanos, japoneses, coreanos y europeos en 3 regiones`}
  heroBody={`<p><strong>Categoría dulces importados</strong> agrupa tiendas especializadas en golosinas de USA, Japón, Corea y Europa: Haribo, Hi-Chew, Kit Kat japonés, Pocky, Reese's, Sour Patch, chocolate belga y galletas británicas. Filtramos solo proveedores con reseñas reales de Google Maps para que encuentres producto fresco, rotación activa y disponibilidad confiable para eventos y regalos.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> en las tres regiones te permiten comparar precios y disponibilidad antes de abastecer mesas de dulces temáticas, regalos corporativos o detalles para XV años con estética internacional. Cada registro incluye teléfono, horario, marcas clave y ficha técnica.</p>`}
  ogImage="/img/galeria/candy-bar-profesional-eventos.avif"
  dulcerias={dulcerias}
  faqs={faqs}
  sectionTitle="Tiendas de"
  sectionHighlight="Dulces Importados"
/>
