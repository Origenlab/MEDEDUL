---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias.filter(d =>
  d.especialidades.some(e => e.toLowerCase().includes('importado')) ||
  d.productos.some(p => p.toLowerCase().includes('importado'))
).sort((a, b) => b.resenas - a.resenas);

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Dulces Importados', url: '/directorio/categorias/dulces-importados' }
];

const faqs = [
  {
    question: '¿Dónde comprar dulces importados en CDMX?',
    answer: `Tenemos ${dulcerias.length} dulcerías con dulces importados verificadas en CDMX. Encontrarás dulces americanos, japoneses, coreanos y europeos.`
  },
  {
    question: '¿Qué marcas de dulces importados encuentro?',
    answer: 'Encontrarás marcas como Haribo, Trolli, Hi-Chew, Pocky, Kit Kat japonés, Reese\'s, Sour Patch, Swedish Fish y muchas marcas más de USA, Japón, Corea y Europa.'
  },
  {
    question: '¿Los dulces importados son más caros?',
    answer: 'Los dulces importados suelen tener un precio mayor que los nacionales, pero comprando al mayoreo puedes obtener mejores precios. Las tiendas en La Merced y Norte 70 tienen opciones competitivas.'
  }
];
---

<BaseLayout
  title={`Dulces Importados | ${dulcerias.length} Tiendas en CDMX`}
  description={`Encuentra tiendas de dulces importados en CDMX. ${dulcerias.length} dulcerías verificadas con dulces americanos, japoneses, coreanos y europeos.`}
  canonical="/directorio/categorias/dulces-importados"
  ogImage="/img/galeria/candy-bar-profesional-eventos.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Categoria Dulces Importados Premium"
    highlight="Importados"
    subtitle={`${dulcerias.length} tiendas verificadas con dulces americanos, japoneses, coreanos y europeos en Ciudad de Mexico`}
    secondaryContent={`<p><strong>Categoria dulces importados</strong> reune a las tiendas especializadas en producto americano, asiatico y europeo dentro de Ciudad de Mexico. Filtramos proveedores con catalogo estable de Hershey's, Reese's, Pocky, Hi-Chew, KitKat japones, Haribo aleman, Cadbury britanico y golosinas coreanas para que tu mesa de dulces tenga la variedad premium que los invitados reconocen y valoran como diferencial.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> te ayudan a comparar precios, marcas y disponibilidad real antes de comprar cajas completas para eventos, candy bars tematicos, regalos corporativos o packs personalizados. Cada registro incluye ubicacion, horario y especialidad confirmada para que planifiques pedidos al mayoreo o por pieza sin depender de listados genericos sin verificacion operativa.</p>`}
  />

  <section class="categoria-listado">
    <div class="container">
      <SectionHeader
        title="Tiendas de"
        titleHighlight="Dulces Importados"
        subtitle={`${dulcerias.length} tiendas verificadas en Google Maps`}
      />
      <div class="proveedores-grid">
        {dulcerias.map(prov => (
          <DulceriaCard dulceria={prov} />
        ))}
      </div>
      <div class="ver-directorio">
        <a href="/directorio" class="btn-directorio">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  .categoria-listado {
    padding: 80px 0;
    background: #fff;
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .ver-directorio {
    text-align: center;
    margin-top: 40px;
  }

  .btn-directorio {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #fff;
    border: 2px solid var(--rosa-principal);
    border-radius: 50px;
    color: var(--rosa-principal);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-directorio:hover {
    background: var(--rosa-principal);
    color: #fff;
  }

  @media (max-width: 1200px) {
    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria-listado,
    .faq-section {
      padding: 50px 0;
    }

    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
