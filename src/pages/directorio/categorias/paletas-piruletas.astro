---
import CategoriaLayout from '@/components/directorio/CategoriaLayout.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias
  .filter(
    (d) =>
      d.productos.some((p) => p.toLowerCase().includes('paleta')) ||
      d.especialidades.some((e) => e.toLowerCase().includes('paleta'))
  )
  .sort((a, b) => b.resenas - a.resenas);

const top3 = dulcerias.slice(0, 3);

const faqs = [
  {
    question: '¿Dónde comprar paletas al mayoreo en la zona metropolitana?',
    answer: `El directorio MEDEDUL lista ${dulcerias.length} dulcerías con paletas y piruletas en las tres regiones. Las mejores opciones mayoreo están en La Merced (CDMX) y Norte 70 (GAM). En Edo Mex destacan mayoristas de Tultitlán y Naucalpan; en Valle de Toluca hay mayoristas en 5 de Mayo y tiendas artesanales de Metepec para paletas de autor y cake pops personalizados.`
  },
  {
    question: '¿Qué tipos de paletas encuentro en el directorio?',
    answer: 'Paletas de caramelo (Vero, De la Rosa, Indy, Rockaleta), paletas enchiladas con chamoy y tajín, paletas de chocolate tipo chocoretas, piruletas artesanales con rayas de colores, cake pops personalizados, paletas de goma, paletas rellenas, Bon Bon Bum (importada de Colombia) y paletas heladas tipo Paletón.'
  },
  {
    question: '¿Las paletas son buena opción para mesas de dulces?',
    answer: 'Excelentes — funcionan como "estación visible" clavadas en espumas floral o bases decoradas, generan fotos muy vistosas y los invitados las toman fácilmente. Para bodas y XV años prefiere piruletas artesanales con colores pantone específicos; para fiestas infantiles paletas comerciales por costo; para eventos corporativos cake pops personalizados con logo.'
  },
  {
    question: '¿Cuántas paletas necesito para mi evento?',
    answer: 'Regla general: 1.5–2 paletas por invitado si son el dulce principal de una estación, o 0.5–1 por invitado si son complemento en mesa de dulces más amplia. Para 100 invitados: 150–200 paletas surtidas. Las piruletas artesanales/cake pops cuentan como 1 por invitado por su mayor tamaño y costo.'
  },
  {
    question: '¿Qué tiendas destacan en esta categoría?',
    answer: top3.length
      ? `Entre los más reseñados figuran ${top3.map((d) => d.nombre).join(', ')}. Cada ficha incluye variedad de paletas, precios por pieza o paquete, capacidad de personalización y reseñas reales de Google Maps.`
      : 'Consulta el listado para comparar por región, rating y número de reseñas.'
  }
];
---

<CategoriaLayout
  categoriaNombre="Paletas y Piruletas"
  categoriaSlug="paletas-piruletas"
  metaTitle={`Paletas y Piruletas | ${dulcerias.length} Tiendas en CDMX, Edo Mex y Valle de Toluca`}
  metaDescription={`Directorio verificado de ${dulcerias.length} tiendas de paletas, piruletas y cake pops en CDMX, Estado de México y Valle de Toluca. Paletas artesanales, enchiladas, de chocolate y personalizadas para eventos con reseñas reales.`}
  heroTitle="Categoría Paletas y Piruletas"
  heroHighlight="Paletas"
  heroSubtitle={`${dulcerias.length} tiendas verificadas con paletas artesanales, piruletas, cake pops y paletas enchiladas en 3 regiones`}
  heroBody={`<p><strong>Categoría paletas y piruletas</strong> concentra a las tiendas especializadas en paletas de caramelo, paletas enchiladas, piruletas artesanales con rayas de colores, cake pops personalizados y paletas de chocolate. Ideal para mesas de dulces tipo "estación visible" clavadas en base floral, fiestas infantiles, XV años con estética vibrante y eventos corporativos con paleta de marca.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> en CDMX, Estado de México y Valle de Toluca te permiten comparar variedad, precios por pieza y capacidad de personalización. Cada ficha incluye teléfono, horarios, tipos de paleta y reseñas reales de Google Maps.</p>`}
  ogImage="/img/eventos/cumpleanos/infantiles/candy-bar-infantil-colorido.avif"
  dulcerias={dulcerias}
  faqs={faqs}
  sectionTitle="Tiendas de"
  sectionHighlight="Paletas y Piruletas"
/>
