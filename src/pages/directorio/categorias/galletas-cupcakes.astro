---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias.filter(d =>
  d.productos.some(p => {
    const lower = p.toLowerCase();
    return lower.includes('galleta') || lower.includes('cupcake') || lower.includes('postre');
  }) ||
  d.tipo === 'Tienda de Golosinas Premium'
).sort((a, b) => b.resenas - a.resenas);

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Galletas y Cupcakes', url: '/directorio/categorias/galletas-cupcakes' }
];

const faqs = [
  {
    question: '¿Dónde comprar galletas decoradas en CDMX?',
    answer: `Tenemos ${dulcerias.length} tiendas que ofrecen galletas, cupcakes y productos premium. Muchas ofrecen opciones personalizadas para eventos.`
  },
  {
    question: '¿Qué tipos de galletas y cupcakes encuentro?',
    answer: 'Encontrarás galletas decoradas, cupcakes artesanales, galletas de mantequilla, brownies, cake pops, macarons y productos de repostería fina.'
  },
  {
    question: '¿Puedo pedir galletas personalizadas para mi evento?',
    answer: 'Sí, muchas tiendas premium ofrecen galletas decoradas y cupcakes personalizados con la temática de tu evento. Contacta directamente a cada tienda para conocer opciones.'
  }
];
---

<BaseLayout
  title={`Galletas y Cupcakes | ${dulcerias.length} Tiendas en CDMX`}
  description={`Encuentra tiendas de galletas decoradas y cupcakes en CDMX. ${dulcerias.length} tiendas verificadas con repostería artesanal y productos premium.`}
  canonical="/directorio/categorias/galletas-cupcakes"
  ogImage="/img/galeria/candy-bar-gourmet-elegante.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Categoria Galletas y Cupcakes Artesanales"
    highlight="Galletas"
    subtitle={`${dulcerias.length} tiendas verificadas con galletas decoradas, cupcakes personalizados y reposteria fina en Ciudad de Mexico`}
    secondaryContent={`<p><strong>Categoria galletas y cupcakes</strong> concentra a los obradores especializados en reposteria visual para eventos: galletas decoradas con royal icing, cupcakes con buttercream, macarons franceses, tartaletas individuales, cake pops y mini postres personalizados por tematica o paleta de color. Filtramos proveedores con experiencia demostrada, entrega puntual y presentacion profesional que aguanta el transporte y las horas de exhibicion.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> te permiten cotizar galleta por pieza, armar packs de cupcakes corporativos, coordinar reposteria para bodas, baby showers, XV anos o eventos empresariales. Cada registro muestra ubicacion, horario, especialidad y resenas reales en Google Maps para que decidas con datos y sin listados genericos que no verifican operacion ni calidad.</p>`}
  />

  <section class="categoria-listado">
    <div class="container">
      <SectionHeader
        title="Tiendas de"
        titleHighlight="Galletas y Cupcakes"
        subtitle={`${dulcerias.length} tiendas verificadas en Google Maps`}
      />
      <div class="proveedores-grid">
        {dulcerias.map(prov => (
          <DulceriaCard dulceria={prov} />
        ))}
      </div>
      <div class="ver-directorio">
        <a href="/directorio" class="btn-directorio">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  .categoria-listado {
    padding: 80px 0;
    background: #fff;
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .ver-directorio {
    text-align: center;
    margin-top: 40px;
  }

  .btn-directorio {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #fff;
    border: 2px solid var(--rosa-principal);
    border-radius: 50px;
    color: var(--rosa-principal);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-directorio:hover {
    background: var(--rosa-principal);
    color: #fff;
  }

  @media (max-width: 1200px) {
    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria-listado,
    .faq-section {
      padding: 50px 0;
    }

    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
