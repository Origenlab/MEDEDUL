---
import CategoriaLayout from '@/components/directorio/CategoriaLayout.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias
  .filter(
    (d) =>
      d.productos.some((p) => {
        const lower = p.toLowerCase();
        return lower.includes('galleta') || lower.includes('cupcake') || lower.includes('postre');
      }) ||
      d.tipo === 'Tienda de Golosinas Premium'
  )
  .sort((a, b) => b.resenas - a.resenas);

const top3 = dulcerias.slice(0, 3);

const faqs = [
  {
    question: '¿Dónde comprar galletas decoradas y cupcakes en la zona metropolitana?',
    answer: `El directorio MEDEDUL lista ${dulcerias.length} tiendas con galletas, cupcakes y repostería fina en las tres regiones. Las tiendas premium están concentradas en Polanco y Del Valle (CDMX), Galerías Metepec (Valle de Toluca) y zonas residenciales del Estado de México. La mayoría acepta pedidos personalizados con 48–72 horas de anticipación.`
  },
  {
    question: '¿Qué tipos de productos encuentro en esta categoría?',
    answer: 'Galletas decoradas con glasé real, cupcakes con buttercream o ganache, galletas de mantequilla en formas temáticas, brownies, cake pops, macarons franceses, tartaletas individuales, whoopie pies, pay de limón en vaso, tiramisú personal y cheesecake en formato minimal para mesa de postres.'
  },
  {
    question: '¿Puedo pedir galletas personalizadas para mi evento?',
    answer: 'Sí — la mayoría de tiendas premium trabaja sobre pedido con diseños personalizados: logo de empresa, iniciales de novios, personajes de fiesta infantil, colores pantone específicos para bodas y XV años. El tiempo mínimo suele ser 5–7 días para pedidos de 50+ piezas; 2–3 semanas para eventos con 200+ galletas decoradas. Pide siempre muestra antes de confirmar.'
  },
  {
    question: '¿Cuánto cuesta una galleta decorada o cupcake para evento?',
    answer: 'Rango típico: galleta decorada sencilla $25–45, galleta con glasé detallado $50–90, cupcake con topping básico $30–55, cupcake con figura fondant $70–120. Macarons franceses $35–60 por pieza. Pedidos de 100+ piezas suelen tener descuento escalonado. Estos precios reflejan tiendas premium; tiendas de barrio pueden estar 30–40% abajo.'
  },
  {
    question: '¿Qué tiendas destacan en esta categoría?',
    answer: top3.length
      ? `Entre los más reseñados figuran ${top3.map((d) => d.nombre).join(', ')}. Cada ficha incluye productos específicos, capacidad de pedido personalizado, tiempos de entrega y reseñas reales de Google Maps.`
      : 'Consulta el listado para comparar por región, rating y número de reseñas.'
  }
];
---

<CategoriaLayout
  categoriaNombre="Galletas y Cupcakes"
  categoriaSlug="galletas-cupcakes"
  metaTitle={`Galletas, Cupcakes y Repostería Fina | ${dulcerias.length} Tiendas Verificadas`}
  metaDescription={`Directorio verificado de ${dulcerias.length} tiendas de galletas decoradas, cupcakes, macarons y repostería fina en CDMX, Estado de México y Valle de Toluca. Pedidos personalizados para eventos con reseñas reales de Google Maps.`}
  heroTitle="Categoría Galletas, Cupcakes y Repostería Fina"
  heroHighlight="Galletas y Cupcakes"
  heroSubtitle={`${dulcerias.length} tiendas premium verificadas con galletas decoradas, cupcakes artesanales y macarons en 3 regiones`}
  heroBody={`<p><strong>Categoría galletas y cupcakes</strong> concentra a las tiendas premium de repostería fina de la zona metropolitana: galletas decoradas con glasé real, cupcakes con buttercream o fondant, macarons franceses, cake pops, brownies, tartaletas y postres individuales. Ideal para mesas de postres de bodas, XV años, baby showers y eventos corporativos con estética cuidada.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> en CDMX, Estado de México y Valle de Toluca te permiten comparar catálogos, tiempos de entrega, capacidad de personalización y precios por pieza. La mayoría acepta pedidos personalizados — pide siempre muestra y confirma tiempos 5–7 días antes del evento.</p>`}
  ogImage="/img/galeria/dulces-gourmet-chocolate-belga-lujo.avif"
  dulcerias={dulcerias}
  faqs={faqs}
  sectionTitle="Tiendas de"
  sectionHighlight="Galletas y Cupcakes"
/>
