---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias.filter(d =>
  d.productos.some(p => p.toLowerCase().includes('gomita')) ||
  d.especialidades.some(e => e.toLowerCase().includes('confitería') || e.toLowerCase().includes('gomita'))
).sort((a, b) => b.resenas - a.resenas);

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Gomitas y Confitería', url: '/directorio/categorias/gomitas-confiteria' }
];

const faqs = [
  {
    question: '¿Dónde comprar gomitas al mayoreo en CDMX?',
    answer: `Tenemos ${dulcerias.length} dulcerías con gomitas y confitería variada. Los mejores precios al mayoreo están en La Merced y el corredor de Norte 70.`
  },
  {
    question: '¿Qué tipos de gomitas encuentro?',
    answer: 'Encontrarás gomitas de azúcar, gomitas enchiladas, gomitas importadas, ositos de goma, gusanos, aros, gomitas ácidas y muchas variedades más.'
  },
  {
    question: '¿Las gomitas son populares para mesas de dulces?',
    answer: 'Sí, las gomitas son de los dulces más populares para mesas de dulces en fiestas infantiles y eventos. Su colorido las hace ideales para decoraciones temáticas.'
  }
];
---

<BaseLayout
  title={`Gomitas y Confitería | ${dulcerias.length} Tiendas en CDMX`}
  description={`Encuentra las mejores tiendas de gomitas y confitería en CDMX. ${dulcerias.length} dulcerías verificadas con gomitas importadas, enchiladas y más.`}
  canonical="/directorio/categorias/gomitas-confiteria"
  ogImage="/img/galeria/candy-bar-colorido-fiestas.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Categoria Gomitas y Confiteria Variada"
    highlight="Gomitas"
    subtitle={`${dulcerias.length} tiendas verificadas con gomitas importadas, dulces enchilados y confiteria mayoreo en Ciudad de Mexico`}
    secondaryContent={`<p><strong>Categoria gomitas y confiteria</strong> reune a las tiendas con mayor rotacion y variedad para mesas de dulces coloridas: gomitas acidas, gomitas enchiladas, rellenos de tamarindo, ositos Haribo, regaliz, malvaviscos, paletas cristal, dulces de leche, obleas y toda la confiteria clasica que nunca falta en un candy bar infantil o juvenil.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> te permiten comparar precios por kilo, por pieza y al mayoreo para abastecer eventos grandes, fiestas infantiles, XV anos tematicos o paquetes corporativos. Cada ficha incluye ubicacion exacta, horarios reales, telefono de contacto y especialidad confirmada mediante resenas publicas de Google Maps, evitando listados genericos sin operacion activa.</p>`}
  />

  <section class="categoria-listado">
    <div class="container">
      <SectionHeader
        title="Tiendas de"
        titleHighlight="Gomitas y Confitería"
        subtitle={`${dulcerias.length} tiendas verificadas en Google Maps`}
      />
      <div class="proveedores-grid">
        {dulcerias.map(prov => (
          <DulceriaCard dulceria={prov} />
        ))}
      </div>
      <div class="ver-directorio">
        <a href="/directorio" class="btn-directorio">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqs} />
</BaseLayout>

<style>
  .categoria-listado {
    padding: 80px 0;
    background: #fff;
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .ver-directorio {
    text-align: center;
    margin-top: 40px;
  }

  .btn-directorio {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #fff;
    border: 2px solid var(--rosa-principal);
    border-radius: 50px;
    color: var(--rosa-principal);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-directorio:hover {
    background: var(--rosa-principal);
    color: #fff;
  }

  @media (max-width: 1200px) {
    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categoria-listado,
    .faq-section {
      padding: 50px 0;
    }

    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
