---
import CategoriaLayout from '@/components/directorio/CategoriaLayout.astro';
import { todasLasDulcerias } from '@/data/dulcerias';

const dulcerias = todasLasDulcerias
  .filter(
    (d) =>
      d.productos.some((p) => p.toLowerCase().includes('gomita')) ||
      d.especialidades.some(
        (e) => e.toLowerCase().includes('confitería') || e.toLowerCase().includes('gomita')
      )
  )
  .sort((a, b) => b.resenas - a.resenas);

const top3 = dulcerias.slice(0, 3);

const faqs = [
  {
    question: '¿Dónde comprar gomitas al mayoreo en la zona metropolitana?',
    answer: `El directorio MEDEDUL lista ${dulcerias.length} dulcerías con gomitas y confitería variada en las tres regiones. Los mejores precios mayoreo están en La Merced (CDMX) y corredor Norte 70 (GAM). En Edo Mex destacan Central de Abasto Tultitlán y mayoristas de Naucalpan; en Valle de Toluca los mayoristas de 5 de Mayo ofrecen precios competitivos para eventos regionales.`
  },
  {
    question: '¿Qué tipos de gomitas encuentro en el directorio?',
    answer: 'Catálogo típico: gomitas de azúcar y sin azúcar, enchiladas (chamoy, tajín), importadas (Haribo, Trolli, Albanese), ositos de goma, gusanos, aros ácidos, serpientes, dientes, corazones, cereza, mango, sandía y combos surtidos. Muchas tiendas venden por kilo al mayoreo y por pieza al menudeo.'
  },
  {
    question: '¿Las gomitas son populares para mesas de dulces?',
    answer: 'Son de los dulces más versátiles para candy bar: colorido intenso, precio accesible por kilo, bajo riesgo de derretimiento, vida de anaquel larga y gustan a todas las edades. Ideales para fiestas infantiles, XV años, baby showers y eventos corporativos informales. Funcionan muy bien en frascos de vidrio transparente para potenciar el impacto visual.'
  },
  {
    question: '¿Cómo calcular cuántas gomitas necesito para mi evento?',
    answer: 'Regla general: 80–120 gramos por invitado en mesa de dulces con 6–8 variedades. Para eventos con 100 personas eso son 8–12 kg de gomitas surtidas. Si tu candy bar incluye chocolate, cupcakes y dulces tradicionales además de gomitas, baja a 40–60 gramos por invitado. Compra 15% extra como margen de seguridad.'
  },
  {
    question: '¿Qué tiendas destacan en esta categoría?',
    answer: top3.length
      ? `Entre los más reseñados figuran ${top3.map((d) => d.nombre).join(', ')}. Cada ficha incluye variedades de gomitas, precios por kilo, horarios verificados y reseñas reales de Google Maps.`
      : 'Consulta el listado para comparar por región, rating y número de reseñas.'
  }
];
---

<CategoriaLayout
  categoriaNombre="Gomitas y Confitería"
  categoriaSlug="gomitas-confiteria"
  metaTitle={`Gomitas y Confitería | ${dulcerias.length} Tiendas en CDMX, Edo Mex y Valle de Toluca`}
  metaDescription={`Directorio verificado de ${dulcerias.length} tiendas de gomitas y confitería en CDMX, Estado de México y Valle de Toluca. Gomitas importadas, enchiladas, ácidas, ositos y surtidos al mayoreo con reseñas reales.`}
  heroTitle="Categoría Gomitas y Confitería"
  heroHighlight="Gomitas"
  heroSubtitle={`${dulcerias.length} tiendas verificadas con gomitas importadas, enchiladas, ácidas y surtidos al mayoreo en 3 regiones`}
  heroBody={`<p><strong>Categoría gomitas y confitería</strong> concentra a las tiendas con mayor variedad de gomitas nacionales e importadas de la zona metropolitana: ositos Haribo, gusanos Trolli, gomitas enchiladas con chamoy y tajín, ácidas, mini-frutas, aros y combos surtidos. Ideal para mesas de dulces de fiestas infantiles, XV años, bodas informales y bolos de regalo con estética colorida.</p><p><strong>${dulcerias.length} tiendas verificadas</strong> en CDMX, Estado de México y Valle de Toluca te permiten comparar precios por kilo, variedad y disponibilidad antes de surtir tu evento. Cada ficha incluye teléfono, horarios, variedades clave y reseñas reales de Google Maps.</p>`}
  ogImage="/img/galeria/candy-bar-colorido-fiestas.avif"
  dulcerias={dulcerias}
  faqs={faqs}
  sectionTitle="Tiendas de"
  sectionHighlight="Gomitas y Confitería"
/>
