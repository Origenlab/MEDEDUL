---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Dulces Tradicionales', url: '/directorio/dulces-tradicionales' }
];

const proveedores = [
  {
    nombre: 'El Bofito Norte 70',
    slug: 'el-bofito-norte-70',
    descripcion: 'Una de las dulcerías más grandes y reconocidas en la zona de Bondojito. Amplio surtido de dulces mexicanos tradicionales y precios de mayoreo.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 5551 7733',
    imagen: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    rating: 4.3,
    resenas: 2947,
    verificado: true,
    destacado: true,
    especialidades: ['Dulces a granel', 'Mayoreo', 'Dulces mexicanos']
  },
  {
    nombre: 'Dulcería El Remate',
    slug: 'dulceria-el-remate',
    descripcion: 'Dulcería de mayoreo con más de 2,400 reseñas. Especializada en surtido amplio de dulces tradicionales mexicanos y artículos para fiestas.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 5551 6249',
    imagen: '/img/galeria/mesa-dulces-mexicanos-tradicionales-exterior.avif',
    rating: 4.4,
    resenas: 2410,
    verificado: true,
    destacado: true,
    especialidades: ['Mayoreo', 'Dulces tradicionales', 'Artículos para fiestas']
  },
  {
    nombre: 'Dulcería El Gordo',
    slug: 'dulceria-el-gordo',
    descripcion: 'Ubicada en el corazón del Mercado de Dulces La Merced, el centro histórico de distribución de dulces de la CDMX. Variedad de dulces mexicanos.',
    ubicacion: 'Mercado de Dulces La Merced',
    telefono: '55 5522 8007',
    imagen: '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif',
    rating: 4.3,
    resenas: 429,
    verificado: true,
    destacado: true,
    especialidades: ['Mercado La Merced', 'Dulces mexicanos', 'Mayoreo']
  },
  {
    nombre: 'Dulcería Guachitos',
    slug: 'dulceria-guachitos',
    descripcion: 'Dulcería popular en Iztapalapa con más de 600 reseñas. Amplio surtido de dulces tradicionales, botanas y artículos para piñatas.',
    ubicacion: 'La Esperanza, Iztapalapa',
    telefono: '55 5607 5406',
    imagen: '/img/galeria/candy-bar-infantil-colorido.avif',
    rating: 4.3,
    resenas: 628,
    verificado: true,
    destacado: true,
    especialidades: ['Dulces variados', 'Piñatas', 'Botanas']
  },
  {
    nombre: 'Dulcería Mixcoac',
    slug: 'dulceria-mixcoac',
    descripcion: 'Dulcería tradicional en la zona de Mixcoac. Más de 1,100 reseñas la respaldan como una opción confiable para dulces mexicanos y artículos para fiestas.',
    ubicacion: 'Mixcoac, Benito Juárez',
    telefono: '55 1518 0985',
    imagen: '/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif',
    rating: 4.3,
    resenas: 1135,
    verificado: true,
    destacado: true,
    especialidades: ['Dulces mexicanos', 'Artículos para fiestas', 'Confitería']
  },
  {
    nombre: 'Dulcería La 27',
    slug: 'dulceria-la-27',
    descripcion: 'Excelente opción en la zona de La Merced con rating de 4.6. Variedad de dulces tradicionales y precios accesibles.',
    ubicacion: 'La Merced, Venustiano Carranza',
    telefono: '55 5762 0736',
    imagen: '/img/galeria/candy-bar-gourmet-elegante.avif',
    rating: 4.6,
    resenas: 111,
    verificado: true,
    destacado: false,
    especialidades: ['Dulces tradicionales', 'Precios accesibles', 'Zona La Merced']
  }
];

const faqsCategoria = [
  {
    question: '¿Los dulces tradicionales son más económicos para eventos?',
    answer: 'Generalmente sí. Los dulces tradicionales mexicanos suelen ser más económicos que los importados, especialmente cuando compras en dulcerías de mayoreo como El Bofito o El Remate.'
  },
  {
    question: '¿Dónde puedo conseguir dulces tradicionales a mayoreo en CDMX?',
    answer: 'Las mejores zonas para comprar dulces a mayoreo son: El Mercado de Dulces La Merced (Dulcería El Gordo, La 27) y la zona de Bondojito en Gustavo A. Madero (El Bofito, El Remate).'
  },
  {
    question: '¿Qué dulces tradicionales son los más populares para fiestas?',
    answer: 'Los más solicitados son: mazapanes, cocadas, tamarindos, paletas de dulce, chicles, gomitas enchiladas y dulces de leche como glorias y jamoncillos.'
  },
  {
    question: '¿Puedo hacer pedidos grandes para mi evento?',
    answer: 'Sí, la mayoría de estas dulcerías ofrecen precios especiales para pedidos de mayoreo. Te recomendamos contactarlas directamente para cotizaciones de cantidades grandes.'
  }
];

const categoriaSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Proveedores de Dulces Tradicionales Mexicanos en CDMX",
  "description": "Directorio de tiendas de dulces tradicionales mexicanos verificadas en Ciudad de México",
  "numberOfItems": proveedores.length,
  "itemListElement": proveedores.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "description": p.descripcion,
      "telephone": `+52${p.telefono.replace(/\s/g, '')}`,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": p.rating,
        "reviewCount": p.resenas
      }
    }
  }))
};
---

<BaseLayout
  title="Dulces Tradicionales Mexicanos | Directorio CDMX 2025"
  description={`Encuentra ${proveedores.length} proveedores de dulces tradicionales mexicanos en CDMX. Mazapanes, cocadas, tamarindos y más. Precios de mayoreo.`}
  canonical="/directorio/dulces-tradicionales"
  ogImage="/img/galeria/mesa-dulces-mexicanos-tradicionales-exterior.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(categoriaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Dulces Tradicionales Mexicanos"
    highlight="Tradicionales"
    subtitle="Mazapanes, cocadas, tamarindos y más"
    secondaryContent={`<p>Descubre las mejores dulcerías de <strong>dulces tradicionales mexicanos</strong> en CDMX. Perfectos para mesas de dulces con esencia mexicana, fiestas patrias y eventos temáticos.</p><p><strong>${proveedores.length} dulcerías verificadas</strong> con información real de Google Maps.</p>`}
    showCTA={false}
  />

  <section class="filtros-section">
    <div class="container">
      <div class="filtros-wrapper">
        <div class="filtros-info">
          <span class="resultados-count">{proveedores.length} proveedores encontrados</span>
        </div>
        <div class="filtros-opciones">
          <select class="filtro-select">
            <option value="">Todas las zonas</option>
            <option value="gam">Gustavo A. Madero</option>
            <option value="merced">La Merced</option>
            <option value="iztapalapa">Iztapalapa</option>
            <option value="benito-juarez">Benito Juárez</option>
          </select>
          <select class="filtro-select">
            <option value="">Ordenar por</option>
            <option value="rating">Mejor calificados</option>
            <option value="resenas">Más reseñas</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <div class="directorio-layout">
    <div class="container">
      <div class="directorio-grid">
        <main class="directorio-main">
          <div class="proveedores-lista">
            {proveedores.map(prov => (
              <div class={`proveedor-item ${prov.destacado ? 'proveedor-item--destacado' : ''}`}>
                <div class="proveedor-imagen">
                  <img
                    src={getCdnUrl(prov.imagen, { w: 400, q: 80 })}
                    alt={prov.nombre}
                    loading="lazy"
                    width="400"
                    height="300"
                  />
                  {prov.destacado && <span class="badge-destacado">Destacado</span>}
                </div>
                <div class="proveedor-contenido">
                  <div class="proveedor-header">
                    <div>
                      <h2>{prov.nombre}</h2>
                      <div class="proveedor-ubicacion">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                          <circle cx="12" cy="10" r="3"/>
                        </svg>
                        {prov.ubicacion}
                      </div>
                    </div>
                    {prov.verificado && (
                      <span class="badge-verificado" title="Negocio verificado">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Verificado
                      </span>
                    )}
                  </div>

                  <p class="proveedor-descripcion">{prov.descripcion}</p>

                  <div class="proveedor-especialidades">
                    {prov.especialidades.map(esp => (
                      <span class="especialidad-tag">{esp}</span>
                    ))}
                  </div>

                  <div class="proveedor-footer">
                    <div class="proveedor-rating">
                      <div class="rating-stars">
                        {[1,2,3,4,5].map(star => (
                          <svg viewBox="0 0 24 24" fill={star <= Math.floor(prov.rating) ? "#FFB800" : "#E0E0E0"}>
                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                          </svg>
                        ))}
                      </div>
                      <span class="rating-numero">{prov.rating}</span>
                      <span class="rating-resenas">({prov.resenas.toLocaleString()} reseñas)</span>
                    </div>

                    <div class="proveedor-acciones">
                      <a href={`/directorio/${prov.slug}`} class="btn-perfil">Ver perfil</a>
                      <a href={`https://wa.me/52${prov.telefono.replace(/\s/g, '')}`} class="btn-whatsapp" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                        </svg>
                        Contactar
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </main>

        <DirectorioSidebar currentSlug="dulces-tradicionales" showCategorias={true} />
      </div>
    </div>
  </div>

  <section class="otras-categorias">
    <div class="container">
      <SectionHeader
        title="Explora Otras"
        titleHighlight="Categorías"
        subtitle="Más opciones para tu evento"
      />
      <div class="categorias-grid">
        <a href="/directorio/chocolates-trufas" class="cat-link">
          <span class="cat-icon">🍫</span>
          <span>Chocolates y Trufas</span>
        </a>
        <a href="/directorio/gomitas-confiteria" class="cat-link">
          <span class="cat-icon">🍭</span>
          <span>Gomitas y Confitería</span>
        </a>
        <a href="/directorio/galletas-cupcakes" class="cat-link">
          <span class="cat-icon">🧁</span>
          <span>Galletas y Cupcakes</span>
        </a>
        <a href="/directorio/paletas-piruletas" class="cat-link">
          <span class="cat-icon">🍡</span>
          <span>Paletas y Piruletas</span>
        </a>
        <a href="/directorio/dulces-importados" class="cat-link">
          <span class="cat-icon">🌍</span>
          <span>Dulces Importados</span>
        </a>
      </div>
    </div>
  </section>

  <section class="faq-section section-padding">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre"
        titleHighlight="Dulces Tradicionales"
        subtitle="Información útil para tu evento"
      />
      <FAQ items={faqsCategoria} id="faq-tradicionales" />
    </div>
  </section>

  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Busco%20proveedores%20de%20dulces%20tradicionales%20mexicanos"
    badge="Dulces Tradicionales"
    title="¿Necesitas Ayuda para"
    titleHighlight="Encontrar Proveedor"
    text="Te ayudamos a encontrar el proveedor perfecto de dulces tradicionales para tu evento."
    buttonText="Pedir Recomendación"
  />
</BaseLayout>

<style>
  .filtros-section {
    padding: 24px 0;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    position: sticky;
    top: 70px;
    z-index: 50;
  }

  .filtros-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .resultados-count {
    font-weight: 600;
    color: var(--texto-oscuro);
  }

  .filtros-opciones {
    display: flex;
    gap: 12px;
  }

  .filtro-select {
    padding: 10px 20px;
    border: 2px solid #f0f0f0;
    border-radius: 10px;
    font-size: 0.9rem;
    background: #fff;
    cursor: pointer;
  }

  .filtro-select:focus {
    outline: none;
    border-color: var(--rosa-principal);
  }

  .directorio-layout {
    padding: 50px 0 80px;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .directorio-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
  }

  .proveedores-lista {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .proveedor-item {
    display: grid;
    grid-template-columns: 320px 1fr;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
  }

  .proveedor-item--destacado {
    border: 2px solid rgba(255, 184, 0, 0.4);
    box-shadow: 0 8px 30px rgba(255, 184, 0, 0.15);
  }

  .proveedor-imagen {
    position: relative;
    height: 100%;
    min-height: 240px;
  }

  .proveedor-imagen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge-destacado {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, #FFB800 0%, #FF8C00 100%);
    color: #fff;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .proveedor-contenido {
    padding: 28px;
    display: flex;
    flex-direction: column;
  }

  .proveedor-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  .proveedor-header h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 8px;
  }

  .proveedor-ubicacion {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--texto-light);
  }

  .proveedor-ubicacion svg {
    width: 16px;
    height: 16px;
  }

  .badge-verificado {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .badge-verificado svg {
    width: 18px;
    height: 18px;
  }

  .proveedor-descripcion {
    font-size: 0.95rem;
    color: var(--texto-light);
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .proveedor-especialidades {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .especialidad-tag {
    background: rgba(209, 0, 122, 0.08);
    color: var(--rosa-principal);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .proveedor-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid #f5f5f5;
  }

  .proveedor-rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .rating-stars {
    display: flex;
    gap: 2px;
  }

  .rating-stars svg {
    width: 18px;
    height: 18px;
  }

  .rating-numero {
    font-weight: 700;
    color: var(--texto-oscuro);
  }

  .rating-resenas {
    font-size: 0.85rem;
    color: var(--texto-light);
  }

  .proveedor-acciones {
    display: flex;
    gap: 12px;
  }

  .btn-perfil {
    padding: 10px 24px;
    border: 2px solid #f0f0f0;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--texto-oscuro);
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-perfil:hover {
    border-color: var(--rosa-principal);
    color: var(--rosa-principal);
  }

  .btn-whatsapp {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    background: #25D366;
    border-radius: 10px;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-whatsapp svg {
    width: 20px;
    height: 20px;
  }

  .btn-whatsapp:hover {
    background: #128C7E;
  }

  .otras-categorias {
    padding: 80px 0;
    background: #fff;
  }

  .categorias-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
  }

  .cat-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: #fff;
    border: 2px solid #f0f0f0;
    border-radius: 50px;
    text-decoration: none;
    color: var(--texto-oscuro);
    font-weight: 500;
    transition: all 0.3s;
  }

  .cat-link:hover {
    border-color: var(--rosa-principal);
    background: rgba(209, 0, 122, 0.05);
  }

  .cat-icon {
    font-size: 1.3rem;
  }

  .faq-section {
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  @media (max-width: 1200px) {
    .directorio-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .proveedor-item {
      grid-template-columns: 1fr;
    }

    .proveedor-imagen {
      height: 200px;
      min-height: auto;
    }

    .filtros-wrapper {
      flex-direction: column;
      align-items: stretch;
    }

    .filtros-opciones {
      flex-wrap: wrap;
    }

    .filtro-select {
      flex: 1;
      min-width: 140px;
    }
  }

  @media (max-width: 768px) {
    .filtros-section {
      top: 60px;
    }

    .proveedor-header {
      flex-direction: column;
    }

    .proveedor-footer {
      flex-direction: column;
      gap: 16px;
      align-items: stretch;
    }

    .proveedor-acciones {
      justify-content: stretch;
    }

    .btn-perfil,
    .btn-whatsapp {
      flex: 1;
      justify-content: center;
    }

    .categorias-grid {
      gap: 10px;
    }

    .cat-link {
      padding: 10px 18px;
      font-size: 0.9rem;
    }
  }
</style>
