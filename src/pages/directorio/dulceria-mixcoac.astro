---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

// Datos de la dulcería
const dulceria = {
  nombre: 'Dulcería Mixcoac',
  slug: 'dulceria-mixcoac',
  tipo: 'Tienda de Golosinas',
  descripcion: 'Dulcería tradicional ubicada en el corazón de Mixcoac, Benito Juárez. Reconocida por su amplia variedad de dulces para fiestas, piñatas y artículos de celebración en la zona sur de CDMX.',
  metaDescription: 'Dulcería Mixcoac - Dulces y piñatas cerca de Metro Mixcoac, Benito Juárez. ⭐ 4.3/5 (1,135 reseñas). Artículos para fiestas y celebraciones. Tel: 55 1518 0985',
  direccion: 'Tiziano 19, Local B',
  colonia: 'Mixcoac',
  alcaldia: 'Benito Juárez',
  cp: '03910',
  ciudad: 'Ciudad de México',
  telefono: '55 1518 0985',
  rating: 4.3,
  resenas: 1135,
  mapsUrl: 'https://maps.app.goo.gl/mixcoac',
  imagen: '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif',
  imagenes: [
    '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif',
    '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    '/img/galeria/candy-bar-gourmet-elegante.avif'
  ],
  horario: {
    lunes: '9:00 - 19:30',
    martes: '9:00 - 19:30',
    miercoles: '9:00 - 19:30',
    jueves: '9:00 - 19:30',
    viernes: '9:00 - 19:30',
    sabado: '9:00 - 18:00',
    domingo: 'Cerrado'
  },
  especialidades: [
    'Dulces para fiestas',
    'Piñatas',
    'Dulces tradicionales',
    'Bolsas de dulces',
    'Confitería variada',
    'Artículos para celebración'
  ],
  servicios: [
    { nombre: 'Dulces para eventos', descripcion: 'Surtido completo para cumpleaños, bautizos y celebraciones' },
    { nombre: 'Piñatas y aguinaldos', descripcion: 'Variedad de piñatas y bolsas para fiestas infantiles' },
    { nombre: 'Confitería tradicional', descripcion: 'Dulces mexicanos y golosinas de todas las marcas' },
    { nombre: 'Asesoría para fiestas', descripcion: 'Te ayudamos a calcular cantidades según tu evento' }
  ],
  verificado: true
};

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: dulceria.alcaldia, url: '/directorio/cdmx/benito-juarez' },
  { name: dulceria.nombre, url: `/directorio/${dulceria.slug}` }
];

const faqsDulceria = [
  {
    question: `¿${dulceria.nombre} tiene variedad de piñatas?`,
    answer: 'Sí, Dulcería Mixcoac cuenta con una amplia variedad de piñatas para diferentes ocasiones y temáticas: personajes infantiles, números, estrellas y modelos tradicionales. Te recomendamos visitarlos o llamar para conocer su inventario actual.'
  },
  {
    question: '¿Arman bolsas de dulces para fiestas?',
    answer: 'Sí, pueden ayudarte a armar bolsas de dulces personalizadas para tu evento. El costo depende del contenido y cantidad. Consulta directamente con ellos para un presupuesto según tu número de invitados.'
  },
  {
    question: '¿Cómo llego en transporte público?',
    answer: 'La dulcería está muy cerca de la estación de Metro Mixcoac (Líneas 7 y 12). Desde la salida son aproximadamente 5 minutos caminando por la calle Tiziano. También hay paradas de metrobús cerca.'
  },
  {
    question: '¿Tienen estacionamiento?',
    answer: 'No cuentan con estacionamiento propio, pero hay opciones de estacionamiento público en la zona. Te recomendamos usar transporte público si es posible.'
  }
];

// Schema para SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": dulceria.nombre,
  "description": dulceria.descripcion,
  "image": `https://mesas-de-dulces.com${dulceria.imagen}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": dulceria.direccion,
    "addressLocality": dulceria.alcaldia,
    "addressRegion": "CDMX",
    "postalCode": dulceria.cp,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.3750",
    "longitude": "-99.1817"
  },
  "telephone": `+52${dulceria.telefono.replace(/\s/g, '')}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": dulceria.rating,
    "reviewCount": dulceria.resenas,
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "19:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "18:00"
    }
  ]
};
---

<BaseLayout
  title={`${dulceria.nombre} | Dulcería y Piñatas cerca de Metro Mixcoac, ${dulceria.alcaldia}`}
  description={dulceria.metaDescription}
  canonical={`/directorio/${dulceria.slug}`}
  ogImage={dulceria.imagen}
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero del Negocio -->
  <section class="negocio-hero">
    <div class="container">
      <div class="negocio-hero-content">
        <div class="negocio-hero-info">
          {dulceria.verificado && (
            <span class="verificado-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Verificado en Google
            </span>
          )}
          <h1>{dulceria.nombre}</h1>
          <p class="negocio-tipo">{dulceria.tipo}</p>

          <div class="negocio-rating">
            <div class="rating-stars">
              {[1,2,3,4,5].map(star => (
                <svg viewBox="0 0 24 24" fill={star <= Math.floor(dulceria.rating) ? "#FFB800" : "#E0E0E0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="rating-numero">{dulceria.rating}</span>
            <span class="rating-resenas">({dulceria.resenas.toLocaleString()} reseñas en Google)</span>
          </div>

          <div class="negocio-ubicacion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="direccion">{dulceria.direccion}</p>
              <p class="zona">{dulceria.colonia}, {dulceria.alcaldia}, CDMX</p>
            </div>
          </div>

          <div class="negocio-acciones">
            <a href={`tel:+52${dulceria.telefono.replace(/\s/g, '')}`} class="btn-principal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Llamar: {dulceria.telefono}
            </a>
            <a href={`https://wa.me/52${dulceria.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul%20y%20me%20gustaría%20información`} class="btn-whatsapp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a href={dulceria.mapsUrl} class="btn-mapa" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <div class="negocio-hero-imagen">
          <img
            src={getCdnUrl(dulceria.imagen, { w: 600, q: 85 })}
            alt={`${dulceria.nombre} - Dulcería cerca de Metro Mixcoac`}
            width="600"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="negocio-layout">
    <div class="container">
      <div class="negocio-grid">
        <!-- Main Content -->
        <main class="negocio-main">
          <!-- Descripción -->
          <section class="negocio-seccion descripcion-principal">
            <h2>Sobre {dulceria.nombre}</h2>
            <div class="descripcion-contenido">
              <p class="descripcion-intro">Con más de <strong>1,100 reseñas positivas en Google</strong> y una calificación de 4.3 estrellas, Dulcería Mixcoac se ha convertido en un <strong>referente para dulces y artículos de fiesta</strong> en la zona sur de la Ciudad de México. Su ubicación privilegiada a pasos del Metro Mixcoac la hace accesible para clientes de toda la ciudad.</p>
              <p class="descripcion-texto">Ubicada en <strong>Tiziano 19, Local B</strong>, en el corazón de la colonia Mixcoac, esta dulcería tradicional ofrece todo lo que necesitas para tus <strong>celebraciones y fiestas infantiles</strong>. Desde piñatas de todas las temáticas hasta bolsas de dulces personalizadas, pasando por confitería tradicional mexicana y golosinas de todas las marcas.</p>
              <p class="descripcion-texto">Ya sea que estés organizando un cumpleaños, un bautizo, una primera comunión o cualquier tipo de celebración familiar, en Dulcería Mixcoac encontrarás <strong>variedad, calidad y precios accesibles</strong>. Su equipo te ayuda a calcular las cantidades necesarias según tu número de invitados.</p>
            </div>
          </section>

          <!-- Beneficios Cards -->
          <section class="negocio-seccion beneficios-section">
            <h2>¿Por qué elegir Dulcería Mixcoac?</h2>
            <div class="beneficios-grid">
              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <h3>+1,100 Reseñas Positivas</h3>
                <p>Una de las <strong>dulcerías mejor valoradas</strong> de Benito Juárez. Los clientes destacan la variedad de productos y el buen servicio.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
                  </svg>
                </div>
                <h3>Cerca del Metro Mixcoac</h3>
                <p>A <strong>5 minutos caminando</strong> de la estación Mixcoac (Líneas 7 y 12). Fácil acceso desde cualquier punto de la ciudad.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </div>
                <h3>Piñatas y Aguinaldos</h3>
                <p>Amplia <strong>variedad de piñatas</strong> para todas las temáticas: personajes, números, estrellas y modelos tradicionales.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                </div>
                <h3>Todo para tu Fiesta</h3>
                <p><strong>Bolsas personalizadas</strong>, dulces a granel, confitería tradicional y todo lo necesario para tu celebración.</p>
              </div>
            </div>
          </section>

          <!-- Productos Destacados -->
          <section class="negocio-seccion productos-section">
            <h2>Productos que Encontrarás</h2>
            <div class="productos-lista">
              <div class="producto-categoria">
                <span class="producto-tag">Piñatas</span>
                <p>Variedad de modelos: personajes infantiles, números, estrellas, tradicionales y temáticas especiales</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Bolsas de Dulces</span>
                <p>Servicio de armado de bolsitas personalizadas para fiestas con diferentes contenidos</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Dulces Tradicionales</span>
                <p>Mazapanes, cocadas, alegrías, obleas, tamarindos y toda la dulcería mexicana</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Confitería</span>
                <p>Gomitas, paletas, chiclosos, caramelos y golosinas de todas las marcas</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Chocolates</span>
                <p>Marcas nacionales e importadas en presentaciones individuales y para regalo</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Artículos para Fiestas</span>
                <p>Complementos para celebraciones: globos, manteles, platos y decoración básica</p>
              </div>
            </div>
          </section>

          <!-- Especialidades -->
          <section class="negocio-seccion">
            <h2>Lo que Encontrarás</h2>
            <div class="especialidades-grid">
              {dulceria.especialidades.map(esp => (
                <div class="especialidad-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <span>{esp}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Servicios -->
          <section class="negocio-seccion">
            <h2>Servicios</h2>
            <div class="servicios-grid">
              {dulceria.servicios.map(serv => (
                <div class="servicio-card">
                  <h3>{serv.nombre}</h3>
                  <p>{serv.descripcion}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar para confirmar.</p>
          </section>

          <!-- Ubicación -->
          <section class="negocio-seccion">
            <h2>Cómo Llegar</h2>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> {dulceria.ciudad}</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
                <p><strong>Referencia:</strong> A 5 minutos del Metro Mixcoac (Líneas 7 y 12)</p>
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías -->
  <section class="otras-dulcerias section-padding">
    <div class="container">
      <SectionHeader
        title="Otras Dulcerías en"
        titleHighlight="CDMX"
        subtitle="Explora más opciones de dulcerías verificadas"
      />
      <div class="service-grid">
        <ServiceCard
          href="/directorio/dulceria-el-remate"
          image="/img/galeria/candy-bar-colorido-fiestas.avif"
          alt="Dulcería El Remate - Precios accesibles Av. Juárez CDMX"
          title="Dulcería El Remate"
          excerpt="4.1 estrellas (1,062 reseñas). La más reseñada de CDMX con precios accesibles en Av. Juárez."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-guachitos"
          image="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
          alt="Dulcería Guachitos - Av. Tláhuac CDMX"
          title="Dulcería Guachitos"
          excerpt="4.3 estrellas (628 reseñas). Popular dulcería en Av. Tláhuac con precios accesibles y horario extendido."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-candy-gram"
          image="/img/galeria/candy-bar-gourmet-elegante.avif"
          alt="Dulcería Candy Gram - Iztapalapa CDMX"
          title="Dulcería Candy Gram"
          excerpt="4.1 estrellas (15 reseñas). Servicio personalizado y productos de calidad en Iztapalapa."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-chispita"
          image="/img/galeria/dulces-variados-mesa.avif"
          alt="Dulcería Chispita - Tlalpan CDMX"
          title="Dulcería Chispita"
          excerpt="4.8 estrellas (243 reseñas). La mejor calificación de CDMX con excelente servicio en Tlalpan."
          cta="Ver Dulcería"
        />
      </div>
      <div class="ver-todas-wrapper">
        <a href="/directorio/todos" class="btn-ver-todas">
          Ver todas las dulcerías
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20dulces%20para%20mi%20evento"
    badge="Mesa de Dulces"
    title="¿Necesitas una Mesa de Dulces"
    titleHighlight="Profesional"
    text="En Mededul diseñamos mesas de dulces personalizadas para bodas, XV años, baby showers y todo tipo de eventos."
    buttonText="Cotizar Mesa de Dulces"
  />
</BaseLayout>

<style>
  /* Hero del Negocio */
  .negocio-hero {
    padding: 60px 0 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .negocio-hero-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 60px;
    align-items: center;
  }

  .verificado-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .verificado-badge svg {
    width: 20px;
    height: 20px;
  }

  .negocio-hero-info h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .negocio-tipo {
    font-size: 1.1rem;
    color: var(--rosa-principal);
    font-weight: 500;
    margin: 0 0 20px;
  }

  .negocio-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .rating-stars {
