---
import DulceriaLayout from '@/components/directorio/DulceriaLayout.astro';
import { getDulceriaPorSlug } from '@/data/dulcerias';

const dulceria = getDulceriaPorSlug('dulces-y-botanas-azcapotzalco');
if (!dulceria) return Astro.redirect('/directorio');
---

<DulceriaLayout dulceria={dulceria} />
