---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import {
  getDulceriasPorMunicipio,
  municipiosInfo,
  getMunicipiosConDulcerias
} from '@/data/dulcerias';

export function getStaticPaths() {
  const municipios = Object.keys(municipiosInfo);
  return municipios.map((slug) => ({
    params: { municipio: slug },
    props: { municipioSlug: slug }
  }));
}

const { municipioSlug } = Astro.props;
const info = municipiosInfo[municipioSlug];
const dulcerias = getDulceriasPorMunicipio(municipioSlug);

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Estado de México', url: '/directorio/edomex' },
  { name: info.nombre, url: `/directorio/edomex/${municipioSlug}` }
];

// Desglose por tipo de negocio — muestra composición real del municipio
const tiposConteo = dulcerias.reduce<Record<string, number>>((acc, d) => {
  acc[d.tipo] = (acc[d.tipo] || 0) + 1;
  return acc;
}, {});

const tipoOrden = [
  'Dulcería Mayoreo',
  'Tienda de Golosinas',
  'Tienda de Golosinas Premium',
  'Dulcería Tradicional'
];
const tiposEnMunicipio = tipoOrden
  .filter((t) => tiposConteo[t])
  .map((t) => ({ tipo: t, conteo: tiposConteo[t] }));

// Estadísticas agregadas
const totalResenas = dulcerias.reduce((sum, d) => sum + d.resenas, 0);
const promedioRating =
  dulcerias.length > 0
    ? (dulcerias.reduce((sum, d) => sum + d.rating, 0) / dulcerias.length).toFixed(1)
    : '0';
const destacadas = dulcerias.filter((d) => d.destacado).length;

// Top 3 por reseñas — para el intro SEO
const top3 = [...dulcerias].sort((a, b) => b.resenas - a.resenas).slice(0, 3);

// Municipios cercanos
const todosMunicipios = getMunicipiosConDulcerias();
const municipiosCercanos = todosMunicipios.filter((a) => a.slug !== municipioSlug).slice(0, 6);

// FAQ — 6 preguntas municipio-específicas con datos reales
const faqsMunicipio = [
  {
    question: `¿Cuántas dulcerías verificadas hay en ${info.nombre}?`,
    answer: `El directorio MEDEDUL lista ${dulcerias.length} ${dulcerias.length === 1 ? 'dulcería verificada' : 'dulcerías verificadas'} en ${info.nombre}, ${info.descripcion} Cada ficha incluye dirección, teléfono, horarios, especialidades y reseñas reales de Google Maps.`
  },
  {
    question: `¿Dónde se concentran las dulcerías en ${info.nombre}?`,
    answer: `La zona comercial principal es ${info.zonaComercial}. ${info.caracteristicas.join(', ')}. Para planear visitas de compra eficientes, conviene agrupar paradas en este corredor y aprovechar que varios negocios operan con horarios similares entre semana.`
  },
  {
    question: `¿Qué tipos de dulcerías puedo encontrar en ${info.nombre}?`,
    answer:
      tiposEnMunicipio.length > 0
        ? `En ${info.nombre} encontrarás ${tiposEnMunicipio
            .map((t) => `${t.conteo} ${t.tipo.toLowerCase()}${t.conteo > 1 ? 's' : ''}`)
            .join(', ')}. Esto permite cubrir desde abasto mayorista hasta regalo gourmet y dulces tradicionales del centro del país.`
        : `${info.nombre} cuenta con una mezcla de dulcerías tradicionales y tiendas de golosinas que atienden fiestas, eventos familiares y comercio de barrio.`
  },
  {
    question: `¿Las dulcerías en ${info.nombre} venden al mayoreo?`,
    answer: `Sí. Varias dulcerías locales ofrecen precios escalonados por volumen, sobre todo las catalogadas como "Dulcería Mayoreo". Recomendamos llamar por teléfono antes de ir para confirmar disponibilidad, mínimos de compra y si manejan factura, ya que muchos negocios familiares del Edo Mex trabajan sobre pedido especial para grandes cantidades.`
  },
  {
    question: `¿Conviene cruzar a CDMX o comprar en ${info.nombre}?`,
    answer: `Si tu evento ocurre dentro del Estado de México, comprar en ${info.nombre} ahorra traslados, peajes del Circuito Exterior Mexiquense o Periférico Norte y tiempo frente a ir a La Merced o Norte 70 en CDMX. El ticket promedio por kilogramo es comparable, y reduce el riesgo de derretimiento del chocolate durante el trayecto.`
  },
  {
    question: `¿Qué productos son típicos de las dulcerías de ${info.nombre}?`,
    answer: `El catálogo estándar incluye: gomitas nacionales e importadas, paletas Vero/De la Rosa/Indy, chocolates Ricolino/Hershey, tamarindos y cacahuates enchilados, dulces tradicionales mexicanos, bolsitas transparentes para bolo, piñatas y artículos de fiesta. En negocios tipo "Dulcería Tradicional" encontrarás dulces típicos artesanales (palanquetas, jamoncillos, camotes, cocadas) sobre todo cerca de ${info.zonaComercial}.`
  }
];

// JSON-LD: BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://mesas-de-dulces.com/' },
    { '@type': 'ListItem', position: 2, name: 'Directorio', item: 'https://mesas-de-dulces.com/directorio' },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Estado de México',
      item: 'https://mesas-de-dulces.com/directorio/edomex'
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: info.nombre,
      item: `https://mesas-de-dulces.com/directorio/edomex/${municipioSlug}`
    }
  ]
};

// JSON-LD: FAQPage
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqsMunicipio.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer }
  }))
};

// JSON-LD: ItemList con LocalBusiness
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Dulcerías en ${info.nombre}, Estado de México`,
  description: `Directorio verificado de ${dulcerias.length} dulcerías en ${info.nombre}, Estado de México.`,
  numberOfItems: dulcerias.length,
  itemListElement: dulcerias.slice(0, 20).map((d, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://mesas-de-dulces.com/directorio/${d.slug}`,
    item: {
      '@type': 'LocalBusiness',
      '@id': `https://mesas-de-dulces.com/directorio/${d.slug}#business`,
      name: d.nombre,
      url: `https://mesas-de-dulces.com/directorio/${d.slug}`,
      address: {
        '@type': 'PostalAddress',
        streetAddress: d.direccion,
        addressLocality: d.alcaldia,
        addressRegion: 'MEX',
        addressCountry: 'MX',
        postalCode: d.cp
      },
      ...(d.telefono !== 'Sin teléfono registrado' && d.telefono !== 'Ver en Google Maps'
        ? { telephone: `+52${d.telefono.replace(/\s/g, '')}` }
        : {}),
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: d.rating,
        reviewCount: d.resenas
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: d.coordenadas.lat,
        longitude: d.coordenadas.lng
      }
    }
  }))
};

// JSON-LD: Place para el municipio
const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: info.nombre,
  description: info.descripcion,
  address: {
    '@type': 'PostalAddress',
    addressLocality: info.nombre,
    addressRegion: 'MEX',
    addressCountry: 'MX'
  },
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: 'Estado de México'
  }
};

// Etiqueta humana por tipo (plural)
const tipoPluralLabel: Record<string, string> = {
  'Dulcería Mayoreo': 'mayoristas',
  'Tienda de Golosinas': 'tiendas de golosinas',
  'Tienda de Golosinas Premium': 'tiendas premium',
  'Dulcería Tradicional': 'dulcerías tradicionales'
};
---

<BaseLayout
  title={`Dulcerías en ${info.nombre}, Edo Mex | ${dulcerias.length} Proveedores Verificados`}
  description={`Directorio verificado de ${dulcerias.length} dulcerías en ${info.nombre}, Estado de México. ${info.zonaComercial}. Mayoreo, menudeo, materias primas y dulces tradicionales con reseñas reales de Google Maps.`}
  canonical={`/directorio/edomex/${municipioSlug}`}
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(placeSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title={`Dulcerías en ${info.nombre}, Edo Mex`}
    highlight={info.nombre}
    subtitle={`${dulcerias.length} proveedores verificados con reseñas reales · ${info.descripcion}`}
    secondaryContent={`<p><strong>Dulcerías en ${info.nombre}</strong> seleccionadas y auditadas para que encuentres opciones cercanas con datos confirmados de contacto, horario y especialidad de producto. El listado concentra negocios tradicionales, dulcerías mayoristas y tiendas de golosinas distribuidas en <strong>${info.zonaComercial}</strong>, evitando que cruces a CDMX para resolver tu mesa de dulces o el surtido de una fiesta.</p><p><strong>${dulcerias.length} proveedores verificados</strong> destacan por ${info.caracteristicas.join(', ').toLowerCase()}. ${top3.length > 0 ? `Entre los más reseñados figuran <strong>${top3.map((d) => d.nombre).join('</strong>, <strong>')}</strong>.` : ''} Usa este directorio como base operativa para surtir mesas de dulces, armar bolos de fiesta infantil o abastecer eventos sociales y corporativos en el Estado de México.</p>`}
  />

  <!-- Stats del Municipio -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-numero">{dulcerias.length}</span>
          <span class="stat-label">Dulcerías verificadas</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">{promedioRating}</span>
          <span class="stat-label">Rating promedio Google</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">{totalResenas.toLocaleString('es-MX')}</span>
          <span class="stat-label">Reseñas reales en Maps</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">{destacadas > 0 ? destacadas : '100%'}</span>
          <span class="stat-label">{destacadas > 0 ? 'Destacadas por MEDEDUL' : 'Verificados'}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tipos de dulcería del municipio -->
  {tiposEnMunicipio.length > 1 && (
    <section class="tipos-section">
      <div class="container">
        <SectionHeader
          title="Mezcla de"
          titleHighlight="Proveedores"
          subtitle={`Composición del directorio en ${info.nombre} por tipo de negocio`}
        />
        <div class="tipos-grid">
          {tiposEnMunicipio.map((t) => (
            <div class="tipo-card">
              <span class="tipo-conteo">{t.conteo}</span>
              <span class="tipo-nombre">{tipoPluralLabel[t.tipo] ?? t.tipo}</span>
              <span class="tipo-descr">{t.tipo}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Características de la zona -->
  <section class="zona-info">
    <div class="container">
      <SectionHeader
        title="Zona Comercial"
        titleHighlight={info.zonaComercial}
        subtitle={`Lo que hace especial a ${info.nombre} para comprar dulces`}
      />
      <div class="caracteristicas-grid">
        {info.caracteristicas.map((carac) => (
          <div class="caracteristica-card">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{carac}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Listado de Dulcerías con Sidebar -->
  <section class="dulcerias-listado">
    <div class="container">
      <SectionHeader
        title="Dulcerías en"
        titleHighlight={info.nombre}
        subtitle={`${dulcerias.length} proveedores verificados en Google Maps`}
      />
      <div class="directorio-grid">
        <main class="directorio-main">
          <div class="proveedores-grid">
            {dulcerias.map((prov) => (
              <DulceriaCard dulceria={prov} />
            ))}
          </div>
        </main>
        <DirectorioSidebar />
      </div>
    </div>
  </section>

  <!-- Municipios Cercanos -->
  {municipiosCercanos.length > 0 && (
    <section class="alcaldias-cercanas">
      <div class="container">
        <SectionHeader
          title="Explora otros"
          titleHighlight="Municipios"
          subtitle="Más dulcerías verificadas en el Estado de México"
        />
        <div class="alcaldias-grid">
          {municipiosCercanos.map((a) => (
            <a href={`/directorio/edomex/${a.slug}`} class="alcaldia-link">
              <span class="alcaldia-nombre">{a.nombre}</span>
              <span class="alcaldia-count">{a.cantidad} dulcerías</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <FAQContactModule faqItems={faqsMunicipio} />
</BaseLayout>

<style>
  .stats-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #a0005f 100%);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .stat-card {
    text-align: center;
    color: #fff;
  }

  .stat-numero {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .tipos-section {
    padding: 80px 0;
    background: #fff;
  }

  .tipos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .tipo-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: #fafafa;
    border-radius: 14px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    text-align: center;
  }

  .tipo-conteo {
    font-family: 'Poppins', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--rosa-principal);
    line-height: 1;
  }

  .tipo-nombre {
    margin-top: 6px;
    font-weight: 600;
    color: var(--texto-oscuro);
    text-transform: capitalize;
  }

  .tipo-descr {
    margin-top: 4px;
    font-size: 0.78rem;
    color: #888;
  }

  .zona-info {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .caracteristicas-grid {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .caracteristica-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid #f0f0f0;
  }

  .caracteristica-card svg {
    width: 24px;
    height: 24px;
    color: var(--rosa-principal);
    flex-shrink: 0;
  }

  .caracteristica-card span {
    font-weight: 500;
    color: var(--texto-oscuro);
  }

  .dulcerias-listado {
    padding: 80px 0;
    background: #fff;
  }

  .directorio-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
    align-items: start;
    margin-top: 40px;
  }

  .directorio-main {
    min-width: 0;
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .alcaldias-cercanas {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .alcaldias-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 40px;
  }

  .alcaldia-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border: 1px solid #f0f0f0;
    text-decoration: none;
}

  .alcaldia-link:hover {
    border-color: var(--rosa-principal);

    box-shadow: 0 8px 30px rgba(209, 0, 122, 0.1);
  }

  .alcaldia-nombre {
    font-weight: 600;
    color: var(--texto-oscuro);
  }

  .alcaldia-count {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--rosa-principal);
    background: rgba(209, 0, 122, 0.1);
    padding: 4px 12px;
    border-radius: 20px;
  }

  @media (max-width: 1200px) {
    .directorio-grid {
      grid-template-columns: 1fr;
    }
    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
    .tipos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats-section {
      padding: 40px 0;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .stat-numero {
      font-size: 2rem;
    }
    .tipos-section,
    .zona-info,
    .dulcerias-listado,
    .faq-section,
    .alcaldias-cercanas {
      padding: 50px 0;
    }
    .caracteristicas-grid {
      flex-direction: column;
      align-items: stretch;
    }
    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .alcaldias-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
    .alcaldias-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
