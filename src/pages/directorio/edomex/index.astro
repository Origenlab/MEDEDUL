---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import { getEstadisticasDirectorio } from '@/data/dulcerias';

const stats = getEstadisticasDirectorio();

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Estado de México', url: '/directorio/edomex' }
];

const municipiosPlaneados = [
  'Naucalpan', 'Tlalnepantla', 'Ecatepec', 'Nezahualcóyotl',
  'Toluca', 'Metepec', 'Texcoco', 'Atizapán',
  'Cuautitlán Izcalli', 'Huixquilucan', 'Coacalco', 'Tultitlán'
];
---

<BaseLayout
  title="Dulcerías en Estado de México | Próximamente"
  description="Próximamente: directorio de dulcerías verificadas en Estado de México. Mientras tanto, explora nuestro directorio de CDMX con más de 120 dulcerías."
  canonical="/directorio/edomex"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
  noindex={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Estado de México"
    highlight="Próximamente"
    subtitle="Estamos verificando proveedores en el Edomex"
    secondaryContent={`<p>Estamos verificando cada dulcería en Estado de México para ofrecerte <strong>información 100% real y confiable</strong>.</p><p>Mientras tanto, explora nuestro <strong>directorio de CDMX con ${stats.total} dulcerías verificadas</strong>.</p>`}
    showCTA={false}
  />

  <section class="proximamente-section">
    <div class="container">
      <div class="proximamente-content">
        <div class="proximamente-card">
          <div class="proximamente-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h2>Verificando Información</h2>
          <p>Estamos visitando y verificando cada dulcería en los principales municipios del Estado de México. Solo publicamos datos confirmados en Google Maps.</p>

          <div class="municipios-planeados">
            <h3>Municipios en proceso de verificación:</h3>
            <div class="municipios-grid">
              {municipiosPlaneados.map(m => (
                <span class="municipio-tag">{m}</span>
              ))}
            </div>
          </div>

          <div class="proximamente-cta">
            <a href="/directorio/todos" class="btn-directorio-cdmx">
              Ver Directorio CDMX ({stats.total} dulcerías)
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Busco%20proveedores%20de%20dulces%20en%20Estado%20de%20México"
    badge="Edomex"
    title="¿Conoces una dulcería en"
    titleHighlight="Estado de México"
    text="Si conoces una dulcería que debemos incluir, contáctanos. Tu recomendación nos ayuda a crecer."
    buttonText="Recomendar Dulcería"
  />
</BaseLayout>

<style>
  .proximamente-section {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .proximamente-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .proximamente-card {
    background: #fff;
    border-radius: 24px;
    padding: 48px 40px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
    text-align: center;
  }

  .proximamente-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  .proximamente-icon svg {
    width: 40px;
    height: 40px;
    color: #fff;
  }

  .proximamente-card h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 16px;
  }

  .proximamente-card > p {
    font-size: 1.05rem;
    color: var(--texto-light);
    line-height: 1.7;
    margin: 0 0 32px;
  }

  .municipios-planeados {
    text-align: left;
    margin-bottom: 32px;
  }

  .municipios-planeados h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--texto-oscuro);
    margin: 0 0 16px;
  }

  .municipios-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .municipio-tag {
    background: rgba(99, 102, 241, 0.08);
    color: #6366F1;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .proximamente-cta {
    margin-top: 8px;
  }

  .btn-directorio-cdmx {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    color: #fff;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-directorio-cdmx svg {
    width: 20px;
    height: 20px;
  }

  .btn-directorio-cdmx:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(209, 0, 122, 0.3);
  }

  @media (max-width: 768px) {
    .proximamente-section {
      padding: 50px 0;
    }

    .proximamente-card {
      padding: 32px 24px;
    }

    .proximamente-card h2 {
      font-size: 1.4rem;
    }
  }
</style>
