---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import { getDulceriasPorMunicipio, getDulceriasPorEstado, municipiosInfo } from '@/data/dulcerias';

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Estado de México', url: '/directorio/edomex' }
];

// Calcular municipios dinámicamente desde la base de datos
const municipiosConteo = Object.entries(municipiosInfo).map(([slug, info]) => ({
  nombre: info.nombre,
  slug,
  proveedores: getDulceriasPorMunicipio(slug).length
})).sort((a, b) => b.proveedores - a.proveedores);

const totalProveedores = getDulceriasPorEstado('edomex').length;
const municipiosActivos = municipiosConteo.filter(m => m.proveedores > 0).length;
---

<BaseLayout
  title="Directorio de Dulces en Estado de México | Proveedores por Municipio"
  description={`Encuentra proveedores de dulces para fiestas en municipios del Estado de México. ${totalProveedores}+ negocios verificados en Naucalpan, Tlalnepantla, Toluca, Metepec y más.`}
  canonical="/directorio/edomex"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Proveedores de Dulces por Municipio en Edo Mex"
    highlight="Edo Mex"
    subtitle={`Directorio geolocalizado con ${totalProveedores}+ proveedores verificados en ${municipiosActivos} municipios del Estado de Mexico`}
    secondaryContent={`<p><strong>Directorio por municipio</strong> organiza a los mejores proveedores de dulces del Estado de Mexico segun tu ubicacion, para que encuentres dulcerias, mayoristas, tiendas tradicionales y proveedores de materias primas cerca de tu domicilio o venue del evento sin necesidad de cruzar a CDMX. Cada ficha incluye direccion, telefono, horarios y resenas reales de Google Maps para tomar decisiones sin perder tiempo.</p><p><strong>${totalProveedores}+ proveedores verificados</strong> repartidos en la zona conurbada, Valle de Toluca y oriente del estado te permiten comparar opciones por zona, especialidad y rango de precio. Usa este directorio para surtir mesas de dulces, armar bolos de fiesta infantil, abastecer eventos corporativos o localizar mayoristas regionales como los de Central de Abastos Tultitlan.</p>`}
  />

  <!-- Todos los Municipios -->
  <section class="alcaldias-section">
    <div class="container">
      <SectionHeader
        title="Todos los"
        titleHighlight="Municipios"
        subtitle="Explora proveedores en todo el Estado de Mexico"
      />
      <div class="alcaldias-grid">
        {municipiosConteo.map(municipio => (
          <a href={`/directorio/edomex/${municipio.slug}`} class="alcaldia-card">
            <span class="alcaldia-nombre">{municipio.nombre}</span>
            <span class="alcaldia-count">{municipio.proveedores} {municipio.proveedores === 1 ? 'proveedor' : 'proveedores'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-numero">{totalProveedores}+</span>
          <span class="stat-label">Proveedores en Edo Mex</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">{municipiosActivos}</span>
          <span class="stat-label">Municipios cubiertos</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">3</span>
          <span class="stat-label">Zonas (conurbada · Valle Toluca · oriente)</span>
        </div>
        <div class="stat-card">
          <span class="stat-numero">100%</span>
          <span class="stat-label">Verificados</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .alcaldias-section {
    padding: 80px 0;
    background: #fff;
  }

  .alcaldias-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 50px;
  }

  .alcaldia-card {
    display: flex;
    flex-direction: column;
    padding: 20px 24px;
    background: #fafafa;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .alcaldia-card:hover {
    background: rgba(209, 0, 122, 0.08);
  }

  .alcaldia-nombre {
    font-weight: 600;
    color: var(--texto-oscuro);
    margin-bottom: 4px;
  }

  .alcaldia-count {
    font-size: 0.85rem;
    color: var(--rosa-principal);
  }

  .stats-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .stat-card {
    text-align: center;
    color: #fff;
  }

  .stat-numero {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.95rem;
    opacity: 0.85;
  }

  @media (max-width: 1024px) {
    .alcaldias-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }

  @media (max-width: 768px) {
    .alcaldias-section {
      padding: 50px 0;
    }

    .alcaldias-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .stat-numero {
      font-size: 2rem;
    }
  }
</style>
