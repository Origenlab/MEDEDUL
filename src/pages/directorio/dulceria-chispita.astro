---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

// Datos de la dulcería
const dulceria = {
  nombre: 'Dulcería Chispita',
  slug: 'dulceria-chispita',
  tipo: 'Tienda de Golosinas',
  descripcion: 'Dulcería ubicada en el corazón de Azcapotzalco, sobre la avenida principal. Ofrece amplia variedad de dulces, botanas, piñatas y artículos para fiestas, con la ventaja de abrir los domingos.',
  metaDescription: 'Dulcería Chispita - Dulces y artículos para fiestas en Av. Azcapotzalco, Centro de Azcapotzalco. ⭐ 4.1/5 (123 reseñas). Abierto domingos. Tel: 55 6788 0847',
  direccion: 'Av. Azcapotzalco 696',
  colonia: 'Centro de Azcapotzalco',
  alcaldia: 'Azcapotzalco',
  cp: '02000',
  ciudad: 'Ciudad de México',
  telefono: '55 6788 0847',
  rating: 4.1,
  resenas: 123,
  mapsUrl: 'https://maps.app.goo.gl/chispita',
  imagen: '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif',
  imagenes: [
    '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif',
    '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    '/img/galeria/candy-bar-gourmet-elegante.avif'
  ],
  horario: {
    lunes: '9:00 - 19:00',
    martes: '9:00 - 19:00',
    miercoles: '9:00 - 19:00',
    jueves: '9:00 - 19:00',
    viernes: '9:00 - 19:00',
    sabado: '9:00 - 18:00',
    domingo: '10:00 - 14:00'
  },
  especialidades: [
    'Ubicación céntrica',
    'Dulces variados',
    'Artículos para fiestas',
    'Botanas',
    'Piñatas',
    'Confitería'
  ],
  servicios: [
    { nombre: 'Dulces para eventos', descripcion: 'Surtido completo para cumpleaños, bautizos y celebraciones' },
    { nombre: 'Piñatas y aguinaldos', descripcion: 'Variedad de piñatas y bolsas para fiestas infantiles' },
    { nombre: 'Botanas y snacks', descripcion: 'Amplia selección de botanas para cualquier ocasión' },
    { nombre: 'Artículos para fiestas', descripcion: 'Todo lo necesario para tu celebración' }
  ],
  verificado: true
};

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: dulceria.alcaldia, url: '/directorio/cdmx/azcapotzalco' },
  { name: dulceria.nombre, url: `/directorio/${dulceria.slug}` }
];

const faqsDulceria = [
  {
    question: `¿${dulceria.nombre} abre los domingos?`,
    answer: 'Sí, Dulcería Chispita abre los domingos de 10:00 a 14:00 horas. Es una de las pocas dulcerías en la zona que atiende los fines de semana completos, lo que la hace muy conveniente para compras de último momento.'
  },
  {
    question: '¿Dónde está ubicada exactamente la dulcería?',
    answer: 'Dulcería Chispita se encuentra sobre la Avenida Azcapotzalco número 696, en el Centro de Azcapotzalco. Es una ubicación muy céntrica y accesible, sobre una de las avenidas principales de la alcaldía.'
  },
  {
    question: '¿Tienen artículos para fiestas infantiles?',
    answer: 'Sí, además de dulces y confitería, Dulcería Chispita ofrece piñatas, bolsas de aguinaldo y artículos básicos para fiestas. Te recomendamos visitarlos o llamar para conocer su inventario actual.'
  },
  {
    question: '¿Venden botanas además de dulces?',
    answer: 'Sí, la dulcería cuenta con una sección de botanas y snacks variados. Es una opción práctica si necesitas surtir tanto dulces como botanas para tu evento en un solo lugar.'
  }
];

// Schema para SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": dulceria.nombre,
  "description": dulceria.descripcion,
  "image": `https://mesas-de-dulces.com${dulceria.imagen}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": dulceria.direccion,
    "addressLocality": dulceria.alcaldia,
    "addressRegion": "CDMX",
    "postalCode": dulceria.cp,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.4869",
    "longitude": "-99.1840"
  },
  "telephone": `+52${dulceria.telefono.replace(/\s/g, '')}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": dulceria.rating,
    "reviewCount": dulceria.resenas,
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Sunday",
      "opens": "10:00",
      "closes": "14:00"
    }
  ]
};
---

<BaseLayout
  title={`${dulceria.nombre} | Dulcería en Centro de ${dulceria.alcaldia}, CDMX`}
  description={dulceria.metaDescription}
  canonical={`/directorio/${dulceria.slug}`}
  ogImage={dulceria.imagen}
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero del Negocio -->
  <section class="negocio-hero">
    <div class="container">
      <div class="negocio-hero-content">
        <div class="negocio-hero-info">
          {dulceria.verificado && (
            <span class="verificado-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Verificado en Google
            </span>
          )}
          <h1>{dulceria.nombre}</h1>
          <p class="negocio-tipo">{dulceria.tipo}</p>

          <div class="negocio-rating">
            <div class="rating-stars">
              {[1,2,3,4,5].map(star => (
                <svg viewBox="0 0 24 24" fill={star <= Math.floor(dulceria.rating) ? "#FFB800" : "#E0E0E0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="rating-numero">{dulceria.rating}</span>
            <span class="rating-resenas">({dulceria.resenas.toLocaleString()} reseñas en Google)</span>
          </div>

          <div class="negocio-ubicacion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="direccion">{dulceria.direccion}</p>
              <p class="zona">{dulceria.colonia}, {dulceria.alcaldia}, CDMX</p>
            </div>
          </div>

          <div class="negocio-acciones">
            <a href={`tel:+52${dulceria.telefono.replace(/\s/g, '')}`} class="btn-principal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Llamar: {dulceria.telefono}
            </a>
            <a href={`https://wa.me/52${dulceria.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul%20y%20me%20gustaría%20información`} class="btn-whatsapp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a href={dulceria.mapsUrl} class="btn-mapa" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <div class="negocio-hero-imagen">
          <img
            src={getCdnUrl(dulceria.imagen, { w: 600, q: 85 })}
            alt={`${dulceria.nombre} - Dulcería en Centro de Azcapotzalco`}
            width="600"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="negocio-layout">
    <div class="container">
      <div class="negocio-grid">
        <!-- Main Content -->
        <main class="negocio-main">
          <!-- Descripción -->
          <section class="negocio-seccion descripcion-principal">
            <h2>Sobre {dulceria.nombre}</h2>
            <div class="descripcion-contenido">
              <p class="descripcion-intro">Ubicada en el <strong>corazón del Centro de Azcapotzalco</strong>, sobre la Avenida Azcapotzalco, Dulcería Chispita se ha convertido en una <strong>opción conveniente para los habitantes de la zona norte</strong> de la Ciudad de México. Su ubicación privilegiada sobre una de las avenidas principales de la alcaldía la hace fácil de encontrar y accesible desde cualquier punto.</p>
              <p class="descripcion-texto">En <strong>Av. Azcapotzalco 696</strong>, esta dulcería ofrece una variada selección de dulces, confitería, botanas y artículos para fiestas. Una de sus principales ventajas es que <strong>abre los domingos de 10:00 a 14:00</strong>, siendo una de las pocas opciones en la zona para compras de último momento los fines de semana.</p>
              <p class="descripcion-texto">Ya sea que necesites surtir dulces para una fiesta infantil, busques piñatas y aguinaldos, o simplemente quieras botanas y golosinas para la semana, Dulcería Chispita te ofrece <strong>variedad y conveniencia</strong> en una ubicación céntrica de Azcapotzalco.</p>
            </div>
          </section>

          <!-- Beneficios Cards -->
          <section class="negocio-seccion beneficios-section">
            <h2>¿Por qué elegir Dulcería Chispita?</h2>
            <div class="beneficios-grid">
              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <h3>Ubicación Céntrica en Azcapotzalco</h3>
                <p>En pleno <strong>Centro de Azcapotzalco</strong>, sobre la avenida principal. Fácil de encontrar y accesible desde cualquier punto de la alcaldía.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <h3>Abierto los Domingos</h3>
                <p>Atiende <strong>domingos de 10:00 a 14:00</strong>. Ideal para compras de último momento cuando otras dulcerías están cerradas.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </div>
                <h3>Artículos para Fiestas</h3>
                <p>Además de dulces, encuentras <strong>piñatas, aguinaldos</strong> y todo lo necesario para celebraciones en un solo lugar.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                    <line x1="4" y1="22" x2="4" y2="15"/>
                  </svg>
                </div>
                <h3>Sobre Avenida Principal</h3>
                <p>Ubicada en <strong>Av. Azcapotzalco 696</strong>, una de las vías más transitadas. Fácil acceso en transporte público o auto.</p>
              </div>
            </div>
          </section>

          <!-- Productos Destacados -->
          <section class="negocio-seccion productos-section">
            <h2>Productos que Encontrarás</h2>
            <div class="productos-lista">
              <div class="producto-categoria">
                <span class="producto-tag">Dulces Variados</span>
                <p>Amplia selección de dulces de todas las marcas: gomitas, paletas, chicles, caramelos y más</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Piñatas</span>
                <p>Variedad de piñatas para fiestas infantiles: personajes, números y modelos tradicionales</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Botanas y Snacks</span>
                <p>Sección completa de botanas: papas, cacahuates, chicharrones y frituras de todas las marcas</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Confitería</span>
                <p>Dulces tradicionales mexicanos: mazapanes, cocadas, alegrías y tamarindos</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Artículos para Fiestas</span>
                <p>Bolsas de aguinaldo, manteles, globos y artículos básicos para celebraciones</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Chocolates</span>
                <p>Chocolates de marcas nacionales en presentaciones individuales y familiares</p>
              </div>
            </div>
          </section>

          <!-- Especialidades -->
          <section class="negocio-seccion">
            <h2>Lo que Encontrarás</h2>
            <div class="especialidades-grid">
              {dulceria.especialidades.map(esp => (
                <div class="especialidad-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <span>{esp}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Servicios -->
          <section class="negocio-seccion">
            <h2>Servicios</h2>
            <div class="servicios-grid">
              {dulceria.servicios.map(serv => (
                <div class="servicio-card">
                  <h3>{serv.nombre}</h3>
                  <p>{serv.descripcion}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar para confirmar.</p>
          </section>

          <!-- Ubicación -->
          <section class="negocio-seccion">
            <h2>Cómo Llegar</h2>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> {dulceria.ciudad}</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
                <p><strong>Referencia:</strong> Sobre la Avenida Azcapotzalco, cerca del centro de la alcaldía</p>
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías -->
  <section class="otras-dulcerias section-padding">
    <div class="container">
      <SectionHeader
        title="Otras Dulcerías en"
        titleHighlight="CDMX"
        subtitle="Explora más opciones de dulcerías verificadas"
      />
      <div class="service-grid">
        <ServiceCard
          href="/directorio/dulceria-mixcoac"
          image="/img/galeria/candy-bar-colorido-fiestas.avif"
          alt="Dulcería Mixcoac - Dulces tradicionales y modernos"
          title="Dulcería Mixcoac"
          excerpt="4.2 estrellas (596 reseñas). Amplia variedad de dulces tradicionales y modernos en Mixcoac."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-melissa"
          image="/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif"
          alt="Dulcería Melissa - Atención personalizada para eventos"
          title="Dulcería Melissa"
          excerpt="4.5 estrellas (637 reseñas). Especializada en atención personalizada para eventos en Aragón."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-guachitos"
          image="/img/galeria/dulces-variados-mesa.avif"
          alt="Dulcería Guachitos - Precios accesibles en Av. Tláhuac"
          title="Dulcería Guachitos"
          excerpt="4.3 estrellas (628 reseñas). Popular dulcería en Av. Tláhuac con precios accesibles y horario extendido."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-la-27"
          image="/img/galeria/candy-bar-profesional-eventos.avif"
          alt="Dulcería La 27 - Excelente atención en Ignacio Zaragoza"
          title="Dulcería La 27"
          excerpt="4.6 estrellas (111 reseñas). La mejor calificación de Ignacio Zaragoza con excelente atención."
          cta="Ver Dulcería"
        />
      </div>
      <div class="ver-todas-wrapper">
        <a href="/directorio/todos" class="btn-ver-todas">
          Ver todas las dulcerías
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20dulces%20para%20mi%20evento"
    badge="Mesa de Dulces"
    title="¿Necesitas una Mesa de Dulces"
    titleHighlight="Profesional"
    text="En Mededul diseñamos mesas de dulces personalizadas para bodas, XV años, baby showers y todo tipo de eventos."
    buttonText="Cotizar Mesa de Dulces"
  />
</BaseLayout>

<style>
  /* Hero del Negocio */
  .negocio-hero {
    padding: 60px 0 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .negocio-hero-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 60px;
    align-items: center;
  }

  .verificado-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .verificado-badge svg {
    width: 20px;
    height: 20px;
  }

  .negocio-hero-info h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .negocio-tipo {
    font-size: 1.1rem;
    color: var(--rosa-principal);
    font-weight: 500;
    margin: 0 0 20px;
  }

  .negocio-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .rating-stars {
