---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import { todasLasDulcerias, getEstadisticasDirectorio } from '@/data/dulcerias';

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Todos los Proveedores', url: '/directorio/todos' }
];

// Ordenar por reseñas (más populares primero)
const proveedores = [...todasLasDulcerias].sort((a, b) => b.resenas - a.resenas);
const stats = getEstadisticasDirectorio();

// Categorías únicas
const categorias = ['Todos', ...new Set(proveedores.map(p => p.tipo))];

// Alcaldías únicas
const alcaldias = [...new Set(proveedores.map(p => p.alcaldia))].sort();

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio Completo de Dulcerías en CDMX",
  "description": `Listado completo de ${stats.total} dulcerías verificadas en Ciudad de México`,
  "numberOfItems": stats.total,
  "itemListElement": proveedores.slice(0, 20).map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "address": `${p.direccion}, ${p.colonia}, ${p.alcaldia}`,
      "telephone": p.telefono !== 'Sin teléfono registrado' ? `+52${p.telefono.replace(/\s/g, '')}` : undefined,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": p.rating,
        "reviewCount": p.resenas
      }
    }
  }))
};
---

<BaseLayout
  title={`${stats.total} Dulcerías en CDMX | Directorio Completo Verificado 2026`}
  description={`Directorio completo de ${stats.total} dulcerías verificadas en ${stats.alcaldias} alcaldías de Ciudad de México. +${stats.totalResenas.toLocaleString()} reseñas reales. Encuentra la dulcería perfecta para tu evento.`}
  canonical="/directorio/todos"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(listSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Todas las Dulcerías"
    highlight="Dulcerías"
    subtitle="Directorio completo de proveedores verificados"
    secondaryContent={`<p>Explora nuestro directorio completo de <strong>dulcerías en CDMX</strong>. Todas verificadas con información real de Google Maps.</p><p><strong>${stats.total} dulcerías</strong> en ${stats.alcaldias} alcaldías con +${stats.totalResenas.toLocaleString()} reseñas de clientes reales.</p>`}
    showCTA={false}
  />

  <section class="filtros-section">
    <div class="container">
      <div class="filtros-wrapper">
        <div class="filtros-categorias">
          {categorias.map((cat, i) => (
            <button class={`filtro-btn ${i === 0 ? 'active' : ''}`} data-categoria={cat}>{cat}</button>
          ))}
        </div>
        <div class="filtros-secundarios">
          <select class="filtro-select" id="filtro-zona">
            <option value="">Todas las alcaldías</option>
            {alcaldias.map(alc => (
              <option value={alc.toLowerCase().replace(/\./g, '').replace(/\s/g, '-').replace(/á/g, 'a').replace(/é/g, 'e').replace(/í/g, 'i').replace(/ó/g, 'o').replace(/ú/g, 'u')}>{alc}</option>
            ))}
          </select>
          <select class="filtro-select" id="filtro-orden">
            <option value="resenas">Más reseñas</option>
            <option value="rating">Mejor calificados</option>
            <option value="nombre">Nombre A-Z</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <div class="directorio-layout">
    <div class="container">
      <div class="directorio-grid">
        <main class="directorio-main">
          <div class="proveedores-header">
            <span class="resultados-count">{stats.total} dulcerías encontradas</span>
            <div class="stats-mini">
              <span><strong>{stats.verificadas}</strong> verificadas</span>
              <span><strong>{stats.destacadas}</strong> destacadas</span>
              <span><strong>+{stats.totalResenas.toLocaleString()}</strong> reseñas</span>
            </div>
          </div>

          <div class="proveedores-grid">
            {proveedores.map(prov => (
              <div data-categoria={prov.tipo} data-alcaldia={prov.alcaldiaSlug}>
                <DulceriaCard dulceria={prov} />
              </div>
            ))}
          </div>
        </main>

        <DirectorioSidebar currentSlug="todos" />
      </div>
    </div>
  </div>

  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20ayuda%20para%20encontrar%20una%20dulcería"
    badge="Ayuda Personalizada"
    title="¿No encuentras lo que"
    titleHighlight="buscas"
    text="Te ayudamos a encontrar la dulcería perfecta para tu evento. Conocemos todas las dulcerías del directorio."
    buttonText="Pedir Recomendación"
  />
</BaseLayout>

<style>
  .filtros-section {
    padding: 24px 0;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    position: sticky;
    top: 70px;
    z-index: 50;
  }

  .filtros-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .filtros-categorias {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filtro-btn {
    padding: 10px 20px;
    background: #f5f5f5;
    border: none;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--texto-oscuro);
    cursor: pointer;
    transition: all 0.3s;
  }

  .filtro-btn:hover,
  .filtro-btn.active {
    background: var(--rosa-principal);
    color: #fff;
  }

  .filtros-secundarios {
    display: flex;
    gap: 12px;
  }

  .filtro-select {
    padding: 10px 20px;
    border: 2px solid #f0f0f0;
    border-radius: 10px;
    font-size: 0.9rem;
    background: #fff;
  }

  .directorio-layout {
    padding: 50px 0 80px;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .directorio-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 40px;
  }

  .proveedores-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .resultados-count {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--texto-oscuro);
  }

  .stats-mini {
    display: flex;
    gap: 20px;
    font-size: 0.9rem;
    color: var(--texto-light);
  }

  .stats-mini strong {
    color: var(--rosa-principal);
  }

  .proveedores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  @media (max-width: 1200px) {
    .directorio-grid {
      grid-template-columns: 1fr;
    }

    .proveedores-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .proveedores-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .filtros-categorias {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 10px;
    }

    .filtro-btn {
      flex-shrink: 0;
    }

    .filtros-section {
      top: 60px;
    }

    .filtros-secundarios {
      flex-direction: column;
    }

    .filtro-select {
      width: 100%;
    }

    .proveedores-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .proveedores-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
