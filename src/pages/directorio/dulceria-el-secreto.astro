---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

// Datos de la dulcería
const dulceria = {
  nombre: 'Dulcería El Secreto',
  slug: 'dulceria-el-secreto',
  tipo: 'Tienda de Golosinas Premium',
  descripcion: 'Dulcería premium ubicada en la exclusiva zona de San Ángel Inn, Álvaro Obregón. Especializada en chocolates artesanales, confitería importada y productos gourmet para eventos de alto nivel en la Ciudad de México.',
  metaDescription: 'Dulcería El Secreto - Dulces gourmet y chocolates artesanales en San Ángel Inn. ⭐ 4.4/5 (87 reseñas). Confitería premium para eventos exclusivos. Tel: 55 5550 3622',
  direccion: 'Av. Altavista 131',
  colonia: 'San Ángel Inn',
  alcaldia: 'Álvaro Obregón',
  cp: '01060',
  ciudad: 'Ciudad de México',
  telefono: '55 5550 3622',
  rating: 4.4,
  resenas: 87,
  mapsUrl: 'https://maps.app.goo.gl/sanangel',
  imagen: '/img/galeria/candy-bar-gourmet-elegante.avif',
  imagenes: [
    '/img/galeria/candy-bar-gourmet-elegante.avif',
    '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif',
    '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif'
  ],
  horario: {
    lunes: '10:00 - 19:00',
    martes: '10:00 - 19:00',
    miercoles: '10:00 - 19:00',
    jueves: '10:00 - 19:00',
    viernes: '10:00 - 19:00',
    sabado: '10:00 - 18:00',
    domingo: 'Cerrado'
  },
  especialidades: [
    'Zona premium',
    'Dulces selectos',
    'Productos gourmet',
    'Chocolates finos',
    'Confitería de autor',
    'Eventos exclusivos'
  ],
  servicios: [
    { nombre: 'Chocolates Artesanales', descripcion: 'Selección de chocolates finos belgas, suizos y mexicanos de alta gama' },
    { nombre: 'Confitería Importada', descripcion: 'Dulces exclusivos de Europa y Estados Unidos para paladares exigentes' },
    { nombre: 'Asesoría para Eventos', descripcion: 'Servicio personalizado para bodas, XV años y eventos corporativos premium' },
    { nombre: 'Empaque de Regalo', descripcion: 'Presentaciones elegantes y personalizadas para obsequios distinguidos' }
  ],
  verificado: true
};

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: dulceria.alcaldia, url: '/directorio/cdmx/alvaro-obregon' },
  { name: dulceria.nombre, url: `/directorio/${dulceria.slug}` }
];

const faqsDulceria = [
  {
    question: `¿${dulceria.nombre} ofrece productos para bodas de lujo?`,
    answer: 'Sí, Dulcería El Secreto está especializada en eventos de alto nivel. Ofrecen una selección curada de chocolates belgas, confitería importada y dulces artesanales perfectos para bodas elegantes, cenas de ensayo y eventos nupciales premium. Pueden asesorarte en la selección según tu temática y presupuesto.'
  },
  {
    question: '¿Tienen chocolates importados y artesanales?',
    answer: 'Absolutamente. Su especialidad son los chocolates finos: marcas belgas y suizas, chocolate mexicano de origen, trufas artesanales y bombones de autor. También manejan presentaciones especiales para regalo y eventos corporativos de alta gama.'
  },
  {
    question: '¿Es posible hacer pedidos personalizados para eventos exclusivos?',
    answer: 'Sí, ofrecen servicio de pedidos personalizados para eventos de alto nivel. Pueden preparar selecciones especiales, empaques corporativos con branding, y asesorarte en cantidades y presentaciones para tu evento. Recomendamos contactarlos con anticipación para pedidos grandes.'
  },
  {
    question: '¿Qué los diferencia de otras dulcerías?',
    answer: 'Dulcería El Secreto se distingue por su ubicación en la exclusiva zona de San Ángel Inn, su selección curada de productos gourmet y premium, y su enfoque en clientes que buscan calidad sobre cantidad. Ideal para quienes organizan eventos donde cada detalle importa.'
  }
];

// Schema para SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": dulceria.nombre,
  "description": dulceria.descripcion,
  "image": `https://mesas-de-dulces.com${dulceria.imagen}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": dulceria.direccion,
    "addressLocality": dulceria.alcaldia,
    "addressRegion": "CDMX",
    "postalCode": dulceria.cp,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.3468",
    "longitude": "-99.1931"
  },
  "telephone": `+52${dulceria.telefono.replace(/\s/g, '')}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": dulceria.rating,
    "reviewCount": dulceria.resenas,
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "10:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "18:00"
    }
  ]
};
---

<BaseLayout
  title={`${dulceria.nombre} | Dulcería Premium y Gourmet en San Ángel Inn, ${dulceria.alcaldia}`}
  description={dulceria.metaDescription}
  canonical={`/directorio/${dulceria.slug}`}
  ogImage={dulceria.imagen}
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero del Negocio -->
  <section class="negocio-hero">
    <div class="container">
      <div class="negocio-hero-content">
        <div class="negocio-hero-info">
          {dulceria.verificado && (
            <span class="verificado-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Verificado en Google
            </span>
          )}
          <span class="premium-badge">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Zona Premium
          </span>
          <h1>{dulceria.nombre}</h1>
          <p class="negocio-tipo">{dulceria.tipo}</p>

          <div class="negocio-rating">
            <div class="rating-stars">
              {[1,2,3,4,5].map(star => (
                <svg viewBox="0 0 24 24" fill={star <= Math.floor(dulceria.rating) ? "#FFB800" : "#E0E0E0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="rating-numero">{dulceria.rating}</span>
            <span class="rating-resenas">({dulceria.resenas.toLocaleString()} reseñas en Google)</span>
          </div>

          <div class="negocio-ubicacion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="direccion">{dulceria.direccion}</p>
              <p class="zona">{dulceria.colonia}, {dulceria.alcaldia}, CDMX</p>
            </div>
          </div>

          <div class="negocio-acciones">
            <a href={`tel:+52${dulceria.telefono.replace(/\s/g, '')}`} class="btn-principal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Llamar: {dulceria.telefono}
            </a>
            <a href={`https://wa.me/52${dulceria.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul%20y%20me%20gustaría%20información%20sobre%20productos%20premium`} class="btn-whatsapp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a href={dulceria.mapsUrl} class="btn-mapa" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <div class="negocio-hero-imagen">
          <img
            src={getCdnUrl(dulceria.imagen, { w: 600, q: 85 })}
            alt={`${dulceria.nombre} - Dulcería Gourmet en San Ángel Inn`}
            width="600"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="negocio-layout">
    <div class="container">
      <div class="negocio-grid">
        <!-- Main Content -->
        <main class="negocio-main">
          <!-- Descripción -->
          <section class="negocio-seccion descripcion-principal">
            <h2>Sobre {dulceria.nombre}</h2>
            <div class="descripcion-contenido">
              <p class="descripcion-intro">Ubicada en el corazón de <strong>San Ángel Inn</strong>, una de las zonas más exclusivas de la Ciudad de México, Dulcería El Secreto se ha consolidado como <strong>referente en confitería premium y chocolates artesanales</strong>. Con una calificación de 4.4 estrellas y una clientela selecta, esta boutique de dulces atiende a quienes buscan <strong>productos gourmet de la más alta calidad</strong>.</p>
              <p class="descripcion-texto">Su selección cuidadosamente curada incluye <strong>chocolates belgas y suizos</strong>, trufas artesanales, confitería importada de Europa y dulces de autor mexicanos. Cada producto es seleccionado pensando en eventos donde cada detalle cuenta: <strong>bodas de lujo, cenas de gala, eventos corporativos</strong> y celebraciones que requieren un nivel de sofisticación superior.</p>
              <p class="descripcion-texto">La ubicación en <strong>Av. Altavista 131</strong> no es casualidad: San Ángel Inn es sinónimo de elegancia y buen gusto en CDMX. Aquí encontrarás no solo productos excepcionales, sino también <strong>asesoría personalizada</strong> para crear experiencias dulces memorables en tus eventos más importantes.</p>
            </div>
          </section>

          <!-- Beneficios Cards -->
          <section class="negocio-seccion beneficios-section">
            <h2>¿Por qué elegir Dulcería El Secreto?</h2>
            <div class="beneficios-grid">
              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <h3>Zona Premium San Ángel</h3>
                <p>Ubicada en la <strong>exclusiva San Ángel Inn</strong>, una de las colonias más elegantes de CDMX. Ambiente sofisticado y atención de primer nivel.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <h3>Dulces Gourmet Selectos</h3>
                <p><strong>Confitería importada</strong> de Europa, dulces de autor y productos exclusivos que no encontrarás en dulcerías convencionales.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <line x1="3" y1="9" x2="21" y2="9"/>
                    <line x1="9" y1="21" x2="9" y2="9"/>
                  </svg>
                </div>
                <h3>Chocolates Artesanales Finos</h3>
                <p><strong>Chocolates belgas, suizos y mexicanos de origen</strong>. Trufas, bombones y presentaciones premium para regalo y eventos.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </div>
                <h3>Eventos de Alto Nivel</h3>
                <p>Especialistas en <strong>bodas elegantes, XV años de lujo</strong> y eventos corporativos donde cada detalle debe ser impecable.</p>
              </div>
            </div>
          </section>

          <!-- Productos Destacados -->
          <section class="negocio-seccion productos-section">
            <h2>Productos Premium que Encontrarás</h2>
            <div class="productos-lista">
              <div class="producto-categoria">
                <span class="producto-tag">Chocolates Artesanales</span>
                <p>Trufas belgas, bombones suizos, chocolate mexicano de origen único y creaciones de chocolatiers reconocidos</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Confitería Importada</span>
                <p>Dulces finos de Francia, Italia, Alemania y Estados Unidos. Marcas exclusivas no disponibles en tiendas convencionales</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Dulces de Autor</span>
                <p>Creaciones únicas de confiteros mexicanos, caramelos artesanales y golosinas gourmet de producción limitada</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Macarons y Petit Fours</span>
                <p>Delicadas piezas francesas, galletas gourmet y minipostres perfectos para mesas de dulces elegantes</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Presentaciones de Regalo</span>
                <p>Cajas y empaques premium, cestas gourmet personalizadas y obsequios corporativos distinguidos</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Confites para Eventos</span>
                <p>Almendras garapiñadas, dragées, confetti italiano y dulces selectos para bodas y celebraciones de lujo</p>
              </div>
            </div>
          </section>

          <!-- Especialidades -->
          <section class="negocio-seccion">
            <h2>Lo que Encontrarás</h2>
            <div class="especialidades-grid">
              {dulceria.especialidades.map(esp => (
                <div class="especialidad-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <span>{esp}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Servicios -->
          <section class="negocio-seccion">
            <h2>Servicios Premium</h2>
            <div class="servicios-grid">
              {dulceria.servicios.map(serv => (
                <div class="servicio-card">
                  <h3>{serv.nombre}</h3>
                  <p>{serv.descripcion}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar para confirmar disponibilidad de productos específicos.</p>
          </section>

          <!-- Ubicación -->
          <section class="negocio-seccion">
            <h2>Cómo Llegar</h2>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> {dulceria.ciudad}</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
                <p><strong>Referencia:</strong> Zona de San Ángel, cerca del Museo de El Carmen y Plaza San Jacinto</p>
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías -->
  <section class="otras-dulcerias section-padding">
    <div class="container">
      <SectionHeader
        title="Otras Dulcerías en"
        titleHighlight="CDMX"
        subtitle="Explora más opciones de dulcerías verificadas"
      />
      <div class="service-grid">
        <ServiceCard
          href="/directorio/dulceria-el-remate"
          image="/img/galeria/candy-bar-colorido-fiestas.avif"
          alt="Dulcería El Remate - La más reseñada de CDMX"
          title="Dulcería El Remate"
          excerpt="4.1 estrellas (1,062 reseñas). La más reseñada de CDMX con precios accesibles en Av. Juárez."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-el-gordo"
          image="/img/galeria/dulces-variados-mesa.avif"
          alt="Dulcería El Gordo - Tradición desde 1995 en Iztapalapa"
          title="Dulcería El Gordo"
          excerpt="4.1 estrellas (529 reseñas). Tradición desde 1995 con precios mayoreo en Iztapalapa."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-agam"
          image="/img/galeria/barra-dulces-fiestas-cdmx.avif"
          alt="Dulcería Agam - Calidad y variedad en Iztapalapa"
          title="Dulcería Agam"
          excerpt="4.5 estrellas (229 reseñas). Excelente calidad y variedad en Iztapalapa con precios competitivos."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-candy-gram"
          image="/img/galeria/mesa-dulces-tematica-personalizada.avif"
          alt="Dulcería Candy Gram - Servicio personalizado en Iztapalapa"
          title="Dulcería Candy Gram"
          excerpt="4.1 estrellas (15 reseñas). Servicio personalizado y productos de calidad en Iztapalapa."
          cta="Ver Dulcería"
        />
      </div>
      <div class="ver-todas-wrapper">
        <a href="/directorio/todos" class="btn-ver-todas">
          Ver todas las dulcerías
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20una%20mesa%20de%20dulces%20premium%20para%20mi%20evento"
    badge="Mesa de Dulces Premium"
    title="¿Necesitas una Mesa de Dulces"
    titleHighlight="Exclusiva"
    text="En Mededul diseñamos mesas de dulces gourmet y premium para bodas elegantes, XV años de lujo y eventos de alto nivel."
    buttonText="Cotizar Mesa Premium"
  />
</BaseLayout>

<style>
  /* Hero del Negocio */
  .negocio-hero {
    padding: 60px 0 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .negocio-hero-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 60px;
    align-items: center;
  }

  .verificado-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 8px 16px;
    border-radius: 50px;
