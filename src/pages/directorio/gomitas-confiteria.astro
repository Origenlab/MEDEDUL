---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { getCdnUrl } from '@/lib/cdn';

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: 'Gomitas y Confitería', url: '/directorio/gomitas-confiteria' }
];

const proveedores = [
  {
    nombre: 'El Bofito Norte 70',
    slug: 'el-bofito-norte-70',
    descripcion: 'Una de las dulcerías más grandes de CDMX con enorme variedad de gomitas nacionales e importadas. Precios de mayoreo ideales para eventos grandes.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 5551 7733',
    imagen: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    rating: 4.3,
    resenas: 2947,
    verificado: true,
    destacado: true,
    especialidades: ['Gomitas a granel', 'Mayoreo', 'Variedad importada']
  },
  {
    nombre: 'Dulcería Melissa',
    slug: 'dulceria-melissa',
    descripcion: 'Dulcería con excelente calificación (4.5) y amplio surtido de gomitas, confitería y dulces para fiestas infantiles.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 7675 9070',
    imagen: '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif',
    rating: 4.5,
    resenas: 637,
    verificado: true,
    destacado: true,
    especialidades: ['Gomitas variadas', 'Fiestas infantiles', 'Confitería']
  },
  {
    nombre: 'Dulcería Guachitos',
    slug: 'dulceria-guachitos',
    descripcion: 'Popular dulcería en Iztapalapa con surtido de gomitas enchiladas, confitería y todo para armar piñatas coloridas.',
    ubicacion: 'La Esperanza, Iztapalapa',
    telefono: '55 5607 5406',
    imagen: '/img/galeria/candy-bar-infantil-colorido.avif',
    rating: 4.3,
    resenas: 628,
    verificado: true,
    destacado: true,
    especialidades: ['Gomitas enchiladas', 'Piñatas', 'Dulces infantiles']
  },
  {
    nombre: 'Dulcería El Remate',
    slug: 'dulceria-el-remate',
    descripcion: 'Dulcería de mayoreo con más de 2,400 reseñas. Gran surtido de gomitas, malvaviscos y confitería para eventos.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 5551 6249',
    imagen: '/img/galeria/mesa-dulces-mexicanos-tradicionales-exterior.avif',
    rating: 4.4,
    resenas: 2410,
    verificado: true,
    destacado: true,
    especialidades: ['Mayoreo', 'Malvaviscos', 'Confitería variada']
  },
  {
    nombre: 'Dulcería Chispita',
    slug: 'dulceria-chispita',
    descripcion: 'Dulcería céntrica en Azcapotzalco con variedad de gomitas, botanas y artículos para fiestas a precios accesibles.',
    ubicacion: 'Centro de Azcapotzalco',
    telefono: '55 6788 0847',
    imagen: '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif',
    rating: 4.1,
    resenas: 123,
    verificado: true,
    destacado: false,
    especialidades: ['Gomitas variadas', 'Botanas', 'Artículos para fiestas']
  },
  {
    nombre: 'Dulcería Agam',
    slug: 'dulceria-agam',
    descripcion: 'Pequeña dulcería con la mejor calificación de la zona (4.6). Atención personalizada y buen surtido de gomitas y confitería.',
    ubicacion: 'Bondojito, Gustavo A. Madero',
    telefono: '55 7155 0262',
    imagen: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    rating: 4.6,
    resenas: 36,
    verificado: true,
    destacado: false,
    especialidades: ['Mejor calificación zona', 'Atención personalizada', 'Confitería']
  }
];

const faqsCategoria = [
  {
    question: '¿Dónde comprar gomitas a mayoreo en CDMX?',
    answer: 'Las mejores opciones para comprar gomitas a mayoreo son El Bofito Norte 70 y Dulcería El Remate en la zona de Bondojito (Gustavo A. Madero). Ambas tienen miles de reseñas y precios competitivos.'
  },
  {
    question: '¿Tienen gomitas enchiladas y con chamoy?',
    answer: 'Sí, todas las dulcerías del directorio manejan gomitas enchiladas y con chamoy. Dulcería Guachitos en Iztapalapa es especialmente conocida por sus gomitas picosas.'
  },
  {
    question: '¿Puedo armar paquetes de gomitas para mesas de dulces?',
    answer: 'Sí, la mayoría de las dulcerías ofrecen asesoría para armar paquetes por cantidad de invitados. Contacta directamente para cotizaciones personalizadas.'
  },
  {
    question: '¿Cuál dulcería tiene la mejor calificación para gomitas?',
    answer: 'Dulcería Agam tiene la mejor calificación (4.6) de la zona, seguida de Dulcería Melissa (4.5). Ambas ofrecen excelente variedad de gomitas y atención personalizada.'
  }
];

const categoriaSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Proveedores de Gomitas y Confitería en CDMX",
  "description": "Directorio de dulcerías con gomitas, malvaviscos y confitería variada en Ciudad de México",
  "numberOfItems": proveedores.length,
  "itemListElement": proveedores.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.nombre,
      "description": p.descripcion,
      "telephone": `+52${p.telefono.replace(/\s/g, '')}`,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": p.rating,
        "reviewCount": p.resenas
      }
    }
  }))
};
---

<BaseLayout
  title="Gomitas y Confitería | Directorio CDMX 2025"
  description={`${proveedores.length} dulcerías con gomitas, malvaviscos y confitería en CDMX. Mayoreo y menudeo. Gomitas enchiladas, importadas y más.`}
  canonical="/directorio/gomitas-confiteria"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(categoriaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Gomitas y Confiteria en CDMX"
    highlight="Gomitas"
    subtitle={`${proveedores.length} dulcerias verificadas con gomitas importadas, enchiladas artesanales, mashmelos y confiteria a granel`}
    secondaryContent={`<p><strong>Gomitas y confiteria de alta rotacion</strong> en Ciudad de Mexico, curadas en este directorio con tiendas que manejan desde marcas importadas premium hasta gomitas enchiladas artesanales con chamoy, tamarindo y chile en polvo. Cada proveedor verificado incluye datos reales de Google Maps, horarios, especialidad y rango de precios para que surtas con confianza y producto fresco.</p><p><strong>${proveedores.length} dulcerias verificadas</strong> te permiten comparar precios por mayoreo, variedad de gomitas acidas, gomitas de oso, confiteria a granel, mashmelos y clasicos como malvaviscos cubiertos de chocolate. Ideales para abastecer mesas de dulces, candy bar infantil, bolos de fiesta y eventos empresariales con presupuesto y logistica controlados.</p>`}
  />

  <section class="filtros-section">
    <div class="container">
      <div class="filtros-wrapper">
        <span class="resultados-count">{proveedores.length} proveedores encontrados</span>
        <div class="filtros-opciones">
          <select class="filtro-select">
            <option value="">Todas las alcaldías</option>
            <option value="gam">Gustavo A. Madero</option>
            <option value="iztapalapa">Iztapalapa</option>
            <option value="azcapotzalco">Azcapotzalco</option>
          </select>
          <select class="filtro-select">
            <option value="">Ordenar por</option>
            <option value="rating">Mejor calificados</option>
            <option value="resenas">Más reseñas</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <div class="directorio-layout">
    <div class="container">
      <div class="directorio-grid">
        <main class="directorio-main">
          <div class="proveedores-lista">
            {proveedores.map(prov => (
              <div class={`proveedor-item ${prov.destacado ? 'proveedor-item--destacado' : ''}`}>
                <div class="proveedor-imagen">
                  <img src={getCdnUrl(prov.imagen, { w: 400, q: 80 })} alt={prov.nombre} loading="lazy" width="400" height="300" />
                  {prov.destacado && <span class="badge-destacado">Destacado</span>}
                </div>
                <div class="proveedor-contenido">
                  <div class="proveedor-header">
                    <div>
                      <h2>{prov.nombre}</h2>
                      <div class="proveedor-ubicacion">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {prov.ubicacion}
                      </div>
                    </div>
                    {prov.verificado && <span class="badge-verificado"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Verificado</span>}
                  </div>
                  <p class="proveedor-descripcion">{prov.descripcion}</p>
                  <div class="proveedor-especialidades">{prov.especialidades.map(esp => <span class="especialidad-tag">{esp}</span>)}</div>
                  <div class="proveedor-footer">
                    <div class="proveedor-rating">
                      <div class="rating-stars">{[1,2,3,4,5].map(star => <svg viewBox="0 0 24 24" fill={star <= Math.floor(prov.rating) ? "#FFB800" : "#E0E0E0"}><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                      <span class="rating-numero">{prov.rating}</span>
                      <span class="rating-resenas">({prov.resenas.toLocaleString()} reseñas)</span>
                    </div>
                    <div class="proveedor-acciones">
                      <a href={`/directorio/${prov.slug}`} class="btn-perfil">Ver perfil</a>
                      <a href={`https://wa.me/52${prov.telefono.replace(/\s/g, '')}`} class="btn-whatsapp" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>Contactar</a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </main>

        <DirectorioSidebar currentSlug="gomitas-confiteria" showCategorias={true} />
      </div>
    </div>
  </div>

  <section class="otras-categorias">
    <div class="container">
      <SectionHeader title="Explora Otras" titleHighlight="Categorías" subtitle="Más opciones para tu evento" />
      <div class="categorias-grid">
        <a href="/directorio/dulces-tradicionales" class="cat-link"><span class="cat-icon">🍬</span><span>Dulces Tradicionales</span></a>
        <a href="/directorio/chocolates-trufas" class="cat-link"><span class="cat-icon">🍫</span><span>Chocolates y Trufas</span></a>
        <a href="/directorio/galletas-cupcakes" class="cat-link"><span class="cat-icon">🧁</span><span>Galletas y Cupcakes</span></a>
        <a href="/directorio/paletas-piruletas" class="cat-link"><span class="cat-icon">🍡</span><span>Paletas y Piruletas</span></a>
        <a href="/directorio/dulces-importados" class="cat-link"><span class="cat-icon">🌍</span><span>Dulces Importados</span></a>
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsCategoria} />
</BaseLayout>

<style>
  .filtros-section { padding: 24px 0; background: #fff; border-bottom: 1px solid #f0f0f0; position: sticky; top: 70px; z-index: 50; }
  .filtros-wrapper { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
  .resultados-count { font-weight: 600; color: var(--texto-oscuro); }
  .filtros-opciones { display: flex; gap: 12px; }
  .filtro-select { padding: 10px 20px; border: 2px solid #f0f0f0; border-radius: 10px; font-size: 0.9rem; background: #fff; cursor: pointer; }

  .directorio-layout { padding: 50px 0 80px; background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%); }
  .directorio-grid { display: grid; grid-template-columns: 1fr 340px; gap: 40px; }

  .proveedores-lista { display: flex; flex-direction: column; gap: 24px; }
  .proveedor-item { display: grid; grid-template-columns: 320px 1fr; background: #fff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border: 1px solid #f0f0f0; }
  .proveedor-item--destacado { border: 2px solid rgba(255, 184, 0, 0.4); box-shadow: 0 8px 30px rgba(255, 184, 0, 0.15); }
  .proveedor-imagen { position: relative; height: 100%; min-height: 240px; }
  .proveedor-imagen img { width: 100%; height: 100%; object-fit: cover; }
  .badge-destacado { position: absolute; top: 16px; left: 16px; background: linear-gradient(135deg, #FFB800 0%, #FF8C00 100%); color: #fff; padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
  .proveedor-contenido { padding: 28px; display: flex; flex-direction: column; }
  .proveedor-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 16px; }
  .proveedor-header h2 { font-family: 'Poppins', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--texto-oscuro); margin: 0 0 8px; }
  .proveedor-ubicacion { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; color: var(--texto-light); }
  .proveedor-ubicacion svg { width: 16px; height: 16px; }
  .badge-verificado { display: inline-flex; align-items: center; gap: 6px; background: rgba(37, 211, 102, 0.1); color: #128C7E; padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
  .badge-verificado svg { width: 18px; height: 18px; }
  .proveedor-descripcion { font-size: 0.95rem; color: var(--texto-light); line-height: 1.6; margin: 0 0 16px; }
  .proveedor-especialidades { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .especialidad-tag { background: rgba(209, 0, 122, 0.08); color: var(--rosa-principal); padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 500; }
  .proveedor-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px; border-top: 1px solid #f5f5f5; }
  .proveedor-rating { display: flex; align-items: center; gap: 8px; }
  .rating-stars { display: flex; gap: 2px; }
  .rating-stars svg { width: 18px; height: 18px; }
  .rating-numero { font-weight: 700; color: var(--texto-oscuro); }
  .rating-resenas { font-size: 0.85rem; color: var(--texto-light); }
  .proveedor-acciones { display: flex; gap: 12px; }
  .btn-perfil { padding: 10px 24px; border: 2px solid #f0f0f0; border-radius: 10px; font-size: 0.9rem; font-weight: 600; color: var(--texto-oscuro); text-decoration: none; }
  .btn-perfil:hover { border-color: var(--rosa-principal); color: var(--rosa-principal); }
  .btn-whatsapp { display: flex; align-items: center; gap: 8px; padding: 10px 24px; background: #25D366; border-radius: 10px; color: #fff; font-size: 0.9rem; font-weight: 600; text-decoration: none; }
  .btn-whatsapp svg { width: 20px; height: 20px; }
  .btn-whatsapp:hover { background: #128C7E; }

  .otras-categorias { padding: 80px 0; background: #fff; }
  .categorias-grid { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; margin-top: 40px; }
  .cat-link { display: flex; align-items: center; gap: 10px; padding: 14px 24px; background: #fff; border: 2px solid #f0f0f0; border-radius: 50px; text-decoration: none; color: var(--texto-oscuro); font-weight: 500; }
  .cat-link:hover { border-color: var(--rosa-principal); }
  .cat-icon { font-size: 1.3rem; }

  @media (max-width: 1200px) { .directorio-grid { grid-template-columns: 1fr; } }
  @media (max-width: 900px) { .proveedor-item { grid-template-columns: 1fr; } .proveedor-imagen { height: 200px; min-height: auto; } .filtros-wrapper { flex-direction: column; } }
  @media (max-width: 768px) { .filtros-section { top: 60px; } .proveedor-header, .proveedor-footer { flex-direction: column; gap: 16px; } .proveedor-acciones { width: 100%; } .btn-perfil, .btn-whatsapp { flex: 1; justify-content: center; } }
</style>
