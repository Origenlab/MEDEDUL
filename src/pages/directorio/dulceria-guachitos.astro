---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

// Datos de la dulcería
const dulceria = {
  nombre: 'Dulcería Guachitos',
  slug: 'dulceria-guachitos',
  tipo: 'Tienda de Golosinas',
  descripcion: 'Dulcería popular en Iztapalapa, ubicada sobre Av. Tláhuac. Reconocida por su variedad de dulces tradicionales, golosinas y artículos para fiestas con precios accesibles para la zona oriente de CDMX.',
  metaDescription: 'Dulcería Guachitos - Dulces y piñatas en Av. Tláhuac 4388, Lomas Estrella, Iztapalapa. ⭐ 4.3/5 (628 reseñas). Precios accesibles. Abierto domingos. Tel: 55 5607 5406',
  direccion: 'Av. Tláhuac 4388',
  colonia: 'Lomas Estrella',
  alcaldia: 'Iztapalapa',
  cp: '09890',
  ciudad: 'Ciudad de México',
  telefono: '55 5607 5406',
  rating: 4.3,
  resenas: 628,
  mapsUrl: 'https://maps.app.goo.gl/guachitos',
  imagen: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
  imagenes: [
    '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif',
    '/img/galeria/candy-bar-gourmet-elegante.avif'
  ],
  horario: {
    lunes: '9:00 - 20:00',
    martes: '9:00 - 20:00',
    miercoles: '9:00 - 20:00',
    jueves: '9:00 - 20:00',
    viernes: '9:00 - 20:00',
    sabado: '9:00 - 19:00',
    domingo: '10:00 - 15:00'
  },
  especialidades: [
    'Dulces tradicionales',
    'Golosinas variadas',
    'Artículos para fiestas',
    'Piñatas',
    'Botanas',
    'Precios accesibles'
  ],
  servicios: [
    { nombre: 'Dulces para eventos', descripcion: 'Surtido completo para cumpleaños, fiestas y celebraciones familiares' },
    { nombre: 'Piñatas y aguinaldos', descripcion: 'Variedad de piñatas y bolsas para fiestas infantiles' },
    { nombre: 'Botanas y frituras', descripcion: 'Amplio surtido de botanas para cualquier ocasión' },
    { nombre: 'Dulcería tradicional', descripcion: 'Dulces mexicanos y golosinas de todas las marcas' }
  ],
  verificado: true
};

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: dulceria.alcaldia, url: '/directorio/cdmx/iztapalapa' },
  { name: dulceria.nombre, url: `/directorio/${dulceria.slug}` }
];

const faqsDulceria = [
  {
    question: `¿${dulceria.nombre} abre los domingos?`,
    answer: 'Sí, Dulcería Guachitos abre los domingos de 10:00 a 15:00 horas. Es una de las pocas dulcerías en la zona oriente que ofrece servicio dominical, ideal para compras de último momento antes de tus eventos.'
  },
  {
    question: '¿Tienen estacionamiento disponible?',
    answer: 'Al estar ubicados sobre Av. Tláhuac, el estacionamiento puede ser limitado en hora pico. Te recomendamos llegar temprano entre semana o utilizar transporte público. Hay paradas de microbús y peseros cercanas.'
  },
  {
    question: '¿Venden piñatas y artículos para fiestas?',
    answer: 'Sí, Dulcería Guachitos cuenta con variedad de piñatas para diferentes ocasiones y temáticas. También encontrarás artículos básicos para fiestas como bolsas de dulces, botanas y confitería para tus celebraciones.'
  },
  {
    question: '¿Sus precios son de mayoreo o menudeo?',
    answer: 'Dulcería Guachitos maneja precios accesibles tanto para compras al menudeo como para cantidades medianas. Para compras muy grandes, te recomendamos llamar para consultar disponibilidad y posibles descuentos.'
  }
];

// Schema para SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": dulceria.nombre,
  "description": dulceria.descripcion,
  "image": `https://mesas-de-dulces.com${dulceria.imagen}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": dulceria.direccion,
    "addressLocality": dulceria.alcaldia,
    "addressRegion": "CDMX",
    "postalCode": dulceria.cp,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.3183",
    "longitude": "-99.0855"
  },
  "telephone": `+52${dulceria.telefono.replace(/\s/g, '')}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": dulceria.rating,
    "reviewCount": dulceria.resenas,
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Sunday",
      "opens": "10:00",
      "closes": "15:00"
    }
  ]
};
---

<BaseLayout
  title={`${dulceria.nombre} | Dulcería en Av. Tláhuac, ${dulceria.colonia}, ${dulceria.alcaldia}`}
  description={dulceria.metaDescription}
  canonical={`/directorio/${dulceria.slug}`}
  ogImage={dulceria.imagen}
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero del Negocio -->
  <section class="negocio-hero">
    <div class="container">
      <div class="negocio-hero-content">
        <div class="negocio-hero-info">
          {dulceria.verificado && (
            <span class="verificado-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Verificado en Google
            </span>
          )}
          <h1>{dulceria.nombre}</h1>
          <p class="negocio-tipo">{dulceria.tipo}</p>

          <div class="negocio-rating">
            <div class="rating-stars">
              {[1,2,3,4,5].map(star => (
                <svg viewBox="0 0 24 24" fill={star <= Math.floor(dulceria.rating) ? "#FFB800" : "#E0E0E0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="rating-numero">{dulceria.rating}</span>
            <span class="rating-resenas">({dulceria.resenas.toLocaleString()} reseñas en Google)</span>
          </div>

          <div class="negocio-ubicacion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="direccion">{dulceria.direccion}</p>
              <p class="zona">{dulceria.colonia}, {dulceria.alcaldia}, CDMX</p>
            </div>
          </div>

          <div class="negocio-acciones">
            <a href={`tel:+52${dulceria.telefono.replace(/\s/g, '')}`} class="btn-principal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Llamar: {dulceria.telefono}
            </a>
            <a href={`https://wa.me/52${dulceria.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul%20y%20me%20gustaría%20información`} class="btn-whatsapp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a href={dulceria.mapsUrl} class="btn-mapa" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <div class="negocio-hero-imagen">
          <img
            src={getCdnUrl(dulceria.imagen, { w: 600, q: 85 })}
            alt={`${dulceria.nombre} - Dulcería en Av. Tláhuac, Iztapalapa`}
            width="600"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="negocio-layout">
    <div class="container">
      <div class="negocio-grid">
        <!-- Main Content -->
        <main class="negocio-main">
          <!-- Descripción -->
          <section class="negocio-seccion descripcion-principal">
            <h2>Sobre {dulceria.nombre}</h2>
            <div class="descripcion-contenido">
              <p class="descripcion-intro">Con más de <strong>620 reseñas positivas en Google</strong> y una calificación de 4.3 estrellas, Dulcería Guachitos se ha consolidado como una de las <strong>dulcerías más populares de la zona oriente</strong> de la Ciudad de México. Su ubicación estratégica sobre <strong>Av. Tláhuac</strong> la hace accesible para vecinos de Lomas Estrella, Agrícola Oriental, Santa Martha y colonias cercanas de Iztapalapa.</p>
              <p class="descripcion-texto">Ubicada en <strong>Av. Tláhuac 4388</strong>, en la colonia Lomas Estrella, esta dulcería destaca por ofrecer <strong>precios accesibles</strong> sin sacrificar la variedad. Aquí encontrarás desde dulces tradicionales mexicanos hasta golosinas de marcas reconocidas, piñatas para todas las ocasiones y artículos básicos para fiestas infantiles.</p>
              <p class="descripcion-texto">Una de las ventajas de Dulcería Guachitos es su <strong>horario extendido incluyendo domingos</strong>, algo poco común en la zona. Esto te permite hacer compras de último momento para tus celebraciones familiares. Con atención de lunes a viernes hasta las 20:00 y domingos hasta las 15:00, siempre tendrás tiempo de surtir lo que necesitas.</p>
            </div>
          </section>

          <!-- Beneficios Cards -->
          <section class="negocio-seccion beneficios-section">
            <h2>¿Por qué elegir Dulcería Guachitos?</h2>
            <div class="beneficios-grid">
              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <h3>+620 Reseñas Positivas</h3>
                <p>Una de las <strong>dulcerías mejor valoradas</strong> de Iztapalapa. Los clientes destacan la variedad y los precios accesibles.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <h3>Sobre Av. Tláhuac</h3>
                <p>Ubicación <strong>fácil de encontrar</strong> en una de las avenidas principales de la zona oriente. Accesible en transporte público.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                  </svg>
                </div>
                <h3>Precios Accesibles</h3>
                <p><strong>Economía sin sacrificar calidad</strong>. Ideales para familias que buscan surtir sus fiestas sin gastar de más.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <h3>Abierto Domingos</h3>
                <p><strong>Horario extendido</strong> incluyendo domingos de 10 a 15 hrs. Perfecto para compras de último momento.</p>
              </div>
            </div>
          </section>

          <!-- Productos Destacados -->
          <section class="negocio-seccion productos-section">
            <h2>Productos que Encontrarás</h2>
            <div class="productos-lista">
              <div class="producto-categoria">
                <span class="producto-tag">Dulces Tradicionales</span>
                <p>Mazapanes, cocadas, alegrías, obleas, tamarindos, cajeta y toda la dulcería mexicana clásica</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Golosinas Variadas</span>
                <p>Gomitas, paletas, chiclosos, caramelos y dulces de todas las marcas populares</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Piñatas</span>
                <p>Variedad de modelos: personajes infantiles, números, estrellas y piñatas tradicionales</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Botanas y Frituras</span>
                <p>Amplio surtido de botanas, cacahuates, papas y frituras para fiestas y reuniones</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Artículos para Fiestas</span>
                <p>Bolsas para dulces, conos, complementos básicos para celebraciones infantiles</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Chocolates</span>
                <p>Marcas nacionales en presentaciones individuales y para compartir</p>
              </div>
            </div>
          </section>

          <!-- Especialidades -->
          <section class="negocio-seccion">
            <h2>Lo que Encontrarás</h2>
            <div class="especialidades-grid">
              {dulceria.especialidades.map(esp => (
                <div class="especialidad-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <span>{esp}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Servicios -->
          <section class="negocio-seccion">
            <h2>Servicios</h2>
            <div class="servicios-grid">
              {dulceria.servicios.map(serv => (
                <div class="servicio-card">
                  <h3>{serv.nombre}</h3>
                  <p>{serv.descripcion}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar para confirmar.</p>
          </section>

          <!-- Ubicación -->
          <section class="negocio-seccion">
            <h2>Cómo Llegar</h2>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> {dulceria.ciudad}</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
                <p><strong>Referencia:</strong> Sobre Av. Tláhuac, zona Lomas Estrella. Accesible en microbús y pesero.</p>
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías -->
  <section class="otras-dulcerias section-padding">
    <div class="container">
      <SectionHeader
        title="Otras Dulcerías en"
        titleHighlight="CDMX"
        subtitle="Explora más opciones de dulcerías verificadas"
      />
      <div class="service-grid">
        <ServiceCard
          href="/directorio/dulceria-mixcoac"
          image="/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif"
          alt="Dulcería Mixcoac - Amplia variedad de dulces tradicionales y modernos"
          title="Dulcería Mixcoac"
          excerpt="4.2 estrellas (596 reseñas). Amplia variedad de dulces tradicionales y modernos en Mixcoac."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-el-gordo"
          image="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
          alt="Dulcería El Gordo - Tradición desde 1995 con precios mayoreo"
          title="Dulcería El Gordo"
          excerpt="4.1 estrellas (529 reseñas). Tradición desde 1995 con precios mayoreo en Iztapalapa."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-la-27"
          image="/img/galeria/candy-bar-gourmet-elegante.avif"
          alt="Dulcería La 27 - La mejor calificación de Ignacio Zaragoza"
          title="Dulcería La 27"
          excerpt="4.6 estrellas (111 reseñas). La mejor calificación de Ignacio Zaragoza con excelente atención."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-agam"
          image="/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif"
          alt="Dulcería Agam - Excelente calidad y variedad en Iztapalapa"
          title="Dulcería Agam"
          excerpt="4.5 estrellas (229 reseñas). Excelente calidad y variedad en Iztapalapa con precios competitivos."
          cta="Ver Dulcería"
        />
      </div>
      <div class="ver-todas-wrapper">
        <a href="/directorio/todos" class="btn-ver-todas">
          Ver todas las dulcerías
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20dulces%20para%20mi%20evento"
    badge="Mesa de Dulces"
    title="¿Necesitas una Mesa de Dulces"
    titleHighlight="Profesional"
    text="En Mededul diseñamos mesas de dulces personalizadas para bodas, XV años, baby showers y todo tipo de eventos."
    buttonText="Cotizar Mesa de Dulces"
  />
</BaseLayout>

<style>
  /* Hero del Negocio */
  .negocio-hero {
    padding: 60px 0 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .negocio-hero-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 60px;
    align-items: center;
  }

  .verificado-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .verificado-badge svg {
    width: 20px;
    height: 20px;
  }

  .negocio-hero-info h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .negocio-tipo {
    font-size: 1.1rem;
    color: var(--rosa-principal);
    font-weight: 500;
