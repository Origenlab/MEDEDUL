---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import FAQ from '@/components/global/FAQ.astro';
import { getCdnUrl } from '@/lib/cdn';

// Datos de la dulcería
const dulceria = {
  nombre: 'El Bofito Norte 70',
  slug: 'el-bofito-norte-70',
  tipo: 'Tienda de Golosinas',
  descripcion: 'Dulcería de mayoreo y menudeo en Gustavo A. Madero, CDMX. Amplia variedad de dulces tradicionales mexicanos, gomitas, chocolates, botanas y artículos para fiestas. Más de 2,900 reseñas en Google.',
  metaDescription: 'El Bofito Norte 70 - Dulcería mayoreo en Aragón, CDMX. ⭐ 4.3/5 (2,947 reseñas). Dulces tradicionales, gomitas, chocolates y artículos para fiestas. Precios accesibles. Tel: 55 5551 7733',
  direccion: 'Nte. 70 6004, Aragón Inguarán',
  colonia: 'Aragón Inguarán',
  alcaldia: 'Gustavo A. Madero',
  cp: '07000',
  ciudad: 'Ciudad de México',
  telefono: '55 5551 7733',
  rating: 4.3,
  resenas: 2947,
  mapsUrl: 'https://maps.app.goo.gl/JV69HuQt3djPx9WZ9',
  imagen: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
  imagenes: [
    '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif',
    '/img/galeria/candy-bar-gourmet-elegante.avif',
    '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif'
  ],
  horario: {
    lunes: '9:00 - 20:00',
    martes: '9:00 - 20:00',
    miercoles: '9:00 - 20:00',
    jueves: '9:00 - 20:00',
    viernes: '9:00 - 20:00',
    sabado: '9:00 - 19:00',
    domingo: '10:00 - 16:00'
  },
  especialidades: [
    'Dulces a granel',
    'Golosinas importadas',
    'Dulces tradicionales mexicanos',
    'Botanas y frituras',
    'Piñatas y artículos para fiestas',
    'Mayoreo y menudeo'
  ],
  servicios: [
    { nombre: 'Venta por mayoreo', descripcion: 'Precios especiales para compras en cantidad' },
    { nombre: 'Variedad de dulces', descripcion: 'Miles de productos de diferentes marcas' },
    { nombre: 'Dulces tradicionales', descripcion: 'Mazapanes, cocadas, alegrías y más' },
    { nombre: 'Artículos para fiestas', descripcion: 'Todo para tu celebración' }
  ],
  verificado: true
};

const breadcrumbItems = [
  { name: 'Directorio', url: '/directorio' },
  { name: dulceria.alcaldia, url: '/directorio/cdmx/gustavo-a-madero' },
  { name: dulceria.nombre, url: `/directorio/${dulceria.slug}` }
];

const faqsDulceria = [
  {
    question: `¿${dulceria.nombre} vende por mayoreo?`,
    answer: 'Sí, El Bofito Norte 70 ofrece precios especiales para compras al mayoreo. Te recomendamos contactarlos directamente para consultar descuentos según la cantidad de tu pedido.'
  },
  {
    question: '¿Qué tipos de dulces puedo encontrar?',
    answer: 'Encontrarás una gran variedad: dulces tradicionales mexicanos (mazapanes, cocadas, alegrías), gomitas, chocolates, botanas, frituras, dulces importados y artículos para fiestas como piñatas.'
  },
  {
    question: '¿Hacen entregas a domicilio?',
    answer: 'Te recomendamos contactar directamente a la dulcería para consultar disponibilidad de envíos, especialmente para pedidos grandes de mayoreo.'
  },
  {
    question: '¿Aceptan todas las formas de pago?',
    answer: 'La mayoría de dulcerías en la zona aceptan efectivo. Para pagos con tarjeta, te sugerimos confirmar directamente con el negocio.'
  }
];

// Schema para SEO
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": dulceria.nombre,
  "description": dulceria.descripcion,
  "image": `https://mesas-de-dulces.com${dulceria.imagen}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": dulceria.direccion,
    "addressLocality": dulceria.alcaldia,
    "addressRegion": "CDMX",
    "postalCode": dulceria.cp,
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "19.4802",
    "longitude": "-99.0892"
  },
  "telephone": `+52${dulceria.telefono.replace(/\s/g, '')}`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": dulceria.rating,
    "reviewCount": dulceria.resenas,
    "bestRating": "5",
    "worstRating": "1"
  },
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Sunday",
      "opens": "10:00",
      "closes": "16:00"
    }
  ]
};
---

<BaseLayout
  title={`${dulceria.nombre} | Dulcería Mayoreo en Aragón, ${dulceria.alcaldia} CDMX`}
  description={dulceria.metaDescription}
  canonical={`/directorio/${dulceria.slug}`}
  ogImage={dulceria.imagen}
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero del Negocio -->
  <section class="negocio-hero">
    <div class="container">
      <div class="negocio-hero-content">
        <div class="negocio-hero-info">
          {dulceria.verificado && (
            <span class="verificado-badge">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Verificado en Google
            </span>
          )}
          <h1>{dulceria.nombre}</h1>
          <p class="negocio-tipo">{dulceria.tipo}</p>

          <div class="negocio-rating">
            <div class="rating-stars">
              {[1,2,3,4,5].map(star => (
                <svg viewBox="0 0 24 24" fill={star <= Math.floor(dulceria.rating) ? "#FFB800" : "#E0E0E0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="rating-numero">{dulceria.rating}</span>
            <span class="rating-resenas">({dulceria.resenas.toLocaleString()} reseñas en Google)</span>
          </div>

          <div class="negocio-ubicacion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="direccion">{dulceria.direccion}</p>
              <p class="zona">{dulceria.colonia}, {dulceria.alcaldia}, CDMX</p>
            </div>
          </div>

          <div class="negocio-acciones">
            <a href={`tel:+52${dulceria.telefono.replace(/\s/g, '')}`} class="btn-principal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
              Llamar: {dulceria.telefono}
            </a>
            <a href={`https://wa.me/52${dulceria.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul%20y%20me%20gustaría%20información`} class="btn-whatsapp" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a href={dulceria.mapsUrl} class="btn-mapa" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <div class="negocio-hero-imagen">
          <img
            src={getCdnUrl(dulceria.imagen, { w: 600, q: 85 })}
            alt={`${dulceria.nombre} - Dulcería en ${dulceria.alcaldia}`}
            width="600"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="negocio-layout">
    <div class="container">
      <div class="negocio-grid">
        <!-- Main Content -->
        <main class="negocio-main">
          <!-- Descripción -->
          <section class="negocio-seccion descripcion-principal">
            <h2>Sobre {dulceria.nombre}</h2>
            <div class="descripcion-contenido">
              <p class="descripcion-intro">Una de las <strong>dulcerías más grandes y reconocidas</strong> del norte de la Ciudad de México. Con más de <strong>2,900 reseñas en Google</strong> y una calificación de 4.3 estrellas, El Bofito Norte 70 se ha consolidado como el destino preferido para comprar <strong>dulces al mayoreo y menudeo</strong> en la zona de Aragón, Gustavo A. Madero.</p>
              <p class="descripcion-texto">Ubicada estratégicamente en la <strong>Avenida Norte 70 #6004</strong>, esta dulcería ofrece una experiencia de compra única con <strong>miles de productos</strong> a precios accesibles. Desde dulces tradicionales mexicanos como mazapanes, cocadas y alegrías, hasta gomitas importadas, chocolates de marcas reconocidas y todo lo necesario para armar tu <strong>mesa de dulces perfecta</strong>.</p>
              <p class="descripcion-texto">Ya sea que busques surtir tu negocio, organizar una fiesta infantil, preparar un evento especial o simplemente consentirte con tus dulces favoritos, El Bofito Norte 70 tiene todo lo que necesitas. Su amplio catálogo incluye <strong>botanas, frituras, piñatas y artículos para fiestas</strong>, convirtiéndose en tu aliado ideal para cualquier celebración.</p>
            </div>
          </section>

          <!-- Beneficios Cards -->
          <section class="negocio-seccion beneficios-section">
            <h2>¿Por qué elegir El Bofito Norte 70?</h2>
            <div class="beneficios-grid">
              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <h3>+2,900 Reseñas en Google</h3>
                <p>Con una calificación de <strong>4.3 estrellas</strong>, El Bofito se ha ganado la confianza de miles de familias y comerciantes que buscan dulces de calidad.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <h3>Ubicación Estratégica</h3>
                <p>En la <strong>Avenida Norte 70</strong>, Aragón Inguarán. Fácil acceso desde Gustavo A. Madero, Venustiano Carranza y alcaldías cercanas del norte de CDMX.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 12V8H6a2 2 0 01-2-2c0-1.1.9-2 2-2h12v4"/>
                    <path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/>
                    <path d="M18 12a2 2 0 000 4h4v-4h-4z"/>
                  </svg>
                </div>
                <h3>Precios de Mayoreo</h3>
                <p><strong>Descuentos especiales</strong> para compras en cantidad. Ideal para organizadores de eventos, tiendas, escuelas y comerciantes.</p>
              </div>

              <div class="beneficio-card">
                <div class="beneficio-icono">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                </div>
                <h3>Variedad Inigualable</h3>
                <p><strong>Miles de productos</strong>: dulces mexicanos, gomitas importadas, chocolates, botanas, piñatas y todo para mesas de dulces.</p>
              </div>
            </div>
          </section>

          <!-- Productos Destacados -->
          <section class="negocio-seccion productos-section">
            <h2>Productos que Encontrarás</h2>
            <div class="productos-lista">
              <div class="producto-categoria">
                <span class="producto-tag">Dulces Mexicanos</span>
                <p>Mazapanes, cocadas, alegrías, tamarindos, obleas, glorias y dulces tradicionales</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Gomitas y Confitería</span>
                <p>Gomitas importadas, nacionales, enchiladas, ácidas y de todas las marcas</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Chocolates</span>
                <p>Diversas marcas nacionales e importadas, bombones y chocolates para regalo</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Botanas y Frituras</span>
                <p>Papas, chicharrones, cacahuates, palomitas y snacks variados</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Artículos para Fiestas</span>
                <p>Piñatas, bolsas de dulces, decoraciones y todo para tu evento</p>
              </div>
              <div class="producto-categoria">
                <span class="producto-tag">Mesas de Dulces</span>
                <p>Surtido completo para armar mesas de dulces en bodas, XV años y baby showers</p>
              </div>
            </div>
          </section>

          <!-- Especialidades -->
          <section class="negocio-seccion">
            <h2>Lo que Encontrarás</h2>
            <div class="especialidades-grid">
              {dulceria.especialidades.map(esp => (
                <div class="especialidad-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <span>{esp}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Servicios -->
          <section class="negocio-seccion">
            <h2>Servicios</h2>
            <div class="servicios-grid">
              {dulceria.servicios.map(serv => (
                <div class="servicio-card">
                  <h3>{serv.nombre}</h3>
                  <p>{serv.descripcion}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar para confirmar.</p>
          </section>

          <!-- Ubicación -->
          <section class="negocio-seccion">
            <h2>Cómo Llegar</h2>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> {dulceria.ciudad}</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías -->
  <section class="otras-dulcerias section-padding">
    <div class="container">
      <SectionHeader
        title="Otras Dulcerías en"
        titleHighlight="CDMX"
        subtitle="Explora más opciones de dulcerías verificadas"
      />
      <div class="service-grid">
        <ServiceCard
          href="/directorio/dulceria-melissa"
          image="/img/galeria/candy-bar-gourmet-elegante.avif"
          alt="Dulcería Melissa - Atención personalizada para eventos"
          title="Dulcería Melissa"
          excerpt="4.5 estrellas (637 reseñas). Especializada en atención personalizada para eventos en Aragón."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-guachitos"
          image="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
          alt="Dulcería Guachitos - Dulces en Iztapalapa"
          title="Dulcería Guachitos"
          excerpt="4.3 estrellas (628 reseñas). Popular dulcería en Av. Tláhuac con precios accesibles y horario extendido."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-la-27"
          image="/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif"
          alt="Dulcería La 27 - Mejor calificada en Ignacio Zaragoza"
          title="Dulcería La 27"
          excerpt="4.6 estrellas (111 reseñas). La mejor calificación de Ignacio Zaragoza con excelente atención."
          cta="Ver Dulcería"
        />
        <ServiceCard
          href="/directorio/dulceria-el-secreto"
          image="/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif"
          alt="Dulcería El Secreto - Dulces premium San Ángel"
          title="Dulcería El Secreto"
          excerpt="4.4 estrellas (87 reseñas). Dulcería premium en San Ángel Inn con chocolates artesanales y confitería gourmet."
          cta="Ver Dulcería"
        />
      </div>
      <div class="ver-todas-wrapper">
        <a href="/directorio/todos" class="btn-ver-todas">
          Ver todas las dulcerías
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Necesito%20dulces%20para%20mi%20evento"
    badge="Mesa de Dulces"
    title="¿Necesitas una Mesa de Dulces"
    titleHighlight="Profesional"
    text="En Mededul diseñamos mesas de dulces personalizadas para bodas, XV años, baby showers y todo tipo de eventos."
    buttonText="Cotizar Mesa de Dulces"
  />
</BaseLayout>

<style>
  /* Hero del Negocio */
  .negocio-hero {
    padding: 60px 0 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .negocio-hero-content {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 60px;
    align-items: center;
  }

  .verificado-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .verificado-badge svg {
    width: 20px;
    height: 20px;
  }

  .negocio-hero-info h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--texto-oscuro);
