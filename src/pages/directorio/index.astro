---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import DirectorioSidebar from '@/components/directorio/DirectorioSidebar.astro';
import DulceriaCard from '@/components/directorio/DulceriaCard.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import { getCdnUrl } from '@/lib/cdn';
import {
  todasLasDulcerias,
  getDulceriasDestacadas,
  getEstadisticasDirectorio,
  alcaldiasInfo
} from '@/data/dulcerias';

const breadcrumbItems = [
  { name: 'Directorio de Dulces', url: '/directorio' }
];

// Obtener datos
const stats = getEstadisticasDirectorio();
const proveedoresDestacados = getDulceriasDestacadas().slice(0, 4);

// Categorias de proveedores
const categorias = [
  {
    nombre: 'Dulces Tradicionales',
    icono: '🍬',
    descripcion: 'Alegrías, cocadas, mazapanes, tamarindos y dulces típicos mexicanos',
    cantidad: todasLasDulcerias.filter(d => d.tipo === 'Dulcería Tradicional' || d.especialidades.some(e => e.toLowerCase().includes('tradicional'))).length,
    href: '/directorio/categorias/dulces-tradicionales'
  },
  {
    nombre: 'Chocolates y Trufas',
    icono: '🍫',
    descripcion: 'Chocolaterías artesanales, trufas gourmet y bombones finos',
    cantidad: todasLasDulcerias.filter(d => d.productos.some(p => p.toLowerCase().includes('chocolate'))).length,
    href: '/directorio/categorias/chocolates-trufas'
  },
  {
    nombre: 'Gomitas y Confitería',
    icono: '🍭',
    descripcion: 'Gomitas importadas, dulces enchilados y confitería variada',
    cantidad: todasLasDulcerias.filter(d => d.productos.some(p => p.toLowerCase().includes('gomita'))).length,
    href: '/directorio/categorias/gomitas-confiteria'
  },
  {
    nombre: 'Mayoreo La Merced',
    icono: '📦',
    descripcion: 'Dulcerías de mayoreo en el legendario Mercado de La Merced',
    cantidad: todasLasDulcerias.filter(d => d.tipo === 'Dulcería Mayoreo').length,
    href: '/directorio/todos'
  },
  {
    nombre: 'Paletas y Piruletas',
    icono: '🍡',
    descripcion: 'Paletas artesanales, cake pops y piruletas personalizadas',
    cantidad: todasLasDulcerias.filter(d => d.productos.some(p => p.toLowerCase().includes('paleta'))).length,
    href: '/directorio/categorias/paletas-piruletas'
  },
  {
    nombre: 'Dulces Importados',
    icono: '🌍',
    descripcion: 'Dulces americanos, japoneses, coreanos y de todo el mundo',
    cantidad: todasLasDulcerias.filter(d => d.especialidades.some(e => e.toLowerCase().includes('importado'))).length,
    href: '/directorio/categorias/dulces-importados'
  }
];

// Zonas CDMX con datos reales
const zonasCDMX = Object.entries(stats.porAlcaldia).map(([nombre, cantidad]) => ({
  nombre,
  cantidad,
  slug: nombre.toLowerCase()
    .replace(/\./g, '')
    .replace(/\s+/g, '-')
    .replace(/á/g, 'a').replace(/é/g, 'e').replace(/í/g, 'i').replace(/ó/g, 'o').replace(/ú/g, 'u')
})).sort((a, b) => b.cantidad - a.cantidad);

// Zonas Estado de Mexico (placeholder para futura expansión)
const zonasEdomex = [
  { nombre: 'Naucalpan', cantidad: 5, slug: 'naucalpan' },
  { nombre: 'Tlalnepantla', cantidad: 4, slug: 'tlalnepantla' },
  { nombre: 'Ecatepec', cantidad: 6, slug: 'ecatepec' },
  { nombre: 'Nezahualcóyotl', cantidad: 3, slug: 'nezahualcoyotl' },
  { nombre: 'Toluca', cantidad: 8, slug: 'toluca' },
  { nombre: 'Metepec', cantidad: 4, slug: 'metepec' }
];

// FAQs del directorio
const faqsDirectorio = [
  {
    question: '¿Cómo verifican los negocios listados?',
    answer: 'Verificamos cada negocio mediante su ficha activa en Google Business/Maps. Confirmamos dirección, teléfono, reseñas reales y que el negocio esté operando. Los negocios verificados muestran una insignia especial y sus datos son 100% reales.'
  },
  {
    question: '¿Puedo contactar directamente a las dulcerías?',
    answer: 'Sí, cada listado incluye el teléfono directo del negocio cuando está disponible. Puedes llamar o enviar WhatsApp sin intermediarios. También incluimos el enlace a Google Maps para que puedas visitarlos y ver reseñas de otros clientes.'
  },
  {
    question: '¿Las dulcerías venden al mayoreo?',
    answer: `Sí, tenemos ${todasLasDulcerias.filter(d => d.tipo === 'Dulcería Mayoreo').length} dulcerías especializadas en mayoreo, principalmente en el Mercado de La Merced y el corredor Norte 70. También las dulcerías de menudeo suelen ofrecer precios especiales para pedidos grandes.`
  },
  {
    question: '¿Cuál es la mejor zona para comprar dulces al mayoreo?',
    answer: 'El Mercado de Dulces de La Merced es el centro de distribución más grande de México, con los mejores precios de mayoreo. El corredor de Norte 70 en Gustavo A. Madero también tiene excelentes opciones con alta competencia y buenos precios.'
  },
  {
    question: '¿Qué zonas de CDMX cubre el directorio?',
    answer: `Actualmente cubrimos ${stats.alcaldias} alcaldías de CDMX con ${stats.total} dulcerías verificadas: ${zonasCDMX.slice(0, 5).map(z => z.nombre).join(', ')}, y más. Estamos en constante expansión agregando nuevos negocios cada semana.`
  }
];

// Schema para SEO
const directorioSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio de Dulcerías para Fiestas en CDMX",
  "description": `Directorio verificado de ${stats.total} dulcerías y tiendas de golosinas en Ciudad de México. Negocios reales con ${stats.totalResenas.toLocaleString()}+ reseñas en Google.`,
  "numberOfItems": stats.total,
  "itemListElement": todasLasDulcerias.slice(0, 20).map((prov, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": prov.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": prov.direccion,
        "addressLocality": prov.alcaldia,
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "telephone": prov.telefono !== 'Sin teléfono registrado' ? `+52${prov.telefono.replace(/\s/g, '')}` : undefined,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": prov.rating,
        "reviewCount": prov.resenas
      }
    }
  }))
};
---

<BaseLayout
  title={`${stats.total} Dulcerías en CDMX | Directorio Verificado 2026`}
  description={`Encuentra las mejores dulcerías en CDMX. ${stats.total} tiendas verificadas con +${stats.totalResenas.toLocaleString()} reseñas reales en ${stats.alcaldias} alcaldías. La Merced, Norte 70, Mixcoac y más.`}
  canonical="/directorio"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(directorioSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Directorio de Dulcerias en CDMX"
    highlight="Dulcerias"
    subtitle={`Directorio verificado 2026 · ${stats.total} tiendas con +${stats.totalResenas.toLocaleString()} resenas reales de Google Maps`}
    secondaryContent={`<p><strong>Directorio profesional de dulcerias en Ciudad de Mexico</strong> curado para que encuentres proveedores reales, verificados y con informacion actualizada de contacto, horarios y catalogo. Cada negocio listado cuenta con resenas auditadas y ubicacion comprobable para que compres con confianza y sin perder tiempo en busquedas fallidas.</p><p><strong>${stats.total} dulcerias verificadas</strong> distribuidas en ${stats.alcaldias} alcaldias de CDMX y zona metropolitana, respaldadas por mas de ${stats.totalResenas.toLocaleString()} resenas de clientes reales. Usa este directorio para surtir tu mesa de dulces, armar bolos para fiestas infantiles o localizar dulces tradicionales mexicanos al mejor precio del mercado.</p>`}
  />

  <!-- Buscador y Stats -->
  <section class="buscador-section">
    <div class="container">
      <div class="buscador-wrapper">
        <div class="buscador-box">
          <div class="buscador-input-group">
            <svg class="buscador-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="text" placeholder="Buscar dulcerías por nombre o zona..." class="buscador-input" id="buscador-input" />
          </div>
          <select class="buscador-select" id="buscador-zona">
            <option value="">Todas las zonas</option>
            <optgroup label="CDMX">
              {zonasCDMX.map(z => <option value={z.slug}>{z.nombre} ({z.cantidad})</option>)}
            </optgroup>
            <optgroup label="Estado de México (Próximamente)">
              {zonasEdomex.map(z => <option value={z.slug} disabled>{z.nombre}</option>)}
            </optgroup>
          </select>
          <a href="/directorio/todos" class="buscador-btn">
            <span>Ver Todas</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-numero">{stats.total}</span>
            <span class="stat-label">Dulcerías</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">{stats.alcaldias}</span>
            <span class="stat-label">Alcaldías</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">{Math.round(stats.totalResenas / 1000)}k+</span>
            <span class="stat-label">Reseñas</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">100%</span>
            <span class="stat-label">Verificados</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <WhyChooseUs
    badge="Directorio Verificado"
    title="¿Por qué confiar en nuestro"
    titleHighlight="Directorio"
    descriptions={[
      `Cada negocio en nuestro directorio ha sido verificado manualmente en Google Maps. Solo incluimos dulcerías con ficha activa, reseñas reales y datos confirmados.`
    ]}
    stats={[
      { number: String(stats.total), label: 'Dulcerías Verificadas' },
      { number: String(stats.alcaldias), label: 'Alcaldías Cubiertas' },
      { number: `${Math.round(stats.totalResenas / 1000)}k+`, label: 'Reseñas Totales' },
      { number: '100%', label: 'Verificadas en Google' }
    ]}
    features={[
      { num: 1, title: 'Verificados en Google', desc: 'Cada dulcería tiene ficha activa en Google Maps con reseñas reales de clientes.', img: '/img/galeria/candy-bar-profesional-eventos.avif' },
      { num: 2, title: 'Precios de Mayoreo', desc: 'Muchos proveedores ofrecen precios de mayoreo sin mínimos de compra.', img: '/img/galeria/dulces-variados-mesa.avif' },
      { num: 3, title: 'Todas las Alcaldías', desc: `Cobertura en ${stats.alcaldias} alcaldías de CDMX para que encuentres cerca de ti.`, img: '/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif' },
      { num: 4, title: 'Actualizado 2026', desc: 'Información actualizada con horarios, teléfonos y direcciones confirmadas.', img: '/img/galeria/candy-bar-gourmet-elegante.avif' }
    ]}
  />

  <!-- Main Content with Sidebar -->
  <div class="directorio-layout">
    <div class="container">
      <div class="directorio-grid">
        <!-- Main Content -->
        <main class="directorio-main">
          <!-- Proveedores Destacados -->
          <section class="destacados-section">
            <SectionHeader
              title="Dulcerías"
              titleHighlight="Destacadas"
              subtitle="Las tiendas mejor calificadas por la comunidad"
            />

            <div class="proveedores-grid-destacados">
              {proveedoresDestacados.map(prov => (
                <DulceriaCard dulceria={prov} />
              ))}
            </div>

            <div class="ver-todos-wrapper">
              <a href="/directorio/todos" class="btn-ver-todos">
                Ver las {stats.total} dulcerías
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </section>

          <!-- Categorias -->
          <section class="categorias-section">
            <SectionHeader
              title="Explora por"
              titleHighlight="Categoría"
              subtitle="Encuentra exactamente lo que necesitas para tu evento"
            />

            <div class="categorias-grid">
              {categorias.map(cat => (
                <a href={cat.href} class="categoria-card">
                  <span class="categoria-icono">{cat.icono}</span>
                  <div class="categoria-info">
                    <h3>{cat.nombre}</h3>
                    <p>{cat.descripcion}</p>
                    <span class="categoria-cantidad">{cat.cantidad} negocios</span>
                  </div>
                  <svg class="categoria-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </section>

          <!-- Zonas -->
          <section class="zonas-section">
            <SectionHeader
              title="Explora por"
              titleHighlight="Zona"
              subtitle="Encuentra dulcerías cerca de ti en CDMX y zona metropolitana"
            />
            <div class="zonas-grid-wrapper">
              <!-- CDMX -->
              <div class="zona-bloque">
                <div class="zona-header">
                  <div class="zona-icono">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <h2>Ciudad de México</h2>
                    <p>{stats.alcaldias} alcaldías con dulcerías verificadas</p>
                  </div>
                </div>
                <div class="zona-lista">
                  {zonasCDMX.map(z => (
                    <a href={`/directorio/cdmx/${z.slug}`} class="zona-item">
                      <span class="zona-nombre">{z.nombre}</span>
                      <span class="zona-cantidad">{z.cantidad}</span>
                    </a>
                  ))}
                </div>
                <a href="/directorio/todos" class="zona-ver-todas">Ver todas las dulcerías en CDMX</a>
              </div>

              <!-- Estado de Mexico -->
              <div class="zona-bloque zona-bloque--edomex">
                <div class="zona-header">
                  <div class="zona-icono zona-icono--edomex">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <h2>Estado de México</h2>
                    <p>Próximamente disponible</p>
                  </div>
                </div>
                <div class="zona-lista">
                  {zonasEdomex.map(z => (
                    <span class="zona-item zona-item--edomex zona-item--disabled">
                      <span class="zona-nombre">{z.nombre}</span>
                      <span class="zona-cantidad zona-cantidad--edomex">Pronto</span>
                    </span>
                  ))}
                </div>
                <span class="zona-ver-todas zona-ver-todas--edomex zona-ver-todas--disabled">Próximamente</span>
              </div>
            </div>
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar showCategorias={false} />
      </div>
    </div>
  </div>

  <!-- Registra tu negocio -->
  <section class="registro-section">
    <div class="container">
      <div class="registro-content">
        <div class="registro-texto">
          <span class="registro-badge">Para Negocios</span>
          <h2>¿Tienes una Dulcería? <span>Regístrate Gratis</span></h2>
          <p>Si tienes una dulcería o tienda de golosinas en CDMX o Estado de México, puedes aparecer en nuestro directorio sin costo. Ya tenemos {stats.total} negocios verificados.</p>

          <ul class="registro-beneficios">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Perfil completo con fotos y descripción
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Enlace directo a tu ficha de Google
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Contacto directo con clientes potenciales
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              Insignia de negocio verificado
            </li>
          </ul>

          <a href="https://wa.me/525525226442?text=Hola!%20Tengo%20una%20dulcería%20y%20quiero%20aparecer%20en%20el%20directorio" class="btn-registrar">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            </svg>
            Registrar mi Dulcería
          </a>
        </div>

        <div class="registro-imagen">
          <img
            src={getCdnUrl('/img/galeria/candy-bar-gourmet-elegante.avif', { w: 600, q: 80 })}
            alt="Registra tu dulcería en el directorio"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQContactModule faqItems={faqsDirectorio} />
</BaseLayout>

<style>
  /* Layout con Sidebar */
  .directorio-layout {
    padding: 50px 0 70px;
    background: #fff;
  }

  .directorio-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 40px;
    align-items: start;
  }

  .directorio-main {
    min-width: 0;
  }

  /* Buscador Section — card flotante sobre fondo gris debajo del QuickEventNav */
  .buscador-section {
    padding: 60px 0 10px;
    background: linear-gradient(180deg, #faf7fa 0%, #fff 100%);
    position: relative;
    z-index: 2;
  }

  .buscador-wrapper {
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 12px 40px rgba(26, 26, 46, 0.08);
    border: 1px solid #f0ebf0;
    padding: 32px;
  }

  .buscador-box {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .buscador-input-group {
    flex: 1;
    position: relative;
    min-width: 0;
  }

  .buscador-icon {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: #999;
    pointer-events: none;
  }

  .buscador-input {
    width: 100%;
    padding: 16px 20px 16px 52px;
    border: 2px solid #f0f0f0;
    border-radius: 12px;
    font-size: 0.95rem;
    font-family: inherit;
    background: #fafafa;
    transition: all 0.25s;
  }

  .buscador-input:focus {
    outline: none;
    background: #fff;
    border-color: var(--rosa-principal);
    box-shadow: 0 0 0 4px rgba(209, 0, 122, 0.1);
  }

  .buscador-select {
    padding: 16px 20px;
    border: 2px solid #f0f0f0;
    border-radius: 12px;
    font-size: 0.95rem;
    font-family: inherit;
    background: #fafafa;
    min-width: 220px;
    cursor: pointer;
    color: var(--texto-oscuro);
  }

  .buscador-select:focus {
    outline: none;
    background: #fff;
    border-color: var(--rosa-principal);
  }

  .buscador-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 28px;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.25s;
  }

  .buscador-btn svg {
    width: 18px;
    height: 18px;
  }

  .buscador-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(209, 0, 122, 0.3);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 26px;
    padding-top: 26px;
    border-top: 1px solid #f0f0f0;
  }

  .stat-item {
    text-align: center;
  }

  .stat-numero {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--rosa-principal);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
