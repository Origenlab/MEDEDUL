    slug: 'dulceria-melissa',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Gustavo A. Madero, CDMX',
    direccion: 'Av. Victoria Ote. 3602-A, Aragón Inguarán',
    imagen: '/img/galeria/candy-bar-baby-shower-rosa-pastel-flores.avif',
    rating: 4.5,
    resenas: 637,
    telefono: '55 7675 9070',
    mapsUrl: 'https://maps.app.goo.gl/melissa',
    verificado: true,
    destacado: false,
    especialidades: ['Dulces variados', 'Atención personalizada', 'Eventos']
  }
];

// Todos los proveedores reales
const todosProveedores = [
  ...proveedoresDestacados,
  {
    nombre: 'Dulcería Agam',
    slug: 'dulceria-agam',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Gustavo A. Madero, CDMX',
    direccion: 'Nte. 70 5627-A, Bondojito',
    rating: 4.6,
    resenas: 36,
    telefono: '55 7155 0262',
    verificado: true
  },
  {
    nombre: 'Dulcería Guachitos',
    slug: 'dulceria-guachitos',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Iztapalapa, CDMX',
    direccion: 'Av. Tláhuac 4388, Lomas Estrella',
    rating: 4.3,
    resenas: 628,
    telefono: '55 5607 5406',
    verificado: true
  },
  {
    nombre: 'Dulcería El Gordo',
    slug: 'dulceria-el-gordo',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Venustiano Carranza, CDMX',
    direccion: 'Ramón Corona 50, Local B y C, Mercado de Dulces',
    rating: 4.3,
    resenas: 429,
    telefono: '55 5522 8007',
    verificado: true
  },
  {
    nombre: 'Dulcería La 27',
    slug: 'dulceria-la-27',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Venustiano Carranza, CDMX',
    direccion: 'Calle 19 No. 118, Ignacio Zaragoza',
    rating: 4.6,
    resenas: 111,
    telefono: '55 5762 0736',
    verificado: true
  },
  {
    nombre: 'Dulcería Candy Gram',
    slug: 'dulceria-candy-gram',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Tlalpan, CDMX',
    direccion: 'Acoxpa s/n, Mercado Plaza Mexicana del Sur, Local 2 y 3',
    rating: 4.2,
    resenas: 33,
    telefono: '55 6303 2304',
    verificado: true
  },
  {
    nombre: 'Dulcería Chispita',
    slug: 'dulceria-chispita',
    categoria: 'Tienda de Golosinas',
    ubicacion: 'Azcapotzalco, CDMX',
    direccion: 'Av. Azcapotzalco 696, Centro de Azcapotzalco',
    rating: 4.1,
    resenas: 123,
    telefono: '55 6788 0847',
    verificado: true
  },
  {
    nombre: 'Dulcería El Secreto',
    slug: 'dulceria-el-secreto',
    categoria: 'Tienda de Golosinas Premium',
    ubicacion: 'Álvaro Obregón, CDMX',
    direccion: 'Av. Altavista 131, San Ángel Inn',
    rating: 4.4,
    resenas: 87,
    telefono: '55 5550 3622',
    verificado: true
  }
];

// Zonas CDMX con proveedores reales
const zonasCDMX = [
  { nombre: 'Gustavo A. Madero', cantidad: 4, slug: 'gustavo-a-madero' },
  { nombre: 'Venustiano Carranza', cantidad: 2, slug: 'venustiano-carranza' },
  { nombre: 'Iztapalapa', cantidad: 1, slug: 'iztapalapa' },
  { nombre: 'Benito Juárez', cantidad: 1, slug: 'benito-juarez' },
  { nombre: 'Tlalpan', cantidad: 1, slug: 'tlalpan' },
  { nombre: 'Azcapotzalco', cantidad: 1, slug: 'azcapotzalco' },
  { nombre: 'Álvaro Obregón', cantidad: 1, slug: 'alvaro-obregon' },
  { nombre: 'Centro Histórico', cantidad: 3, slug: 'centro-historico' }
];

// Zonas Estado de Mexico
const zonasEdomex = [
  { nombre: 'Naucalpan', cantidad: 5, slug: 'naucalpan' },
  { nombre: 'Tlalnepantla', cantidad: 4, slug: 'tlalnepantla' },
  { nombre: 'Ecatepec', cantidad: 6, slug: 'ecatepec' },
  { nombre: 'Nezahualcóyotl', cantidad: 3, slug: 'nezahualcoyotl' },
  { nombre: 'Toluca', cantidad: 8, slug: 'toluca' },
  { nombre: 'Metepec', cantidad: 4, slug: 'metepec' },
  { nombre: 'Texcoco', cantidad: 2, slug: 'texcoco' },
  { nombre: 'Atizapán', cantidad: 2, slug: 'atizapan' }
];

const totalProveedores = todosProveedores.length;

// FAQs del directorio
const faqsDirectorio = [
  {
    question: '¿Cómo verifican los negocios listados?',
    answer: 'Verificamos cada negocio mediante su ficha activa en Google Business/Maps. Confirmamos dirección, teléfono, reseñas reales y fotos del establecimiento. Los negocios verificados muestran una insignia especial.'
  },
  {
    question: '¿Puedo contactar directamente a las dulcerías?',
    answer: 'Sí, cada listado incluye el teléfono directo del negocio. Puedes llamar o enviar WhatsApp sin intermediarios. También incluimos el enlace a Google Maps para que puedas visitarlos.'
  },
  {
    question: '¿Los precios son de mayoreo o menudeo?',
    answer: 'La mayoría de las dulcerías listadas manejan tanto mayoreo como menudeo. Te recomendamos contactar directamente para preguntar por precios según la cantidad que necesites para tu evento.'
  },
  {
    question: '¿Estas dulcerías hacen entregas a domicilio?',
    answer: 'Algunas dulcerías ofrecen servicio de entrega, especialmente para pedidos grandes. Contacta directamente al negocio para confirmar disponibilidad y costos de envío a tu zona.'
  },
  {
    question: '¿Qué zonas cubre el directorio?',
    answer: 'Actualmente cubrimos las principales alcaldías de CDMX: Gustavo A. Madero, Venustiano Carranza, Iztapalapa, Benito Juárez, Tlalpan, Azcapotzalco y Álvaro Obregón. Estamos en constante expansión.'
  }
];

// Schema para SEO
const directorioSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio de Dulcerías para Fiestas en CDMX",
  "description": "Directorio verificado de dulcerías y tiendas de golosinas en Ciudad de México. Negocios reales con reseñas en Google.",
  "numberOfItems": totalProveedores,
  "itemListElement": todosProveedores.map((prov, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": prov.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": prov.direccion,
        "addressLocality": prov.ubicacion.split(',')[0],
        "addressRegion": "CDMX",
        "addressCountry": "MX"
      },
      "telephone": prov.telefono,
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": prov.rating,
        "reviewCount": prov.resenas
      }
    }
  }))
};
---

<BaseLayout
  title="Dulcerías en CDMX | Directorio de Tiendas de Dulces Verificadas 2025"
  description="Encuentra las mejores dulcerías en CDMX. ${totalProveedores} tiendas verificadas con reseñas reales. El Bofito, Dulcería Mixcoac, El Remate y más. Precios de mayoreo y menudeo."
  canonical="/directorio"
  ogImage="/img/galeria/candy-bar-fiesta-ninos-arcoiris-dulces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(directorioSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Dulcerías en CDMX"
    highlight="Dulcerías"
    subtitle="Directorio Verificado 2025"
    secondaryContent={`<p>Encuentra las <strong>mejores dulcerías y tiendas de golosinas</strong> en Ciudad de México. Todos los negocios están verificados con reseñas reales en Google.</p><p><strong>${totalProveedores} dulcerías verificadas</strong> con teléfono directo, ubicación en Maps y calificaciones reales de clientes.</p>`}
    showCTA={false}
  />

  <!-- Buscador y Stats -->
  <section class="buscador-section">
    <div class="container">
      <div class="buscador-wrapper">
        <div class="buscador-box">
          <div class="buscador-input-group">
            <svg class="buscador-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="text" placeholder="Buscar dulcerías por nombre o zona..." class="buscador-input" id="buscador-input" />
          </div>
          <select class="buscador-select" id="buscador-zona">
            <option value="">Todas las zonas</option>
            <optgroup label="CDMX">
              {zonasCDMX.map(z => <option value={z.slug}>{z.nombre}</option>)}
            </optgroup>
            <optgroup label="Estado de México">
              {zonasEdomex.map(z => <option value={z.slug}>{z.nombre}</option>)}
            </optgroup>
          </select>
          <a href="/directorio/todos" class="buscador-btn">Ver Todas</a>
        </div>

        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-numero">{totalProveedores}</span>
            <span class="stat-label">Dulcerías</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">7</span>
            <span class="stat-label">Alcaldías</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">8,000+</span>
            <span class="stat-label">Reseñas</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">100%</span>
            <span class="stat-label">Verificados</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="directorio-layout">
    <div class="container">
      <div class="directorio-grid">
        <!-- Main Content -->
        <main class="directorio-main">
          <!-- Proveedores Destacados -->
          <section class="destacados-section">
            <SectionHeader
              title="Dulcerías"
              titleHighlight="Destacadas"
              subtitle="Las tiendas mejor calificadas por la comunidad"
            />

            <div class="proveedores-lista">
              {proveedoresDestacados.map(prov => (
                <article class="proveedor-card-horizontal">
                  <div class="proveedor-imagen">
                    <img
                      src={getCdnUrl(prov.imagen, { w: 400, q: 80 })}
                      alt={`${prov.nombre} - Dulcería en ${prov.ubicacion}`}
                      loading="lazy"
                      width="400"
                      height="280"
                    />
                    {prov.destacado && <span class="proveedor-badge">Destacado</span>}
                    {prov.verificado && (
                      <span class="proveedor-verificado" title="Negocio verificado en Google">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </span>
                    )}
                  </div>
                  <div class="proveedor-contenido">
                    <div class="proveedor-header">
                      <div>
                        <span class="proveedor-categoria">{prov.categoria}</span>
                        <h3><a href={`/directorio/${prov.slug}`}>{prov.nombre}</a></h3>
                      </div>
                      <div class="proveedor-rating">
                        <div class="rating-stars">
                          {[1,2,3,4,5].map(star => (
                            <svg viewBox="0 0 24 24" fill={star <= Math.floor(prov.rating) ? "#FFB800" : "#E0E0E0"}>
                              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                          ))}
                        </div>
                        <span class="rating-numero">{prov.rating}</span>
                        <span class="rating-resenas">({prov.resenas.toLocaleString()} reseñas)</span>
                      </div>
                    </div>

                    <div class="proveedor-ubicacion">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                      </svg>
                      <span>{prov.direccion}, <strong>{prov.ubicacion}</strong></span>
                    </div>

                    {prov.especialidades && (
                      <div class="proveedor-especialidades">
                        {prov.especialidades.map(esp => (
                          <span class="especialidad-tag">{esp}</span>
                        ))}
                      </div>
                    )}

                    <div class="proveedor-acciones">
                      <a href={`/directorio/${prov.slug}`} class="btn-ver-perfil">Ver Perfil Completo</a>
                      <a href={`tel:+52${prov.telefono.replace(/\s/g, '')}`} class="btn-llamar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                        </svg>
                        {prov.telefono}
                      </a>
                      <a href={`https://wa.me/52${prov.telefono.replace(/\s/g, '')}?text=Hola!%20Vi%20su%20dulcería%20en%20el%20directorio%20de%20Mededul`} class="btn-whatsapp" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                        </svg>
                        WhatsApp
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>

            <div class="ver-todos-wrapper">
              <a href="/directorio/todos" class="btn-ver-todos">
                Ver las {totalProveedores} dulcerías
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </section>

          <!-- Categorias -->
          <section class="categorias-section">
            <SectionHeader
              title="Explora por"
              titleHighlight="Categoría"
              subtitle="Encuentra exactamente lo que necesitas para tu evento"
            />

            <div class="categorias-grid">
              {categorias.map(cat => (
                <a href={cat.href} class="categoria-card">
                  <span class="categoria-icono">{cat.icono}</span>
                  <div class="categoria-info">
                    <h3>{cat.nombre}</h3>
                    <p>{cat.descripcion}</p>
                    <span class="categoria-cantidad">{cat.cantidad} negocios</span>
                  </div>
                  <svg class="categoria-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </section>

          <!-- Zonas -->
          <section class="zonas-section">
            <div class="zonas-grid-wrapper">
              <!-- CDMX -->
              <div class="zona-bloque">
                <div class="zona-header">
                  <div class="zona-icono">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <h2>Ciudad de México</h2>
                    <p>{zonasCDMX.length} alcaldías con dulcerías verificadas</p>
                  </div>
                </div>
                <div class="zona-lista">
                  {zonasCDMX.map(z => (
                    <a href={`/directorio/cdmx/${z.slug}`} class="zona-item">
                      <span class="zona-nombre">{z.nombre}</span>
                      <span class="zona-cantidad">{z.cantidad}</span>
                    </a>
                  ))}
                </div>
                <a href="/directorio/cdmx" class="zona-ver-todas">Ver todas las alcaldías CDMX →</a>
              </div>

              <!-- Estado de Mexico -->
              <div class="zona-bloque zona-bloque--edomex">
                <div class="zona-header">
                  <div class="zona-icono zona-icono--edomex">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </div>
                  <div>
                    <h2>Estado de México</h2>
                    <p>Principales municipios</p>
                  </div>
                </div>
                <div class="zona-lista">
                  {zonasEdomex.map(z => (
                    <a href={`/directorio/edomex/${z.slug}`} class="zona-item zona-item--edomex">
                      <span class="zona-nombre">{z.nombre}</span>
                      <span class="zona-cantidad zona-cantidad--edomex">{z.cantidad}</span>
                    </a>
                  ))}
                </div>
                <a href="/directorio/edomex" class="zona-ver-todas zona-ver-todas--edomex">Ver todos los municipios →</a>
              </div>
            </div>
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar showCategorias={false} />
      </div>
    </div>
  </div>

  <!-- Registra tu negocio -->
  <section class="registro-section">
    <div class="container">
      <div class="registro-content">
        <div class="registro-texto">
          <span class="registro-badge">Para Negocios</span>
          <h2>¿Tienes una Dulcería? <span>Regístrate Gratis</span></h2>
