// Características de servicio en Toluca
const caracteristicasToluca = [
  {
    num: 1,
    title: 'Sucursal Toluca-Metepec',
    desc: 'Operamos desde Blvd. Toluca-Metepec 913 en San Jorge Pueblo Nuevo. Tiempo de respuesta y montaje optimizados para el Valle de Toluca.',
