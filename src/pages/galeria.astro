<BaseLayout
  title="Galeria de Mesas de Dulces CDMX | Fotos de Eventos Reales"
  description="Galeria de fotos de mesas de dulces para bodas, XV anos, baby shower, bautizos y eventos corporativos en CDMX. Inspira tu evento con nuestros trabajos reales."
  canonical="/galeria"
  ogImage="/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(galeriaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Galeria de Mesas de Dulces y Candy Bar"
    highlight="Galeria"
    subtitle="Inspira tu evento con nuestros trabajos reales en Ciudad de Mexico"
    secondaryContent={`<p>Explora nuestra <strong>galeria de mesas de dulces</strong> con mas de 500 eventos realizados en CDMX. Cada imagen representa un proyecto real: bodas elegantes, XV anos espectaculares, baby showers tiernos, bautizos significativos y eventos corporativos profesionales.</p><p>Nuestro equipo diseña cada montaje con <strong>atencion al detalle</strong> y <strong>estetica personalizada</strong> segun tu vision. Encuentra inspiracion y contactanos para crear tu mesa perfecta.</p>`}
    showCTA={false}
  />

  <!-- Filtros de Categoria -->
  <section class="galeria-filtros">
    <div class="container">
      <div class="filtros-wrapper">
        <button class="filtro-btn active" data-filter="todos">Todos</button>
        {categorias.map(cat => (
          <button class="filtro-btn" data-filter={cat.id}>
            <span class="filtro-icono">{cat.icono}</span>
            {cat.nombre}
          </button>
        ))}
        <button class="filtro-btn" data-filter="especiales">
          <span class="filtro-icono">✨</span>
          Especiales
        </button>
      </div>
    </div>
  </section>

  <!-- Galeria: Bodas -->
  <section class="galeria-seccion" id="bodas" data-category="bodas">
    <div class="container">
      <SectionHeader
        title="Mesas de Dulces para"
        titleHighlight="Bodas"
        subtitle="Montajes romanticos y elegantes para el dia mas especial"
      />
      <div class="galeria-grid">
        {imagenesBodas.map(img => (
          <div class="galeria-item">
            <img
              src={getCdnUrl(img.src, { w: 640, q: 80 })}
              srcset={getCdnSrcSet(img.src, galleryWidths, { q: 80 })}
              sizes={gallerySizes}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              width="640"
              height="480"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Galeria: XV Anos -->
  <section class="galeria-seccion" id="xv-anos" data-category="xv-anos">
