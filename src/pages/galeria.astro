  <!-- CTA Final -->
  <CTAServices
    href="https://wa.me/525525226442?text=Hola! Vi su galeria y me gustaria cotizar una mesa de dulces"
    badge="Te Inspiraste?"
    title="Crea tu Mesa de Dulces"
    titleHighlight="Perfecta"
    text="Cotiza sin compromiso y hagamos realidad el montaje que imaginaste para tu evento."
    buttonText="Cotizar por WhatsApp"
  />
</BaseLayout>

<style>
  /* Filtros */
  .galeria-filtros {
    padding: 40px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(233, 30, 140, 0.1);
  }

  .filtros-wrapper {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .filtro-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border: 2px solid rgba(233, 30, 140, 0.2);
    background: #fff;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--texto-oscuro);
    cursor: pointer;
  }

  .filtro-btn:hover {
    border-color: var(--rosa-principal);
    color: var(--rosa-principal);
  }

  .filtro-btn.active {
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    color: #fff;
    border-color: transparent;
  }

  .filtro-icono {
    font-size: 1rem;
  }

  /* Secciones de Galeria */
  .galeria-seccion {
    padding: 80px 0;
  }

  .galeria-seccion:nth-child(odd) {
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .galeria-seccion:nth-child(even) {
    background: #fff;
  }

  .galeria-seccion.hidden {
    display: none;
  }

  /* Grid de Galeria */
  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .galeria-grid-large {
    grid-template-columns: repeat(5, 1fr);
  }

  .galeria-item {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    aspect-ratio: 4/3;
  }

  .galeria-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .galeria-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .galeria-grid-large {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 1024px) {
    .galeria-filtros {
      position: relative;
    }

    .galeria-grid,
    .galeria-grid-large {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .filtros-wrapper {
      gap: 8px;
    }

    .filtro-btn {
      padding: 8px 14px;
      font-size: 0.8rem;
    }

    .galeria-seccion {
      padding: 50px 0;
    }

    .galeria-grid,
    .galeria-grid-large {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media (max-width: 480px) {
    .filtro-btn {
      padding: 6px 12px;
      font-size: 0.75rem;
    }

    .filtro-icono {
      display: none;
    }

    .galeria-grid,
    .galeria-grid-large {
      grid-template-columns: 1fr;
      gap: 15px;
    }
  }
</style>

<script>
  // Filtrado de categorias
  const filterBtns = document.querySelectorAll('.filtro-btn');
  const sections = document.querySelectorAll('.galeria-seccion');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Actualizar botones activos
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Mostrar/ocultar secciones
      if (filter === 'todos') {
        sections.forEach(s => s.classList.remove('hidden'));
      } else {
        sections.forEach(s => {
          if (s.getAttribute('data-category') === filter) {
            s.classList.remove('hidden');
          } else {
            s.classList.add('hidden');
          }
        });
      }
    });
  });
</script>
