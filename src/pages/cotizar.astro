---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ProcessSteps from '@/components/global/ProcessSteps.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';

const breadcrumbItems = [
  { name: 'Cotizar', url: '/cotizar' }
];

const paquetesRapidos = [
  {
    tipo: 'Mesa de Dulces',
    desde: '$4,500',
    ideal: '50-80 personas',
    tiempo: '4 horas',
    icon: '🍬',
    popular: true,
    whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20Mesa%20de%20Dulces%20para%20mi%20evento'
  },
  {
    tipo: 'Mesa de Postres',
    desde: '$5,500',
    ideal: '60-100 personas',
    tiempo: '4 horas',
    icon: '🍰',
    popular: false,
    whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20Mesa%20de%20Postres%20para%20mi%20evento'
  },
  {
    tipo: 'Estación Interactiva',
    desde: '$3,200',
    ideal: 'Complemento',
    tiempo: '3 horas',
    icon: '🍫',
    popular: false,
    whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20Estacion%20Interactiva%20para%20mi%20evento'
  },
  {
    tipo: 'Paquete Completo',
    desde: '$8,500',
    ideal: '100+ personas',
    tiempo: '6 horas',
    icon: '✨',
    popular: false,
    whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20un%20Paquete%20Completo%20para%20mi%20evento'
  }
];

const eventos = [
  { nombre: 'Boda', icon: '💍', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20BODA' },
  { nombre: 'XV Años', icon: '👑', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20XV%20AÑOS' },
  { nombre: 'Baby Shower', icon: '👶', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20BABY%20SHOWER' },
  { nombre: 'Bautizo', icon: '🕊️', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20BAUTIZO' },
  { nombre: 'Cumpleaños', icon: '🎂', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20CUMPLEAÑOS' },
  { nombre: 'Corporativo', icon: '🏢', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20EVENTO%20CORPORATIVO' },
  { nombre: 'Graduación', icon: '🎓', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20GRADUACIÓN' },
  { nombre: 'Otro Evento', icon: '🎉', whatsapp: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20para%20mi%20evento' }
];

const beneficios = [
  { num: 1, title: 'Respuesta en 2 horas', desc: 'Cotización rápida por WhatsApp. Sin esperas, sin formularios largos.', img: '/img/galeria/mesa-dulces-elegante-clasica-cristaleria.avif' },
  { num: 2, title: 'Diseño personalizado', desc: 'Adaptado a tu temática, colores y estilo de evento.', img: '/img/galeria/candy-bar-gourmet-elegante.avif' },
  { num: 3, title: 'Montaje incluido', desc: 'Llegamos, instalamos y recogemos. Sin preocupaciones.', img: '/img/galeria/mesa-dulces-eventos-especiales.avif' },
  { num: 4, title: 'Facilidades de pago', desc: '50% anticipo, 50% el día del evento. Aceptamos transferencia.', img: '/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif' }
];

const procesoSteps = [
  { num: 1, title: 'Contáctanos', desc: 'Por WhatsApp con fecha, invitados y tipo de evento' },
  { num: 2, title: 'Recibe Propuesta', desc: 'En menos de 2 horas te enviamos cotización detallada' },
  { num: 3, title: 'Confirma', desc: '50% de anticipo y apartamos tu fecha' },
  { num: 4, title: 'Disfruta', desc: 'Nosotros nos encargamos de todo el día del evento' }
];

const faqsCotizar = [
  {
    question: '¿Cuánto tiempo antes debo cotizar?',
    answer: 'Recomendamos cotizar con 4-8 semanas de anticipación para asegurar disponibilidad. Para fechas próximas, contáctanos y verificamos disponibilidad.'
  },
  {
    question: '¿La cotización tiene costo?',
    answer: 'No, la cotización es completamente gratuita y sin compromiso. Te enviamos propuesta detallada por WhatsApp.'
  },
  {
    question: '¿Qué información necesitan para cotizar?',
    answer: 'Fecha del evento, número de invitados, tipo de evento y zona de CDMX. Con eso preparamos una propuesta inicial.'
  },
  {
    question: '¿Cómo funciona el pago?',
    answer: '50% de anticipo para apartar fecha y el 50% restante el día del evento. Aceptamos transferencia, depósito y efectivo.'
  },
  {
    question: '¿Cubren toda la CDMX?',
    answer: 'Sí, cubrimos toda la CDMX y área metropolitana. Tenemos sucursales en Anzures y Condesa para atención rápida.'
  }
];

const cotizarSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Cotización de Mesas de Dulces - Mededul",
  "description": "Solicita cotización gratuita para mesa de dulces en CDMX. Respuesta en menos de 2 horas por WhatsApp.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Mededul",
    "telephone": "+525525226442"
  },
  "areaServed": "Ciudad de México",
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceType": "WhatsApp",
    "serviceUrl": "https://wa.me/525525226442"
  }
};
---

<BaseLayout
  title="Cotizar Mesa de Dulces CDMX | Respuesta en 2 Horas | Mededul"
  description="Solicita cotización gratuita para tu mesa de dulces en CDMX. Respuesta en menos de 2 horas por WhatsApp. Precios desde $4,500. Sin compromiso."
  canonical="/cotizar"
  ogImage="/img/galeria/mesa-dulces-boda-elegante-blanco-dorado.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(cotizarSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Cotiza tu Mesa de Dulces"
    highlight="Mesa de Dulces"
    subtitle="Respuesta en menos de 2 horas por WhatsApp"
    secondaryContent={`<p><strong>Cotización gratis y sin compromiso.</strong> Envíanos los datos de tu evento y recibe una propuesta personalizada con opciones y precios claros. Sin letra pequeña, sin sorpresas.</p><p>Con <strong>500+ eventos exitosos</strong> y calificación 5.0, te garantizamos respuesta rápida, precios transparentes y el mejor servicio para tu celebración en CDMX.</p>`}
  />

  <!-- CTA Principal WhatsApp -->
  <section class="cta-whatsapp">
    <div class="container">
      <div class="cta-box">
        <div class="cta-stats">
          <div class="stat">
            <span class="stat-number">500+</span>
            <span class="stat-label">Eventos</span>
          </div>
          <div class="stat">
            <span class="stat-number">5.0</span>
            <span class="stat-label">Calificación</span>
          </div>
          <div class="stat">
            <span class="stat-number">2hrs</span>
            <span class="stat-label">Respuesta</span>
          </div>
        </div>
        <a href="https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces" class="cta-button">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizar por WhatsApp
        </a>
        <p class="cta-note">Sin compromiso - Respuesta garantizada</p>
      </div>
    </div>
  </section>

  <!-- Cotización Rápida por Tipo -->
  <section class="cotizar-rapida section-padding">
    <div class="container">
      <SectionHeader
        title="Elige tu Tipo de"
        titleHighlight="Servicio"
        subtitle="Selecciona para cotizar directamente"
      />

      <div class="paquetes-grid">
        {paquetesRapidos.map(paq => (
          <a href={paq.whatsapp} class={`paquete-card ${paq.popular ? 'popular' : ''}`}>
            {paq.popular && <span class="popular-tag">Más Popular</span>}
            <span class="paquete-icon">{paq.icon}</span>
            <h3>{paq.tipo}</h3>
            <div class="paquete-precio">
              <span class="desde">Desde</span>
              <span class="precio">{paq.desde}</span>
            </div>
            <div class="paquete-detalles">
              <span>👥 {paq.ideal}</span>
              <span>⏱️ {paq.tiempo}</span>
            </div>
            <span class="paquete-cta">Cotizar Ahora →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cotizar por Evento -->
  <section class="cotizar-evento section-padding">
    <div class="container">
      <SectionHeader
        title="¿Qué Tipo de"
        titleHighlight="Evento"
        subtitle="Selecciona para recibir propuesta especializada"
      />

      <div class="eventos-grid">
        {eventos.map(ev => (
          <a href={ev.whatsapp} class="evento-card">
            <span class="evento-icon">{ev.icon}</span>
            <span class="evento-nombre">{ev.nombre}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Proceso -->
  <ProcessSteps
    badge="Proceso Simple"
    title="¿Cómo"
    titleHighlight="Funciona"
    subtitle="4 pasos para tu mesa perfecta"
    steps={procesoSteps}
  />

  <!-- Beneficios con WhyChooseUs pattern -->
  <section class="beneficios-section section-padding">
    <div class="container">
      <SectionHeader
        title="¿Por qué Cotizar con"
        titleHighlight="Nosotros"
        subtitle="Ventajas de elegir Mededul"
      />

      <div class="beneficios-grid">
        {beneficios.map(b => (
          <div class="beneficio-card">
            <span class="beneficio-num">0{b.num}</span>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsCotizar} />
</BaseLayout>

<style>
  /* CTA WhatsApp Principal */
  .cta-whatsapp {
    padding: 0 0 60px;
    background: linear-gradient(180deg, #f8f5f9 0%, #fff 100%);
  }

  .cta-box {
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    border-radius: 24px;
    padding: 40px;
    text-align: center;
    color: #fff;
  }

  .cta-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 32px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-number {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 800;
  }

  .stat-label {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #25D366;
    color: #fff;
    padding: 18px 40px;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 30px rgba(37, 211, 102, 0.4);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(37, 211, 102, 0.5);
  }

  .cta-note {
    margin-top: 16px;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  /* Cotización Rápida */
  .cotizar-rapida {
    background: #fff;
  }

  .paquetes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .paquete-card {
    position: relative;
    background: #fff;
    border: 2px solid #f0f0f0;
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    text-decoration: none;
    color: var(--texto-oscuro);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .paquete-card:hover {
    border-color: var(--rosa-principal);
    box-shadow: 0 8px 30px rgba(209, 0, 122, 0.15);
  }

  .paquete-card.popular {
    border-color: var(--rosa-principal);
    background: linear-gradient(180deg, #fff 0%, #fdf8fa 100%);
  }

  .popular-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--rosa-principal);
    color: #fff;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .paquete-icon {
    font-size: 2.5rem;
  }

  .paquete-card h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
  }

  .paquete-precio {
    display: flex;
    flex-direction: column;
  }

  .desde {
    font-size: 0.8rem;
    color: var(--texto-light);
  }

  .precio {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--rosa-principal);
  }

  .paquete-detalles {
    display: flex;
    gap: 16px;
    font-size: 0.85rem;
    color: var(--texto-light);
  }

  .paquete-cta {
    margin-top: 8px;
    color: var(--rosa-principal);
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Cotizar por Evento */
  .cotizar-evento {
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .eventos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .evento-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: #fff;
    padding: 28px 20px;
    border-radius: 16px;
    text-decoration: none;
    border: 2px solid transparent;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
  }

  .evento-card:hover {
    border-color: var(--rosa-principal);
    transform: translateY(-4px);
  }

  .evento-icon {
    font-size: 2.5rem;
  }

  .evento-nombre {
    font-weight: 600;
    color: var(--texto-oscuro);
  }

  /* Beneficios */
  .beneficios-section {
    background: #fff;
  }

  .beneficios-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .beneficio-card {
    text-align: center;
    padding: 32px 24px;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
    border-radius: 16px;
    border: 1px solid rgba(233, 30, 140, 0.08);
  }

  .beneficio-num {
    display: inline-block;
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    color: #fff;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 40px;
    margin-bottom: 16px;
  }

  .beneficio-card h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--texto-oscuro);
  }

  .beneficio-card p {
    margin: 0;
    color: var(--texto-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .paquetes-grid,
    .beneficios-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .eventos-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cta-stats {
      gap: 24px;
    }

    .stat-number {
      font-size: 1.5rem;
    }

    .cta-button {
      padding: 16px 32px;
      font-size: 1rem;
    }

    .paquetes-grid,
    .beneficios-grid {
      grid-template-columns: 1fr;
    }

    .eventos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .cta-box {
      padding: 28px 20px;
    }

    .cta-stats {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
