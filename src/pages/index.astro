---
// Homepage - Mededul Mesas de Dulces
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/global/Hero.astro';
import { getCdnSrcSet, getCdnUrl } from '@/lib/cdn';
import SectionHeader from '@/components/global/SectionHeader.astro';
import ServiceCard from '@/components/global/ServiceCard.astro';
import ReviewCard from '@/components/global/ReviewCard.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';

import {
  subsDulces, subsFrutas, subsPostres, subsQuesos,
  subsSnacks, subsBotanas, subsTradicionles, subsDonas,
  subsCBTematicas, subsCBXV, subsCBBoda, subsCBCumple,
  subsCBBautizo, subsCBComunion, subsCBCorporativo, subsCBBabyShower, subsCBGraduacion,
  subsFuenteChocolate, subsFuenteChamoy, subsParedDulces, subsStandPastel,
  subsDisenoPersonalizado, subsCalidadPremium, subsServicioCompleto, subsCeroEstres,
} from '@/data/subsections';

// FAQ Data
const faqItems = [
  {
    question: "¿Con cuánta anticipación debo reservar mi mesa de dulces?",
    answer: "Recomendamos reservar con al menos 2-3 semanas de anticipación para eventos regulares como cumpleaños o baby showers. Para temporadas altas (diciembre, mayo, noviembre) y eventos grandes como bodas o XV años, sugerimos 4-6 semanas. Esto nos permite diseñar tu mesa con calma y asegurar todos los dulces y postres especiales."
  },
  {
    question: "¿Qué incluye el servicio de renta de mesa de dulces?",
    answer: "Nuestro servicio profesional incluye: diseño personalizado según tu temática, selección de variedad de dulces premium, montaje elegante en tu evento, mobiliario y decoración de la mesa, supervisión durante la fiesta y desmontaje al finalizar. Ofrecemos opciones dulces y salados para satisfacer todos los gustos."
  },
  {
    question: "¿Pueden adaptar la mesa a mi tema o colores específicos?",
    answer: "¡Absolutamente! Eso es lo que mejor hacemos. Ya sea Barbie, superhéroes, elegante en dorado, temática mexicana o cualquier idea que tengas, la hacemos realidad. Nuestro diseño moderno y creativo incluye decoración, cupcakes personalizados y pastel coordinado."
  },
  {
    question: "¿Cuánto cuesta una mesa de dulces en CDMX y Toluca?",
    answer: "El precio varía según el número de invitados, tipo de dulces seleccionados, complejidad del diseño y extras como fuente de chocolate o buffet de postres. Manejamos paquetes desde $3,500 MXN para fiestas infantiles pequeñas, tanto en CDMX como en Toluca, Metepec y Valle de Toluca. Contáctanos para una cotización personalizada sin compromiso."
  },
  {
    question: "¿Qué zonas cubren en CDMX, Estado de México y Toluca?",
    answer: "Operamos con 3 sucursales: Anzures y Condesa en CDMX, y nuestra nueva sucursal Toluca-Metepec (Blvd. Toluca-Metepec 913, San Jorge Pueblo Nuevo). Cubrimos toda la Ciudad de México y zona metropolitana (Polanco, Lomas, Santa Fe, Interlomas, Coyoacán, Naucalpan, Tlalnepantla, Huixquilucan) además del Valle de Toluca completo: Toluca, Metepec, Zinacantepec, Lerma, San Mateo Atenco, Ocoyoacac y Calimaya. Atendemos bodas, XV años, baby shower, corporativos y todo tipo de eventos en cualquier venue de la región."
  },
  {
    question: "¿Ofrecen opciones para personas con restricciones alimenticias?",
    answer: "¡Sí! Podemos incluir opciones sin azúcar, sin gluten, veganas o para cualquier restricción alimenticia. También ofrecemos variedad de sabores deliciosos en dulces tradicionales mexicanos. Solo cuéntanos las necesidades de tus invitados y las integramos al diseño de tu mesa."
  }
];

// Aliados — proveedores de eventos con los que coordinamos montajes.
// Son colaboraciones operativas, NO reseñas de clientes.
const aliados = [
  {
    name: "Palomita.mx",
    link: "",
    giro: "Máquinas de palomitas para eventos",
    desc: "Renta máquinas de palomitas para fiestas y eventos. Cuando un evento combina snacks salados con mesa de dulces, coordinamos horarios y montaje con su equipo."
  },
  {
    name: "MesasPicnic.com",
    link: "https://mesaspicnic.com",
    giro: "Renta de mesas picnic para eventos",
    desc: "Renta mesas picnic para reuniones y eventos al aire libre. Hemos coordinado montajes en los que la mesa de dulces se integra a la estética picnic del evento."
  },
  {
    name: "Brincolins.com",
    link: "https://brincolins.com",
    giro: "Renta de brincolines e inflables",
    desc: "Renta brincolines e inflables para fiestas infantiles. En eventos compartidos sincronizamos la instalación: primero el inflable, después el montaje de la mesa."
  },
  {
    name: "Inflapy.com",
    link: "https://inflapy.com",
    giro: "Renta de inflables para fiestas",
    desc: "Renta inflables para fiestas y kermeses. Cuando coincidimos en un evento, alineamos tiempos de carga, descarga y montaje para que todo quede listo antes de los invitados."
  },
  {
    name: "Redeil.com",
    link: "",
    giro: "Renta de equipo e iluminación",
    desc: "Renta equipo e iluminación para eventos. Coordinamos con su equipo la logística de montaje para que iluminación y mesa de dulces queden listas sin estorbarse."
  },
  {
    name: "Fantasyglobos.com.mx",
    link: "",
    giro: "Decoración con globos",
    desc: "Hace decoración con globos para eventos. Sus arreglos suelen enmarcar nuestras mesas de dulces; coordinamos colores y montaje para que el conjunto se vea integrado."
  },
];

const galleryWidths = [320, 480, 640, 800, 960, 1200];
const gallerySizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw';
const getGalleryImage = (path: string) => ({
  src: getCdnUrl(path, { w: 800, q: 75 }),
  srcset: getCdnSrcSet(path, galleryWidths, { q: 75 })
});
---

<BaseLayout
  title="Mesas de Dulces CDMX, Toluca y Metepec | 500+ Eventos | Mededul"
  description="Mesas de dulces premium en CDMX, Toluca y Metepec con 500+ eventos exitosos. Bodas, XV años, baby shower. Diseño personalizado, montaje incluido, respuesta en 2 horas. Cobertura: CDMX, Estado de México y Valle de Toluca. Cotiza gratis."
  includeOrganizationSchema={true}
  includeLocalBusinessSchema={true}
  includeServiceSchema={true}
  includeWebSiteSchema={true}
>
  <!-- Page Hero Section -->
  <Hero
    id="inicio"
    title="Tu Evento Merece una Mesa de Dulces Inolvidable"
    highlight="Inolvidable"
    subtitle="500+ eventos exitosos en CDMX, Toluca y Metepec · Respuesta en 2 horas · Montaje incluido"
    secondaryContent={`<p>En <strong>Mededul</strong> no solo montamos dulces, creamos el momento que todos tus invitados van a recordar. Ese rincon fotografiable que genera "wow", esa mesa que combina perfectamente con tu evento y esos dulces que desaparecen porque realmente saben increible.</p><p><strong>¿Por que elegirnos?</strong> Porque llevamos 8+ anos perfeccionando cada detalle: desde la seleccion de dulces premium hasta el montaje que llega puntual y se ve impecable. Tú disfrutas tu evento, nosotros nos encargamos del resto.</p>`}
  />

  <!-- Tipos de Mesas Section -->
  <section class="tipos-mesas section-padding" id="tipos-mesas">
    <div class="container">
      <SectionHeader
        title="Elige tu Mesa de Dulces"
        titleHighlight="Mesa de Dulces"
        subtitle="8 opciones para crear la combinacion perfecta"
        content={`<p>Cada evento tiene su personalidad. Por eso ofrecemos desde la clasica <strong>mesa de dulces</strong> hasta opciones gourmet como <strong>quesos y embutidos</strong>. Combina varias para crear una experiencia unica que tus invitados recordaran.</p><p>Todos nuestros montajes incluyen: diseno personalizado a tu tematica, dulces premium seleccionados, instalacion profesional y servicio durante el evento.</p>`}
      />

      <div class="service-grid">
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-dulces"
          image={getCdnUrl("/img/tipos-de-mesas/dulces-personalizadas/mesas-de-dulces-infantiles.avif")}
          alt="Renta de mesas de dulces infantiles personalizadas en CDMX - Candy bar para fiestas de niños"
          title="Mesa de Dulces"
          excerpt="El clásico candy bar que nunca falla. Golosinas seleccionadas, presentación impecable y ese toque mágico que hace brillar cualquier fiesta."
          cta="Cotizar Candy Bar"
          badge="Popular"
          subsections={subsDulces}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-frutas"
          image={getCdnUrl("/img/tipos-de-mesas/frutas/mesas-de-frutas-para-eventos.avif")}
          alt="Mesas de frutas frescas para eventos y fiestas en CDMX - Servicio de catering frutal"
          title="Mesa de Frutas"
          excerpt="Frescura y color en cada bocado. Arreglos espectaculares con fruta de temporada que refrescan y deleitan a todos tus invitados."
          cta="Explorar Frutas Frescas"
          subsections={subsFrutas}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-postres"
          image={getCdnUrl("/img/tipos-de-mesas/postres/mesas-de-postres-cdmx.avif")}
          alt="Mesas de postres gourmet para bodas y XV años en Ciudad de México"
          title="Mesa de Postres"
          excerpt="Cuando los dulces no son suficientes, los postres elevan la experiencia. Macarons, éclairs, pays y creaciones de alta repostería."
          cta="Ver Postres Gourmet"
          subsections={subsPostres}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos"
          image={getCdnUrl("/img/tipos-de-mesas/quesos-embutidos/renta-de-mesa-de-quesos.avif")}
          alt="Renta de mesa de quesos y embutidos gourmet para eventos corporativos y bodas CDMX"
          title="Quesos y Embutidos"
          excerpt="Sofisticación europea en tu evento. Selección de quesos finos, jamones curados y acompañamientos que impresionan paladares exigentes."
          cta="Ver Tabla Gourmet"
          subsections={subsQuesos}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-snacks"
          image={getCdnUrl("/img/tipos-de-mesas/snacks/barra-de-snacks-para-eventos.avif")}
          alt="Barra de snacks y botanas para fiestas infantiles y eventos empresariales"
          title="Mesa de Snacks"
          excerpt="Para esas fiestas que duran hasta tarde. Variedad de snacks salados y dulces que mantienen el ánimo arriba toda la noche."
          cta="Armar Mi Barra"
          subsections={subsSnacks}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-botanas"
          image={getCdnUrl("/img/tipos-de-mesas/botanas/mesas-de-botanas-en-cdmx.avif")}
          alt="Mesas de botanas saladas para fiestas y reuniones en Ciudad de México"
          title="Mesa de Botanas"
          excerpt="El contrapunto perfecto para lo dulce. Nueces garapiñadas, cacahuates japoneses y botanas gourmet que equilibran sabores."
          cta="Ver Botanas Premium"
          subsections={subsBotanas}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-dulces-tradicionales"
          image={getCdnUrl("/img/tipos-de-mesas/dulces-tradicionales/mesa-de-dulces-tipicos-cdmx.avif")}
          alt="Mesa de dulces típicos mexicanos - Candy bar tradicional con mazapanes y obleas"
          title="Dulces Tradicionales"
          excerpt="Un viaje a la infancia mexicana. Alegrías, pepitorias, jamoncillos y esos sabores que nos conectan con nuestras raíces."
          cta="Explorar Dulces Típicos"
          subsections={subsTradicionles}
        />
        <ServiceCard
          href="/tipos-de-mesas-de-dulces/mesa-de-donas-y-cupcakes"
          image={getCdnUrl("/img/tipos-de-mesas/donas-cupcakes/mesa-de-donas-cdm.avif")}
          alt="Mesa de donas y cupcakes decorados para baby shower y cumpleaños CDMX"
          title="Donas y Cupcakes"
          excerpt="La tendencia que conquista Instagram. Torres de donas glaseadas y cupcakes artísticos que son tan fotogénicos como deliciosos."
          cta="Ver Donas Decoradas"
          badge="Tendencia"
          subsections={subsDonas}
        />
      </div>
    </div>
  </section>

  <!-- Eventos Section -->
  <section class="eventos section-padding" id="eventos">
    <div class="container">
      <SectionHeader
        title="Especialistas en tu Tipo de Evento"
        titleHighlight="Tipo de Evento"
        subtitle="Experiencia comprobada en cada celebracion"
        content={`<p>No es lo mismo una mesa para <strong>XV anos</strong> que para un <strong>evento corporativo</strong>. Por eso nos especializamos: conocemos los detalles que hacen la diferencia en cada tipo de celebracion, desde la seleccion de dulces hasta la presentacion.</p><p>Con 500+ eventos realizados, sabemos exactamente como hacer que tu mesa sea el centro de atencion, sin importar si es una boda intima o una fiesta de 300 personas.</p>`}
      />

      <div class="service-grid">
        <ServiceCard
          href="/candy-bar-eventos/mesas-tematicas"
          image={getCdnUrl("/img/tipos-de-mesas/dulces-personalizadas/mesa-dulces-personalizada-tematica.avif")}
          alt="Mesa de dulces temática personalizada en CDMX - Candy bar a medida por concepto"
          title="Mesas Temáticas"
          excerpt="¿Barbie, dinosaurios, unicornios? Tu imaginación es el límite. Recreamos cualquier tema con dulces y decoración a juego."
          cta="Explorar Temas Creativos"
          subsections={subsCBTematicas}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-xv-anos"
          image={getCdnUrl("/img/eventos/xv-anos/mesa-de-dulces-para-xv-anos.avif")}
          alt="Mesa de dulces para XV años en Ciudad de México - Candy bar elegante quinceañeros"
          title="Mesa para XV Años"
          excerpt="La transición de niña a mujer merece una celebración épica. Mesas que combinan glamour juvenil con elegancia atemporal."
          cta="Ver Diseños Quinceañera"
          badge="Favorito"
          subsections={subsCBXV}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-boda"
          image={getCdnUrl("/img/eventos/bodas/mesa-de-dulces-para-bodas.avif")}
          alt="Mesa de dulces para boda elegante CDMX - Candy bar nupcial personalizado"
          title="Mesa para Boda"
          excerpt="El día más importante merece el detalle más dulce. Creamos ese rincón romántico que tus invitados no olvidarán."
          cta="Ver Bodas Elegantes"
          badge="Premium"
          subsections={subsCBBoda}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-cumpleanos-infantil"
          image={getCdnUrl("/img/eventos/cumpleanos/mesa-de-dulces-para-cumpleanos.avif")}
          alt="Mesa de dulces para cumpleaños infantil en CDMX - Candy bar temático niños"
          title="Cumpleaños Infantil"
          excerpt="Los ojos de los niños brillan con nuestra mesa. Personajes favoritos, colores explosivos y todos los dulces que sueñan."
          cta="Ver Fiestas Infantiles"
          subsections={subsCBCumple}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-bautizo"
          image={getCdnUrl("/img/eventos/bautizo/mesa-dulces-bautizo-elegante.avif")}
          alt="Renta de mesa de dulces para bautizo en CDMX - Candy bar blanco y dorado"
          title="Mesa para Bautizo"
          excerpt="Pureza y ternura en cada detalle. Diseños angelicales con paletas suaves que celebran la llegada a la fe."
          cta="Ver Mesas para Bautizo"
          subsections={subsCBBautizo}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-primera-comunion"
          image={getCdnUrl("/img/eventos/comuniones/mesa-de-dulces-para-primera-comunion.avif")}
          alt="Mesa de dulces para primera comunión en Ciudad de México - Candy bar religioso"
          title="Primera Comunión"
          excerpt="Un sacramento especial con dulzura celestial. Mesas sobrias y elegantes que honran este momento espiritual."
          cta="Ver Primera Comunión"
          subsections={subsCBComunion}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-corporativos"
          image={getCdnUrl("/img/eventos/corporativos/barra-de-dulces-para-oficinas.avif")}
          alt="Barra de dulces para eventos corporativos y oficinas CDMX - Candy bar empresarial"
          title="Eventos Corporativos"
          excerpt="Profesionalismo con un toque dulce. Elevamos tus eventos empresariales con presentaciones ejecutivas impecables."
          cta="Ver Eventos Empresariales"
          subsections={subsCBCorporativo}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-baby-shower"
          image={getCdnUrl("/img/eventos/baby-shower/mesa-de-dulces-para-baby-shower-nino.avif")}
          alt="Mesa de dulces para baby shower de niño en CDMX - Candy bar azul celeste"
          title="Baby Shower"
          excerpt="La espera más dulce del mundo. Mesas adorables para niño, niña o la emoción de una revelación de género inolvidable."
          cta="Ver Mesas Baby Shower"
          subsections={subsCBBabyShower}
        />
        <ServiceCard
          href="/candy-bar-eventos/mesa-dulces-graduacion"
          image={getCdnUrl("/img/eventos/graduaciones/mesa-de-dulces-para-fiesta-de-compromiso.avif")}
          alt="Mesa de dulces para graduación en CDMX - Candy bar para fiestas de egresados"
          title="Graduaciones"
          excerpt="Años de esfuerzo merecen una fiesta épica. Mesas con los colores de tu escuela y el orgullo del logro alcanzado."
          cta="Ver Mesas Graduación"
          subsections={subsCBGraduacion}
        />
      </div>
    </div>
  </section>

  <!-- Estaciones Section -->
  <section class="estaciones section-padding" id="estaciones">
    <div class="container">
      <SectionHeader
        title="Estaciones"
        titleHighlight="Interactivas"
        subtitle="Eleva tu evento con experiencias que tus invitados recordaran"
        content={`<p>Complementa tu mesa de dulces con experiencias que generan "wow": <strong>fuente de chocolate belga</strong>, <strong>fuente de chamoy artesanal</strong>, <strong>candy wall fotografiable</strong> y mas. Cada estacion incluye montaje, servicio y todo lo necesario.</p>`}
      />

      <div class="service-grid">
        <ServiceCard
          href="/estaciones-interactivas/fuente-de-chocolate"
          image={getCdnUrl("/img/estaciones-interactivas/fuente-chocolate/fuente-de-chocolate-para-eventos.avif")}
          alt="Fuente de chocolate para fiestas y eventos en CDMX - Renta de cascada de chocolate"
          title="Fuente de Chocolate"
          excerpt="La estrella de cualquier fiesta. Chocolate belga cayendo en cascada mientras tus invitados bañan fresas y churros."
          cta="Rentar Fuente de Chocolate"
          badge="Estrella"
          subsections={subsFuenteChocolate}
        />
        <ServiceCard
          href="/estaciones-interactivas/fuente-de-chamoy"
          image={getCdnUrl("/img/estaciones-interactivas/fuente-chamoy/renta-de-fuente-de-chamoy.avif")}
          alt="Renta de fuente de chamoy para fiestas mexicanas en CDMX - Estación interactiva"
          title="Fuente de Chamoy"
          excerpt="El picosito que México ama. Chamoy casero fluyendo para los valientes que buscan ese toque agridulce irresistible."
          cta="Cotizar Fuente Chamoy"
          subsections={subsFuenteChamoy}
        />
        <ServiceCard
          href="/estaciones-interactivas/pared-de-dulces"
          image={getCdnUrl("/img/estaciones-interactivas/pared-dulces/pared-de-dulces-candy-wall.avif")}
          alt="Pared de dulces Candy Wall para eventos en CDMX - Muro de golosinas decorativo"
          title="Pared de Dulces"
          excerpt="El muro más fotografiado de tu fiesta. Dispensadores llenos de golosinas que decoran y endulzan a la vez."
          cta="Ver Candy Wall"
          subsections={subsParedDulces}
        />
        <ServiceCard
          href="/estaciones-interactivas/stand-para-pastel"
          image={getCdnUrl("/img/estaciones-interactivas/stand-pastel/stand-pastel-decorado-eventos.avif")}
          alt="Stand para pastel con decoración de globos CDMX - Estación de pastel para fiestas"
          title="Stand para Pastel"
          excerpt="Tu pastel merece su propio escenario. Marcos decorados con globos, luces o flores que lo hacen protagonista."
          cta="Ver Stands Decorados"
          subsections={subsStandPastel}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SECCIÓN DULCES — Nueva categoría de venta
  ═══════════════════════════════════════════════════════ -->
  <section class="dulces-promo section-padding" id="dulces">
    <div class="container">
      <SectionHeader
        title="Compra los Dulces de"
        titleHighlight="Nuestras Mesas"
        subtitle="Los mismos dulces que usamos en 500+ eventos, ahora disponibles para ti"
        content={`<p>¿Quieres armar tu propia mesa? Vendemos los dulces exactos que seleccionamos para nuestros montajes premium: <strong>a granel por kilo, kits curados por tipo de evento</strong> o el exclusivo <strong>Freeze-Dried Candy</strong>, la tendencia más viral del mundo para eventos. Entrega express en CDMX.</p>`}
      />

      <div class="service-grid">
        <ServiceCard
          href="/dulces/a-granel"
          image={getCdnUrl("/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif")}
          alt="Dulces a granel para mesa de dulces y candy bar CDMX — gomitas, enchilados, chocolates por kilo"
          title="Dulces a Granel"
          excerpt="Gomitas, enchilados gourmet, chocolates finos y mixes curados por 250g, 500g o 1kg. Con guía de cantidades por número de invitados."
          cta="Ver selección"
          badge="Más Popular"
        />
        <ServiceCard
          href="/dulces/kits-por-evento"
          image={getCdnUrl("/img/galeria/mesa-dulces-boda-elegante-dorado-clasica.avif")}
          alt="Kits de dulces curados por tipo de evento — boda, XV años, baby shower, corporativo CDMX"
          title="Kits por Evento"
          excerpt="Surtidos completos calculados para tu número de invitados: boda, XV años, baby shower, corporativo y más. Sin adivinar qué ni cuánto pedir."
          cta="Ver kits"
          badge="Nuevo"
        />
        <ServiceCard
          href="/dulces/freeze-dried"
          image={getCdnUrl("/img/galeria/candy-bar-empresarial-moderno-minimalista.avif")}
          alt="Freeze dried candy dulces liofilizados premium para eventos en México CDMX"
          title="Freeze-Dried Candy"
          excerpt="La tendencia más viral del mundo de los dulces. Crocantes, intensos y absolutamente instagrameables. Los primeros en CDMX para eventos premium."
          cta="Descubrir"
          badge="Tendencia 2026"
        />
        <ServiceCard
          href="/dulces"
          image={getCdnUrl("/img/galeria/candy-bar-graduacion-birrete-elegante.avif")}
          alt="Mayoreo de dulces para organizadores de eventos y wedding planners CDMX"
          title="Mayoreo B2B"
          excerpt="Para wedding planners, organizadores y salones. Descuentos del 15–25%, facturación CFDI y asesor dedicado. Conviértenos en tu proveedor oficial."
          cta="Cotizar mayoreo"
          badge="Facturación"
        />
      </div>

      <div class="dulces-cta-strip">
