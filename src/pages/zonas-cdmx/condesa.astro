---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import FAQContactModule from '@/components/global/FAQContactModule.astro';
import ReviewCard from '@/components/global/ReviewCard.astro';

const breadcrumbItems = [
  { name: 'Zonas CDMX', url: '/zonas-cdmx' },
  { name: 'Condesa', url: '/zonas-cdmx/condesa' }
];

