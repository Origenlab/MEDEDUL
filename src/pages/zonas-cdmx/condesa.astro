  {
    name: 'Condesa Bohemia',
    icon: '🌿',
    price: '$5,500',
    currency: 'MXN',
    guests: '40-70 personas',
    tagline: 'Estilo relajado y con caracter',
    features: [
      '8-10 variedades artesanales',
      'Estetica boho-chic',
      'Montaje en terrazas o jardines',
      '4 horas de servicio',
      'Traslado Condesa incluido',
      'Adaptacion a espacios pequenos'
    ],
    popular: false,
    ctaText: 'Cotizar Bohemia',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20estilo%20bohemio%20en%20Condesa'
  },
  {
    name: 'Condesa Premium',
    icon: '✨',
    price: '$8,500',
    currency: 'MXN',
    guests: '70-120 personas',
    tagline: 'Elegancia con personalidad',
    features: [
      '12-15 variedades premium',
      'Diseno personalizado',
      'Estacion interactiva',
      '5 horas de servicio',
      'Coordinacion con venue',
      'Backdrop decorativo',
      'Servicio completo'
    ],
    popular: true,
    ctaText: 'Cotizar Premium',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Premium%20para%20Condesa'
  },
  {
    name: 'Condesa Signature',
    icon: '💐',
    price: '$12,500',
    currency: 'MXN',
    guests: '120+ personas',
    tagline: 'Para eventos en casonas y jardines',
    features: [
      '18+ variedades exclusivas',
      'Direccion de arte completa',
      'Multiples estaciones',
      'Servicio todo el evento',
      'Integracion floral',
      'Mesa de quesos artesanales',
      'Personal dedicado'
    ],
    popular: false,
    ctaText: 'Cotizar Signature',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Signature%20para%20Condesa'
  }
];

const caracteristicasCondesa = [
  {
    num: 1,
    title: 'Estamos en la Zona',
    desc: 'Nuestra sucursal Condesa esta en Av. Baja California. Conocemos la zona como nadie y llegamos en minutos.',
    img: '/img/galeria/mesa-dulces-boda-jardin-romantica-rosa-luces.avif'
  },
  {
    num: 2,
    title: 'Espacios Unicos',
    desc: 'Terrazas, jardines, casonas art deco. Sabemos adaptar nuestros montajes a la personalidad de cada espacio.',
    img: '/img/galeria/mesa-dulces-tea-party-vintage-encaje-perlas.avif'
  },
  {
    num: 3,
    title: 'Estetica con Caracter',
    desc: 'La Condesa tiene un estilo propio. Nuestros disenos respetan y realzan esa personalidad bohemia y elegante.',
    img: '/img/galeria/mesa-dulces-baby-shower-boho-eucalipto.avif'
  },
  {
    num: 4,
    title: 'Eventos Intimos',
    desc: 'Muchos eventos en Condesa son intimos y especiales. Nos adaptamos a espacios reducidos con gran impacto visual.',
    img: '/img/galeria/candy-bar-bride-to-be-rosa-negro-champagne.avif'
  }
];

const testimoniosCondesa = [
  {
    name: 'Sofia y Andres',
    initials: 'SA',
    review: 'Nuestra boda en una terraza de la Condesa fue perfecta. La mesa de dulces con estilo botanico fue exactamente lo que soñamos.',
    event: 'Boda Terraza Condesa',
    rating: 5
  },
  {
    name: 'Valentina Garcia',
    initials: 'VG',
    review: 'El baby shower en el Parque Mexico con la mesa de Mededul fue increible. El estilo boho quedo precioso.',
    event: 'Baby Shower Parque Mexico',
    rating: 5
  },
  {
    name: 'Agencia Creativa DF',
    initials: 'AC',
    review: 'Para el evento de lanzamiento de nuestra agencia en Condesa necesitabamos algo con personalidad. Lo lograron perfecto.',
    event: 'Evento Corporativo Condesa',
    rating: 5
  }
];

const faqsCondesa = [
  {
    question: 'Tienen sucursal en la Condesa?',
