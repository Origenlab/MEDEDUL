  },
  {
    question: 'Pueden montar en terrazas y jardines?',
    answer: 'Si, tenemos amplia experiencia en terrazas, jardines y espacios al aire libre de la Condesa. Nos adaptamos a las condiciones de cada espacio.'
  },
  {
    question: 'Que estilo de diseno manejan para Condesa?',
    answer: 'Ofrecemos estilos que van desde boho-chic hasta vintage y moderno. Nos adaptamos a la estetica de la zona y la personalidad de cada cliente.'
  },
  {
    question: 'Pueden trabajar en espacios pequenos?',
    answer: 'Si, muchos eventos en Condesa son intimos. Sabemos crear montajes de alto impacto visual incluso en espacios reducidos.'
  },
  {
    question: 'Hacen eventos en restaurantes de la zona?',
    answer: 'Si, hemos trabajado con varios restaurantes con terraza en la Condesa. Coordinamos directamente con el establecimiento.'
  }
];

const condesaSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Condesa",
  "description": "Servicio de mesas de dulces para eventos en Condesa, CDMX. Bodas en terrazas, baby showers en jardines, eventos intimos con estilo.",
  "areaServed": {
    "@type": "Place",
    "name": "Condesa, Cuauhtemoc, Ciudad de Mexico"
  },
  "telephone": "+525525226442",
  "priceRange": "$5,500 - $12,500 MXN",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Torre A, Av. Baja California 255",
    "addressLocality": "Condesa, Cuauhtemoc",
    "postalCode": "06170",
    "addressCountry": "MX"
  }
};
---

<BaseLayout
  title="Mesas de Dulces en Condesa CDMX | Eventos con Estilo"
  description="Servicio de mesas de dulces en Condesa, CDMX. Bodas en terrazas, baby showers, eventos boho-chic. Sucursal en la zona. Cotiza gratis."
  canonical="/zonas-cdmx/condesa"
  ogImage="/img/galeria/mesa-dulces-boda-jardin-romantica-rosa-luces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(condesaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Condesa, CDMX"
    highlight="Condesa"
    subtitle="Servicio local para la zona mas bohemia de la ciudad"
    secondaryContent={`<p>La <strong>Condesa</strong> tiene un encanto unico: arquitectura art deco, parques hermosos, terrazas con vegetacion y un ambiente cosmopolita. Nuestras <strong>mesas de dulces en Condesa</strong> capturan esa esencia con disenos que tienen personalidad y estilo.</p><p>Nuestra <strong>sucursal esta en la zona</strong>, en Av. Baja California 255. Esto significa respuesta rapida, conocimiento local y la certeza de que llegamos a tu evento sin contratiempos.</p>`}
  />

  <!-- Venues -->
  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Espacios donde hemos <span>creado magia</span></h2>
        <p>Terrazas, jardines y espacios unicos de la Condesa</p>
        <div class="venues-grid">
          {venuesCondesa.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB800">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-condesa"
    badge="Paquetes Condesa"
    title="Servicios con"
    titleHighlight="Personalidad"
    subtitle="Paquetes disenados para el estilo unico de la Condesa"
    packages={paquetesCondesa}
    note="🌿 <strong>Sucursal en la zona:</strong> Estamos en Av. Baja California 255, Condesa. Llegamos a tu evento en minutos."
  />

  <WhyChooseUs
    id="ventajas-condesa"
    badge="Servicio en Condesa"
    title="Somos Locales en"
    titleHighlight="La Condesa"
    descriptions={[
      'Nuestra sucursal esta en el corazon de la Condesa. Conocemos los espacios, las terrazas favoritas y la estetica que buscan los eventos de la zona.',
      'Ya sea una boda intima en una azotea, un baby shower en un jardin o un evento corporativo con estilo, entendemos la vibra de la Condesa.'
    ]}
    stats={[
      { number: '40+', label: 'Eventos en Condesa' },
      { number: '5 min', label: 'A cualquier punto' },
      { number: '5.0', label: 'Calificacion' },
      { number: 'Sucursal', label: 'En la zona' }
    ]}
    features={caracteristicasCondesa}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Condesa"
        subtitle="Lo que dicen nuestros vecinos de la zona"
      />
      <div class="testimonios-grid">
        {testimoniosCondesa.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsCondesa} />
</BaseLayout>

<style>
  .venues-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .venues-content {
    text-align: center;
    color: #fff;
  }

  .venues-content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 12px;
  }

  .venues-content h2 span {
    color: rgba(255,255,255,0.8);
  }

  .venues-content > p {
    font-size: 1rem;
    opacity: 0.85;
    margin: 0 0 40px;
  }

  .venues-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .venue-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .testimonios-section {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 50px;
  }

  @media (max-width: 1024px) {
    .testimonios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .venues-content h2 {
      font-size: 1.5rem;
    }

    .venues-grid {
      gap: 10px;
    }

    .venue-item {
      padding: 10px 16px;
      font-size: 0.8rem;
    }

    .testimonios-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
