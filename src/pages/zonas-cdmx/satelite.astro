];

const testimoniosSatelite = [
  {
    name: 'Familia Lopez',
    initials: 'FL',
    review: 'Los XV anos de mi hija en un salon de Satelite quedaron increibles. La mesa de dulces fue lo que mas les gusto a los invitados.',
