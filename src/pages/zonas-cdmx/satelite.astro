      'Backdrop decorativo',
      'Servicio completo'
    ],
    popular: true,
    ctaText: 'Cotizar Premium',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Premium%20para%20Satelite'
  },
  {
    name: 'Satelite Completo',
    icon: '🎊',
    price: '$12,500',
    currency: 'MXN',
    guests: '120+ personas',
    tagline: 'Eventos grandes con estilo',
    features: [
      '18+ variedades exclusivas',
      'Direccion de arte',
      'Multiples estaciones',
      'Servicio todo el evento',
      'Mesa de quesos',
      'Integracion decorativa',
      'Personal dedicado'
    ],
    popular: false,
    ctaText: 'Cotizar Completo',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Completo%20para%20Satelite'
  }
];

const caracteristicasSatelite = [
  {
    num: 1,
    title: 'Tradicion Familiar',
    desc: 'Satelite es zona de familias con tradicion. Entendemos los XV anos, bodas y bautizos que se celebran aqui.',
    img: '/img/galeria/mesa-dulces-xv-anos-rosa-plateado-cristales.avif'
  },
  {
    num: 2,
    title: 'Jardines Amplios',
    desc: 'Muchas casas tienen jardines perfectos para eventos. Sabemos aprovechar esos espacios.',
