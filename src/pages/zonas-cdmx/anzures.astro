      '5 horas de servicio',
      'Coordinacion total',
      'Backdrop profesional',
      'Servicio completo'
    ],
    popular: true,
    ctaText: 'Cotizar Premium',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Premium%20para%20Anzures'
  },
  {
    name: 'Anzures Elite',
    icon: '💎',
    price: '$14,000',
    currency: 'MXN',
    guests: '130+ personas',
    tagline: 'Maxima calidad garantizada',
    features: [
      '20+ variedades exclusivas',
      'Direccion creativa completa',
      'Multiples estaciones',
      'Servicio todo el evento',
      'Mesa de quesos premium',
      'Integracion floral',
      'Personal dedicado'
    ],
    popular: false,
    ctaText: 'Cotizar Elite',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Elite%20para%20Anzures'
  }
];

const caracteristicasAnzures = [
  {
    num: 1,
    title: 'Nuestra Sucursal Principal',
    desc: 'Estamos en Av. Ejercito Nacional 216, Anzures. Es nuestra base de operaciones, conocemos cada rincon de la zona.',
    img: '/img/galeria/candy-bar-empresarial-moderno-minimalista.avif'
  },
  {
    num: 2,
    title: 'Respuesta Inmediata',
    desc: 'Al estar en la zona, podemos atender emergencias, hacer visitas previas y coordinar sin problema.',
