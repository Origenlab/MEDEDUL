  },
  {
    num: 4,
    title: 'Eventos Corporativos',
    desc: 'Muchas empresas estan en Anzures. Entendemos las necesidades de eventos de negocios.',
    img: '/img/galeria/candy-bar-graduacion-birrete-elegante.avif'
  }
];

const testimoniosAnzures = [
  {
    name: 'Empresa Financiera MX',
    initials: 'EF',
    review: 'Excelente servicio para nuestro evento de fin de ano en Anzures. Profesionales y puntuales. La facturacion fue inmediata.',
