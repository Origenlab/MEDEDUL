  },
  {
    name: 'Anzures Premium',
    icon: '⭐',
    price: '$9,000',
    currency: 'MXN',
    guests: '80-130 personas',
    tagline: 'Nuestra sucursal esta aqui',
    features: [
      '14-16 variedades premium',
      'Diseno personalizado completo',
