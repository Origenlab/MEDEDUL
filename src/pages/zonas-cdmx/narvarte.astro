  {
    name: 'Narvarte Esencial',
    icon: '🎈',
    price: '$4,800',
    currency: 'MXN',
    guests: '30-60 personas',
    tagline: 'Ideal para reuniones intimas',
    features: [
      '8-10 variedades selectas',
