---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Hero from '@/components/global/Hero.astro';
import WhyChooseUs from '@/components/global/WhyChooseUs.astro';
import PricingPackages from '@/components/global/PricingPackages.astro';
import SectionHeader from '@/components/global/SectionHeader.astro';
import FAQ from '@/components/global/FAQ.astro';
import CTAServices from '@/components/global/CTAServices.astro';
import ReviewCard from '@/components/global/ReviewCard.astro';

const breadcrumbItems = [
  { name: 'Zonas CDMX', url: '/zonas-cdmx' },
  { name: 'Del Valle', url: '/zonas-cdmx/del-valle' }
];

const venuesDelValle = [
  'Parque Hundido',
  'Parque de los Venados',
  'Salones de eventos',
  'Jardines privados',
  'Restaurantes con terraza',
  'Clubes sociales',
  'Casas con jardin',
  'Espacios corporativos'
];

const paquetesDelValle = [
  {
    name: 'Del Valle Clasico',
    icon: '🏡',
    price: '$5,200',
    currency: 'MXN',
    guests: '40-70 personas',
    tagline: 'Para reuniones familiares',
    features: [
      '8-10 variedades selectas',
      'Diseno clasico elegante',
      'Montaje en jardines',
      '4 horas de servicio',
      'Traslado Del Valle incluido',
      'Adaptacion a espacios residenciales'
    ],
    popular: false,
    ctaText: 'Cotizar Clasico',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20clasica%20en%20Del%20Valle'
  },
  {
    name: 'Del Valle Premium',
    icon: '⭐',
    price: '$8,200',
    currency: 'MXN',
    guests: '70-120 personas',
    tagline: 'El mas solicitado',
    features: [
      '12-15 variedades premium',
      'Diseno personalizado',
      'Estacion interactiva',
      '5 horas de servicio',
      'Coordinacion con venue',
      'Backdrop decorativo',
      'Servicio completo'
    ],
    popular: true,
    ctaText: 'Cotizar Premium',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Premium%20para%20Del%20Valle'
  },
  {
    name: 'Del Valle Signature',
    icon: '💫',
    price: '$12,000',
    currency: 'MXN',
    guests: '120+ personas',
    tagline: 'Eventos grandes con estilo',
    features: [
      '18+ variedades exclusivas',
      'Direccion de arte completa',
      'Multiples estaciones',
      'Servicio todo el evento',
      'Integracion floral',
      'Mesa de quesos',
      'Personal dedicado'
    ],
    popular: false,
    ctaText: 'Cotizar Signature',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Signature%20para%20Del%20Valle'
  }
];

const caracteristicasDelValle = [
  {
    num: 1,
    title: 'Zona Familiar',
    desc: 'Del Valle es una colonia de familias. Entendemos las celebraciones familiares: bautizos, comuniones, cumpleanos.',
    img: '/img/galeria/mesa-dulces-bautizo-angeles-blanco-celeste.avif'
  },
  {
    num: 2,
    title: 'Jardines Amplios',
    desc: 'Muchas casas en Del Valle tienen jardines perfectos para eventos. Sabemos aprovechar esos espacios.',
    img: '/img/galeria/mesa-dulces-boda-jardin-romantica-rosa-luces.avif'
  },
  {
    num: 3,
    title: 'Acceso Central',
    desc: 'Ubicacion centrica con buen acceso. Llegamos facilmente desde cualquier punto.',
    img: '/img/galeria/mesa-dulces-baby-shower-boho-eucalipto.avif'
  },
  {
    num: 4,
    title: 'Eventos Tradicionales',
    desc: 'XV anos, bodas, bautizos. Especializados en eventos tradicionales mexicanos con un toque moderno.',
    img: '/img/galeria/mesa-dulces-xv-anos-rosa-plateado-cristales.avif'
  }
];

const testimoniosDelValle = [
  {
    name: 'Familia Rodriguez',
    initials: 'FR',
    review: 'Los XV anos de mi hija en el jardin de la casa quedaron perfectos. La mesa de dulces fue el centro de atencion.',
    event: 'XV Anos Del Valle',
    rating: 5
  },
  {
    name: 'Patricia y Juan',
    initials: 'PJ',
    review: 'Nuestra boda en un salon de Del Valle quedo hermosa. Mededul se coordino perfecto con todos los proveedores.',
    event: 'Boda Salon Del Valle',
    rating: 5
  },
  {
    name: 'Familia Gonzalez',
    initials: 'FG',
    review: 'El bautizo de nuestro bebe en el jardin fue inolvidable. La mesa de dulces en tonos celestes quedo preciosa.',
    event: 'Bautizo Casa Del Valle',
    rating: 5
  }
];

const faqsDelValle = [
  {
    question: 'Cubren toda la zona de Del Valle?',
    answer: 'Si, cubrimos Del Valle Centro, Del Valle Norte, Del Valle Sur, Napoles, Insurgentes Mixcoac y colonias aledanas.'
  },
  {
    question: 'Pueden montar en jardines de casas?',
    answer: 'Si, tenemos amplia experiencia en jardines residenciales. Nos adaptamos al espacio disponible con montajes de alto impacto.'
  },
  {
    question: 'Trabajan los fines de semana?',
    answer: 'Si, la mayoria de nuestros eventos son sabados y domingos. Tenemos disponibilidad en todos los horarios.'
  },
  {
    question: 'Ofrecen mesas para XV anos?',
    answer: 'Si, los XV anos son una de nuestras especialidades. Ofrecemos disenos tematicos, colores personalizados y decoracion especial.'
  },
  {
    question: 'El montaje incluye desmontaje?',
    answer: 'Si, incluimos montaje y desmontaje completo. Llegamos con anticipacion y nos retiramos al final sin que tengas que preocuparte.'
  }
];

const delValleSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Del Valle",
  "description": "Servicio de mesas de dulces para eventos familiares en Del Valle, CDMX. XV anos, bodas, bautizos, cumpleanos.",
  "areaServed": {
    "@type": "Place",
    "name": "Del Valle, Benito Juarez, Ciudad de Mexico"
  },
  "telephone": "+525525226442",
  "priceRange": "$5,200 - $12,000 MXN"
};
---

<BaseLayout
  title="Mesas de Dulces en Del Valle CDMX | Eventos Familiares"
  description="Servicio de mesas de dulces en Del Valle, CDMX. XV anos, bodas, bautizos, cumpleanos. Montaje en jardines y salones. Cotiza gratis."
  canonical="/zonas-cdmx/del-valle"
  ogImage="/img/galeria/mesa-dulces-xv-anos-rosa-plateado-cristales.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(delValleSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Del Valle, CDMX"
    highlight="Del Valle"
    subtitle="La colonia familiar por excelencia"
    secondaryContent={`<p><strong>Del Valle</strong> es una de las colonias mas familiares de la ciudad. Jardines amplios, casas con espacios para eventos y una tradicion de celebraciones que nos encanta atender.</p><p>Nuestras <strong>mesas de dulces en Del Valle</strong> estan disenadas para eventos familiares: XV anos, bodas, bautizos, primeras comuniones y cumpleanos con el estilo que mereces.</p>`}
  />

  <!-- Venues -->
  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Espacios donde hemos <span>creado magia</span></h2>
        <p>Jardines, salones y espacios de Del Valle</p>
        <div class="venues-grid">
          {venuesDelValle.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB800">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-delvalle"
    badge="Paquetes Del Valle"
    title="Servicios para"
    titleHighlight="Familias"
    subtitle="Paquetes perfectos para celebraciones familiares"
    packages={paquetesDelValle}
    note="🏡 <strong>Eventos en casa:</strong> Nos especializamos en montajes para jardines y espacios residenciales."
  />

  <WhyChooseUs
    id="ventajas-delvalle"
    badge="Servicio en Del Valle"
    title="Expertos en Eventos"
    titleHighlight="Familiares"
    descriptions={[
      'Del Valle es territorio de familias y celebraciones tradicionales. XV anos, bodas, bautizos, comuniones - los conocemos todos.',
      'Sabemos trabajar en jardines de casas, coordinar con otros proveedores y hacer que tu evento familiar sea inolvidable.'
    ]}
    stats={[
      { number: '50+', label: 'Eventos en Del Valle' },
      { number: '5.0', label: 'Calificacion' },
      { number: '100%', label: 'Puntualidad' },
      { number: '8+', label: 'Anos experiencia' }
    ]}
    features={caracteristicasDelValle}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Del Valle"
        subtitle="Lo que dicen las familias de la zona"
      />
      <div class="testimonios-grid">
        {testimoniosDelValle.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section section-padding">
    <div class="container">
      <SectionHeader
        title="Preguntas sobre Servicio en"
        titleHighlight="Del Valle"
        subtitle="Resolvemos tus dudas sobre eventos familiares"
      />
      <FAQ items={faqsDelValle} id="faq-delvalle" />
    </div>
  </section>

  <CTAServices
    href="https://wa.me/525525226442?text=Hola!%20Tengo%20un%20evento%20familiar%20en%20Del%20Valle%20y%20quiero%20cotizar%20una%20mesa%20de%20dulces"
    badge="Evento en Del Valle"
    title="Cotiza para tu Evento en"
    titleHighlight="Del Valle"
    text="Indicanos tu tipo de evento, fecha y numero de invitados. Te enviamos cotizacion personalizada."
    buttonText="Cotizar por WhatsApp"
  />
</BaseLayout>

<style>
  .venues-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .venues-content {
    text-align: center;
    color: #fff;
  }

  .venues-content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 12px;
  }

  .venues-content h2 span {
    color: rgba(255,255,255,0.8);
  }

  .venues-content > p {
    font-size: 1rem;
    opacity: 0.85;
    margin: 0 0 40px;
  }

  .venues-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .venue-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .testimonios-section {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 50px;
  }

  .faq-section {
    background: #fff;
  }

  @media (max-width: 1024px) {
    .testimonios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .venues-content h2 {
      font-size: 1.5rem;
    }

    .venues-grid {
      gap: 10px;
    }

    .venue-item {
      padding: 10px 16px;
      font-size: 0.8rem;
    }

    .testimonios-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
