    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces%20estilo%20colonial%20en%20Coyoacan'
  },
  {
    name: 'Coyoacan Premium',
    icon: '🌺',
