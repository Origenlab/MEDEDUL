      'Backdrop tematico',
      'Servicio completo'
    ],
    popular: true,
    ctaText: 'Cotizar Premium',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Premium%20para%20Coyoacan'
  },
  {
    name: 'Coyoacan Hacienda',
    icon: '🎭',
