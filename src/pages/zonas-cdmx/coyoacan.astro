const faqsCoyoacan = [
  {
    question: 'Cubren todo Coyoacan?',
    answer: 'Si, cubrimos Centro Historico, Pedregal, Villa Coyoacan, Del Carmen, Santa Catarina y colonias aledanas.'
  },
  {
    question: 'Ofrecen mesas con dulces mexicanos?',
    answer: 'Si, podemos incluir dulces tradicionales mexicanos: alegrías, cocadas, mazapanes, jamoncillos, tamarindos y mas.'
  },
  {
    question: 'Trabajan en haciendas y fincas?',
    answer: 'Si, tenemos experiencia en haciendas, fincas y espacios coloniales de Coyoacan. Conocemos sus caracteristicas.'
  },
  {
    question: 'Pueden hacer montajes tematicos mexicanos?',
    answer: 'Si, ofrecemos disenos con estetica mexicana contemporanea: colores vibrantes, textiles, elementos florales tradicionales.'
  },
  {
    question: 'Como es el acceso al centro historico?',
    answer: 'Conocemos la zona perfectamente. Coordinamos horarios de acceso y contamos con permisos necesarios.'
  }
];

const coyoacanSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Coyoacan",
  "description": "Servicio de mesas de dulces para eventos en Coyoacan, CDMX. Bodas en haciendas, eventos con esencia mexicana.",
  "areaServed": {
    "@type": "Place",
    "name": "Coyoacan, Ciudad de Mexico"
  },
  "telephone": "+525525226442",
  "priceRange": "$5,500 - $13,500 MXN"
};
---

<BaseLayout
  title="Mesas de Dulces en Coyoacan CDMX | Eventos con Esencia Mexicana"
  description="Servicio de mesas de dulces en Coyoacan, CDMX. Bodas en haciendas, eventos coloniales, celebraciones con toque mexicano. Cotiza gratis."
  canonical="/zonas-cdmx/coyoacan"
  ogImage="/img/galeria/mesa-dulces-boda-jardin-romantica-rosa-luces.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(coyoacanSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Coyoacan, CDMX"
    highlight="Coyoacan"
    subtitle="El corazon historico de la ciudad"
    secondaryContent={`<p><strong>Coyoacan</strong> es el alma de Mexico: calles empedradas, haciendas coloniales, jardines con historia y una energia unica. Nuestras <strong>mesas de dulces en Coyoacan</strong> capturan esa esencia mexicana con elegancia.</p><p>Desde bodas en haciendas hasta bautizos en jardines coloniales, sabemos crear montajes que se integran perfectamente con los espacios magicos de esta zona.</p>`}
  />

  <!-- Venues -->
  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Espacios donde hemos <span>creado magia</span></h2>
        <p>Haciendas, jardines y espacios coloniales de Coyoacan</p>
        <div class="venues-grid">
          {venuesCoyoacan.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB800">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-coyoacan"
    badge="Paquetes Coyoacan"
    title="Servicios con"
    titleHighlight="Esencia Mexicana"
    subtitle="Paquetes que honran la tradicion con estilo contemporaneo"
    packages={paquetesCoyoacan}
    note="🌺 <strong>Dulces mexicanos:</strong> Podemos incluir dulces tradicionales en tu mesa."
  />

  <WhyChooseUs
    id="ventajas-coyoacan"
    badge="Servicio en Coyoacan"
    title="Expertos en Espacios"
    titleHighlight="Historicos"
    descriptions={[
      'Coyoacan tiene espacios unicos: haciendas, casonas coloniales, jardines con siglos de historia. Sabemos trabajar en ellos.',
      'Ofrecemos la opcion de integrar dulces mexicanos tradicionales con nuestra presentacion premium y contemporanea.'
    ]}
    stats={[
      { number: '40+', label: 'Eventos en Coyoacan' },
      { number: '5.0', label: 'Calificacion' },
      { number: '100%', label: 'Satisfaccion' },
      { number: '8+', label: 'Anos experiencia' }
    ]}
    features={caracteristicasCoyoacan}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Coyoacan"
        subtitle="Lo que dicen nuestros clientes de la zona"
      />
      <div class="testimonios-grid">
        {testimoniosCoyoacan.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsCoyoacan} />
</BaseLayout>

<style>
  .venues-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .venues-content {
    text-align: center;
    color: #fff;
  }

  .venues-content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 12px;
  }

  .venues-content h2 span {
    color: rgba(255,255,255,0.8);
  }

  .venues-content > p {
    font-size: 1rem;
    opacity: 0.85;
    margin: 0 0 40px;
  }

  .venues-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .venue-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .testimonios-section {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 50px;
  }

  @media (max-width: 1024px) {
    .testimonios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .venues-content h2 {
      font-size: 1.5rem;
    }

    .venues-grid {
      gap: 10px;
    }

    .venue-item {
      padding: 10px 16px;
      font-size: 0.8rem;
    }

    .testimonios-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
