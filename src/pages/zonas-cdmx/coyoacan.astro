      'Personal dedicado'
    ],
    popular: false,
    ctaText: 'Cotizar Hacienda',
    ctaUrl: 'https://wa.me/525525226442?text=Hola!%20Me%20interesa%20el%20paquete%20Hacienda%20para%20Coyoacan'
  }
];

const caracteristicasCoyoacan = [
  {
    num: 1,
    title: 'Esencia Mexicana',
    desc: 'Coyoacan es el alma de Mexico. Nuestros disenos pueden incorporar elementos mexicanos con elegancia.',
    img: '/img/galeria/mesa-dulces-tradicional-mexicana-colores.avif'
  },
  {
    num: 2,
    title: 'Espacios Coloniales',
    desc: 'Haciendas, casonas y jardines con historia. Sabemos integrar nuestras mesas con estos espacios unicos.',
