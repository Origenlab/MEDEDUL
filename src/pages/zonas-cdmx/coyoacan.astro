  }
];

const testimoniosCoyoacan = [
  {
    name: 'Ana y Roberto',
    initials: 'AR',
    review: 'Nuestra boda en una hacienda de Coyoacan fue magica. La mesa de dulces con toque mexicano quedo espectacular.',
    event: 'Boda Hacienda Coyoacan',
    rating: 5
  },
  {
    name: 'Familia Martinez',
    initials: 'FM',
    review: 'El bautizo de nuestra hija en un jardin colonial quedo hermoso. La mesa de dulces tradicionales fue el exito.',
    event: 'Bautizo Jardin Coyoacan',
    rating: 5
  },
  {
    name: 'Lucia Fernandez',
    initials: 'LF',
