  }
];

const caracteristicasTlalnepantla = [
  {
    num: 1,
    title: 'Precios Competitivos',
    desc: 'Ofrecemos paquetes accesibles con la misma calidad premium. La mejor relacion calidad-precio.',
    img: '/img/galeria/mesa-dulces-cumpleanos-infantil-arcoiris.avif'
