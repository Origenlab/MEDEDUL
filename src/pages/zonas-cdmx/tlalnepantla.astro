  },
  {
    question: 'El traslado tiene costo?',
    answer: 'El traslado a Tlalnepantla esta incluido en todos nuestros paquetes. Sin costos adicionales.'
  },
  {
    question: 'Tienen precios accesibles?',
    answer: 'Si, nuestros paquetes para Tlalnepantla comienzan desde $4,800. Ofrecemos opciones para diferentes presupuestos.'
  },
  {
    question: 'Hacen eventos corporativos?',
    answer: 'Si, la zona industrial de Tlalnepantla tiene muchas empresas. Atendemos eventos corporativos con facturacion incluida.'
  },
  {
    question: 'Trabajan fines de semana?',
    answer: 'Si, la mayoria de nuestros eventos son sabados y domingos. Tenemos disponibilidad en todos los horarios.'
  }
];

const tlalnepantlaSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Tlalnepantla",
  "description": "Servicio de mesas de dulces en Tlalnepantla. XV anos, bodas, eventos corporativos. Precios accesibles.",
  "areaServed": {
    "@type": "Place",
    "name": "Tlalnepantla de Baz, Estado de Mexico"
  },
  "telephone": "+525525226442",
  "priceRange": "$4,800 - $11,000 MXN"
};
---

<BaseLayout
  title="Mesas de Dulces en Tlalnepantla | Precios Accesibles"
  description="Servicio de mesas de dulces en Tlalnepantla. XV anos, bodas, eventos corporativos. Paquetes desde $4,800. Cotiza gratis."
  canonical="/zonas-cdmx/tlalnepantla"
  ogImage="/img/galeria/mesa-dulces-xv-anos-rosa-plateado-cristales.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(tlalnepantlaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Tlalnepantla"
    highlight="Tlalnepantla"
    subtitle="Calidad premium a precios accesibles"
    secondaryContent={`<p><strong>Tlalnepantla</strong> es uno de los municipios mas importantes del area metropolitana. Familias, empresas y una gran tradicion de celebraciones.</p><p>Nuestras <strong>mesas de dulces en Tlalnepantla</strong> ofrecen la misma calidad premium que en toda la ciudad, con precios competitivos y traslado incluido.</p>`}
  />

  <!-- Venues -->
  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Espacios donde hemos <span>creado magia</span></h2>
        <p>Salones, jardines y espacios de Tlalnepantla</p>
        <div class="venues-grid">
          {venuesTlalnepantla.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB800">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-tlalnepantla"
    badge="Paquetes Tlalnepantla"
    title="Opciones"
    titleHighlight="Accesibles"
    subtitle="Calidad premium adaptada a tu presupuesto"
    packages={paquetesTlalnepantla}
    note="💰 <strong>Desde $4,800:</strong> Paquetes accesibles con calidad garantizada."
  />

  <WhyChooseUs
    id="ventajas-tlalnepantla"
    badge="Servicio en Tlalnepantla"
    title="La Mejor Opcion en"
    titleHighlight="Tlalnepantla"
    descriptions={[
      'Llevamos nuestra calidad premium a Tlalnepantla con precios competitivos. Sin sacrificar presentacion ni servicio.',
      'Atendemos tanto eventos familiares como corporativos. Facturacion inmediata para empresas de la zona industrial.'
    ]}
    stats={[
      { number: '40+', label: 'Eventos' },
      { number: '$4,800', label: 'Desde' },
      { number: '5.0', label: 'Calificacion' },
      { number: 'Incluido', label: 'Traslado' }
    ]}
    features={caracteristicasTlalnepantla}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Tlalnepantla"
        subtitle="Lo que dicen nuestros clientes"
      />
      <div class="testimonios-grid">
        {testimoniosTlalnepantla.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsTlalnepantla} />
</BaseLayout>

<style>
  .venues-section {
    padding: 60px 0;
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
  }

  .venues-content {
    text-align: center;
    color: #fff;
  }

  .venues-content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 12px;
  }

  .venues-content h2 span {
    color: rgba(255,255,255,0.8);
  }

  .venues-content > p {
    font-size: 1rem;
    opacity: 0.85;
    margin: 0 0 40px;
  }

  .venues-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .venue-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .testimonios-section {
    padding: 80px 0;
    background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%);
  }

  .testimonios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 50px;
  }

  @media (max-width: 1024px) {
    .testimonios-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .venues-content h2 {
      font-size: 1.5rem;
    }

    .venues-grid {
      gap: 10px;
    }

    .venue-item {
      padding: 10px 16px;
      font-size: 0.8rem;
    }

    .testimonios-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
