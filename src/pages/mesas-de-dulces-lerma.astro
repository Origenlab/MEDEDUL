  }
];

const lermaSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mededul - Mesas de Dulces en Lerma",
  "description": "Servicio profesional de mesas de dulces para eventos corporativos en parques industriales, bodas, XV años y eventos sociales en Lerma, Estado de México. Branding corporativo, factura CFDI y cobertura completa.",
  "url": "https://mesas-de-dulces.com/mesas-de-dulces-lerma",
  "telephone": "+525521775184",
  "priceRange": "$5,500 - $13,500 MXN",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Blvd. Toluca-Metepec 913",
    "addressLocality": "San Jorge Pueblo Nuevo, Metepec",
    "addressRegion": "Estado de México",
    "postalCode": "52169",
    "addressCountry": "MX"
  },
  "areaServed": [
    { "@type": "City", "name": "Lerma" },
    { "@type": "Place", "name": "San Mateo Otzacatipan, Lerma" },
    { "@type": "Place", "name": "San Pedro Tultepec, Lerma" },
    { "@type": "Place", "name": "Parque Industrial Lerma" }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "11",
    "bestRating": "5"
  }
};
---

<BaseLayout
  title="Mesas de Dulces en Lerma | Corporativos y Eventos | Mededul"
  description="Mesas de dulces premium en Lerma, Estado de México. Especialistas en eventos corporativos para parques industriales, bodas y XV años. Branding incluido, factura CFDI. Cotización gratis."
  canonical="/mesas-de-dulces-lerma"
  ogImage="/img/galeria/mesa-dulces-evento-corporativo-profesional.avif"
  includeCategoryStyles={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(lermaSchema)} slot="head" />

  <Breadcrumbs items={breadcrumbItems} />

  <Hero
    title="Mesas de Dulces en Lerma, EdoMex"
    highlight="Lerma"
    subtitle="Especialistas en eventos corporativos y bodas · Branding y factura CFDI"
    secondaryContent={`<p><strong>Mededul Lerma</strong> opera desde nuestra <a href="/sucursales/toluca"><strong>sucursal Toluca-Metepec</strong></a> con cobertura completa para <strong>parques industriales, corporativos y eventos sociales</strong>. Lerma concentra empresas, plantas y oficinas corporativas, y diseñamos paquetes especializados para activaciones, fin de año, lanzamientos y celebraciones internas.</p><p>También atendemos <strong>bodas, XV años y eventos familiares</strong> en Hacienda La Glorieta, Quinta Real Lerma, jardines y salones locales. Branding corporativo, factura CFDI y servicio premium con respuesta en menos de 24 horas. <a href="/sucursales/toluca">Ver sucursal Toluca-Metepec →</a></p>`}
  />

  <section class="venues-section">
    <div class="container">
      <div class="venues-content">
        <h2>Venues y Corporativos donde hemos <span>trabajado</span></h2>
        <p>Parques industriales, haciendas y salones de Lerma</p>
        <div class="venues-grid">
          {venuesLerma.map(venue => (
            <div class="venue-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--rosa-principal)">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {venue}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PricingPackages
    id="paquetes-lerma"
    badge="Paquetes para Lerma"
    title="Servicios para"
    titleHighlight="Lerma"
    subtitle="Paquetes diseñados para corporativos, bodas y eventos sociales"
    packages={paquetesLerma}
    note="💡 <strong>Branding corporativo, factura CFDI y traslado desde Metepec incluidos.</strong> Coordinación con RRHH y áreas de eventos."
  />

  <WhyChooseUs
    id="ventajas-lerma"
    badge="Servicio en Lerma"
    title="Por qué elegir"
    titleHighlight="Mededul Lerma"
    descriptions={[
      'Especialistas en eventos corporativos para parques industriales y oficinas de Lerma. Branding integrado, factura CFDI y coordinación profesional.',
      'También cobertura premium para bodas, XV años y eventos sociales en haciendas y salones de Lerma con la misma calidad que en CDMX.'
    ]}
    stats={[
      { number: '11+', label: 'Eventos en Lerma' },
      { number: '5.0', label: 'Calificación' },
      { number: '25 min', label: 'Desde sucursal' },
      { number: '100%', label: 'Branding incluido' }
    ]}
    features={caracteristicasLerma}
  />

  <section class="testimonios-section">
    <div class="container">
      <SectionHeader
        title="Testimonios de Eventos en"
        titleHighlight="Lerma"
        subtitle="Corporativos y eventos sociales"
      />
      <div class="testimonios-grid">
        {testimoniosLerma.map(t => (
          <ReviewCard
            name={t.name}
            initials={t.initials}
            review={t.review}
            event={t.event}
            rating={t.rating}
            verified={true}
          />
        ))}
      </div>
    </div>
  </section>

  <FAQContactModule faqItems={faqsLerma} />
</BaseLayout>

<style>
  .venues-section { padding: 60px 0; background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%); }
  .venues-content { text-align: center; color: #fff; }
  .venues-content h2 { font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 700; margin: 0 0 12px; }
  .venues-content h2 span { color: rgba(255,255,255,0.8); }
  .venues-content > p { font-size: 1rem; opacity: 0.85; margin: 0 0 40px; }
  .venues-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; }
  .venue-item {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    padding: 12px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 500;
  }
  .venue-item svg { fill: #FFB800; }

  .testimonios-section { padding: 80px 0; background: linear-gradient(180deg, #fdf8fa 0%, #fff 100%); }
  .testimonios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 50px; }

  @media (max-width: 1024px) { .testimonios-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .venues-content h2 { font-size: 1.5rem; }
    .venues-grid { gap: 10px; }
    .venue-item { padding: 10px 16px; font-size: 0.8rem; }
    .testimonios-grid { grid-template-columns: 1fr; }
  }
</style>
