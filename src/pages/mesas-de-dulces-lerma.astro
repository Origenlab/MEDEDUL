  {
    num: 1,
    title: 'Especialistas en Corporativos',
    desc: 'Lerma concentra parques industriales y corporativos. Tenemos paquetes diseñados para eventos empresariales, lanzamientos, fin de año y activaciones de marca.',
    img: '/img/galeria/mesa-dulces-evento-corporativo-profesional.avif'
  },
  {
    num: 2,
    title: 'Branding Corporativo',
    desc: 'Integramos logos, colores institucionales y mensajes de marca al diseño de la mesa. Backdrops, vasos y empaques personalizados disponibles.',
    img: '/img/galeria/candy-bar-empresarial-moderno-minimalista.avif'
  },
  {
    num: 3,
    title: 'Eventos Sociales en Haciendas',
    desc: 'También atendemos bodas, XV años y celebraciones familiares en haciendas y salones de Lerma. Mismo estándar premium que en CDMX y Metepec.',
    img: '/img/galeria/mesa-dulces-boda-elegante-dorado-velas-trufas.avif'
  },
  {
    num: 4,
    title: 'Factura CFDI',
    desc: 'Emitimos factura CFDI para personas físicas y morales. Atención profesional con RRHH y áreas de eventos para procesos empresariales.',
    img: '/img/galeria/mesa-dulces-lujo-dorado-cristal-eventos.avif'
  }
];

const testimoniosLerma = [
  {
    name: 'TechnoLerma SA',
    initials: 'TL',
    review: 'Contratamos a Mededul para nuestro evento de fin de año en planta Lerma. Profesionales, puntuales y la mesa quedó alineada con nuestro branding. Volveremos a contratarlos.',
    event: 'Evento Corporativo, Parque Industrial Lerma',
    rating: 5
  },
  {
    name: 'Ana y Mateo',
    initials: 'AM',
    review: 'Nuestra boda en Hacienda La Glorieta fue inolvidable. La mesa de dulces se integró perfecto con la decoración y los invitados quedaron sorprendidos.',
    event: 'Boda en Hacienda La Glorieta, Lerma',
    rating: 5
  },
  {
    name: 'Logistica del Centro',
    initials: 'LC',
