---
// BaseLayout - Main layout for all pages
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import TopBar from '@/components/global/TopBar.astro';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import '@/styles/global.css';
import '@/styles/layout.css';
import '@/styles/design-system.css';
import '@/styles/mobile.css';
import blogStylesHref from '@/styles/blog.css?url';
import articleStylesHref from '@/styles/article.css?url';
import categoryStylesHref from '@/styles/category.css?url';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  article?: {
    category: string;
    tags?: string[];
  };
  noindex?: boolean;
  includeOrganizationSchema?: boolean;
  includeLocalBusinessSchema?: boolean;
  includeServiceSchema?: boolean;
  includeBlogStyles?: boolean;
  includeArticleStyles?: boolean;
  includeCategoryStyles?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  article,
  noindex = false,
  includeOrganizationSchema = false,
  includeLocalBusinessSchema = false,
  includeServiceSchema = false,
  includeBlogStyles = false,
  includeArticleStyles = false,
  includeCategoryStyles = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const googleFontsHref = 'https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Pacifico&display=swap';

---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      article={article}
      noindex={noindex}
    />

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/img/branding/favicon-mededul-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/branding/favicon-mededul-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/branding/apple-touch-icon-mededul.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#D1007A" />
    <meta name="msapplication-TileColor" content="#D1007A" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: async stylesheet to reduce render blocking -->
    <link rel="preload" as="style" href={googleFontsHref} />
    <script is:inline define:vars={{ googleFontsHref }}>
      (() => {
        if (document.querySelector('link[data-google-fonts]')) return;
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = googleFontsHref;
        link.setAttribute('data-google-fonts', 'true');
        document.head.appendChild(link);
      })();
    </script>
    <noscript>
      <link
        href={googleFontsHref}
        rel="stylesheet"
      />
    </noscript>
    {includeBlogStyles && <link rel="stylesheet" href={blogStylesHref} />}
    {includeArticleStyles && <link rel="stylesheet" href={articleStylesHref} />}
    {includeCategoryStyles && <link rel="stylesheet" href={categoryStylesHref} />}

    <!-- JSON-LD Schemas -->
    {includeOrganizationSchema && <JsonLd type="Organization" />}
    {includeLocalBusinessSchema && <JsonLd type="LocalBusiness" />}
    {includeServiceSchema && <JsonLd type="Service" />}

    <!-- GA4: pendiente — agregar ID real cuando Frank configure Google Analytics -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script> -->
    <slot name="head" />
  <!-- ExactDN CDN -->
  <script is:inline>
    (function(){
      var cdn = "https://e2pex68gctc.exactdn.com";
      if (window.location.hostname === "localhost") return;
      document.addEventListener("DOMContentLoaded", function(){
        var imgs = document.querySelectorAll("img[src^=\"/img/\"]");
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].src = cdn + imgs[i].getAttribute("src");
        }
      });
    })();
  </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Saltar al contenido</a>
    <TopBar />
    <Header currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <script is:inline>
      (() => {
        let lastOffset = -1;
        let lastTopbar = -1;
        const applyHeaderOffset = () => {
          const topBar = document.querySelector('.top-bar');
          const header = document.querySelector('.header');
          const topbarH = topBar?.offsetHeight || 0;
          const offset = topbarH + (header?.offsetHeight || 0);
          if (topbarH !== lastTopbar) {
            lastTopbar = topbarH;
            document.documentElement.style.setProperty('--topbar-offset', `${topbarH}px`);
          }
          if (offset !== lastOffset) {
            lastOffset = offset;
            document.documentElement.style.setProperty('--site-header-offset', `${offset}px`);
          }
        };

        const applyOnNextFrame = () => window.requestAnimationFrame(applyHeaderOffset);

        applyOnNextFrame();
        window.addEventListener('load', applyOnNextFrame, { passive: true });
        window.addEventListener('resize', applyOnNextFrame, { passive: true });
        document.addEventListener('astro:page-load', applyOnNextFrame);
      })();
    </script>

    <slot name="scripts" />

    <!-- DMChamp chat widget (data-cfasync=false → opt-out de Cloudflare Rocket Loader) -->
    <script data-cfasync="false" src="https://api.dmchamp.com/v1/chat-widget/QjJvgg44KjPKkctV92lS"></script>

    <!--
      Interceptor global: cualquier link/botón a WhatsApp (wa.me, api.whatsapp.com,
      whatsapp://, [data-whatsapp]) abre el widget DMChamp en vez de salir a WA.
      Opt-out por elemento: agregar `data-no-dmchamp` para conservar el flujo directo.
    -->
    <script is:inline>
      (function () {
        if (window.__mededulDMChampInterceptor) return;
        window.__mededulDMChampInterceptor = true;

        var WA_PATTERN = /(?:^|[\/.@:])(?:wa\.me|api\.whatsapp\.com|web\.whatsapp\.com|whatsapp:)/i;

        function tryOpenDMChamp() {
          // 1) APIs globales conocidas que pudiera exponer el widget
          var apis = [
            window.dmchamp, window.DMChamp, window.DMChampWidget,
            window.DmChamp, window.dmChamp, window.dmchampWidget
          ];
          for (var i = 0; i < apis.length; i++) {
            var a = apis[i];
            if (!a) continue;
            if (typeof a.open === 'function')   { try { a.open();   return true; } catch (_) {} }
            if (typeof a.show === 'function')   { try { a.show();   return true; } catch (_) {} }
            if (typeof a.toggle === 'function') { try { a.toggle(); return true; } catch (_) {} }
          }
          // 2) Botón launcher del widget (DOM o shadow DOM)
          var hostSelectors = [
            '[id^="dmchamp"]', '[id*="dm-champ"]', '[id*="dmchamp"]',
            '[class*="dmchamp"]', '[class*="dm-champ"]',
            '[data-dmchamp-launcher]', '.dmchamp-launcher'
          ];
          for (var j = 0; j < hostSelectors.length; j++) {
            var host = document.querySelector(hostSelectors[j]);
            if (!host) continue;
            // shadow DOM
            if (host.shadowRoot) {
              var inner = host.shadowRoot.querySelector('button, [role="button"], a');
              if (inner && typeof inner.click === 'function') { inner.click(); return true; }
            }
            // light DOM
            var btn = host.querySelector ? host.querySelector('button, [role="button"], a') : null;
            var target = btn || host;
            if (target && typeof target.click === 'function') { target.click(); return true; }
          }
          return false;
        }

        function openWithRetry(fallbackHref) {
          var start = Date.now();
          var maxMs = 5000;
          (function tick() {
            if (tryOpenDMChamp()) return;
            if (Date.now() - start > maxMs) {
              // Fallback: si después de 5s no carga el widget, abre WhatsApp directo
              if (fallbackHref) {
                try { window.open(fallbackHref, '_blank', 'noopener,noreferrer'); } catch (_) {}
              }
              return;
            }
            setTimeout(tick, 180);
          })();
        }

        function isWAHref(href) {
          if (!href) return false;
          return WA_PATTERN.test(href);
        }

        document.addEventListener('click', function (e) {
          var node = e.target;
          if (!(node instanceof Element)) return;
          var trigger = node.closest('a, button, [role="button"], [data-whatsapp]');
          if (!trigger) return;
          if (trigger.hasAttribute('data-no-dmchamp')) return;

          var href = trigger.getAttribute('href') || trigger.getAttribute('data-whatsapp') || '';
          var clsList = trigger.classList || { contains: function () { return false; } };
          var isWA =
            isWAHref(href) ||
            trigger.hasAttribute('data-whatsapp') ||
            clsList.contains('whatsapp-trigger') ||
            clsList.contains('js-whatsapp');

          if (!isWA) return;

          e.preventDefault();
          e.stopPropagation();
          openWithRetry(href);
        }, true); // capture: intercepta antes que cualquier otro handler
      })();
    </script>
  </body>
</html>
