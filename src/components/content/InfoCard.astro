---
/**
 * InfoCard Component
 * Purpose: Informational cards for concepts, definitions, highlights
 *
 * @example
 * <InfoCard title="¿Qué son los macarons?">
 *   Los macarons son delicados dulces franceses hechos con merengue,
 *   almendra molida y rellenos cremosos.
 * </InfoCard>
 *
 * @example with icon
 * <InfoCard title="Tip profesional" icon="💡" variant="tip">
 *   Reserva con 3 semanas de anticipación para mejores resultados.
 * </InfoCard>
 */

interface Props {
  title: string;
  icon?: string;
  variant?: 'default' | 'tip' | 'definition' | 'highlight';
}

const { title, icon, variant = 'default' } = Astro.props;

const defaultIcons = {
  default: '📌',
  tip: '💡',
  definition: '📖',
  highlight: '✨'
};

const displayIcon = icon || defaultIcons[variant];
---

<article class={`info-card info-${variant}`}>
  <header class="info-header">
    {displayIcon && <span class="info-icon">{displayIcon}</span>}
    <h4 class="info-title">{title}</h4>
  </header>
  <div class="info-body">
    <slot />
  </div>
</article>

<style>
  .info-card {
    margin: 32px 0;
    padding: 28px;
    border-radius: 20px;
    background: var(--blanco, #ffffff);
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .info-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, #d1007a 0%, #7a2bc2 100%);
  }

  .info-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.1);
  }

  .info-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }

  .info-icon {
    font-size: 1.6rem;
    line-height: 1;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fff7fb 0%, #fef3fa 100%);
    border-radius: 14px;
    box-shadow: inset 0 0 0 1px rgba(209,0,122,0.12);
  }

  .info-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--negro-suave, #2D3436);
    margin: 0;
    line-height: 1.3;
  }

  .info-body {
    font-size: 0.95rem;
    color: var(--gris-texto, #636E72);
    line-height: 1.7;
  }

  .info-body :global(p) {
    margin: 0;
  }

  .info-body :global(p + p) {
    margin-top: 12px;
  }

  /* Default variant */
  .info-default {
    background: var(--gris-claro, #F8F9FA);
    border-color: transparent;
  }

  /* Tip variant */
  .info-tip {
    background: linear-gradient(135deg, #fff8e1 0%, #fffbf0 100%);
    border-color: rgba(255, 212, 59, 0.3);
  }

  .info-tip::before {
    background: linear-gradient(90deg, #f39c12 0%, #ffd43b 100%);
  }

  .info-tip .info-title {
    color: #c47306;
  }

  /* Definition variant */
  .info-definition {
    background: linear-gradient(135deg, #e3f2fd 0%, #f3e8fd 100%);
    border-color: rgba(116, 185, 255, 0.25);
  }

  .info-definition::before {
    background: linear-gradient(90deg, #0984e3 0%, #74b9ff 100%);
  }

  .info-definition .info-title {
    color: #0984e3;
  }

  /* Highlight variant */
  .info-highlight {
    background: linear-gradient(135deg, #fff7fb 0%, #fef3fa 100%);
    border-color: rgba(233, 30, 140, 0.2);
  }

  .info-highlight .info-title {
    color: var(--rosa-principal, #D1007A);
  }

  .info-highlight .info-body {
    color: var(--negro-suave, #2D3436);
  }

  @media (max-width: 480px) {
    .info-card {
      padding: 20px;
    }

    .info-icon {
      font-size: 1.25rem;
    }

    .info-title {
      font-size: 1rem;
    }
  }
</style>
