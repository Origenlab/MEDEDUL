---
/**
 * StatCard Component
 * Purpose: Highlight a single metric or key number
 *
 * @example
 * <StatCard value="500+" label="Eventos realizados" />
 * <StatCard value="4.9" label="Calificación" suffix="/5" icon="⭐" />
 */

interface Props {
  value: string | number;
  label: string;
  suffix?: string;
  icon?: string;
  accent?: boolean;
}

const { value, label, suffix, icon, accent = false } = Astro.props;
---

<div class={`stat-card ${accent ? 'stat-accent' : ''}`}>
  {icon && <span class="stat-icon">{icon}</span>}
  <div class="stat-value">
    {value}
    {suffix && <span class="stat-suffix">{suffix}</span>}
  </div>
  <div class="stat-label">{label}</div>
</div>

<style>
  .stat-card {
    background: var(--blanco, #ffffff);
    border-radius: 20px;
    padding: 30px 24px;
    text-align: center;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.06);
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .stat-card::after {
    content: "";
    position: absolute;
    top: -40px;
    right: -40px;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(209,0,122,0.08), rgba(122,43,194,0.08));
    transition: transform 0.4s ease;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 36px rgba(209, 0, 122, 0.16);
  }

  .stat-card:hover::after {
    transform: scale(1.4);
  }

  .stat-accent {
    background: linear-gradient(135deg, #d1007a 0%, #7a2bc2 100%);
    color: #ffffff;
  }

  .stat-accent::after {
    background: rgba(255,255,255,0.1);
  }

  .stat-accent .stat-label {
    color: rgba(255, 255, 255, 0.9);
  }

  .stat-icon {
    display: block;
    font-size: 2.4rem;
    margin-bottom: 12px;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  .stat-value {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #d1007a 0%, #7a2bc2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    z-index: 1;
  }

  .stat-accent .stat-value {
    background: none;
    -webkit-text-fill-color: #ffffff;
    color: #ffffff;
  }

  .stat-suffix {
    font-size: 1.25rem;
    font-weight: 600;
    opacity: 0.7;
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--gris-texto, #636E72);
    font-weight: 500;
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .stat-card {
      padding: 20px 16px;
    }

    .stat-value {
      font-size: 2rem;
    }

    .stat-label {
      font-size: 0.85rem;
    }
  }
</style>
