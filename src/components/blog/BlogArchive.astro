---
import BlogPostCard from '@/components/blog/BlogPostCard.astro';
import BlogSidebar from '@/components/blog/BlogSidebar.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  featuredPosts: CollectionEntry<'blog'>[];
  categories: string[];
  currentPage: number;
  totalPages: number;
}

const { posts, featuredPosts, categories, currentPage, totalPages } = Astro.props;

const pageUrl = (page: number) => page <= 1 ? '/blog' : `/blog/pagina/${page}`;
---

<section class="blog-content">
  <div class="blog-container">
    <div class="blog-layout">
      <div class="blog-main-col">
        {posts.length > 0 ? (
          <div class="blog-posts-grid">
            {posts.map((post, index) => (
              <BlogPostCard post={post} index={index} />
            ))}
          </div>
        ) : (
          <div class="no-articles">
            <p>Pronto publicaremos articulos nuevos sobre mesas de dulces.</p>
          </div>
        )}

        {totalPages > 1 && (
          <nav class="blog-pagination" aria-label="Paginacion del blog">
            <a class:list={['blog-page-link', { disabled: currentPage === 1 }]} href={currentPage === 1 ? '#' : pageUrl(currentPage - 1)} aria-label="Pagina anterior">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              <span>Anterior</span>
            </a>
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
              <a class:list={['blog-page-link', 'blog-page-number', { active: page === currentPage }]} href={pageUrl(page)} aria-label={`Pagina ${page}`}>{page}</a>
            ))}
            <a class:list={['blog-page-link', { disabled: currentPage === totalPages }]} href={currentPage === totalPages ? '#' : pageUrl(currentPage + 1)} aria-label="Pagina siguiente">
              <span>Siguiente</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </nav>
        )}
      </div>

      <BlogSidebar featuredPosts={featuredPosts} categories={categories} />
    </div>
  </div>
</section>

<style>
  .blog-content {
    padding: clamp(36px, 5vw, 70px) 0 clamp(48px, 6vw, 90px);
    background:
      radial-gradient(circle at 100% 0%, rgba(209, 0, 122, 0.07), transparent 42%),
      radial-gradient(circle at 0% 100%, rgba(90, 26, 163, 0.07), transparent 40%),
      var(--gris-claro);
  }

  /* Container propio del blog: mas ancho que el global y fluido */
  .blog-container {
    width: 100%;
    max-width: 1680px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 40px);
  }

  .blog-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: clamp(24px, 2.5vw, 40px);
    align-items: start;
  }

  /* Override de cascada: blog.css tiene .blog-main .posts-grid con max-width 1400px.
     Usamos clases propias para garantizar comportamiento responsivo */
  .blog-main-col {
    min-width: 0;
  }

  .blog-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(18px, 1.6vw, 28px);
    max-width: none;
    margin: 0;
    padding: 0;
  }

  /* Paginacion profesional */
  .blog-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-top: clamp(32px, 4vw, 48px);
    flex-wrap: wrap;
  }

  .blog-page-link {
    min-width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 0 14px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--texto-oscuro);
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 0.88rem;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    transition: all 0.2s ease;
  }

  .blog-page-link:hover {
    border-color: var(--rosa-principal);
    color: var(--rosa-principal);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(209, 0, 122, 0.15);
    text-decoration: none;
  }

  .blog-page-link.active {
    background: var(--gradiente-rosa);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 14px rgba(209, 0, 122, 0.35);
  }

  .blog-page-link.active:hover {
    color: #fff;
    transform: translateY(-1px);
  }

  .blog-page-link.disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  .blog-page-number {
    padding: 0;
  }

  .no-articles {
    text-align: center;
    padding: 80px 20px;
    background: #fff;
    border-radius: 20px;
    color: var(--texto-light);
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  /* ===== RESPONSIVE ===== */

  /* Laptops chicas / tablets grandes: sidebar mas estrecho */
  @media (max-width: 1280px) {
    .blog-layout {
      grid-template-columns: minmax(0, 1fr) 300px;
    }

    .blog-posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Tablets: sidebar baja al final, grid 2 cols */
  @media (max-width: 1024px) {
    .blog-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }

    .blog-posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Mobile: una columna */
  @media (max-width: 768px) {
    .blog-posts-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .blog-pagination {
      gap: 4px;
    }

    .blog-page-link {
      min-width: 40px;
      height: 40px;
      padding: 0 10px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .blog-page-link {
      min-width: 36px;
      height: 38px;
      padding: 0 8px;
      font-size: 0.8rem;
    }

    .blog-page-link svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
