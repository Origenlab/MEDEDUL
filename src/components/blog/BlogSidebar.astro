---
import { categoryMeta } from '@/content/config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  featuredPosts: CollectionEntry<'blog'>[];
  categories: string[];
}

const { featuredPosts, categories } = Astro.props;

const importantLinks = [
  { label: 'Mesas de dulces para bodas', url: '/candy-bar-eventos/mesa-dulces-boda' },
  { label: 'Dulces para XV anos', url: '/candy-bar-eventos/mesa-dulces-xv-anos' },
  { label: 'Candy bar corporativo', url: '/candy-bar-eventos/mesa-dulces-corporativos' },
  { label: 'Mesas para baby shower', url: '/candy-bar-eventos/mesa-dulces-baby-shower' },
  { label: 'Estaciones interactivas', url: '/estaciones-interactivas' },
  { label: 'Tipos de mesas de dulces', url: '/tipos-de-mesas-de-dulces' }
];

const enlacesImportantes = [
  { label: 'Servicios', url: '/servicios' },
  { label: 'Cotizar evento', url: '/contacto' },
  { label: 'Aviso de privacidad', url: '/aviso-privacidad' },
  { label: 'Terminos y condiciones', url: '/terminos-condiciones' }
];

const coberturaZonas = {
  cdmx: ['Polanco', 'Lomas', 'Bosques', 'Interlomas', 'Santa Fe', 'Pedregal', 'Condesa', 'Roma', 'Coyoacan', 'Del Valle'],
  toluca: ['Metepec Zona Esmeralda', 'Toluca Centro', 'San Carlos', 'Las Marinas']
};
---

<aside class="blog-sidebar">
  <div class="sidebar-widget">
    <h3 class="sidebar-title">Contenido relacionado</h3>
    <ul class="sidebar-list">
      {importantLinks.map(link => (
        <li>
          <a href={link.url}>
            <span class="sidebar-arrow" aria-hidden="true">›</span>
            <span>{link.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget">
    <h3 class="sidebar-title">Enlaces importantes</h3>
    <ul class="sidebar-list">
      {enlacesImportantes.map(link => (
        <li>
          <a href={link.url}>
            <span class="sidebar-arrow" aria-hidden="true">›</span>
            <span>{link.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget">
    <h3 class="sidebar-title">Categorias</h3>
    <ul class="sidebar-list sidebar-categories">
      {categories.map(category => {
        const meta = categoryMeta[category as keyof typeof categoryMeta];
        return (
          <li>
            <a href={`/blog/categoria/${category}`}>
              <span class="sidebar-cat-icon" aria-hidden="true">{meta?.icon}</span>
              <span>{meta?.name || category}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="sidebar-widget">
    <h3 class="sidebar-title">Articulos destacados</h3>
    <ul class="sidebar-featured">
      {featuredPosts.map((post, i) => (
        <li>
          <a href={`/blog/${post.slug}`}>
            <span class="featured-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="featured-title">{post.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget sidebar-cobertura">
    <h3 class="sidebar-title sidebar-title--light">Sucursales CDMX &amp; Toluca</h3>
    <p class="cobertura-intro">Operacion profesional con cobertura activa en zonas premium:</p>
    <div class="cobertura-block">
      <span class="cobertura-label">CDMX</span>
      <p class="cobertura-zonas">{coberturaZonas.cdmx.join(' · ')}</p>
    </div>
    <div class="cobertura-block">
      <span class="cobertura-label">Toluca / Metepec</span>
      <p class="cobertura-zonas">{coberturaZonas.toluca.join(' · ')}</p>
    </div>
    <a
      class="cobertura-cta"
      href="https://wa.me/525525226442?text=Hola!%20Quiero%20cotizar%20una%20mesa%20de%20dulces"
      target="_blank"
      rel="noopener"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.52 3.48A11.93 11.93 0 0 0 12.05 0C5.5 0 .17 5.33.17 11.88c0 2.09.55 4.13 1.59 5.93L0 24l6.34-1.66a11.86 11.86 0 0 0 5.7 1.45h.01c6.55 0 11.88-5.33 11.88-11.88 0-3.17-1.23-6.16-3.41-8.43zM12.05 21.8h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-3.76.99 1-3.67-.23-.38a9.86 9.86 0 0 1-1.51-5.27c0-5.46 4.44-9.9 9.91-9.9 2.65 0 5.13 1.03 7 2.9a9.85 9.85 0 0 1 2.9 7c0 5.46-4.44 9.92-9.89 9.92zm5.43-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15s-.77.97-.94 1.17c-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.39-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.88 1.22 3.08.15.2 2.1 3.21 5.09 4.5.71.31 1.27.49 1.7.63.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2.01-1.41.25-.69.25-1.28.17-1.41-.07-.13-.27-.2-.57-.35z"/></svg>
      <span>Cotizar por WhatsApp</span>
    </a>
  </div>
</aside>

<style>
  .blog-sidebar {
    position: sticky;
    top: 130px;
    display: grid;
    gap: 18px;
    min-width: 0;
  }

  .sidebar-widget {
    background: #fff;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
    padding: 22px 22px 24px;
    position: relative;
    overflow: hidden;
  }

  .sidebar-widget::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--gradiente-rosa);
    opacity: 0.9;
  }

  .sidebar-title {
    font-family: var(--font-principal);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--texto-oscuro);
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    position: relative;
  }

  .sidebar-title::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 36px;
    height: 2px;
    background: var(--rosa-principal);
    border-radius: 2px;
  }

  .sidebar-list,
  .sidebar-featured,
  .sidebar-categories {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
  }

  /* Enlaces: sin underline, hover de color y bg suave */
  .sidebar-list a,
  .sidebar-featured a,
  .sidebar-categories a {
    color: var(--texto-oscuro);
    text-decoration: none !important;
    font-size: 0.92rem;
    line-height: 1.45;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 9px 10px;
    margin: 0 -10px;
    border-radius: 10px;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .sidebar-list a:hover,
  .sidebar-featured a:hover,
  .sidebar-categories a:hover {
    background: linear-gradient(135deg, rgba(209, 0, 122, 0.07) 0%, rgba(90, 26, 163, 0.05) 100%);
    color: var(--rosa-principal);
    text-decoration: none !important;
  }

  .sidebar-arrow {
    color: var(--rosa-principal);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.3;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .sidebar-list a:hover .sidebar-arrow {
    transform: translateX(3px);
  }

  .sidebar-cat-icon {
    font-size: 1.05rem;
    line-height: 1.3;
    flex-shrink: 0;
  }

  /* Articulos destacados con numeracion */
  .sidebar-featured {
    gap: 2px;
  }

  .sidebar-featured a {
    align-items: flex-start;
    padding: 12px 10px;
  }

  .featured-num {
    font-family: var(--font-principal);
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1;
    color: rgba(209, 0, 122, 0.25);
    min-width: 26px;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .sidebar-featured a:hover .featured-num {
    color: var(--rosa-principal);
  }

  .featured-title {
    font-size: 0.88rem;
    line-height: 1.4;
    font-weight: 500;
  }

  /* Widget cobertura: gradiente dulce, contraste alto */
  .sidebar-cobertura {
    background: var(--gradiente-dulce);
    border: none;
    color: #fff;
  }

  .sidebar-cobertura::before {
    background: rgba(255, 255, 255, 0.35);
  }

  .sidebar-title--light {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.15);
  }

  .sidebar-title--light::after {
    background: #fff;
  }

  .cobertura-intro {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.88);
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .cobertura-block {
    margin-bottom: 14px;
  }

  .cobertura-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 6px;
  }

  .cobertura-zonas {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.92);
    margin: 0;
    line-height: 1.55;
  }

  .cobertura-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    margin-top: 18px;
    padding: 13px 16px;
    background: #25d366;
    color: #fff !important;
    text-align: center;
    border-radius: 12px;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none !important;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cobertura-cta:hover {
    color: #fff !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(37, 211, 102, 0.5);
    text-decoration: none !important;
  }

  .cobertura-cta svg {
    flex-shrink: 0;
  }

  /* ===== RESPONSIVE ===== */

  @media (max-width: 1024px) {
    .blog-sidebar {
      position: static;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }

    .sidebar-cobertura {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .blog-sidebar {
      grid-template-columns: 1fr;
    }

    .sidebar-widget {
      padding: 20px 18px 22px;
    }
  }
</style>
