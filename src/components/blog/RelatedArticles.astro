---
import { getCollection, type CollectionEntry } from 'astro:content';
import { getCdnUrl } from '@/lib/cdn';
import { categoryMeta } from '@/content/config';

interface Props {
  post: CollectionEntry<'blog'>;
  limit?: number;
}

const { post, limit = 6 } = Astro.props;

const all = await getCollection('blog', ({ data }) => !data.draft);

// Scoring: same category (+3), each shared tag (+1.2), same location bucket (+0.6)
// Slight recency boost so homologated content surfaces first.
const currentTags = new Set((post.data.tags || []).map((t) => t.toLowerCase()));
const currentLoc = (post.data.location || '').toLowerCase();

const scored = all
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    let score = 0;
    if (p.data.category === post.data.category) score += 3;
    const tags = (p.data.tags || []).map((t) => t.toLowerCase());
    for (const t of tags) if (currentTags.has(t)) score += 1.2;
    const loc = (p.data.location || '').toLowerCase();
    if (currentLoc && loc && (loc.includes('toluca') === currentLoc.includes('toluca'))) score += 0.4;
    return { p, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, limit)
  .map(({ p }) => p);

// Fallback: if underfilled, complete with latest posts of the same category.
let related = scored;
if (related.length < limit) {
  const sameCat = all
    .filter((p) => p.slug !== post.slug && p.data.category === post.data.category)
    .filter((p) => !related.some((r) => r.slug === p.slug));
  related = [...related, ...sameCat].slice(0, limit);
}

// Last-resort fallback: any recent content
if (related.length < limit) {
  const rest = all
    .filter((p) => p.slug !== post.slug)
    .filter((p) => !related.some((r) => r.slug === p.slug));
  related = [...related, ...rest].slice(0, limit);
}
---

{related.length > 0 && (
  <section class="related-articles" aria-label="Articulos relacionados">
    <div class="related-head">
      <span class="related-eyebrow">Sigue leyendo</span>
      <h3 class="related-title">Contenido relacionado del blog</h3>
      <p class="related-sub">Lecturas que complementan este articulo, curadas por el equipo editorial de MEDEDUL.</p>
    </div>

    <div class="related-grid">
      {related.map((p) => {
        const meta = categoryMeta[p.data.category as keyof typeof categoryMeta];
        return (
          <a href={`/blog/${p.slug}`} class="related-card">
            <div class="related-image">
              <img
                src={getCdnUrl(p.data.heroImage, { w: 400, q: 78 })}
                alt={p.data.heroImageAlt || p.data.title}
                width="400"
                height="240"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="related-body">
              {meta && (
                <span class="related-cat">
                  <span aria-hidden="true">{meta.icon}</span>
                  {meta.name}
                </span>
              )}
              <h4>{p.data.title}</h4>
              <p>{p.data.description}</p>
              <span class="related-cta">Leer articulo →</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-articles {
    margin: 56px 0 24px;
    padding: 36px 32px;
    background: linear-gradient(180deg, #fff 0%, #fafafa 100%);
    border-radius: 20px;
    border: 1px solid #eee;
  }

  .related-head {
    margin-bottom: 28px;
  }

  .related-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: #d1007a;
    background: rgba(209, 0, 122, 0.08);
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: 10px;
  }

  .related-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 6px;
    padding: 0;
    background: none;
    border: none;
  }

  .related-sub {
    font-size: 0.92rem;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #eee;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
    border-color: rgba(209, 0, 122, 0.25);
  }

  .related-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f5f5f5;
  }

  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .related-card:hover .related-image img {
    transform: scale(1.04);
  }

  .related-body {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .related-cat {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: #1d4f7a;
    background: linear-gradient(135deg, rgba(116,185,255,0.15) 0%, rgba(85,239,196,0.1) 100%);
    border: 1px solid rgba(116,185,255,0.25);
    padding: 4px 10px;
    border-radius: 999px;
    align-self: flex-start;
  }

  .related-body h4 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.35;
    padding: 0;
    background: none;
    border: none;
  }

  .related-body p {
    font-size: 0.87rem;
    line-height: 1.55;
    color: #666;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-cta {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 600;
    color: #d1007a;
  }

  @media (max-width: 980px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .related-articles {
      padding: 26px 20px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
