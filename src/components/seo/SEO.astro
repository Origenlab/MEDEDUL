---
import { getCdnUrl } from '@/lib/cdn';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  article?: {
    category: string;
    tags?: string[];
  };
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  article,
  noindex = false
} = Astro.props;

const siteUrl = Astro.site?.toString() || 'https://mesas-de-dulces.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const defaultOgImage = getCdnUrl("/img/galeria/mesa-dulces-elegante-03.avif");
const finalOgImage = ogImage ? getCdnUrl(ogImage) : defaultOgImage;

// OG para redes: Facebook/WhatsApp/Twitter NO soportan AVIF/WebP como og:image.
// Si la imagen resuelta es .avif/.webp se sirve el JPEG 1200x630 pre-generado en
// /images/og/ (nombre = ruta bajo /img/ aplanada con guiones, evita colisiones).
function ogSafeUrl(img: string): string {
  const pathname = /^https?:\/\//i.test(img)
    ? new URL(img).pathname
    : (img.split("?")[0] ?? "");
  if (!/\.(avif|webp)$/i.test(pathname)) return img;
  const flat = pathname
    .replace(/^\/img\//i, "")
    .replace(/^\//, "")
    .replace(/\.(avif|webp)$/i, "")
    .split("/")
    .join("-");
  return new URL(`/images/og/${flat}.jpg`, siteUrl).toString();
}
const socialImage = ogSafeUrl(finalOgImage);
const socialImagePath = /^https?:\/\//i.test(socialImage)
  ? new URL(socialImage).pathname
  : (socialImage.split("?")[0] ?? "");
const socialImageExt = (socialImagePath.split(".").pop() ?? "").toLowerCase();
const socialImageType =
  socialImageExt === "png"
    ? "image/png"
    : socialImageExt === "jpg" || socialImageExt === "jpeg"
      ? "image/jpeg"
      : undefined;

const fullTitle = title.includes('Mededul') ? title : `${title} | Mededul`;
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content="Mededul - Mesas de Dulces Profesionales" />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="language" content="Spanish" />
<meta name="revisit-after" content="7 days" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Geo Tags · Cobertura CDMX + Estado de México + Valle de Toluca -->
<meta name="geo.region" content="MX-CMX" />
<meta name="geo.region" content="MX-MEX" />
<meta name="geo.placename" content="Ciudad de Mexico, Toluca, Metepec" />
<meta name="geo.position" content="19.4326;-99.1332" />
<meta name="ICBM" content="19.4326, -99.1332" />
<meta name="coverage" content="CDMX, Estado de Mexico, Toluca, Metepec, Zinacantepec, Lerma, Calimaya" />
<meta name="target" content="Ciudad de Mexico, Toluca, Metepec y Valle de Toluca" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />
{socialImageType && <meta property="og:image:type" content={socialImageType} />}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content="es_MX" />
<meta property="og:site_name" content="Mededul - Mesas de Dulces" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
<meta name="twitter:image:alt" content={title} />

{article && (
  <>
    <meta property="article:section" content={article.category} />
    {article.tags?.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}
