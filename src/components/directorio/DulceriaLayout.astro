                    {dulceria.transporte.metrobus.map(mb => (
                      <li>
                        <strong>Estación {mb.estacion}</strong> (Línea {mb.linea})
                        <span class="transporte-distancia">{mb.distancia}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {dulceria.transporte.referencias && dulceria.transporte.referencias.length > 0 && (
                <div class="transporte-card referencias-card">
                  <div class="transporte-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"/>
                      <line x1="12" y1="16" x2="12" y2="12"/>
                      <line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    <h3>Referencias</h3>
                  </div>
                  <ul class="transporte-lista referencias-lista">
                    {dulceria.transporte.referencias.map(ref => (
                      <li>{ref}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>

          <!-- Horario -->
          <section class="negocio-seccion">
            <h2>Horario de Atención</h2>
            <p class="seccion-intro">
              {dulceria.nombre} opera con horario de lunes a domingo. Para compras grandes y pedidos al mayoreo conviene llegar entre apertura y mediodía, cuando el stock está completo y la atención es más ágil. Los horarios pueden variar en temporadas altas como Navidad, Día de Muertos, regreso a clases y San Valentín; confirma por teléfono antes de traslados largos.
            </p>
            <div class="horario-tabla">
              {Object.entries(dulceria.horario).map(([dia, hora]) => (
                <div class="horario-fila">
                  <span class="horario-dia">{dia.charAt(0).toUpperCase() + dia.slice(1)}</span>
                  <span class="horario-hora">{hora}</span>
                </div>
              ))}
            </div>
            <p class="horario-nota">* Horarios aproximados. Te recomendamos llamar antes de visitar.</p>
          </section>

          <!-- Ubicación Detallada -->
          <section class="negocio-seccion">
            <h2>Ubicación</h2>
            <p class="seccion-intro">
              Dirección exacta verificada en Google Maps. {dulceria.referencia ? `Referencia: ${dulceria.referencia}.` : ''} Si vas en auto, considera que las zonas comerciales de {dulceria.alcaldia} suelen tener estacionamiento limitado en vía pública; conviene llegar temprano o usar estacionamientos cercanos.
            </p>
            <div class="ubicacion-detalle">
              <div class="ubicacion-info">
                <p><strong>Dirección:</strong> {dulceria.direccion}</p>
                <p><strong>Colonia:</strong> {dulceria.colonia}</p>
                <p><strong>Alcaldía:</strong> {dulceria.alcaldia}</p>
                <p><strong>Ciudad:</strong> Ciudad de México</p>
                <p><strong>CP:</strong> {dulceria.cp}</p>
                {dulceria.referencia && <p><strong>Referencia:</strong> {dulceria.referencia}</p>}
              </div>
              <a href={dulceria.mapsUrl} class="btn-mapa-grande" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Abrir en Google Maps
              </a>
            </div>
          </section>

          <!-- Contexto dentro del directorio -->
          <section class="negocio-seccion contexto-section">
            <h2>{dulceria.nombre} dentro del directorio de dulcerías de {dulceria.alcaldia}</h2>
            <div class="contexto-contenido">
              <p>
                <strong>{dulceria.nombre}</strong> forma parte del mapa de dulcerías verificadas de <strong>{dulceria.alcaldia}</strong>, una alcaldía de Ciudad de México donde la oferta de dulces y golosinas es relevante por concentrar tanto comercio de barrio como zonas de abasto. {infoAlcaldia && infoAlcaldia.caracteristicas.length > 0 ? `La zona se caracteriza por ${infoAlcaldia.caracteristicas.slice(0, 2).join(' y ').toLowerCase()}, lo que facilita encontrar varios proveedores en un solo traslado.` : ''} Para planear eventos grandes, recorrer dos o tres puntos del directorio en una misma salida suele rendir mejor que comprar todo en un solo lugar.
              </p>
              <p>
                El formato de <strong>{dulceria.tipo.toLowerCase()}</strong> de esta tienda la posiciona frente a otras opciones de la alcaldía: {dulceria.tipo === 'Dulcería Mayoreo' ? 'compite por volumen y precio, con fortaleza en abasto grande y surtido constante' : ''}{dulceria.tipo === 'Tienda de Golosinas' ? 'compite por variedad y proximidad, con fortaleza en compras por pieza y pedidos flexibles' : ''}{dulceria.tipo === 'Tienda de Golosinas Premium' ? 'compite por calidad y presentación, con fortaleza en líneas importadas y empaques cuidados' : ''}{dulceria.tipo === 'Dulcería Tradicional' ? 'compite por autenticidad y herencia, con fortaleza en dulces mexicanos que otros comercios ya no manejan' : ''}. Antes de decidir, vale la pena comparar precios y especialidades frente a otras tiendas listadas en el directorio y evaluar tiempo de traslado, formas de pago y disponibilidad de productos clave para tu evento o reventa.
              </p>
            </div>
          </section>

          <!-- FAQ -->
          <section class="negocio-seccion">
            <SectionHeader
              title="Preguntas sobre"
              titleHighlight={dulceria.nombre}
            />
            <FAQ items={faqsDulceria} id="faq-dulceria" />
          </section>
        </main>

        <!-- Sidebar -->
        <DirectorioSidebar currentSlug={dulceria.slug} />
      </div>
    </div>
  </div>

  <!-- Otras Dulcerías Relacionadas -->
  {dulceriasRelacionadas.length > 0 && (
    <section class="otras-dulcerias section-padding">
      <div class="container">
        <SectionHeader
          title="Otras Dulcerías en"
          titleHighlight={dulceria.alcaldia}
          subtitle="Explora más opciones de dulcerías verificadas en la zona"
        />
        <div class="relacionadas-grid">
          {dulceriasRelacionadas.map(d => (
