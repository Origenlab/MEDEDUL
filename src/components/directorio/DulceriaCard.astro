---
import { getCdnUrl } from '@/lib/cdn';
import type { Dulceria } from '@/data/dulcerias';

interface Props {
  dulceria: Dulceria;
}

const { dulceria: prov } = Astro.props;
const tieneTelefono = prov.telefono !== 'Sin teléfono registrado';
---

<article class="dulceria-card">
  <div class="dulceria-card__imagen">
    <a href={`/directorio/${prov.slug}`}>
      <img
        src={getCdnUrl(prov.imagen, { w: 400, q: 80 })}
        alt={`${prov.nombre} - ${prov.tipo} en ${prov.colonia}`}
        loading="lazy"
        width="400"
        height="250"
      />
    </a>
    {prov.destacado && <span class="dulceria-card__badge-destacado">Destacado</span>}
    {prov.verificado && (
      <span class="dulceria-card__badge-verificado" title="Negocio verificado en Google">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </span>
    )}
  </div>
  <div class="dulceria-card__contenido">
    <span class="dulceria-card__categoria">{prov.tipo}</span>
    <h3><a href={`/directorio/${prov.slug}`}>{prov.nombre}</a></h3>
    <div class="dulceria-card__rating">
      <div class="dulceria-card__stars">
        {[1,2,3,4,5].map(star => (
          <svg viewBox="0 0 24 24" fill={star <= Math.floor(prov.rating) ? "#FFB800" : "#E0E0E0"}>
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
      <span class="dulceria-card__rating-num">{prov.rating}</span>
      <span class="dulceria-card__rating-count">({prov.resenas.toLocaleString()})</span>
    </div>
    <div class="dulceria-card__ubicacion">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span>{prov.colonia}</span>
    </div>
    <div class="dulceria-card__tags">
      {prov.especialidades.slice(0, 2).map(esp => (
        <span class="dulceria-card__tag">{esp}</span>
      ))}
    </div>
    <div class="dulceria-card__acciones">
      <a href={`/directorio/${prov.slug}`} class="dulceria-card__btn-perfil">Ver Perfil</a>
      {tieneTelefono && (
        <a href={`tel:+52${prov.telefono.replace(/\s/g, '')}`} class="dulceria-card__btn-icon" title={prov.telefono}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </a>
      )}
      <a href={prov.mapsUrl} class="dulceria-card__btn-icon" target="_blank" rel="noopener" title="Ver en Google Maps">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .dulceria-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
    display: flex;
    flex-direction: column;
  }

  .dulceria-card__imagen {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .dulceria-card__imagen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dulceria-card__badge-destacado {
    position: absolute;
    top: 10px;
    left: 10px;
    background: linear-gradient(135deg, #FFB800 0%, #FF8C00 100%);
    color: #fff;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .dulceria-card__badge-verificado {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #fff;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .dulceria-card__badge-verificado svg {
    width: 18px;
    height: 18px;
    color: #25D366;
  }

  .dulceria-card__contenido {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .dulceria-card__categoria {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--rosa-principal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .dulceria-card__contenido h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 4px 0 8px;
    line-height: 1.3;
  }

  .dulceria-card__contenido h3 a {
    color: inherit;
    text-decoration: none;
  }

  .dulceria-card__contenido h3 a:hover {
    color: var(--rosa-principal);
    transition: color 0.3s;
  }

  .dulceria-card__rating {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 10px;
  }

  .dulceria-card__stars {
    display: flex;
    gap: 1px;
  }

  .dulceria-card__stars svg {
    width: 14px;
    height: 14px;
  }

  .dulceria-card__rating-num {
    font-weight: 700;
    color: var(--texto-oscuro);
    font-size: 0.85rem;
  }

  .dulceria-card__rating-count {
    font-size: 0.75rem;
    color: var(--texto-light);
  }

  .dulceria-card__ubicacion {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--texto-light);
    margin-bottom: 10px;
  }

  .dulceria-card__ubicacion svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--rosa-principal);
  }

  .dulceria-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }

  .dulceria-card__tag {
    background: rgba(209, 0, 122, 0.08);
    color: var(--rosa-principal);
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 500;
  }

  .dulceria-card__acciones {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid #f5f5f5;
  }

  .dulceria-card__btn-perfil {
    flex: 1;
    padding: 10px 12px;
    background: var(--rosa-principal);
    border: none;
    border-radius: 10px;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    transition: all 0.3s;
  }

  .dulceria-card__btn-perfil:hover {
    background: #A0005F;
  }

  .dulceria-card__btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: #f5f5f5;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .dulceria-card__btn-icon svg {
    width: 16px;
    height: 16px;
    color: var(--texto-oscuro);
  }

  .dulceria-card__btn-icon:hover {
    background: rgba(209, 0, 122, 0.08);
  }

  .dulceria-card__btn-icon:hover svg {
    color: var(--rosa-principal);
  }
</style>
