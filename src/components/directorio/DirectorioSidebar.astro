---
/**
 * DirectorioSidebar - Sidebar para páginas del directorio
 * Proporciona interlinking con servicios y secciones del sitio
 */
import { getEstadisticasDirectorio, getDulceriasDestacadas } from '@/data/dulcerias';

interface Props {
  currentSlug?: string;
  showServicios?: boolean;
  showEventos?: boolean;
  showZonas?: boolean;
  showCategorias?: boolean;
  showDulceriasTop?: boolean;
}

const {
  currentSlug = '',
  showServicios = true,
  showEventos = true,
  showZonas = true,
  showCategorias = true,
  showDulceriasTop = false
} = Astro.props;

// Obtener estadísticas reales
const stats = getEstadisticasDirectorio();
const dulceriasTop = getDulceriasDestacadas().slice(0, 5);

const servicios = [
  { label: 'Mesa de Dulces', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces', icon: '🍬' },
  { label: 'Mesa de Postres', href: '/tipos-de-mesas-de-dulces/mesa-de-postres', icon: '🍰' },
  { label: 'Mesa de Frutas', href: '/tipos-de-mesas-de-dulces/mesa-de-frutas', icon: '🍓' },
  { label: 'Dulces Tradicionales', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces-tradicionales', icon: '🇲🇽' },
  { label: 'Fuente de Chocolate', href: '/estaciones-interactivas/fuente-de-chocolate', icon: '🍫' }
];

const eventos = [
  { label: 'Bodas', href: '/candy-bar-eventos/mesa-dulces-boda', icon: '💒' },
  { label: 'XV Años', href: '/candy-bar-eventos/mesa-dulces-xv-anos', icon: '👑' },
  { label: 'Baby Shower', href: '/candy-bar-eventos/mesa-dulces-baby-shower', icon: '👶' },
  { label: 'Bautizos', href: '/candy-bar-eventos/mesa-dulces-bautizo', icon: '✝️' },
  { label: 'Cumpleaños', href: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil', icon: '🎂' }
];

// Zonas con datos reales
const zonas = [
  { label: 'CDMX', href: '/directorio/todos', count: `${stats.alcaldias} alcaldías` },
  { label: 'Estado de México', href: '/directorio/edomex', count: 'Próximamente' }
];

const categorias = [
  { label: 'Dulces Tradicionales', href: '/directorio/categorias/dulces-tradicionales', icon: '🍬' },
  { label: 'Chocolates y Trufas', href: '/directorio/categorias/chocolates-trufas', icon: '🍫' },
  { label: 'Gomitas y Confitería', href: '/directorio/categorias/gomitas-confiteria', icon: '🍭' },
  { label: 'Mayoreo La Merced', href: '/directorio/todos', icon: '📦' },
  { label: 'Paletas y Piruletas', href: '/directorio/categorias/paletas-piruletas', icon: '🍡' },
  { label: 'Dulces Importados', href: '/directorio/categorias/dulces-importados', icon: '🌍' }
];
---

<aside class="directorio-sidebar">
  <!-- Stats del Directorio -->
  <div class="sidebar-stats">
    <div class="stat-row">
      <span class="stat-num">{stats.total}</span>
      <span class="stat-txt">Dulcerías</span>
    </div>
    <div class="stat-row">
      <span class="stat-num">{stats.alcaldias}</span>
      <span class="stat-txt">Alcaldías</span>
    </div>
    <div class="stat-row">
      <span class="stat-num">{Math.round(stats.totalResenas / 1000)}k+</span>
      <span class="stat-txt">Reseñas</span>
    </div>
  </div>

  <!-- CTA Principal -->
  <div class="sidebar-cta">
    <h3>¿Necesitas una Mesa de Dulces?</h3>
    <p>Diseñamos mesas personalizadas para tu evento</p>
    <a href="/cotizar" class="sidebar-cta-btn">Cotizar Ahora</a>
  </div>

  {showCategorias && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">
        <span class="sidebar-title-icon">📂</span>
        Categorías
      </h4>
      <ul class="sidebar-list">
        {categorias.map(cat => (
          <li>
            <a href={cat.href} class:list={['sidebar-link', { active: cat.href.includes(currentSlug) }]}>
              <span class="link-icon">{cat.icon}</span>
              <span>{cat.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {showZonas && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">
        <span class="sidebar-title-icon">📍</span>
        Zonas de Cobertura
      </h4>
      <ul class="sidebar-list sidebar-list--zonas">
        {zonas.map(zona => (
          <li>
            <a href={zona.href} class="sidebar-link sidebar-link--zona">
              <span class="zona-nombre">{zona.label}</span>
              <span class="zona-count">{zona.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  {showServicios && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">
        <span class="sidebar-title-icon">🎉</span>
        Nuestros Servicios
      </h4>
      <ul class="sidebar-list">
        {servicios.map(serv => (
          <li>
            <a href={serv.href} class="sidebar-link">
              <span class="link-icon">{serv.icon}</span>
              <span>{serv.label}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/servicios" class="sidebar-ver-mas">Ver todos los servicios →</a>
    </div>
  )}

  {showEventos && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">
        <span class="sidebar-title-icon">✨</span>
        Eventos que Atendemos
      </h4>
      <ul class="sidebar-list">
        {eventos.map(evento => (
          <li>
            <a href={evento.href} class="sidebar-link">
              <span class="link-icon">{evento.icon}</span>
              <span>{evento.label}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/candy-bar-eventos" class="sidebar-ver-mas">Ver todos los eventos →</a>
    </div>
  )}

  <!-- Contacto Rápido -->
  <div class="sidebar-contacto">
    <h4 class="sidebar-title">
      <span class="sidebar-title-icon">📞</span>
      Contacto Directo
    </h4>
    <a href="tel:+525525226442" class="sidebar-telefono">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
      55 2522 6442
    </a>
    <a href="https://wa.me/525525226442?text=Hola!%20Vi%20el%20directorio%20de%20dulces" class="sidebar-whatsapp" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
      WhatsApp
    </a>
  </div>

  <!-- Artículos Relacionados -->
  <div class="sidebar-section sidebar-articulos">
    <h4 class="sidebar-title">
      <span class="sidebar-title-icon">📝</span>
      Blog & Consejos
    </h4>
    <ul class="sidebar-list">
      <li><a href="/blog/mesa-de-dulces-cdmx-guia-completa" class="sidebar-link sidebar-link--articulo">Guía: Mesa de Dulces CDMX</a></li>
      <li><a href="/blog/tendencias-mesas-dulces-2025" class="sidebar-link sidebar-link--articulo">Tendencias 2025</a></li>
      <li><a href="/blog/cuantos-dulces-necesito-para-mi-fiesta" class="sidebar-link sidebar-link--articulo">¿Cuántos dulces necesito?</a></li>
    </ul>
    <a href="/blog" class="sidebar-ver-mas">Ver todos los artículos →</a>
  </div>
</aside>

<style>
  .directorio-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 180px;
  }

  /* Stats del Directorio */
  .sidebar-stats {
    display: flex;
    justify-content: space-around;
    padding: 20px;
    background: linear-gradient(135deg, #fdf8fa 0%, #fff 100%);
    border-radius: 16px;
    border: 2px solid rgba(209, 0, 122, 0.1);
  }

  .stat-row {
    text-align: center;
  }

  .stat-num {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--rosa-principal);
    line-height: 1;
  }

  .stat-txt {
    font-size: 0.75rem;
    color: var(--texto-light);
  }

  /* CTA Principal */
  .sidebar-cta {
    background: linear-gradient(135deg, var(--rosa-principal) 0%, #A0005F 100%);
    border-radius: 20px;
    padding: 28px 24px;
    text-align: center;
    color: #fff;
  }

  .sidebar-cta-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 12px;
  }

  .sidebar-cta h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .sidebar-cta p {
    font-size: 0.85rem;
    opacity: 0.9;
    margin: 0 0 20px;
    line-height: 1.5;
  }

  .sidebar-cta-btn {
    display: inline-block;
    width: 100%;
    padding: 14px 24px;
    background: #fff;
    color: var(--rosa-principal);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 50px;
    transition: all 0.3s;
  }

  .sidebar-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
  }

  /* Secciones */
  .sidebar-section {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
  }

  .sidebar-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Poppins', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--texto-oscuro);
    margin: 0 0 18px;
    padding-bottom: 12px;
    border-bottom: 2px solid rgba(209, 0, 122, 0.15);
  }

  .sidebar-title-icon {
    font-size: 1.1rem;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    font-size: 0.88rem;
    color: var(--texto-light);
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.2s;
  }

  .sidebar-link:hover {
    background: rgba(209, 0, 122, 0.08);
    color: var(--rosa-principal);
    padding-left: 16px;
  }

  .sidebar-link.active {
    background: rgba(209, 0, 122, 0.1);
    color: var(--rosa-principal);
    font-weight: 600;
  }

  .link-icon {
    font-size: 1rem;
    width: 24px;
    text-align: center;
  }

  /* Zonas */
  .sidebar-list--zonas .sidebar-link--zona {
    justify-content: space-between;
    background: #fafafa;
    border: 1px solid #f0f0f0;
  }

  .sidebar-link--zona:hover {
    background: rgba(209, 0, 122, 0.08);
    border-color: rgba(209, 0, 122, 0.2);
  }

  .zona-nombre {
    font-weight: 600;
    color: var(--texto-oscuro);
  }

  .zona-count {
    font-size: 0.75rem;
    color: var(--texto-light);
    background: #fff;
    padding: 4px 10px;
    border-radius: 20px;
  }

  /* Ver más */
  .sidebar-ver-mas {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--rosa-principal);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .sidebar-ver-mas:hover {
    text-decoration: underline;
  }

  /* Contacto */
  .sidebar-contacto {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
  }

  .sidebar-telefono,
  .sidebar-whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
  }

  .sidebar-telefono {
    background: #f8f8f8;
    color: var(--texto-oscuro);
    margin-bottom: 10px;
  }

  .sidebar-telefono:hover {
    background: rgba(209, 0, 122, 0.08);
    color: var(--rosa-principal);
  }

  .sidebar-telefono svg {
    width: 20px;
    height: 20px;
    color: var(--rosa-principal);
  }

  .sidebar-whatsapp {
    background: #25D366;
    color: #fff;
  }

  .sidebar-whatsapp:hover {
    background: #128C7E;
    transform: translateY(-2px);
  }

  .sidebar-whatsapp svg {
    width: 22px;
    height: 22px;
  }

  /* Artículos */
  .sidebar-link--articulo {
    padding: 8px 0;
    border-bottom: 1px solid #f5f5f5;
  }

  .sidebar-link--articulo:last-child {
    border-bottom: none;
  }

  .sidebar-link--articulo:hover {
    padding-left: 8px;
    background: transparent;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .directorio-sidebar {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .sidebar-cta {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .directorio-sidebar {
      grid-template-columns: 1fr;
    }

    .sidebar-cta {
      grid-column: span 1;
    }
  }
</style>
