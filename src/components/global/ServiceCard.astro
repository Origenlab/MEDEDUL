---
import { getCdnSrcSet, getCdnUrl } from '@/lib/cdn';

/**
 * ServiceCard Component - Professional Service Cards
 * ===================================================
 * Card reutilizable para servicios, tipos de mesas y eventos.
 * Soporta subsecciones estilo REDEIL con links internos.
 *
 * Props:
 * @param {string} href - URL del enlace principal (required)
 * @param {string} image - URL de la imagen (required)
 * @param {string} alt - Alt text para SEO (required)
 * @param {string} title - Título de la card (required)
 * @param {string} excerpt - Extracto SEO descriptivo (required)
 * @param {string} cta - Texto del CTA (default: 'Ver más')
 * @param {string} badge - Badge opcional (ej: 'Popular', 'Nuevo')
 * @param {Subsection[]} subsections - Links de subsecciones dentro de la card
 * @param {number} width - Width de imagen para optimización
 * @param {number} height - Height de imagen para optimización
 * @param {'default' | 'featured'} variant - Variante de diseño
 */

interface Subsection {
  label: string;
  sublabel?: string;
  href: string;
}

interface Props {
  href: string;
  image: string;
  alt: string;
  title: string;
  excerpt: string;
  cta?: string;
  badge?: string;
  subsections?: Subsection[];
  width?: number;
  height?: number;
  variant?: 'default' | 'featured';
}

const {
  href,
  image,
  alt,
  title,
  excerpt,
  cta = 'Ver más',
  badge,
  subsections,
  width = 560,
  height = 686,
  variant = 'default'
} = Astro.props;

const isFeatured = variant === 'featured';
const hasSubs = subsections && subsections.length > 0;
const imageWidths = isFeatured ? [400, 560, 720, 960] : [240, 320, 400, 560, 640];
const imageSizes = isFeatured
  ? '(max-width: 1024px) 100vw, 50vw'
  : '(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 307px';
const imageSrc = getCdnUrl(image, { w: width });
const imageSrcSet = getCdnSrcSet(image, imageWidths);
---

<article class={`service-card ${isFeatured ? 'service-card--featured' : ''} ${hasSubs ? 'service-card--has-subs' : ''}`}>
  {badge && <span class="service-card__badge">{badge}</span>}

  <a href={href} class="service-card__image-link" tabindex="-1" aria-label={title}>
    <div class="service-card__image-wrapper">
      <img
        src={imageSrc}
        srcset={imageSrcSet}
        sizes={imageSizes}
        alt={alt}
        class="service-card__image"
        loading="lazy"
        decoding="async"
        fetchpriority="low"
        width={width}
        height={height}
      />
    </div>
  </a>

  <div class="service-card__content">
    <a href={href} class="service-card__title-link">
      <h3 class="service-card__title">{title}</h3>
    </a>
    <p class="service-card__excerpt">{excerpt}</p>

    {hasSubs && (
      <ul class="service-card__subsections" role="list">
        {subsections!.map(sub => (
          <li>
            <a href={sub.href} class="service-card__sub-item">
              <div class="service-card__sub-text">
                <span class="service-card__sub-label">{sub.label}</span>
                {sub.sublabel && <span class="service-card__sub-sublabel">{sub.sublabel}</span>}
              </div>
              <svg class="service-card__sub-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    )}

    <a href={href} class="service-card__cta">
      {cta}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>

<style>
  /* =====================================================
     SERVICE CARD COMPONENT - Professional Design
     Single scoped CSS - SEO optimized
     ===================================================== */

  .service-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .service-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.11);
    transform: translateY(-3px);
  }

  /* Badge */
  .service-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 10;
    padding: 6px 14px;
    background: linear-gradient(135deg, #D1007A 0%, #A0005F 100%);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 50px;
    box-shadow: 0 4px 12px rgba(233, 30, 140, 0.35);
  }

  /* Image link wrapper */
  .service-card__image-link {
    display: block;
    overflow: hidden;
    text-decoration: none;
  }

  .service-card__image-wrapper {
    position: relative;
    overflow: hidden;
  }

  .service-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-card__image {
    transform: scale(1.04);
  }

  /* Cards WITH subsections use 16/9 landscape ratio to save vertical space */
  .service-card--has-subs .service-card__image {
    aspect-ratio: 16 / 9;
  }

  /* Content */
  .service-card__content {
    padding: 22px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  /* Title link */
  .service-card__title-link {
    text-decoration: none;
    display: block;
  }

  .service-card__title-link:hover .service-card__title {
    color: #D1007A;
  }

  /* Title */
  .service-card__title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--texto-oscuro, #1a1a1a);
    margin: 0;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  /* Excerpt */
  .service-card__excerpt {
    font-size: 0.87rem;
    color: var(--gris-texto, #666);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Cards without subsections show 3 lines */
  .service-card:not(.service-card--has-subs) .service-card__excerpt {
    -webkit-line-clamp: 3;
  }

  /* ========================
     SUBSECTIONS LIST
     ======================== */
  .service-card__subsections {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    overflow: hidden;
  }

  .service-card__subsections li {
    border-bottom: 1px solid #f0f0f0;
  }

  .service-card__subsections li:last-child {
    border-bottom: none;
  }

  .service-card__sub-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 14px;
    text-decoration: none;
    background: #fafafa;
    transition: background 0.15s ease, padding-left 0.15s ease;
  }

  .service-card__sub-item:hover {
    background: #fff0f7;
    padding-left: 18px;
  }

  .service-card__sub-item:hover .service-card__sub-arrow {
    transform: translateX(3px);
    color: #D1007A;
  }

  .service-card__sub-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .service-card__sub-label {
    font-family: 'Poppins', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .service-card__sub-sublabel {
    font-size: 0.73rem;
    color: #999;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
  }

  .service-card__sub-arrow {
    flex-shrink: 0;
    color: #ccc;
    transition: transform 0.15s ease, color 0.15s ease;
  }

  /* CTA Link - Premium Design */
  .service-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 13px 20px;
    margin-top: auto;
    background: linear-gradient(135deg, #D1007A 0%, #A0005F 100%);
    color: #ffffff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(209, 0, 122, 0.28);
    text-decoration: none;
    transition: box-shadow 0.2s ease, background 0.2s ease;
  }

  .service-card__cta svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .service-card:hover .service-card__cta {
    box-shadow: 0 6px 22px rgba(209, 0, 122, 0.42);
    background: linear-gradient(135deg, #e0008a 0%, #b0006f 100%);
  }

  .service-card:hover .service-card__cta svg {
    transform: translateX(4px);
  }

  /* =========================
     FEATURED VARIANT
     ========================= */
  .service-card--featured {
    grid-column: span 2;
    flex-direction: row;
  }

  .service-card--featured .service-card__image-link {
    width: 50%;
    flex-shrink: 0;
  }

  .service-card--featured .service-card__image-wrapper {
    height: 100%;
  }

  .service-card--featured .service-card__image {
    height: 100%;
    aspect-ratio: auto;
  }

  .service-card--featured .service-card__content {
    padding: 32px 28px;
    justify-content: center;
  }

  .service-card--featured .service-card__title {
    font-size: 1.4rem;
  }

  .service-card--featured .service-card__excerpt {
    font-size: 0.95rem;
    -webkit-line-clamp: 4;
  }

  .service-card--featured .service-card__cta {
    width: auto;
    padding: 15px 28px;
    font-size: 0.95rem;
  }

  /* =========================
     RESPONSIVE - Tablet
     ========================= */
  @media (max-width: 1024px) {
    .service-card {
      border-radius: 16px;
    }

    .service-card__content {
      padding: 18px 16px 20px;
      gap: 8px;
    }

    .service-card__title {
      font-size: 1.05rem;
    }

    .service-card__excerpt {
      font-size: 0.83rem;
    }

    .service-card--featured {
      grid-column: span 1;
      flex-direction: column;
    }

    .service-card--featured .service-card__image-link {
      width: 100%;
    }

    .service-card--featured .service-card__title {
      font-size: 1.1rem;
    }

    .service-card--featured .service-card__excerpt {
      -webkit-line-clamp: 2;
    }

    .service-card__cta {
      padding: 12px 16px;
      font-size: 0.86rem;
    }

    .service-card--featured .service-card__cta {
      width: 100%;
      padding: 12px 16px;
      font-size: 0.86rem;
    }

    .service-card__sub-item {
      padding: 9px 12px;
    }

    .service-card__sub-label {
      font-size: 0.8rem;
    }

    .service-card__sub-sublabel {
      font-size: 0.71rem;
    }
  }

  /* =========================
     RESPONSIVE - Mobile
     ========================= */
  @media (max-width: 768px) {
    .service-card {
      border-radius: 14px;
    }

    .service-card__badge {
      top: 12px;
      left: 12px;
      padding: 5px 10px;
      font-size: 0.65rem;
    }

    .service-card__content {
      padding: 14px 14px 18px;
      gap: 8px;
    }

    .service-card__title {
      font-size: 0.95rem;
    }

    .service-card__excerpt {
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .service-card__cta {
      padding: 11px 14px;
      font-size: 0.84rem;
      border-radius: 10px;
    }

    .service-card__cta svg {
      width: 15px;
      height: 15px;
    }

    .service-card__subsections {
      border-radius: 10px;
    }

    .service-card__sub-item {
      padding: 9px 12px;
    }

    .service-card__sub-label {
      font-size: 0.78rem;
    }

    .service-card__sub-sublabel {
      display: none;
    }
  }

  /* =========================
     RESPONSIVE - Small Mobile
     ========================= */
  @media (max-width: 480px) {
    .service-card {
      border-radius: 12px;
    }

    .service-card__content {
      padding: 12px 12px 16px;
    }

    .service-card__title {
      font-size: 0.9rem;
    }

    .service-card__excerpt {
      font-size: 0.78rem;
    }

    .service-card__cta {
      padding: 10px 12px;
      font-size: 0.8rem;
      border-radius: 8px;
      gap: 8px;
    }

    .service-card__cta svg {
      width: 14px;
      height: 14px;
    }
  }
</style>
