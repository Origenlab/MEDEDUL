---
import SectionHeader from '@/components/global/SectionHeader.astro';
/**
 * PricingPackages Component - Seccion de Paquetes/Precios
 * ========================================================
 * Componente reutilizable para mostrar paquetes de precios
 * con diseño de tarjetas profesional.
 *
 * Usage:
 * <PricingPackages
 *   badge="Nuestros Paquetes"
 *   title="Elige el"
 *   titleHighlight="Paquete Ideal"
 *   subtitle="Opciones flexibles para tu evento"
 *   packages={[
 *     {
 *       name: "Esencial",
 *       icon: "🍬",
 *       price: "$4,500",
 *       currency: "MXN",
 *       guests: "30-50 personas",
 *       tagline: "Ideal para eventos intimos",
 *       features: ["Feature 1", "Feature 2"],
 *       popular: false,
 *       ctaText: "Cotizar Paquete",
 *       ctaUrl: "https://wa.me/..."
 *     }
 *   ]}
 *   note="Texto opcional al final"
 * />
 */

interface Package {
  name: string;
  icon: string;
  price: string;
  currency?: string;
  guests: string;
  tagline: string;
  features: string[];
  popular?: boolean;
  ctaText?: string;
  ctaUrl: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  subtitle?: string;
  content?: string;
  packages: Package[];
  note?: string;
  id?: string;
}

const {
  badge = "Nuestros Paquetes",
  title,
  titleHighlight,
  subtitle,
  content,
  packages,
  note,
  id
} = Astro.props;

// Procesar titulo con highlight
const renderTitle = () => {
  if (titleHighlight) {
    return `${title} <span>${titleHighlight}</span>`;
  }
  return title;
};
---

<section class="pricing-section" id={id}>
  <div class="container">
    {content ? (
      <SectionHeader
        title={titleHighlight ? `${title} ${titleHighlight}` : title}
        titleHighlight={titleHighlight}
        subtitle={subtitle || badge}
        content={content}
      />
    ) : (
      <div class="pricing-header">
        <span class="pricing-badge">{badge}</span>
        <h2 class="pricing-title" set:html={renderTitle()} />
        {subtitle && <p class="pricing-subtitle">{subtitle}</p>}
      </div>
    )}

    <!-- Packages Grid -->
    <div class="pricing-grid">
      {packages.map((pkg) => (
        <article class:list={['pricing-card', { 'pricing-card--popular': pkg.popular }]}>
          {pkg.popular && (
            <div class="pricing-ribbon">
              <span>Mas Popular</span>
            </div>
          )}

          <div class="pricing-card__top">
            <div class="pricing-card__icon">
              <span>{pkg.icon}</span>
            </div>
            <h3 class="pricing-card__name">{pkg.name}</h3>
            <p class="pricing-card__tagline">{pkg.tagline}</p>
          </div>

          <div class="pricing-card__price">
            <div class="price-wrapper">
              <span class="price-label">Desde</span>
              <span class="price-amount">{pkg.price}</span>
              <span class="price-currency">{pkg.currency || 'MXN'}</span>
            </div>
            <div class="price-guests">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              <span>{pkg.guests}</span>
            </div>
          </div>

          <div class="pricing-card__separator">
            <span>Incluye</span>
          </div>

          <ul class="pricing-card__features">
            {pkg.features.map((feature) => (
              <li>
                <span class="feature-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="feature-text">{feature}</span>
              </li>
            ))}
          </ul>

          <a href={pkg.ctaUrl} class="pricing-card__cta" target="_blank" rel="noopener">
            <span>{pkg.ctaText || 'Cotizar Paquete'}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    {note && (
      <p class="pricing-note" set:html={note} />
    )}
  </div>
</section>

<style>
  /* =====================================================
     PRICING PACKAGES — Redesign premium v2 (bulletproof)
     Colores explícitos, sin background-clip frágil
     ===================================================== */
  .pricing-section {
    padding: 100px 0 110px;
    background:
      radial-gradient(1200px 600px at 50% -100px, rgba(209,0,122,0.06) 0%, transparent 70%),
      linear-gradient(180deg, #fff 0%, #fdf8fa 100%);
    position: relative;
  }

  /* Header legacy (sin content prop) */
  .pricing-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 60px;
  }

  .pricing-badge {
    display: inline-block;
    padding: 9px 22px;
    background: rgba(209, 0, 122, 0.08);
    border: 1px solid rgba(209, 0, 122, 0.18);
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--rosa-principal, #D1007A);
    text-transform: uppercase;
    letter-spacing: 1.6px;
    margin-bottom: 20px;
  }

  .pricing-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.9rem, 3.8vw, 2.6rem);
    font-weight: 700;
    color: var(--texto-oscuro, #1a1a1a);
    line-height: 1.2;
    margin: 0 0 18px;
  }

  .pricing-title :global(span) {
    font-family: 'Pacifico', cursive;
    color: var(--rosa-principal, #D1007A);
    font-weight: 400;
  }

  .pricing-subtitle {
    font-size: 1.05rem;
    color: var(--texto-light, #666);
    line-height: 1.7;
    margin: 0;
  }

  /* Grid */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1220px;
    margin: 0 auto;
    align-items: stretch;
    padding: 10px 0;
  }

  /* ============ Card Base (REGULAR — fondo blanco, texto OSCURO) ============ */
  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    color: #1a1a1a;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 26px;
    padding: 36px 30px 30px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 18px 44px rgba(20, 10, 25, 0.06);
    transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
    overflow: hidden;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 56px rgba(20, 10, 25, 0.09);
    border-color: rgba(209, 0, 122, 0.22);
  }

  .pricing-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, rgba(209,0,122,0.20), rgba(209,0,122,0.55), rgba(209,0,122,0.20));
    opacity: 0.55;
  }

  /* Texto explicito en cards regulares (forzar contraste) */
  .pricing-card .pricing-card__name { color: #1a1a1a !important; }
  .pricing-card .pricing-card__tagline { color: #6b6b75 !important; }
  .pricing-card .price-label { color: #8a8a92 !important; }
  .pricing-card .price-amount { color: #D1007A !important; }
  .pricing-card .price-currency { color: #8a8a92 !important; }
  .pricing-card .price-guests { color: #4a4a55 !important; background: #f6f6f9 !important; }
  .pricing-card .price-guests svg { color: #D1007A !important; }
  .pricing-card .pricing-card__separator span { color: #D1007A !important; }
  .pricing-card .feature-text { color: #2a2a32 !important; }
  .pricing-card .pricing-card__features li { color: #2a2a32 !important; }

  /* ============ Card POPULAR (gradient oscuro, texto BLANCO/DORADO) ============ */
  .pricing-card--popular {
    background:
      radial-gradient(280px 200px at 100% 0%, rgba(255,210,138,0.18), transparent 70%),
      radial-gradient(280px 200px at 0% 100%, rgba(209,0,122,0.20), transparent 70%),
      linear-gradient(160deg, #1f0e1c 0%, #3a0f29 45%, #6b0e4a 100%) !important;
    color: #ffffff !important;
    border-color: transparent !important;
    transform: translateY(-12px) scale(1.02);
    box-shadow:
      0 0 0 1px rgba(255, 210, 138, 0.22) inset,
      0 30px 70px rgba(60, 0, 40, 0.32),
      0 0 0 6px rgba(209, 0, 122, 0.08);
    z-index: 3;
  }

  .pricing-card--popular::before {
    background: linear-gradient(90deg, transparent, #ffd28a 50%, transparent) !important;
    height: 2px !important;
    opacity: 0.9 !important;
  }

  /* Texto explicito en card POPULAR */
  .pricing-card--popular .pricing-card__name { color: #ffffff !important; }
  .pricing-card--popular .pricing-card__tagline { color: rgba(255,255,255,0.78) !important; }
  .pricing-card--popular .price-label { color: rgba(255,255,255,0.65) !important; }
  .pricing-card--popular .price-amount { color: #ffd28a !important; }
  .pricing-card--popular .price-currency { color: rgba(255,255,255,0.65) !important; }
  .pricing-card--popular .price-guests {
    color: #ffffff !important;
    background: rgba(255,255,255,0.10) !important;
  }
  .pricing-card--popular .price-guests svg { color: #ffd28a !important; }
  .pricing-card--popular .pricing-card__separator span { color: #ffd28a !important; }
  .pricing-card--popular .pricing-card__features li { color: rgba(255,255,255,0.95) !important; }
  .pricing-card--popular .feature-text { color: rgba(255,255,255,0.95) !important; }
  .pricing-card--popular .pricing-card__top { border-bottom-color: rgba(255,255,255,0.14) !important; }
  .pricing-card--popular .pricing-card__price { border-bottom-color: rgba(255,255,255,0.14) !important; }

  /* ============ Ribbon "Mas Popular" ============ */
  .pricing-ribbon {
    position: absolute;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, #ffd28a 0%, #f1a85a 100%);
    color: #2b0e22;
    padding: 6px 14px;
    font-size: 0.66rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    border-radius: 50px;
    box-shadow: 0 6px 18px rgba(255, 168, 90, 0.45);
    z-index: 4;
    transform: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .pricing-ribbon::before {
    content: '★';
    font-size: 0.7rem;
    line-height: 1;
  }

  /* ============ Top: icon + name + tagline ============ */
  .pricing-card__top {
    text-align: center;
    padding: 0 0 22px;
    margin-bottom: 22px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
    background: transparent !important;
  }

  .pricing-card__icon {
    width: 76px;
    height: 76px;
    margin: 0 auto 18px;
    background: linear-gradient(135deg, rgba(209,0,122,0.08) 0%, rgba(209,0,122,0.02) 100%);
    border: 1px solid rgba(209,0,122,0.18);
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 22px rgba(209, 0, 122, 0.10);
  }

  .pricing-card--popular .pricing-card__icon {
    background: linear-gradient(135deg, rgba(255,210,138,0.20) 0%, rgba(255,168,90,0.10) 100%) !important;
    border-color: rgba(255, 210, 138, 0.40) !important;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.32) !important;
  }

  .pricing-card__icon span {
    font-size: 2.2rem;
    line-height: 1;
  }

  .pricing-card__name {
    font-family: 'Poppins', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    margin: 0 0 8px;
    letter-spacing: -0.4px;
    line-height: 1.2;
  }

  .pricing-card__tagline {
    font-size: 0.88rem;
    margin: 0;
    line-height: 1.5;
  }

  /* ============ Price block ============ */
  .pricing-card__price {
    text-align: center;
    padding: 0 0 22px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
    background: transparent !important;
  }

  .price-wrapper {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 14px;
    line-height: 1;
  }

  .price-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    align-self: flex-start;
    padding-top: 4px;
    margin-right: 4px;
  }

  .price-amount {
    font-family: 'Poppins', sans-serif;
    font-size: 3.1rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -1.5px;
  }

  .price-currency {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .price-guests {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border-radius: 50px;
    font-size: 0.84rem;
    font-weight: 600;
  }

  /* ============ Separator (header pequeño "Incluye") ============ */
  .pricing-card__separator {
    text-align: left;
    padding: 0;
    margin-bottom: 16px;
  }

  .pricing-card__separator::before {
    display: none;
  }

  .pricing-card__separator span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    background: transparent !important;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    position: relative;
  }

  .pricing-card__separator span::after {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
  }

  /* ============ Features ============ */
  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 26px;
    flex: 1;
    background: transparent !important;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.93rem;
    line-height: 1.5;
    margin: 0;
  }

  .feature-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    box-shadow: 0 4px 10px rgba(209, 0, 122, 0.25);
  }

  .pricing-card--popular .feature-icon {
    background: linear-gradient(135deg, #ffd28a 0%, #f1a85a 100%);
    box-shadow: 0 4px 10px rgba(255, 168, 90, 0.40);
  }

  .feature-icon svg {
    color: #ffffff;
  }

  .pricing-card--popular .feature-icon svg {
    color: #2b0e22;
  }

  .feature-text {
    opacity: 0.95;
  }

  .pricing-card--popular .feature-text {
    opacity: 0.92;
  }

  /* ============ CTA ============ */
  .pricing-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px 22px;
    border-radius: 14px;
    font-family: 'Poppins', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    background: linear-gradient(135deg, var(--rosa-principal, #D1007A) 0%, #A0005F 100%);
    color: #ffffff;
    box-shadow: 0 8px 22px rgba(209, 0, 122, 0.30);
    transition: transform .2s ease, box-shadow .2s ease;
    margin-top: auto;
  }

  .pricing-card__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(209, 0, 122, 0.40);
  }

  .pricing-card--popular .pricing-card__cta {
    background: linear-gradient(135deg, #ffd28a 0%, #f1a85a 100%);
    color: #2b0e22;
    box-shadow: 0 10px 28px rgba(255, 168, 90, 0.40);
  }

  .pricing-card--popular .pricing-card__cta:hover {
    box-shadow: 0 14px 34px rgba(255, 168, 90, 0.55);
  }

  .pricing-card__cta svg {
    flex-shrink: 0;
    transition: transform .2s ease;
  }

  .pricing-card__cta:hover svg {
    transform: translateX(3px);
  }

  /* ============ Note ============ */
  .pricing-note {
    text-align: center;
    font-size: 0.95rem;
    color: var(--texto-light, #555);
    margin: 56px auto 0;
    padding: 18px 28px;
    background: #fff;
    border: 1px solid rgba(209, 0, 122, 0.12);
    border-radius: 16px;
    max-width: 720px;
    line-height: 1.6;
    box-shadow: 0 8px 22px rgba(20, 10, 25, 0.04);
  }

  .pricing-note :global(strong) {
    color: var(--rosa-principal, #D1007A);
  }

  /* ========================
     RESPONSIVE
     ======================== */
  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      gap: 30px;
    }

    .pricing-card--popular {
      transform: none;
    }

    .pricing-card--popular:hover {
      transform: translateY(-4px);
    }
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 70px 0 80px;
    }

    .pricing-card {
      padding: 32px 24px 26px;
    }

    .pricing-card__icon {
      width: 66px;
      height: 66px;
      border-radius: 18px;
    }

    .pricing-card__icon span {
      font-size: 1.95rem;
    }

    .pricing-card__name {
      font-size: 1.3rem;
    }

    .price-amount {
      font-size: 2.6rem;
    }
  }

  @media (max-width: 480px) {
    .pricing-card {
      padding: 28px 20px 22px;
      border-radius: 22px;
    }

    .pricing-card__icon {
      width: 60px;
      height: 60px;
    }

    .pricing-card__icon span {
      font-size: 1.7rem;
    }

    .pricing-card__name {
      font-size: 1.2rem;
    }

    .pricing-card__tagline {
      font-size: 0.85rem;
    }

    .price-amount {
      font-size: 2.3rem;
    }

    .price-guests {
      padding: 8px 14px;
      font-size: 0.8rem;
    }

    .pricing-card__features li {
      font-size: 0.88rem;
    }

    .pricing-card__cta {
      padding: 14px 18px;
      font-size: 0.9rem;
    }

    .pricing-ribbon {
      top: 16px;
      right: 16px;
      font-size: 0.6rem;
      padding: 5px 12px;
    }

    .pricing-note {
      padding: 16px 20px;
      font-size: 0.9rem;
      margin-top: 40px;
    }
  }
</style>
