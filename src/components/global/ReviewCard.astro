---
/**
 * ReviewCard Component v6 — Luxury Editorial Card
 * ================================================
 * Diseño dramaticamente diferente: card con fondo cream, top strip
 * gradient pink, quote en serif italic grande, avatar prominente
 * con ring pink, footer minimalista. Visualmente memorable y
 * profesional como tarjeta de prensa editorial.
 */

interface Props {
  name: string;
  link?: string;
  initials?: string;
  image?: string;
  review: string;
  event: string;
  rating?: number;
  verified?: boolean;
}

const {
  name,
  link,
  initials,
  image,
  review,
  event,
  rating = 5,
  verified = true
} = Astro.props;
---

<article class="review-v6" itemscope itemtype="https://schema.org/Review">
  <!-- Top accent strip -->
  <div class="review-v6__strip" aria-hidden="true"></div>

  <div class="review-v6__body">
    <!-- Opening quote glyph -->
    <span class="review-v6__qmark" aria-hidden="true">"</span>

    <!-- Quote serif italic -->
    <blockquote class="review-v6__quote" itemprop="reviewBody">
      <p>{review}</p>
    </blockquote>

    <!-- Footer: avatar + meta + rating -->
    <footer class="review-v6__foot">
      <div class="review-v6__avatar" itemprop="author" itemscope itemtype="https://schema.org/Person">
        {image ? (
          <img
            src={image}
            alt={name}
            class="review-v6__avatar-img"
            width="48"
            height="48"
            loading="lazy"
            itemprop="image"
          />
        ) : (
          <span class="review-v6__initials" aria-hidden="true">{initials}</span>
        )}
        <meta itemprop="name" content={name} />
      </div>

      <div class="review-v6__meta">
        <div class="review-v6__name-row">
          <cite class="review-v6__name">
            {link ? <a href={link} target="_blank" rel="noopener noreferrer" class="review-v6__name-link">{name}</a> : name}
          </cite>
          {verified && (
            <svg class="review-v6__check" width="14" height="14" viewBox="0 0 24 24" aria-label="Verificado" role="img">
              <path fill="#1d9bf0" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          )}
        </div>
        <span class="review-v6__event">{event}</span>
      </div>

      <div class="review-v6__rating" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
        <meta itemprop="ratingValue" content={String(rating)} />
        <meta itemprop="bestRating" content="5" />
        <div class="review-v6__stars" aria-label={`${rating} de 5 estrellas`}>
          {[1,2,3,4,5].map((star) => (
            <svg
              class={`review-v6__star ${star <= rating ? 'review-v6__star--filled' : ''}`}
              width="14"
              height="14"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
      </div>
    </footer>
  </div>
</article>

<style>
  /* =========================================================
     REVIEW CARD v6 — Luxury Editorial Card
     - Top strip gradient pink (visual signature)
     - Cream background (#fdfbfa) — distinto a blanco puro
     - Quote serif italic grande (Georgia)
     - Opening quote mark gigante pink (decorativo dramático)
     - Avatar con ring pink translúcido
     - Footer compacto en una sola fila
     ========================================================= */

  .review-v6 {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: linear-gradient(180deg, #fffefd 0%, #fdfbfa 100%);
    border-radius: 18px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(15, 15, 30, 0.04),
      0 6px 24px rgba(15, 15, 30, 0.06);
    transition: box-shadow .25s ease;
  }

  .review-v6:hover {
    box-shadow:
      0 2px 4px rgba(15, 15, 30, 0.05),
      0 16px 40px rgba(209, 0, 122, 0.13);
  }

  /* ---------- Top strip (signature visual) ---------- */
  .review-v6__strip {
    height: 6px;
    background: linear-gradient(90deg, #D1007A 0%, #A0005F 50%, #7A2BC2 100%);
    flex-shrink: 0;
  }

  /* ---------- Body ---------- */
  .review-v6__body {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 38px 38px 32px;
  }

  /* ---------- Opening quote glyph (decorativo dramático) ---------- */
  .review-v6__qmark {
    position: absolute;
    top: 18px;
    right: 28px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 5rem;
    line-height: 1;
    font-weight: 700;
    color: rgba(209, 0, 122, 0.14);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ---------- Quote serif italic ---------- */
  .review-v6__quote {
    margin: 0 0 30px;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .review-v6__quote p {
    margin: 0;
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.75;
    color: #2c2c35;
    font-weight: 400;
  }

  /* ---------- Footer ---------- */
  .review-v6__foot {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding-top: 22px;
    border-top: 1px solid rgba(209, 0, 122, 0.10);
  }

  /* Avatar con ring pink */
  .review-v6__avatar {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    padding: 2px;
    border-radius: 50%;
    background: linear-gradient(135deg, #D1007A 0%, #7A2BC2 100%);
  }

  .review-v6__initials {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a2e 0%, #0f0f1e 100%);
    color: #ffffff;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    border: 2px solid #fdfbfa;
  }

  .review-v6__avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #fdfbfa;
  }

  .review-v6__meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .review-v6__name-row {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    min-width: 0;
  }

  .review-v6__name {
    font-style: normal;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #0f0f1e;
    letter-spacing: -0.005em;
    line-height: 1.25;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .review-v6__name-link {
    color: inherit;
    text-decoration: none;
  }

  .review-v6__name-link:hover {
    color: #D1007A;
  }

  .review-v6__check {
    flex-shrink: 0;
  }

  .review-v6__event {
    font-size: 0.78rem;
    color: #6b7280;
    font-weight: 500;
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Rating */
  .review-v6__rating {
    flex-shrink: 0;
  }

  .review-v6__stars {
    display: inline-flex;
    gap: 2px;
  }

  .review-v6__star {
    fill: #e5e7eb;
  }

  .review-v6__star--filled {
    fill: #FFB800;
  }

  /* ==========================================================
     Responsive
     ========================================================== */
  @media (max-width: 768px) {
    .review-v6__body {
      padding: 32px 28px 26px;
    }

    .review-v6__qmark {
      top: 14px;
      right: 22px;
      font-size: 4rem;
    }

    .review-v6__quote {
      margin-bottom: 24px;
    }

    .review-v6__quote p {
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .review-v6__foot {
      gap: 12px;
      padding-top: 18px;
    }

    .review-v6__avatar {
      width: 44px;
      height: 44px;
    }

    .review-v6__initials {
      font-size: 0.82rem;
    }

    .review-v6__name {
      font-size: 0.9rem;
    }

    .review-v6__event {
      font-size: 0.75rem;
    }

    .review-v6__star {
      width: 13px;
      height: 13px;
    }
  }

  @media (max-width: 480px) {
    .review-v6__body {
      padding: 28px 22px 24px;
    }

    .review-v6__qmark {
      font-size: 3.5rem;
      top: 12px;
      right: 18px;
    }

    .review-v6__foot {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      gap: 10px 12px;
    }

    .review-v6__avatar {
      grid-column: 1;
      grid-row: 1 / 3;
    }

    .review-v6__meta {
      grid-column: 2;
      grid-row: 1;
    }

    .review-v6__rating {
      grid-column: 2;
      grid-row: 2;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .review-v6 { transition: none; }
  }
</style>
