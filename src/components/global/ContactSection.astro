---
/**
 * ContactSection v4 — Modern Multi-Branch Contact
 * ================================================
 * Layout: cabecera centrada + 3 sucursales (Anzures matriz, Condesa, Toluca)
 * + canales globales (WhatsApp, Email, Horarios) + formulario premium.
 */

interface Props {
  phone?: string;
  email?: string;
  whatsappNumber?: string;
}

const {
  email = 'info@mesas-de-dulces.com',
  whatsappNumber = '525525226442'
} = Astro.props;

const sucursales = [
  {
    id: 'anzures',
    nombre: 'Anzures',
    ciudad: 'CDMX',
    tag: 'Matriz',
    matriz: true,
    direccion: 'Av. Ejército Nacional Mexicano 216',
    colonia: 'Anzures, Miguel Hidalgo',
    cp: 'CP 11590',
    horario: 'Atención 24 horas',
    horarioCorto: '24 h',
    telefono: '55 2522 6442',
    telefonoLink: 'tel:+525525226442',
    waNumero: '525525226442',
    waText: 'Hola! Me interesa una mesa de dulces — sucursal Anzures CDMX',
    mapsUrl: 'https://maps.app.goo.gl/JV69HuQt3djPx9WZ9'
  },
  {
    id: 'condesa',
    nombre: 'Condesa',
    ciudad: 'CDMX',
    tag: 'Showroom',
    matriz: false,
    direccion: 'Torre A, Av. Baja California 255',
    colonia: 'Condesa, Cuauhtémoc',
    cp: 'CP 06170',
    horario: 'Lun – Sáb · 10:00 – 19:00',
    horarioCorto: 'Lun-Sáb 10-19',
    telefono: '55 2522 6442',
    telefonoLink: 'tel:+525525226442',
    waNumero: '525525226442',
    waText: 'Hola! Me interesa una mesa de dulces — sucursal Condesa CDMX',
    mapsUrl: 'https://maps.app.goo.gl/Ze5acD2HRQ73QTa86'
  },
  {
    id: 'toluca',
    nombre: 'Toluca / Metepec',
    ciudad: 'Edo. México',
    tag: 'Nueva',
    matriz: false,
    destacada: true,
    direccion: 'Blvd. Toluca – Metepec 913',
    colonia: 'San Jorge Pueblo Nuevo, Metepec',
    cp: 'CP 52169',
    horario: 'Lun – Sáb · 10:00 – 19:00',
    horarioCorto: 'Lun-Sáb 10-19',
    telefono: '55 2177 5184',
    telefonoLink: 'tel:+525521775184',
    waNumero: '525521775184',
    waText: 'Hola! Me interesa una mesa de dulces — sucursal Toluca / Metepec',
    mapsUrl: 'https://www.google.com/maps/search/?api=1&query=Blvd.+Toluca-Metepec+913+San+Jorge+Pueblo+Nuevo+52169+Toluca'
  }
];
---

<section class="contact-section" id="contacto" aria-labelledby="contact-heading">

  <!-- ═══ HEADER ═══════════════════════════════════════════ -->
  <div class="contact-header">
    <span class="contact-header__badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Contáctanos · 3 sucursales
    </span>
    <h2 class="contact-header__title" id="contact-heading">
      Hagamos tu evento <span>inolvidable</span>
    </h2>
    <p class="contact-header__intro">
      Cobertura completa en <strong>CDMX, Estado de México y Toluca</strong>. Elige la sucursal más cercana o escríbenos directamente por WhatsApp.
    </p>
  </div>

  <!-- ═══ SUCURSALES GRID ══════════════════════════════════ -->
  <div class="contact-branches">
    {sucursales.map(s => (
      <article class={`branch-card${s.destacada ? ' branch-card--new' : ''}${s.matriz ? ' branch-card--matriz' : ''}`}>
        {s.tag && (
          <span class={`branch-card__ribbon${s.destacada ? ' branch-card__ribbon--new' : s.matriz ? ' branch-card__ribbon--matriz' : ''}`}>
            {s.tag}
          </span>
        )}

        <header class="branch-card__head">
          <span class="branch-card__pin" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <div class="branch-card__title">
            <h3>{s.nombre}</h3>
            <span class="branch-card__city">{s.ciudad}</span>
          </div>
        </header>

        <div class="branch-card__body">
          <p class="branch-card__addr">{s.direccion}</p>
          <p class="branch-card__meta">
            <span>{s.colonia}</span>
            <span class="branch-card__dot" aria-hidden="true">·</span>
            <span>{s.cp}</span>
          </p>
          <p class="branch-card__hours">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            {s.horario}
          </p>
        </div>

        <div class="branch-card__actions">
          <a
            href={s.telefonoLink}
            class="branch-card__btn branch-card__btn--phone"
            aria-label={`Llamar a sucursal ${s.nombre}`}
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <span>{s.telefono}</span>
          </a>
          <div class="branch-card__actions-row">
            <a
              href={`https://wa.me/${s.waNumero}?text=${encodeURIComponent(s.waText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="branch-card__btn branch-card__btn--wa"
              aria-label={`Escribir por WhatsApp a sucursal ${s.nombre}`}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
            <a
              href={s.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="branch-card__btn branch-card__btn--maps"
              aria-label={`Ver sucursal ${s.nombre} en Google Maps`}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Maps
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- ═══ CANALES GLOBALES ══════════════════════════════════ -->
  <div class="contact-channels" aria-label="Canales de contacto generales">
    <a href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola! Me interesa una mesa de dulces para mi evento')}`} target="_blank" rel="noopener noreferrer" class="channel channel--wa">
      <span class="channel__icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </span>
      <div class="channel__text">
        <span class="channel__label">WhatsApp general</span>
        <strong>Respuesta en 2 h</strong>
      </div>
    </a>

    <a href={`mailto:${email}`} class="channel channel--email">
      <span class="channel__icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M22 6l-10 7L2 6"/>
        </svg>
      </span>
      <div class="channel__text">
        <span class="channel__label">Email</span>
        <strong>{email}</strong>
      </div>
    </a>

    <div class="channel channel--hours">
      <span class="channel__icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </span>
      <div class="channel__text">
        <span class="channel__label">Horarios</span>
        <strong>Anzures 24 h · Condesa &amp; Toluca Lun–Sáb 10–19</strong>
      </div>
    </div>
  </div>

  <!-- ═══ FORM ════════════════════════════════════════════ -->
  <div class="contact-form-wrapper">
    <div class="contact-form__header">
      <span class="contact-form__pill">Cotización rápida</span>
      <h3>Reserva tu evento</h3>
      <p>Completa el formulario y te contactaremos por WhatsApp con una propuesta personalizada en menos de 2 horas.</p>
    </div>

    <form id="reserva-form" class="contact-form" novalidate>
      <div class="form-group">
        <label for="nombre">Nombre completo <span class="required">*</span></label>
        <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo" autocomplete="name" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="telefono">WhatsApp <span class="required">*</span></label>
          <div class="input-with-icon">
            <span class="input-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" opacity="0.5">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678" autocomplete="tel" inputmode="tel" />
          </div>
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" autocomplete="email" inputmode="email" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="sucursal">Sucursal preferida <span class="required">*</span></label>
          <select id="sucursal" name="sucursal" required>
            <option value="">Selecciona ubicación...</option>
            <option value="Anzures CDMX">📍 Anzures · CDMX (Matriz)</option>
            <option value="Condesa CDMX">📍 Condesa · CDMX</option>
            <option value="Toluca / Metepec">📍 Toluca / Metepec · Edo. México</option>
            <option value="Sin preferencia">Sin preferencia · más cercana</option>
          </select>
        </div>

        <div class="form-group">
          <label for="tipo-evento">Tipo de evento <span class="required">*</span></label>
          <select id="tipo-evento" name="tipo-evento" required>
            <option value="">Selecciona evento...</option>
            <option value="Boda">💒 Boda</option>
            <option value="XV Anos">👑 XV Años</option>
            <option value="Baby Shower">👶 Baby Shower</option>
            <option value="Cumpleanos">🎂 Cumpleaños</option>
            <option value="Bautizo">⛪ Bautizo</option>
            <option value="Comunion">✝️ Primera Comunión</option>
            <option value="Corporativo">🏢 Evento Corporativo</option>
            <option value="Graduacion">🎓 Graduación</option>
            <option value="Otro">✨ Otro</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="fecha">Fecha del evento <span class="required">*</span></label>
          <input type="date" id="fecha" name="fecha" required />
        </div>

        <div class="form-group">
          <label for="invitados">Invitados aproximados</label>
          <input type="number" id="invitados" name="invitados" placeholder="Ej: 100" min="1" inputmode="numeric" />
        </div>
      </div>

      <div class="form-group">
        <label for="mensaje">Cuéntanos sobre tu evento</label>
        <textarea id="mensaje" name="mensaje" rows="4" placeholder="Temática, colores, servicios que te interesan, ubicación del evento..."></textarea>
      </div>

      <button type="submit" class="btn-whatsapp">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Enviar por WhatsApp
      </button>

      <p class="form-disclaimer">
        Al enviar serás redirigido a WhatsApp · Respuesta en menos de 2 horas.
      </p>
    </form>
  </div>
</section>

<script is:inline define:vars={{ whatsappNumber }}>
  (function () {
    if (window.__mededulContactInit) return;
    window.__mededulContactInit = true;

    const ready = (fn) => document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', fn, { once: true })
      : fn();

    const sucursalToNumber = {
      'Anzures CDMX': '525525226442',
      'Condesa CDMX': '525525226442',
      'Toluca / Metepec': '525521775184',
      'Sin preferencia': whatsappNumber
    };

    ready(function () {
      const form = document.getElementById('reserva-form');
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(form);
        const nombre = fd.get('nombre');
        const telefono = fd.get('telefono');
        const email = fd.get('email');
        const sucursal = fd.get('sucursal');
        const tipoEvento = fd.get('tipo-evento');
        const fecha = fd.get('fecha');
        const invitados = fd.get('invitados');
        const mensaje = fd.get('mensaje');

        let msg = '¡Hola! Me gustaría cotizar una mesa de dulces.\n\n';
        msg += `*Nombre:* ${nombre}\n`;
        msg += `*WhatsApp:* ${telefono}\n`;
        if (email) msg += `*Email:* ${email}\n`;
        msg += `*Sucursal:* ${sucursal}\n`;
        msg += `*Tipo de evento:* ${tipoEvento}\n`;
        msg += `*Fecha:* ${fecha}\n`;
        if (invitados) msg += `*Invitados:* ${invitados}\n`;
        if (mensaje) msg += `\n*Detalles:* ${mensaje}`;

        const target = sucursalToNumber[sucursal] || whatsappNumber;
        const encoded = encodeURIComponent(msg);
        window.open(`https://wa.me/${target}?text=${encoded}`, '_blank');
      });
    });

    document.addEventListener('astro:after-swap', () => {
      window.__mededulContactInit = false;
    });
  })();
</script>

<style>
  /* =====================================================
     CONTACT SECTION v4 — Multi-Branch Premium
     ===================================================== */
  .contact-section {
    background:
      radial-gradient(ellipse 60% 40% at 0% 0%, rgba(209, 0, 122, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse 50% 35% at 100% 100%, rgba(122, 43, 194, 0.04) 0%, transparent 60%),
      linear-gradient(180deg, #fafafd 0%, #ffffff 100%);
    padding: clamp(3rem, 6vw, 5.5rem) 0 clamp(3.5rem, 6.5vw, 6rem);
    width: 100%;
    max-width: 1380px;
    margin: 0 auto;
    padding-left: clamp(1rem, 4vw, 2.5rem);
    padding-right: clamp(1rem, 4vw, 2.5rem);
    box-sizing: border-box;
  }

  /* ── HEADER ────────────────────────────────────────────── */
  .contact-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(2rem, 4vw, 3rem);
  }
  .contact-header__badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 16px;
    background: linear-gradient(135deg, rgba(209, 0, 122, 0.1), rgba(122, 43, 194, 0.08));
    color: #D1007A;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    border-radius: 50px;
    border: 1px solid rgba(209, 0, 122, 0.18);
    margin-bottom: 1rem;
  }
  .contact-header__badge svg { color: #D1007A; }

