---
// TopBar - Barra superior profesional con dos sucursales (CDMX + Toluca)
const phones = [
  {
    city: 'CDMX',
    label: 'Llamar a sucursal CDMX',
    number: '55 2522 6442',
    href: 'tel:+525525226442'
  },
  {
    city: 'Toluca',
    label: 'Llamar a sucursal Toluca / Metepec',
    number: '55 2522 6442',
    href: 'tel:+525525226442'
  }
];
---

<div class="top-bar" role="region" aria-label="Informacion de contacto">
  <div class="container">
    <div class="top-bar__content">
      <!-- Izquierda: marca + horario -->
      <div class="top-bar__left">
        <div class="top-bar__brand">
          <span class="top-bar__icon" aria-hidden="true">🍬</span>
          <span class="top-bar__name">MEDEDUL</span>
          <span class="top-bar__divider" aria-hidden="true"></span>
          <span class="top-bar__tagline">Mesas de dulces premium</span>
        </div>
        <span class="top-bar__hours" aria-label="Horario de atencion">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>Lun&ndash;Sab 10:00&ndash;19:00 h</span>
        </span>
      </div>

      <!-- Derecha: telefonos por sucursal + email + social -->
      <div class="top-bar__right">
        <div class="top-bar__phones" role="group" aria-label="Telefonos de sucursales">
          {phones.map((p) => (
            <a href={p.href} class="phone-pill" aria-label={p.label}>
              <span class="phone-pill__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                </svg>
              </span>
              <span class="phone-pill__body">
                <span class="phone-pill__city">{p.city}</span>
                <span class="phone-pill__number">{p.number}</span>
              </span>
            </a>
          ))}
        </div>

        <a href="mailto:info@mesas-de-dulces.com" class="top-bar__email" aria-label="Enviar correo a info@mesas-de-dulces.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <path d="M22 6l-10 7L2 6"/>
          </svg>
          <span>info@mesas-de-dulces.com</span>
        </a>

        <div class="top-bar__social" aria-label="Redes sociales">
          <a href="https://www.facebook.com/mededul" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/mededul" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@mededul" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* =====================================================
     TOP BAR - Diseno profesional, dos sucursales
     ===================================================== */
  .top-bar {
    background: linear-gradient(180deg, #161616 0%, #1f1f1f 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0;
    min-height: 44px;
    box-sizing: border-box;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1001;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .top-bar .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .top-bar__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    min-height: 44px;
  }

  /* ---------- IZQUIERDA: marca + horario ---------- */
  .top-bar__left {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .top-bar__brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .top-bar__icon {
    font-size: 16px;
    line-height: 1;
  }

  .top-bar__name {
    color: #ffffff;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  .top-bar__divider {
    width: 1px;
    height: 14px;
    background: rgba(255, 255, 255, 0.18);
    margin: 0 2px;
  }

  .top-bar__tagline {
    color: rgba(255, 255, 255, 0.65);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2px;
  }

  .top-bar__hours {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    font-weight: 500;
    padding-left: 18px;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .top-bar__hours svg {
    opacity: 0.75;
    flex-shrink: 0;
  }

  /* ---------- DERECHA: telefonos + email + social ---------- */
  .top-bar__right {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  /* Telefonos como "pills" con etiqueta de ciudad */
  .top-bar__phones {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .phone-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 8px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    color: #ffffff;
    text-decoration: none;
    transition: all 0.18s ease;
    line-height: 1;
  }

  .phone-pill:hover,
  .phone-pill:focus-visible {
    background: rgba(209, 0, 122, 0.18);
    border-color: rgba(247, 167, 205, 0.55);
    transform: translateY(-1px);
    outline: none;
  }

  .phone-pill__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #D1007A 0%, #f7a7cd 100%);
    color: #ffffff;
    flex-shrink: 0;
  }

  .phone-pill__body {
    display: inline-flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.1;
  }

  .phone-pill__city {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.9px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .phone-pill__number {
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.2px;
    color: #ffffff;
    font-variant-numeric: tabular-nums;
  }

  .phone-pill:hover .phone-pill__city {
    color: #f7a7cd;
  }

  /* Email */
  .top-bar__email {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 12.5px;
    font-weight: 500;
    text-decoration: none;
    padding-left: 14px;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    transition: color 0.18s ease;
  }

  .top-bar__email:hover {
    color: #f7a7cd;
  }

  .top-bar__email svg {
    opacity: 0.8;
    flex-shrink: 0;
  }

  /* Social */
  .top-bar__social {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-left: 14px;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .top-bar__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .top-bar__social a:hover {
    background: #D1007A;
    transform: translateY(-1px);
  }

  /* =====================================================
     RESPONSIVE - Desktop pequeno / Tablet grande (1280)
     ===================================================== */
  @media (max-width: 1279px) {
    .top-bar__tagline { display: none; }
    .top-bar__hours { padding-left: 14px; }
  }

  /* =====================================================
     RESPONSIVE - Tablet (1024)
     ===================================================== */
  @media (max-width: 1024px) {
    .top-bar .container { padding: 0 20px; }
    .top-bar__hours { display: none; }
    .top-bar__email { display: none; }
    .top-bar__right { gap: 10px; }
  }

  /* =====================================================
     RESPONSIVE - Mobile (768)
     ===================================================== */
  @media (max-width: 768px) {
    .top-bar { min-height: 42px; }
    .top-bar .container { padding: 0 12px; }
    .top-bar__content { gap: 10px; min-height: 42px; }

    .top-bar__brand { gap: 6px; }
    .top-bar__name { font-size: 11px; letter-spacing: 1px; }
    .top-bar__divider { display: none; }

    .top-bar__right { gap: 8px; }
    .top-bar__phones { gap: 6px; }

    .phone-pill {
      padding: 4px 10px 4px 6px;
      gap: 6px;
    }
    .phone-pill__icon { width: 20px; height: 20px; }
    .phone-pill__icon svg { width: 11px; height: 11px; }
    .phone-pill__city { font-size: 9px; letter-spacing: 0.7px; }
    .phone-pill__number { font-size: 11.5px; }

    .top-bar__social {
      padding-left: 8px;
      gap: 4px;
    }
    .top-bar__social a {
      width: 28px;
      height: 28px;
      min-width: 28px;
      min-height: 28px;
    }
  }

  /* =====================================================
     RESPONSIVE - Small Mobile (560)
     ===================================================== */
  @media (max-width: 560px) {
    .top-bar__brand { display: none; }
    .top-bar__left { gap: 0; }
  }

  /* =====================================================
     RESPONSIVE - Very Small (430)
     ===================================================== */
  @media (max-width: 430px) {
    .top-bar__social { display: none; }
    .top-bar__right { gap: 6px; width: 100%; justify-content: space-between; }
    .top-bar__phones { gap: 5px; width: 100%; justify-content: space-between; }
    .phone-pill { flex: 1; justify-content: center; padding: 4px 8px; }
  }

  /* =====================================================
     RESPONSIVE - Ultra Small (360)
     ===================================================== */
  @media (max-width: 360px) {
    .phone-pill__number { font-size: 11px; letter-spacing: 0; }
    .phone-pill { padding: 4px 6px; }
  }
</style>
