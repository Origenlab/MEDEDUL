          Nuestras Sucursales
        </span>
        <p class="mf-locations__sub">Visítanos en CDMX · Atención personalizada</p>
      </div>
      <div class="mf-locations__grid">
        {sucursales.map(s => (
          <div class="mf-loc">
            <div class="mf-loc__top">
              <span class="mf-loc__badge">{s.nombre}</span>
              <span class="mf-loc__hours">{s.horario}</span>
            </div>
            <p class="mf-loc__addr">{s.direccion}</p>
            <p class="mf-loc__col">{s.colonia}</p>
            <a href={s.mapsUrl} target="_blank" rel="noopener noreferrer" class="mf-loc__map">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Ver en Google Maps
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ BARRA INFERIOR ═══════════════════════════════════ -->
  <div class="mf-bar">
    <div class="mf-wrap">
      <div class="mf-bar__inner">
        <p class="mf-bar__copy">
          &copy; {currentYear} <strong>Mededul</strong> · Mesas de Dulces CDMX ·
          Hecho con <span class="mf-heart" aria-hidden="true">♥</span> en México
        </p>
        <nav class="mf-bar__legal" aria-label="Páginas legales">
          {legalLinks.map((l, i) => (
            <>
              <a href={l.href}>{l.label}</a>
              {i < legalLinks.length - 1 && <span aria-hidden="true">·</span>}
            </>
          ))}
        </nav>
        <div class="mf-bar__badges">
          <span class="mf-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Pago Seguro
          </span>
          <span class="mf-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            +500 Eventos
          </span>
        </div>
      </div>
    </div>
  </div>

</footer>

<style>
/* ═══════════════════════════════════════════════════════════
   MEDEDUL FOOTER v3 — Full-width, Premium, Mobile-first
   ═══════════════════════════════════════════════════════════ */

/* ── Reset base ────────────────────────────────────────────── */
.mf {
  display: block;
  width: 100%;
  /* NO overflow:hidden — rompe el full-width en algunos navegadores */
  background: #07070e;
  color: #fff;
  font-family: 'Poppins', sans-serif;
  position: relative;
}

/* Glow ambiental */
.mf::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 10% 20%, rgba(209,0,122,.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 35% at 90% 80%, rgba(90,26,163,.06) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* ── Wrapper interior centrado ─────────────────────────────── */
.mf-wrap {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1380px;
  margin: 0 auto;
  padding: 0 clamp(20px, 4vw, 60px);
  box-sizing: border-box;
}

/* ════════════════════════════════════════════════════════════
   CTA BAND
   ════════════════════════════════════════════════════════════ */
.mf-cta {
  width: 100%;
  background: linear-gradient(130deg, #b8006a 0%, #8a0053 40%, #501590 100%);
  padding: clamp(36px, 5vw, 60px) 0;
  position: relative;
  z-index: 1;
}

/* línea decorativa superior */
.mf-cta::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #ff6bab, #D1007A, #7c3aed, #D1007A, #ff6bab);
}

.mf-cta__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}

.mf-cta__eyebrow {
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,.6);
  margin: 0 0 10px;
}

.mf-cta__heading {
  font-family: 'Poppins', sans-serif;
  font-size: clamp(1.3rem, 2.8vw, 1.9rem);
  font-weight: 700;
  color: #fff;
  margin: 0;
  line-height: 1.2;
}

.mf-br-sm { display: none; }

.mf-cta__btns {
  display: flex;
  gap: 14px;
  flex-shrink: 0;
  flex-wrap: wrap;
}

.mf-btn {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 14px 28px;
  border-radius: 50px;
  font-size: .88rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  transition: transform .22s ease, box-shadow .22s ease, background .22s ease;
}

.mf-btn--solid {
  background: #fff;
  color: #b8006a;
}
.mf-btn--solid:hover {
  background: #ffe0ee;
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(0,0,0,.2);
}

.mf-btn--outline {
  background: rgba(255,255,255,.12);
  color: #fff;
  border: 1.5px solid rgba(255,255,255,.35);
}
.mf-btn--outline:hover {
  background: rgba(255,255,255,.22);
  transform: translateY(-2px);
}

/* ════════════════════════════════════════════════════════════
   CUERPO PRINCIPAL
   ════════════════════════════════════════════════════════════ */
.mf-body {
  width: 100%;
  padding: clamp(60px, 7vw, 96px) 0 clamp(52px, 6vw, 80px);
  position: relative;
  z-index: 1;
}

.mf-body .mf-wrap {
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: clamp(40px, 5vw, 80px);
  align-items: start;
}

/* ── Columna marca ─────────────────────────────────────────── */
.mf-brand {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.mf-logo {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}
.mf-logo__icon {
  font-size: 2.4rem;
  line-height: 1;
  filter: drop-shadow(0 3px 12px rgba(209,0,122,.5));
}
.mf-logo__text {
