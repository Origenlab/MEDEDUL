---
// Header Component - Professional Navigation v2
import { getCdnUrl } from '@/lib/cdn';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const logoPath = '/img/mededul.png';
const logoSrc = getCdnUrl(logoPath, { w: 240, q: 80 });
const logoSrcSet = [
  `${getCdnUrl(logoPath, { w: 120, q: 80 })} 120w`,
  `${getCdnUrl(logoPath, { w: 240, q: 80 })} 240w`,
  `${getCdnUrl(logoPath, { w: 360, q: 80 })} 360w`,
  `${getCdnUrl(logoPath, { w: 480, q: 80 })} 480w`
].join(', ');

// Navigation structure — Directorio movido al footer
const menuItems = [
  { label: 'Inicio', href: '/', exact: true },
  {
    label: 'Servicios',
    href: '/servicios',
    megaMenu: [
      {
        title: 'Tipos de Mesas',
        icon: '🍬',
        color: '#D1007A',
        items: [
          { label: 'Mesa de Dulces', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces' },
          { label: 'Mesa de Frutas', href: '/tipos-de-mesas-de-dulces/mesa-de-frutas' },
          { label: 'Mesa de Postres', href: '/tipos-de-mesas-de-dulces/mesa-de-postres' },
          { label: 'Quesos y Embutidos', href: '/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos' },
          { label: 'Mesa de Snacks', href: '/tipos-de-mesas-de-dulces/mesa-de-snacks' },
          { label: 'Mesa de Botanas', href: '/tipos-de-mesas-de-dulces/mesa-de-botanas' },
          { label: 'Dulces Tradicionales', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces-tradicionales' },
          { label: 'Donas y Cupcakes', href: '/tipos-de-mesas-de-dulces/mesa-de-donas-y-cupcakes' }
        ],
        viewAll: { label: 'Ver todos los tipos', href: '/tipos-de-mesas-de-dulces' }
      },
      {
        title: 'Candy Bar por Evento',
        icon: '🎉',
        color: '#A0005F',
        items: [
          { label: 'Bodas', href: '/candy-bar-eventos/mesa-dulces-boda' },
          { label: 'XV Años', href: '/candy-bar-eventos/mesa-dulces-xv-anos' },
          { label: 'Baby Shower', href: '/candy-bar-eventos/mesa-dulces-baby-shower' },
          { label: 'Bautizos', href: '/candy-bar-eventos/mesa-dulces-bautizo' },
          { label: 'Primera Comunión', href: '/candy-bar-eventos/mesa-dulces-primera-comunion' },
          { label: 'Cumpleaños Infantil', href: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil' },
          { label: 'Graduaciones', href: '/candy-bar-eventos/mesa-dulces-graduacion' },
          { label: 'Corporativos', href: '/candy-bar-eventos/mesa-dulces-corporativos' }
        ],
        viewAll: { label: 'Ver todos los eventos', href: '/candy-bar-eventos' }
      },
      {
        title: 'Estaciones Interactivas',
        icon: '⭐',
        color: '#7A2BC2',
        items: [
          { label: 'Fuente de Chocolate', href: '/estaciones-interactivas/fuente-de-chocolate' },
          { label: 'Fuente de Chamoy', href: '/estaciones-interactivas/fuente-de-chamoy' },
          { label: 'Pared de Dulces', href: '/estaciones-interactivas/pared-de-dulces' },
          { label: 'Stand para Pastel', href: '/estaciones-interactivas/stand-para-pastel' }
        ],
        viewAll: { label: 'Ver todas las estaciones', href: '/estaciones-interactivas' }
      },
      {
        title: 'Por qué Elegirnos',
        icon: '💎',
        color: '#3A0A74',
        items: [
          { label: 'Diseño Personalizado', href: '/porque-mededul/diseno-personalizado' },
          { label: 'Calidad Premium', href: '/porque-mededul/calidad-premium' },
          { label: 'Servicio Completo', href: '/porque-mededul/servicio-completo' },
          { label: 'Cero Estrés', href: '/porque-mededul/cero-estres' }
        ],
        viewAll: { label: 'Conoce más', href: '/porque-mededul' }
      }
    ]
  },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Sucursales', href: '/sucursales' },
  { label: 'Blog', href: '/blog', startsWith: true },
  { label: 'Contacto', href: '/contacto' }
];

// Check if link is active
const isActive = (item: typeof menuItems[0]) => {
  if (item.exact) return currentPath === item.href;
  if (item.startsWith) return currentPath.startsWith(item.href);
  return currentPath === item.href;
};
---

<header class="header" id="header">
  <div class="header__container">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Mededul — inicio">
      <img
        src={logoSrc}
        srcset={logoSrcSet}
        sizes="240px"
        alt="Mededul - Mesas de Dulces CDMX, Toluca y Metepec"
        width="240"
        height="60"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav" id="nav-menu" aria-label="Navegación principal">
      <ul class="header__menu">
        {menuItems.map(item => (
          <li class:list={['header__item', { 'has-mega': item.megaMenu }]}>
            <a
              href={item.href}
              class:list={['header__link', { active: isActive(item) }]}
            >
              <span class="header__link-text">{item.label}</span>
              {item.megaMenu && (
                <svg class="header__arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              )}
            </a>

            {item.megaMenu && (
              <div class="mega-menu">
                <div class="mega-menu__container">
                  {item.megaMenu.map(column => (
                    <div class="mega-menu__column">
                      <div class="mega-menu__header" style={`--column-color: ${column.color}`}>
                        <span class="mega-menu__icon" aria-hidden="true">{column.icon}</span>
                        <span class="mega-menu__title">{column.title}</span>
                      </div>
                      <ul class="mega-menu__list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mega-menu__link">
                              {subItem.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                      <a href={column.viewAll.href} class="mega-menu__view-all" style={`--column-color: ${column.color}`}>
                        {column.viewAll.label}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <a href="tel:+525525226442" class="header__phone" aria-label="Llamar al 55 2522 6442">
        <span class="header__phone-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </span>
        <span class="header__phone-text">
          <span class="header__phone-label">Llámanos</span>
          <span class="header__phone-num">55 2522 6442</span>
        </span>
      </a>
      <a href="/cotizar" class="header__cta">
        <span>Cotizar</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button class="header__toggle" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu__inner">
      <ul class="mobile-menu__list">
        {menuItems.map(item => (
          <li class:list={['mobile-menu__item', { 'has-submenu': item.megaMenu }]}>
            {item.megaMenu ? (
              <>
                <button class="mobile-menu__link mobile-menu__trigger" type="button">
                  {item.label}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </button>
                <div class="mobile-menu__submenu">
                  {item.megaMenu.map(column => (
                    <div class="mobile-menu__group">
                      <button class="mobile-menu__group-header" type="button" style={`--column-color: ${column.color}`}>
                        <span class="mobile-menu__group-icon">{column.icon}</span>
                        {column.title}
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="6 9 12 15 18 9" />
                        </svg>
                      </button>
                      <ul class="mobile-menu__group-list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mobile-menu__sublink">{subItem.label}</a>
                          </li>
                        ))}
                        <li>
                          <a href={column.viewAll.href} class="mobile-menu__view-all">{column.viewAll.label}</a>
                        </li>
                      </ul>
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <a href={item.href} class:list={['mobile-menu__link', { active: isActive(item) }]}>
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <div class="mobile-menu__footer">
        <a href="tel:+525525226442" class="mobile-menu__phone">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          55 2522 6442
        </a>
        <a href="/cotizar" class="mobile-menu__cta">
          Cotizar
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    // Idempotente: si ya se inicializó en esta página, salir
    if (window.__mededulHeaderInit) return;
    window.__mededulHeaderInit = true;

    const onReady = (fn) => {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fn, { once: true });
      } else {
        fn();
      }
    };

    onReady(function init() {
      const header = document.getElementById('header');
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');

      // Scroll effect
      let lastScroll = -1;
      const onScroll = () => {
        const cur = window.scrollY;
        if (cur === lastScroll) return;
        lastScroll = cur;
        if (!header) return;
        if (cur > 50) header.classList.add('scrolled');
        else header.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      const closeMenu = () => {
        hamburger?.classList.remove('active');
        mobileMenu?.classList.remove('active');
        document.body.classList.remove('menu-open');
        hamburger?.setAttribute('aria-expanded', 'false');
        hamburger?.setAttribute('aria-label', 'Abrir menú');
      };

      const openMenu = () => {
        hamburger?.classList.add('active');
        mobileMenu?.classList.add('active');
        document.body.classList.add('menu-open');
        hamburger?.setAttribute('aria-expanded', 'true');
        hamburger?.setAttribute('aria-label', 'Cerrar menú');
      };

      // Mobile menu toggle (delegado defensivo)
      if (hamburger && mobileMenu) {
        const toggle = (e) => {
          e.preventDefault();
          e.stopPropagation();
          const isOpen = hamburger.classList.contains('active');
          if (isOpen) closeMenu();
          else openMenu();
        };
        hamburger.addEventListener('click', toggle);
        hamburger.addEventListener('touchstart', toggle, { passive: false });
      }

      // Mobile submenu toggles (delegación en mobileMenu)
      mobileMenu?.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        const trigger = target.closest('.mobile-menu__trigger');
        if (trigger) {
          e.preventDefault();
          const parent = trigger.parentElement;
          parent?.classList.toggle('open');
          return;
        }

        const groupHead = target.closest('.mobile-menu__group-header');
        if (groupHead) {
          e.preventDefault();
          const parent = groupHead.parentElement;
          parent?.classList.toggle('open');
          return;
        }

        // Cerrar menú al hacer click en cualquier link real
        const link = target.closest('a.mobile-menu__sublink, a.mobile-menu__view-all, a.mobile-menu__link, a.mobile-menu__phone, a.mobile-menu__cta');
        if (link && !link.classList.contains('mobile-menu__trigger')) {
          closeMenu();
        }
      });

      // Cerrar con tecla Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
          closeMenu();
        }
      });

      // Cerrar al redimensionar a desktop
      let resizeRaf;
      window.addEventListener('resize', () => {
        if (resizeRaf) cancelAnimationFrame(resizeRaf);
        resizeRaf = requestAnimationFrame(() => {
          if (window.innerWidth > 1024 && mobileMenu?.classList.contains('active')) {
            closeMenu();
          }
        });
      }, { passive: true });
    });
  })();
</script>

<style>
  /* =====================================================
     HEADER v2 — Professional Premium Design
     ===================================================== */
  .header {
    position: fixed;
    /* topbar real (medido por JS); fallback acorde al min-height del topbar */
    top: var(--topbar-offset, 48px);
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-top: 1px solid rgba(15, 15, 30, 0.04);
    border-bottom: 1px solid rgba(15, 15, 30, 0.06);
    box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;
    transition: box-shadow .25s ease, background .25s ease, border-color .25s ease;
  }

  .header.scrolled {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 6px 24px rgba(15, 15, 30, 0.07);
    border-bottom-color: rgba(15, 15, 30, 0.08);
  }

  .header__container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 14px 36px;
    min-height: 82px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* Logo */
  .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    line-height: 0;
    transition: opacity .2s ease;
  }
  .header__logo:hover { opacity: .85; }

  .header__logo img {
    height: 56px;
    width: auto;
    max-width: 240px;
    display: block;
    object-fit: contain;
  }

  /* Navigation */
  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__item { position: relative; }

  .header__link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    font-size: 0.92rem;
    font-weight: 500;
    color: #2a2a35;
    text-decoration: none;
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: color .2s ease, background .2s ease;
  }

  .header__link::before {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 4px;
    height: 2px;
    background: linear-gradient(90deg, #D1007A, #7A2BC2);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform .25s ease;
  }

  .header__link:hover { color: #D1007A; }
  .header__link:hover::before { transform: scaleX(1); }

  .header__link.active { color: #D1007A; }
  .header__link.active::before { transform: scaleX(1); }

  .header__arrow {
    transition: transform .25s ease;
    opacity: .65;
  }
  .header__item.has-mega:hover > .header__link .header__arrow {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* Mega Menu */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    padding-top: 14px;
    opacity: 0;
    visibility: hidden;
    transition: opacity .2s ease, transform .25s ease, visibility 0s linear .2s;
    pointer-events: none;
  }

  .header__item.has-mega:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition: opacity .25s ease, transform .25s ease, visibility 0s linear 0s;
    pointer-events: auto;
  }

  .mega-menu__container {
    display: grid;
    grid-template-columns: repeat(4, 220px);
    gap: 0;
    background: #ffffff;
    border-radius: 14px;
    border: 1px solid rgba(15, 15, 30, 0.06);
    box-shadow:
      0 1px 2px rgba(15, 15, 30, 0.04),
      0 24px 60px rgba(15, 15, 30, 0.14);
    overflow: hidden;
  }

  .mega-menu__column {
    padding: 22px 20px;
    border-right: 1px solid #f3f3f6;
  }
  .mega-menu__column:last-child { border-right: none; }

  .mega-menu__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--column-color, #D1007A);
  }

  .mega-menu__icon { font-size: 1.1rem; line-height: 1; }

  .mega-menu__title {
    font-size: 0.74rem;
    font-weight: 700;
    color: #1a1a26;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .mega-menu__list {
    list-style: none;
    padding: 0;
    margin: 0 0 14px;
  }
  .mega-menu__list li { margin-bottom: 2px; }

  .mega-menu__link {
    display: block;
    padding: 7px 10px;
    font-size: 0.875rem;
    color: #555560;
    text-decoration: none;
    border-radius: 6px;
    transition: color .15s ease, background .15s ease, padding-left .2s ease;
  }
  .mega-menu__link:hover {
    color: #D1007A;
    background: rgba(209, 0, 122, 0.05);
    padding-left: 14px;
  }

  .mega-menu__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--column-color, #D1007A);
    text-decoration: none;
    padding: 6px 0;
    transition: gap .2s ease;
  }
  .mega-menu__view-all:hover { gap: 10px; }

  /* Actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }

  .header__phone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 12px 6px 6px;
    text-decoration: none;
    border-radius: 12px;
    transition: background .2s ease;
  }
  .header__phone:hover { background: rgba(209, 0, 122, 0.05); }

  .header__phone-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(209, 0, 122, 0.12), rgba(122, 43, 194, 0.10));
    color: #D1007A;
    flex-shrink: 0;
  }

  .header__phone-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .header__phone-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: #8b8b95;
  }
  .header__phone-num {
    font-size: 0.92rem;
    font-weight: 600;
    color: #1a1a26;
    margin-top: 2px;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #ffffff;
    background: linear-gradient(135deg, #D1007A 0%, #A0005F 60%, #7A2BC2 100%);
    background-size: 200% 100%;
    background-position: 0% 50%;
    border-radius: 50px;
    text-decoration: none;
    box-shadow:
      0 1px 2px rgba(209, 0, 122, 0.25),
      0 6px 18px rgba(209, 0, 122, 0.28);
    transition: background-position .35s ease, box-shadow .25s ease, transform .15s ease;
    letter-spacing: 0.02em;
  }
  .header__cta:hover {
    background-position: 100% 50%;
    box-shadow:
      0 1px 2px rgba(209, 0, 122, 0.3),
      0 10px 26px rgba(209, 0, 122, 0.38);
    transform: translateY(-1px);
  }
  .header__cta:active { transform: translateY(0); }
  .header__cta svg { transition: transform .2s ease; }
  .header__cta:hover svg { transform: translateX(3px); }

  /* Mobile Toggle */
  .header__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 12px;
    background: none;
    border: 1px solid rgba(15, 15, 30, 0.08);
    border-radius: 10px;
    cursor: pointer;
    transition: background .2s ease, border-color .2s ease;
  }
  .header__toggle:hover { background: rgba(15, 15, 30, 0.03); border-color: rgba(15, 15, 30, 0.14); }
  .header__toggle:active { background: rgba(15, 15, 30, 0.05); }

  .header__toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: #2a2a35;
    border-radius: 2px;
    transition: transform .25s ease, opacity .2s ease;
  }
  .header__toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
