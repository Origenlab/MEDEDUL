---
// Header Component - Professional Navigation v4 (robust click + hover + mobile)
import { getCdnUrl } from '@/lib/cdn';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const logoPath = '/img/mededul.png';
const logoSrc = getCdnUrl(logoPath, { w: 240, q: 80 });
const logoSrcSet = [
  `${getCdnUrl(logoPath, { w: 120, q: 80 })} 120w`,
  `${getCdnUrl(logoPath, { w: 240, q: 80 })} 240w`,
  `${getCdnUrl(logoPath, { w: 360, q: 80 })} 360w`,
  `${getCdnUrl(logoPath, { w: 480, q: 80 })} 480w`
].join(', ');

// Sucursales para el bloque de contacto del header
const sucursales = [
  {
    id: 'cdmx',
    city: 'CDMX',
    cityFull: 'Ciudad de Mexico',
    number: '55 2522 6442',
    tel: 'tel:+525525226442',
    whatsapp: 'https://wa.me/525525226442?text=Hola%20MEDEDUL%2C%20me%20interesa%20cotizar%20una%20mesa%20de%20dulces',
    horario: 'Lun-Sab 10:00-19:00 h',
    zona: 'Anzures & Condesa'
  },
  {
    id: 'toluca',
    city: 'Toluca',
    cityFull: 'Toluca / Metepec',
    number: '55 2177 5184',
    tel: 'tel:+525521775184',
    whatsapp: 'https://wa.me/525521775184?text=Hola%20MEDEDUL%2C%20me%20interesa%20cotizar%20una%20mesa%20de%20dulces%20en%20Toluca%2FMetepec',
    horario: 'Lun-Sab 10:00-19:00 h',
    zona: 'Metepec'
  }
];

// Navigation structure — Directorio movido al footer
const menuItems = [
  { label: 'Inicio', href: '/', exact: true },
  {
    label: 'Servicios',
    href: '/servicios',
    megaMenu: [
      {
        title: 'Tipos de Mesas',
        icon: '🍬',
        color: '#D1007A',
        items: [
          { label: 'Mesa de Dulces', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces' },
          { label: 'Mesa de Frutas', href: '/tipos-de-mesas-de-dulces/mesa-de-frutas' },
          { label: 'Mesa de Postres', href: '/tipos-de-mesas-de-dulces/mesa-de-postres' },
          { label: 'Quesos y Embutidos', href: '/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos' },
          { label: 'Mesa de Snacks', href: '/tipos-de-mesas-de-dulces/mesa-de-snacks' },
          { label: 'Mesa de Botanas', href: '/tipos-de-mesas-de-dulces/mesa-de-botanas' },
          { label: 'Dulces Tradicionales', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces-tradicionales' },
          { label: 'Donas y Cupcakes', href: '/tipos-de-mesas-de-dulces/mesa-de-donas-y-cupcakes' }
        ],
        viewAll: { label: 'Ver todos los tipos', href: '/tipos-de-mesas-de-dulces' }
      },
      {
        title: 'Candy Bar por Evento',
        icon: '🎉',
        color: '#A0005F',
        items: [
          { label: 'Bodas', href: '/candy-bar-eventos/mesa-dulces-boda' },
          { label: 'XV Años', href: '/candy-bar-eventos/mesa-dulces-xv-anos' },
          { label: 'Baby Shower', href: '/candy-bar-eventos/mesa-dulces-baby-shower' },
          { label: 'Bautizos', href: '/candy-bar-eventos/mesa-dulces-bautizo' },
          { label: 'Primera Comunión', href: '/candy-bar-eventos/mesa-dulces-primera-comunion' },
          { label: 'Cumpleaños Infantil', href: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil' },
          { label: 'Graduaciones', href: '/candy-bar-eventos/mesa-dulces-graduacion' },
          { label: 'Corporativos', href: '/candy-bar-eventos/mesa-dulces-corporativos' }
        ],
        viewAll: { label: 'Ver todos los eventos', href: '/candy-bar-eventos' }
      },
      {
        title: 'Estaciones Interactivas',
        icon: '⭐',
        color: '#7A2BC2',
        items: [
          { label: 'Fuente de Chocolate', href: '/estaciones-interactivas/fuente-de-chocolate' },
          { label: 'Fuente de Chamoy', href: '/estaciones-interactivas/fuente-de-chamoy' },
          { label: 'Pared de Dulces', href: '/estaciones-interactivas/pared-de-dulces' },
          { label: 'Stand para Pastel', href: '/estaciones-interactivas/stand-para-pastel' }
        ],
        viewAll: { label: 'Ver todas las estaciones', href: '/estaciones-interactivas' }
      },
      {
        title: 'Por qué Elegirnos',
        icon: '💎',
        color: '#3A0A74',
        items: [
          { label: 'Diseño Personalizado', href: '/porque-mededul/diseno-personalizado' },
          { label: 'Calidad Premium', href: '/porque-mededul/calidad-premium' },
          { label: 'Servicio Completo', href: '/porque-mededul/servicio-completo' },
          { label: 'Cero Estrés', href: '/porque-mededul/cero-estres' }
        ],
        viewAll: { label: 'Conoce más', href: '/porque-mededul' }
      }
    ]
  },
  { label: 'Nosotros', href: '/nosotros' },
  {
    label: 'Sucursales',
    href: '/sucursales',
    startsWith: true,
    megaMenu: [
      {
        title: 'Sucursal CDMX',
        icon: '🏙️',
        color: '#D1007A',
        items: [
          { label: 'Sucursal CDMX (Anzures + Condesa)', href: '/sucursales/cdmx' },
          { label: 'Anzures (Matriz)', href: '/sucursales/cdmx#anzures' },
          { label: 'Condesa', href: '/sucursales/cdmx#condesa' },
          { label: 'Zonas CDMX que cubrimos', href: '/zonas-cdmx' }
        ],
        viewAll: { label: 'Ver sucursal CDMX', href: '/sucursales/cdmx' }
      },
      {
        title: 'Sucursal Toluca',
        icon: '🏞️',
        color: '#7A2BC2',
        items: [
          { label: 'Sucursal Toluca - Metepec', href: '/sucursales/toluca' },
          { label: 'Mesas de Dulces Metepec', href: '/mesas-de-dulces-metepec' },
          { label: 'Mesas de Dulces Toluca', href: '/mesas-de-dulces-toluca' },
          { label: 'Mesas de Dulces Zinacantepec', href: '/mesas-de-dulces-zinacantepec' },
          { label: 'Mesas de Dulces Lerma', href: '/mesas-de-dulces-lerma' }
        ],
        viewAll: { label: 'Ver sucursal Toluca', href: '/sucursales/toluca' }
      },
      {
        title: 'Cobertura total',
        icon: '📍',
        color: '#A0005F',
        items: [
          { label: 'Ver todas las sucursales', href: '/sucursales' },
          { label: 'Cobertura CDMX (16 alcaldias)', href: '/zonas-cdmx' },
          { label: 'Cobertura Valle de Toluca', href: '/sucursales/toluca#zonas-toluca' },
          { label: 'Como trabajamos', href: '/proceso' }
        ],
        viewAll: { label: 'Hub de sucursales', href: '/sucursales' }
      }
    ]
  },
  { label: 'Blog', href: '/blog', startsWith: true },
  { label: 'Contacto', href: '/contacto' }
];

// Check if link is active
const isActive = (item: typeof menuItems[0]) => {
  if (item.exact) return currentPath === item.href;
  if (item.startsWith) return currentPath.startsWith(item.href);
  return currentPath === item.href;
};
---

<header class="header" id="header">
  <div class="header__container">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Mededul — inicio">
      <img
        src={logoSrc}
        srcset={logoSrcSet}
        sizes="240px"
        alt="Mededul - Mesas de Dulces CDMX, Toluca y Metepec"
        width="240"
        height="60"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav" id="nav-menu" aria-label="Navegación principal">
      <ul class="header__menu">
        {menuItems.map((item, idx) => (
          <li class:list={['header__item', { 'has-mega': item.megaMenu }]} data-mega-id={item.megaMenu ? `mega-${idx}` : undefined}>
            <a
              href={item.href}
              class:list={['header__link', { active: isActive(item) }]}
            >
              <span class="header__link-text">{item.label}</span>
            </a>
            {item.megaMenu && (
              <button
                type="button"
                class="header__mega-toggle"
                aria-expanded="false"
                aria-controls={`mega-${idx}`}
                aria-label={`Abrir submenú de ${item.label}`}
              >
                <svg class="header__arrow" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
            )}

            {item.megaMenu && (
              <div class="mega-menu" id={`mega-${idx}`} role="region" aria-label={`Submenú de ${item.label}`}>
                <div class="mega-menu__container">
                  {item.megaMenu.map(column => (
                    <div class="mega-menu__column">
                      <div class="mega-menu__header" style={`--column-color: ${column.color}`}>
                        <span class="mega-menu__icon" aria-hidden="true">{column.icon}</span>
                        <span class="mega-menu__title">{column.title}</span>
                      </div>
                      <ul class="mega-menu__list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mega-menu__link">
                              {subItem.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                      <a href={column.viewAll.href} class="mega-menu__view-all" style={`--column-color: ${column.color}`}>
                        {column.viewAll.label}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <!-- Dual sucursal contact -->
      <div class="header__contact" aria-label="Contacto sucursales">
        {sucursales.map((s) => (
          <a href={s.tel} class="suc-chip" aria-label={`Llamar a sucursal ${s.cityFull} al ${s.number}`}>
            <span class="suc-chip__icon" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </span>
            <span class="suc-chip__body">
              <span class="suc-chip__city">{s.city}</span>
              <span class="suc-chip__num">{s.number}</span>
            </span>
          </a>
        ))}
      </div>

      <a href="/cotizar" class="header__cta">
        <span>Cotizar</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button class="header__toggle" id="hamburger" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__inner">
      <ul class="mobile-menu__list">
        {menuItems.map(item => (
          <li class:list={['mobile-menu__item', { 'has-submenu': item.megaMenu }]}>
            {item.megaMenu ? (
              <>
                <div class="mobile-menu__row">
                  <a href={item.href} class:list={['mobile-menu__link', 'mobile-menu__link--main', { active: isActive(item) }]}>
                    {item.label}
                  </a>
                  <button class="mobile-menu__trigger" type="button" aria-expanded="false" aria-label={`Mostrar submenú de ${item.label}`}>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                </div>
                <div class="mobile-menu__submenu">
                  {item.megaMenu.map(column => (
                    <div class="mobile-menu__group">
                      <button class="mobile-menu__group-header" type="button" aria-expanded="false" style={`--column-color: ${column.color}`}>
                        <span class="mobile-menu__group-icon">{column.icon}</span>
                        <span class="mobile-menu__group-title">{column.title}</span>
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="6 9 12 15 18 9" />
                        </svg>
                      </button>
                      <ul class="mobile-menu__group-list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mobile-menu__sublink">{subItem.label}</a>
                          </li>
                        ))}
                        <li>
                          <a href={column.viewAll.href} class="mobile-menu__view-all">{column.viewAll.label}</a>
                        </li>
                      </ul>
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <a href={item.href} class:list={['mobile-menu__link', { active: isActive(item) }]}>
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- Mobile footer: tarjetas de sucursal CDMX + Toluca -->
      <div class="mobile-menu__footer">
        <div class="mm-suc__grid">
          {sucursales.map((s) => (
            <div class="mm-suc">
              <div class="mm-suc__head">
                <span class="mm-suc__badge">{s.city}</span>
                <span class="mm-suc__zone">{s.zona}</span>
              </div>
              <div class="mm-suc__num">{s.number}</div>
              <div class="mm-suc__hours">{s.horario}</div>
              <div class="mm-suc__btns">
                <a href={s.tel} class="mm-suc__btn mm-suc__btn--call" aria-label={`Llamar a ${s.cityFull}`}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                  Llamar
                </a>
                <a href={s.whatsapp} target="_blank" rel="noopener noreferrer" class="mm-suc__btn mm-suc__btn--wa" aria-label={`WhatsApp ${s.cityFull}`}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
              </div>
            </div>
          ))}
        </div>
        <a href="/cotizar" class="mobile-menu__cta">
          Cotizar mi evento
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    if (window.__mededulHeaderInit) return;
    window.__mededulHeaderInit = true;

    const ready = (fn) => {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fn, { once: true });
      } else {
        fn();
      }
    };

    ready(function init() {
      const header = document.getElementById('header');
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (!header) return;

      const isDesktop = () => window.matchMedia('(min-width: 1025px)').matches;

      /* ====== Scroll effect ====== */
      let lastScroll = -1;
      const onScroll = () => {
        const cur = window.scrollY;
        if (cur === lastScroll) return;
        lastScroll = cur;
        if (cur > 50) header.classList.add('scrolled');
        else header.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      /* ====== Mobile menu open/close ====== */
      const closeMobile = () => {
        if (!hamburger || !mobileMenu) return;
        hamburger.classList.remove('active');
        mobileMenu.classList.remove('active');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('menu-open');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Abrir menú');
      };

      const openMobile = () => {
        if (!hamburger || !mobileMenu) return;
        hamburger.classList.add('active');
        mobileMenu.classList.add('active');
        mobileMenu.setAttribute('aria-hidden', 'false');
        document.body.classList.add('menu-open');
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Cerrar menú');
      };

      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (hamburger.classList.contains('active')) closeMobile();
          else openMobile();
        });
      }

      /* ====== Mobile menu inner interactions ====== */
      if (mobileMenu) {
        mobileMenu.addEventListener('click', (e) => {
          const t = e.target;
          if (!(t instanceof Element)) return;

          // top-level submenu toggle (Servicios, Sucursales)
          const trigger = t.closest('.mobile-menu__trigger');
          if (trigger) {
            e.preventDefault();
            const item = trigger.closest('.mobile-menu__item');
            if (!item) return;
            const willOpen = !item.classList.contains('open');
            // Close other top-level submenus
            mobileMenu.querySelectorAll('.mobile-menu__item.open').forEach((el) => {
              if (el !== item) {
                el.classList.remove('open');
                const otherTrig = el.querySelector('.mobile-menu__trigger');
                if (otherTrig) otherTrig.setAttribute('aria-expanded', 'false');
              }
            });
            item.classList.toggle('open', willOpen);
            trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            return;
          }

          // group header toggle (Tipos de Mesas, Candy Bar, ...)
          const groupHead = t.closest('.mobile-menu__group-header');
          if (groupHead) {
            e.preventDefault();
            const group = groupHead.parentElement;
            if (!group) return;
            const willOpen = !group.classList.contains('open');
            group.classList.toggle('open', willOpen);
            groupHead.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            return;
          }

          // any navigation link closes the menu
          const link = t.closest(
            'a.mobile-menu__sublink, a.mobile-menu__view-all, a.mobile-menu__link, a.mm-suc__btn, a.mobile-menu__cta'
          );
          if (link) closeMobile();
        });
      }

      /* ====== Desktop mega menu: hover-intent JS + click toggle ====== */
      const megaItems = header.querySelectorAll('.header__item.has-mega');
      const closeTimers = new WeakMap();

      const closeItem = (it) => {
        it.classList.remove('open');
        const btn = it.querySelector('.header__mega-toggle');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      };

      const closeAllMega = () => {
        megaItems.forEach((it) => {
          const t = closeTimers.get(it);
          if (t) { clearTimeout(t); closeTimers.delete(it); }
          closeItem(it);
        });
      };

      const openItem = (it) => {
        const t = closeTimers.get(it);
        if (t) { clearTimeout(t); closeTimers.delete(it); }
        megaItems.forEach((other) => { if (other !== it) closeItem(other); });
        it.classList.add('open');
        const btn = it.querySelector('.header__mega-toggle');
        if (btn) btn.setAttribute('aria-expanded', 'true');
      };

      const scheduleClose = (it, delay = 220) => {
        const prev = closeTimers.get(it);
        if (prev) clearTimeout(prev);
        const t = setTimeout(() => {
          closeItem(it);
          closeTimers.delete(it);
        }, delay);
        closeTimers.set(it, t);
      };

      megaItems.forEach((item) => {
        // Hover-intent: abrir al entrar, cerrar con delay al salir
        item.addEventListener('mouseenter', () => {
          if (!isDesktop()) return;
          openItem(item);
        });
        item.addEventListener('mouseleave', () => {
          if (!isDesktop()) return;
          scheduleClose(item);
        });

        // Click en la flecha = toggle (cubre teclado, touchscreen, trackpad lento)
        const btn = item.querySelector('.header__mega-toggle');
        if (btn) {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (item.classList.contains('open')) closeItem(item);
            else openItem(item);
          });
        }
      });

      // Click fuera del header cierra todos
      document.addEventListener('click', (e) => {
        const t = e.target;
        if (!(t instanceof Element)) return;
        if (!t.closest('.header__item.has-mega')) closeAllMega();
      });

      /* ====== Escape closes everything ====== */
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        if (mobileMenu && mobileMenu.classList.contains('active')) closeMobile();
        closeAllMega();
      });

      /* ====== Resize: close mobile on desktop, close mega on mobile ====== */
      let resizeRaf;
      window.addEventListener('resize', () => {
        if (resizeRaf) cancelAnimationFrame(resizeRaf);
        resizeRaf = requestAnimationFrame(() => {
          if (isDesktop() && mobileMenu && mobileMenu.classList.contains('active')) {
            closeMobile();
          }
          if (!isDesktop()) {
            closeAllMega();
          }
        });
      }, { passive: true });
    });
  })();
</script>

