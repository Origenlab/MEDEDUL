---
// Header Component - Professional Navigation v3 (dual sucursal contact)
import { getCdnUrl } from '@/lib/cdn';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const logoPath = '/img/mededul.png';
const logoSrc = getCdnUrl(logoPath, { w: 240, q: 80 });
const logoSrcSet = [
  `${getCdnUrl(logoPath, { w: 120, q: 80 })} 120w`,
  `${getCdnUrl(logoPath, { w: 240, q: 80 })} 240w`,
  `${getCdnUrl(logoPath, { w: 360, q: 80 })} 360w`,
  `${getCdnUrl(logoPath, { w: 480, q: 80 })} 480w`
].join(', ');

// Sucursales para el bloque de contacto del header
const sucursales = [
  {
    id: 'cdmx',
    city: 'CDMX',
    cityFull: 'Ciudad de Mexico',
    number: '55 2522 6442',
    tel: 'tel:+525525226442',
    whatsapp: 'https://wa.me/525525226442?text=Hola%20MEDEDUL%2C%20me%20interesa%20cotizar%20una%20mesa%20de%20dulces',
    horario: 'Lun-Sab 10:00-19:00 h',
    zona: 'Anzures & Condesa'
  },
  {
    id: 'toluca',
    city: 'Toluca',
    cityFull: 'Toluca / Metepec',
    number: '55 2177 5184',
    tel: 'tel:+525521775184',
    whatsapp: 'https://wa.me/525521775184?text=Hola%20MEDEDUL%2C%20me%20interesa%20cotizar%20una%20mesa%20de%20dulces%20en%20Toluca%2FMetepec',
    horario: 'Lun-Sab 10:00-19:00 h',
    zona: 'Metepec'
  }
];

// Navigation structure — Directorio movido al footer
const menuItems = [
  { label: 'Inicio', href: '/', exact: true },
  {
    label: 'Servicios',
    href: '/servicios',
    megaMenu: [
      {
        title: 'Tipos de Mesas',
        icon: '🍬',
        color: '#D1007A',
        items: [
          { label: 'Mesa de Dulces', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces' },
          { label: 'Mesa de Frutas', href: '/tipos-de-mesas-de-dulces/mesa-de-frutas' },
          { label: 'Mesa de Postres', href: '/tipos-de-mesas-de-dulces/mesa-de-postres' },
          { label: 'Quesos y Embutidos', href: '/tipos-de-mesas-de-dulces/mesa-de-quesos-y-embutidos' },
          { label: 'Mesa de Snacks', href: '/tipos-de-mesas-de-dulces/mesa-de-snacks' },
          { label: 'Mesa de Botanas', href: '/tipos-de-mesas-de-dulces/mesa-de-botanas' },
          { label: 'Dulces Tradicionales', href: '/tipos-de-mesas-de-dulces/mesa-de-dulces-tradicionales' },
          { label: 'Donas y Cupcakes', href: '/tipos-de-mesas-de-dulces/mesa-de-donas-y-cupcakes' }
        ],
        viewAll: { label: 'Ver todos los tipos', href: '/tipos-de-mesas-de-dulces' }
      },
      {
        title: 'Candy Bar por Evento',
        icon: '🎉',
        color: '#A0005F',
        items: [
          { label: 'Bodas', href: '/candy-bar-eventos/mesa-dulces-boda' },
          { label: 'XV Años', href: '/candy-bar-eventos/mesa-dulces-xv-anos' },
          { label: 'Baby Shower', href: '/candy-bar-eventos/mesa-dulces-baby-shower' },
          { label: 'Bautizos', href: '/candy-bar-eventos/mesa-dulces-bautizo' },
          { label: 'Primera Comunión', href: '/candy-bar-eventos/mesa-dulces-primera-comunion' },
          { label: 'Cumpleaños Infantil', href: '/candy-bar-eventos/mesa-dulces-cumpleanos-infantil' },
          { label: 'Graduaciones', href: '/candy-bar-eventos/mesa-dulces-graduacion' },
          { label: 'Corporativos', href: '/candy-bar-eventos/mesa-dulces-corporativos' }
        ],
        viewAll: { label: 'Ver todos los eventos', href: '/candy-bar-eventos' }
      },
      {
        title: 'Estaciones Interactivas',
        icon: '⭐',
        color: '#7A2BC2',
        items: [
          { label: 'Fuente de Chocolate', href: '/estaciones-interactivas/fuente-de-chocolate' },
          { label: 'Fuente de Chamoy', href: '/estaciones-interactivas/fuente-de-chamoy' },
          { label: 'Pared de Dulces', href: '/estaciones-interactivas/pared-de-dulces' },
          { label: 'Stand para Pastel', href: '/estaciones-interactivas/stand-para-pastel' }
        ],
        viewAll: { label: 'Ver todas las estaciones', href: '/estaciones-interactivas' }
      },
      {
        title: 'Por qué Elegirnos',
        icon: '💎',
        color: '#3A0A74',
        items: [
          { label: 'Diseño Personalizado', href: '/porque-mededul/diseno-personalizado' },
          { label: 'Calidad Premium', href: '/porque-mededul/calidad-premium' },
          { label: 'Servicio Completo', href: '/porque-mededul/servicio-completo' },
          { label: 'Cero Estrés', href: '/porque-mededul/cero-estres' }
        ],
        viewAll: { label: 'Conoce más', href: '/porque-mededul' }
      }
    ]
  },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Sucursales', href: '/sucursales' },
  { label: 'Blog', href: '/blog', startsWith: true },
  { label: 'Contacto', href: '/contacto' }
];

// Check if link is active
const isActive = (item: typeof menuItems[0]) => {
  if (item.exact) return currentPath === item.href;
  if (item.startsWith) return currentPath.startsWith(item.href);
  return currentPath === item.href;
};
---

<header class="header" id="header">
  <div class="header__container">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Mededul — inicio">
      <img
        src={logoSrc}
        srcset={logoSrcSet}
        sizes="240px"
        alt="Mededul - Mesas de Dulces CDMX, Toluca y Metepec"
        width="240"
        height="60"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav" id="nav-menu" aria-label="Navegación principal">
      <ul class="header__menu">
        {menuItems.map(item => (
          <li class:list={['header__item', { 'has-mega': item.megaMenu }]}>
            <a
              href={item.href}
              class:list={['header__link', { active: isActive(item) }]}
            >
              <span class="header__link-text">{item.label}</span>
              {item.megaMenu && (
                <svg class="header__arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              )}
            </a>

            {item.megaMenu && (
              <div class="mega-menu">
                <div class="mega-menu__container">
                  {item.megaMenu.map(column => (
                    <div class="mega-menu__column">
                      <div class="mega-menu__header" style={`--column-color: ${column.color}`}>
                        <span class="mega-menu__icon" aria-hidden="true">{column.icon}</span>
                        <span class="mega-menu__title">{column.title}</span>
                      </div>
                      <ul class="mega-menu__list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mega-menu__link">
                              {subItem.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                      <a href={column.viewAll.href} class="mega-menu__view-all" style={`--column-color: ${column.color}`}>
                        {column.viewAll.label}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <!-- Dual sucursal contact -->
      <div class="header__contact" aria-label="Contacto sucursales">
        {sucursales.map((s) => (
          <a href={s.tel} class="suc-chip" aria-label={`Llamar a sucursal ${s.cityFull} al ${s.number}`}>
            <span class="suc-chip__icon" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </span>
            <span class="suc-chip__body">
              <span class="suc-chip__city">{s.city}</span>
              <span class="suc-chip__num">{s.number}</span>
            </span>
          </a>
        ))}
      </div>

      <a href="/cotizar" class="header__cta">
        <span>Cotizar</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button class="header__toggle" id="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu__inner">
      <ul class="mobile-menu__list">
        {menuItems.map(item => (
          <li class:list={['mobile-menu__item', { 'has-submenu': item.megaMenu }]}>
            {item.megaMenu ? (
              <>
                <button class="mobile-menu__link mobile-menu__trigger" type="button" aria-expanded="false">
                  {item.label}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </button>
                <div class="mobile-menu__submenu">
                  {item.megaMenu.map(column => (
                    <div class="mobile-menu__group">
                      <button class="mobile-menu__group-header" type="button" style={`--column-color: ${column.color}`}>
                        <span class="mobile-menu__group-icon">{column.icon}</span>
                        {column.title}
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="6 9 12 15 18 9" />
                        </svg>
                      </button>
                      <ul class="mobile-menu__group-list">
                        {column.items.map(subItem => (
                          <li>
                            <a href={subItem.href} class="mobile-menu__sublink">{subItem.label}</a>
                          </li>
                        ))}
                        <li>
                          <a href={column.viewAll.href} class="mobile-menu__view-all">{column.viewAll.label}</a>
                        </li>
                      </ul>
                    </div>
                  ))}
                </div>
              </>
            ) : (
              <a href={item.href} class:list={['mobile-menu__link', { active: isActive(item) }]}>
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- Mobile footer: tarjetas de sucursal CDMX + Toluca -->
      <div class="mobile-menu__footer">
        <div class="mm-suc__grid">
          {sucursales.map((s) => (
            <div class="mm-suc">
              <div class="mm-suc__head">
                <span class="mm-suc__badge">{s.city}</span>
                <span class="mm-suc__zone">{s.zona}</span>
              </div>
              <div class="mm-suc__num">{s.number}</div>
              <div class="mm-suc__hours">{s.horario}</div>
              <div class="mm-suc__btns">
                <a href={s.tel} class="mm-suc__btn mm-suc__btn--call" aria-label={`Llamar a ${s.cityFull}`}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                  </svg>
                  Llamar
                </a>
                <a href={s.whatsapp} target="_blank" rel="noopener noreferrer" class="mm-suc__btn mm-suc__btn--wa" aria-label={`WhatsApp ${s.cityFull}`}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
              </div>
            </div>
          ))}
        </div>
        <a href="/cotizar" class="mobile-menu__cta">
          Cotizar mi evento
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    if (window.__mededulHeaderInit) return;
    window.__mededulHeaderInit = true;

    const onReady = (fn) => {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', fn, { once: true });
      } else {
        fn();
      }
    };

    onReady(function init() {
      const header = document.getElementById('header');
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');

      // Scroll effect
      let lastScroll = -1;
      const onScroll = () => {
        const cur = window.scrollY;
        if (cur === lastScroll) return;
        lastScroll = cur;
        if (!header) return;
        if (cur > 50) header.classList.add('scrolled');
        else header.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });

      const closeMenu = () => {
        hamburger?.classList.remove('active');
        mobileMenu?.classList.remove('active');
        document.body.classList.remove('menu-open');
        hamburger?.setAttribute('aria-expanded', 'false');
        hamburger?.setAttribute('aria-label', 'Abrir menú');
      };

      const openMenu = () => {
        hamburger?.classList.add('active');
        mobileMenu?.classList.add('active');
        document.body.classList.add('menu-open');
        hamburger?.setAttribute('aria-expanded', 'true');
        hamburger?.setAttribute('aria-label', 'Cerrar menú');
      };

      if (hamburger && mobileMenu) {
        const toggle = (e) => {
          e.preventDefault();
          e.stopPropagation();
          const isOpen = hamburger.classList.contains('active');
          if (isOpen) closeMenu();
          else openMenu();
        };
        hamburger.addEventListener('click', toggle);
        hamburger.addEventListener('touchstart', toggle, { passive: false });
      }

      mobileMenu?.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        const trigger = target.closest('.mobile-menu__trigger');
        if (trigger) {
          e.preventDefault();
          const parent = trigger.parentElement;
          const willOpen = !parent?.classList.contains('open');
          parent?.classList.toggle('open');
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          return;
        }

        const groupHead = target.closest('.mobile-menu__group-header');
        if (groupHead) {
          e.preventDefault();
          const parent = groupHead.parentElement;
          parent?.classList.toggle('open');
          return;
        }

        const link = target.closest(
          'a.mobile-menu__sublink, a.mobile-menu__view-all, a.mobile-menu__link, a.mm-suc__btn, a.mobile-menu__cta'
        );
        if (link && !link.classList.contains('mobile-menu__trigger')) {
          closeMenu();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
          closeMenu();
        }
      });

      let resizeRaf;
      window.addEventListener('resize', () => {
        if (resizeRaf) cancelAnimationFrame(resizeRaf);
        resizeRaf = requestAnimationFrame(() => {
          if (window.innerWidth > 1024 && mobileMenu?.classList.contains('active')) {
            closeMenu();
          }
        });
      }, { passive: true });
    });
  })();
</script>

<style>
  /* =====================================================
     HEADER v3 — Premium con dos sucursales (CDMX + Toluca)
     ===================================================== */
  .header {
    position: fixed;
    top: var(--topbar-offset, 44px);
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-top: 1px solid rgba(15, 15, 30, 0.04);
    border-bottom: 1px solid rgba(15, 15, 30, 0.06);
    box-shadow: 0 1px 0 rgba(255,255,255,0.7) inset;
    transition: box-shadow .25s ease, background .25s ease, border-color .25s ease;
  }

  .header.scrolled {
    background: rgba(255, 255, 255, 0.985);
    box-shadow: 0 8px 28px rgba(15, 15, 30, 0.08);
    border-bottom-color: rgba(15, 15, 30, 0.08);
  }

  .header__container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 12px 32px;
    min-height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  /* ---------- Logo ---------- */
  .header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    line-height: 0;
    transition: transform .25s ease, opacity .2s ease;
  }
  .header__logo:hover { opacity: .9; transform: scale(1.02); }

  .header__logo img {
    height: 54px;
    width: auto;
    max-width: 240px;
    display: block;
    object-fit: contain;
  }

  /* ---------- Navigation ---------- */
  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__menu {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__item { position: relative; }

  .header__link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 13px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #2a2a35;
    text-decoration: none;
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: color .2s ease, background .2s ease;
  }

  .header__link::before {
    content: '';
    position: absolute;
    left: 13px;
    right: 13px;
    bottom: 4px;
    height: 2px;
    background: linear-gradient(90deg, #D1007A, #7A2BC2);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform .25s ease;
  }

  .header__link:hover { color: #D1007A; }
  .header__link:hover::before { transform: scaleX(1); }

  .header__link.active { color: #D1007A; }
  .header__link.active::before { transform: scaleX(1); }

  .header__link:focus-visible {
    outline: 2px solid #D1007A;
    outline-offset: 3px;
  }

  .header__arrow {
    transition: transform .25s ease;
    opacity: .6;
  }
  .header__item.has-mega:hover > .header__link .header__arrow {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ---------- Mega Menu ---------- */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    padding-top: 14px;
    opacity: 0;
    visibility: hidden;
    transition: opacity .2s ease, transform .25s ease, visibility 0s linear .2s;
    pointer-events: none;
  }

  .header__item.has-mega:hover .mega-menu,
  .header__item.has-mega:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition: opacity .25s ease, transform .25s ease, visibility 0s linear 0s;
    pointer-events: auto;
  }

  .mega-menu__container {
    display: grid;
    grid-template-columns: repeat(4, 220px);
    gap: 0;
    background: #ffffff;
    border-radius: 14px;
    border: 1px solid rgba(15, 15, 30, 0.06);
    box-shadow:
      0 1px 2px rgba(15, 15, 30, 0.04),
      0 24px 60px rgba(15, 15, 30, 0.14);
    overflow: hidden;
  }

  .mega-menu__column {
    padding: 22px 20px;
    border-right: 1px solid #f3f3f6;
  }
  .mega-menu__column:last-child { border-right: none; }

  .mega-menu__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--column-color, #D1007A);
  }

  .mega-menu__icon { font-size: 1.1rem; line-height: 1; }

  .mega-menu__title {
    font-size: 0.74rem;
    font-weight: 700;
    color: #1a1a26;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .mega-menu__list { list-style: none; padding: 0; margin: 0 0 14px; }
